<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <script>!function(){try{var p=JSON.parse(localStorage.getItem('rsm_prefs_v1'))||{},r=document.documentElement,s={sm:'14px',md:'16px',lg:'18px',xl:'20px'};if(p.theme&&p.theme!=='auto')r.dataset.theme=p.theme;if(p.fontsize)r.style.fontSize=s[p.fontsize]||'16px';if(p.uiDensity)r.dataset.density=p.uiDensity;if(p.contrast)r.style.filter='contrast(1.16)';}catch(e){}}();</script>
  <link rel="icon" href="/img/favicon.png" type="image/png" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Preferenze – Rivalta sul Mincio</title>
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@400,500,700,800,900&display=swap" rel="stylesheet" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,650;1,9..144,550&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:        #17221d;
      --ink-soft:   #31453b;
      --cream:      #f7f0e4;
      --paper:      #fffaf0;
      --mist:       #e4ddcf;
      --marsh:      #253f35;
      --marsh-2:    #3d6353;
      --water:      #2f6b67;
      --clay:       #b8663f;
      --reed:       #c6a462;
      --line:       rgba(37, 63, 53, 0.15);
      --ok:         #2f6b67;
      --err:        #b83232;
      --radius:     14px;
      --shadow-card: 0 2px 24px rgba(37, 63, 53, 0.09), 0 0 0 1px rgba(37, 63, 53, 0.07);
      --sans:       "Cabinet Grotesk", system-ui, sans-serif;
      --serif:      "Fraunces", Georgia, serif;
      --ease:       cubic-bezier(0.32, 0.72, 0, 1);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background:
        radial-gradient(circle at 14% 8%, rgba(198, 164, 98, 0.28), transparent 28rem),
        radial-gradient(circle at 88% 2%, rgba(47, 107, 103, 0.16), transparent 34rem),
        linear-gradient(135deg, var(--cream), #efe5d2 54%, #f8f2e8);
      color: var(--ink);
      min-height: 100vh;
      line-height: 1.5;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    body::before {
      content: '';
      position: fixed; inset: 0;
      z-index: 0; pointer-events: none;
      opacity: 0.16;
      background-image:
        radial-gradient(circle at 12% 18%, rgba(23, 34, 29, 0.11) 0 1px, transparent 1px),
        radial-gradient(circle at 77% 54%, rgba(23, 34, 29, 0.08) 0 1px, transparent 1px);
      background-size: 23px 23px, 31px 31px;
      mix-blend-mode: multiply;
    }
    a { color: var(--marsh); text-decoration: none; }
    a:hover { color: var(--water); }

    /* ── Nav Island ── */
    .site-header {
      position: fixed;
      top: 20px; left: 0; right: 0;
      z-index: 70;
      pointer-events: none;
    }
    .nav-island {
      position: relative;
      width: min(100% - 28px, 1240px);
      margin: 0 auto;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 18px;
      padding: 8px 10px 8px 12px;
      border: 1px solid rgba(255, 250, 240, 0.68);
      border-radius: 999px;
      background: rgba(247, 240, 228, 0.82);
      box-shadow: 0 18px 48px rgba(23, 34, 29, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      pointer-events: auto;
    }
    .brand {
      display: inline-flex; align-items: center; gap: 11px;
      min-width: 0; color: var(--ink); text-decoration: none;
    }
    .logo-mark {
      width: 42px; height: 42px; flex: 0 0 42px;
      border-radius: 14px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }
    .logo-mark img { width: 42px; height: 42px; object-fit: cover; display: block; }
    .brand-name { display: grid; line-height: 1.02; letter-spacing: -0.02em; }
    .brand-name strong { font-size: 0.98rem; font-weight: 800; }
    .brand-name span { font-size: 0.72rem; color: rgba(23, 34, 29, 0.55); font-weight: 600; }
    #user-menu-wrap { display: flex; align-items: center; }

    .profile-btn {
      border: 0; border-radius: 999px;
      background: #253f35; color: #fffaf0;
      min-height: 42px; padding: 0 16px;
      display: inline-flex; align-items: center; justify-content: center;
      gap: 9px; font-weight: 500;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
      transition: transform 420ms var(--ease), background 420ms var(--ease), box-shadow 420ms var(--ease);
      cursor: pointer; font-family: var(--sans);
    }
    .profile-btn:hover { transform: translateY(-1px); background: #1f362e; box-shadow: 0 14px 30px rgba(23,34,29,.18), inset 0 1px 0 rgba(255,255,255,.20); }
    .profile-btn:active { transform: scale(0.98); }
    .profile-menu { position: relative; }
    .profile-avatar { width: 26px; height: 26px; display: inline-flex; align-items: center; justify-content: center; border-radius: 8px; font-size: 1rem; line-height: 1; }
    .profile-dropdown {
      position: absolute; right: 0; top: calc(100% + 12px);
      width: 230px; padding: 10px;
      border: 1px solid rgba(255,250,240,.58);
      border-radius: 24px;
      background: rgba(255,250,240,.94);
      box-shadow: 0 26px 80px rgba(37,63,53,.16);
      backdrop-filter: blur(20px);
      opacity: 0; visibility: hidden;
      transform: translateY(10px) scale(0.98);
      transition: opacity 360ms var(--ease), transform 360ms var(--ease), visibility 360ms var(--ease);
    }
    .profile-dropdown.open { opacity: 1; visibility: visible; transform: translateY(0) scale(1); }
    .profile-dropdown__section-title { padding: 8px 10px; font-size: 0.66rem; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(23,34,29,.5); font-weight: 900; }
    .profile-dropdown a, .profile-dropdown button {
      width: 100%; border: 0; background: transparent; color: #17221d;
      display: flex; align-items: center; justify-content: space-between;
      min-height: 38px; padding: 0 10px; border-radius: 14px;
      font-weight: 750; text-align: left; text-decoration: none; cursor: pointer;
      transition: background 300ms var(--ease), transform 300ms var(--ease);
    }
    .profile-dropdown a:hover, .profile-dropdown button:hover, .profile-dropdown .active { background: rgba(37,63,53,.08); transform: translateX(2px); }
    .profile-dropdown .danger { color: #8f3b28; }
    .profile-dropdown__sep { height: 1px; background: rgba(37,63,53,.15); margin: 8px 4px; }
    @media (max-width: 600px) { .brand-name span { display: none; } }

    /* ── Page ── */
    .page {
      position: relative; z-index: 1;
      max-width: 940px; margin: 0 auto;
      padding: 108px 20px 80px;
      display: flex; flex-direction: column; gap: 10px;
    }

    /* ── Page Header ── */
    .page-header { margin-bottom: 18px; }
    .page-header h1 { font-family: var(--serif); font-size: 2.1rem; font-weight: 650; letter-spacing: -.03em; color: var(--ink); margin-bottom: 5px; }
    .page-header p { color: var(--ink-soft); font-size: .88rem; }

    /* ── Section headers ── */
    .section-label {
      font-size: .68rem; font-weight: 900; text-transform: uppercase;
      letter-spacing: .14em; color: var(--ink-soft);
      padding: 20px 0 8px;
    }
    .section-label:first-child { padding-top: 0; }

    /* ── Cards ── */
    .bcard {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 20px; padding: 22px;
      display: flex; flex-direction: column; gap: 14px;
      box-shadow: var(--shadow-card);
    }
    .bcard-label {
      font-size: .68rem; font-weight: 800; text-transform: uppercase;
      letter-spacing: .12em; color: var(--ink-soft);
    }

    /* ── Grid layouts ── */
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .grid-3 { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
    .grid-profile { display: grid; grid-template-columns: 200px 1fr; gap: 10px; }
    .col-span-2 { grid-column: span 2; }

    /* ── Avatar Preview ── */
    .preview-wrap { display: flex; flex-direction: column; align-items: center; gap: 10px; flex: 1; justify-content: center; }
    .preview-avatar {
      width: 84px; height: 84px;
      border-radius: 22px;
      display: flex; align-items: center; justify-content: center;
      font-size: 2.4rem;
      transition: background .25s var(--ease), transform .2s var(--ease);
      flex-shrink: 0;
      box-shadow: 0 4px 20px rgba(37,63,53,.18);
    }
    .preview-avatar:hover { transform: scale(1.04); }
    .preview-username { font-size: .82rem; font-weight: 700; color: var(--ink-soft); }
    .preview-display { font-family: var(--serif); font-size: 1.05rem; font-weight: 650; color: var(--ink); }
    .preview-profile-link {
      font-size: .75rem; color: var(--water); font-weight: 600;
      display: inline-flex; align-items: center; gap: 4px;
    }
    .preview-profile-link:hover { color: var(--marsh); }

    /* ── Emoji & Color grids ── */
    .emoji-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; }
    .emoji-grid input[type="radio"] { display: none; }
    .emoji-grid label {
      display: flex; align-items: center; justify-content: center;
      font-size: 1.35rem; cursor: pointer;
      border-radius: 10px; border: 2px solid transparent;
      padding: 6px; transition: all .15s;
      background: rgba(37,63,53,.04);
    }
    .emoji-grid label:hover { background: rgba(37,63,53,.1); }
    .emoji-grid input:checked + label { border-color: var(--marsh); background: rgba(37,63,53,.1); }

    .color-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 8px; }
    .color-grid input[type="radio"] { display: none; }
    .color-grid label {
      display: block; width: 100%; aspect-ratio: 1;
      border-radius: 10px; cursor: pointer;
      border: 3px solid transparent; transition: all .15s;
    }
    .color-grid label:hover { transform: scale(1.1); }
    .color-grid input:checked + label { border-color: var(--ink); box-shadow: 0 0 0 2px var(--marsh); }

    /* ── Form fields ── */
    .field { display: flex; flex-direction: column; gap: 6px; }
    .field label { font-size: .75rem; font-weight: 800; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-soft); }
    .field input, .field textarea, .field select {
      background: rgba(255,250,240,.7); border: 1px solid var(--line); border-radius: 12px;
      color: var(--ink); font-family: var(--sans); font-size: .92rem; padding: 11px 16px;
      transition: border-color .18s, box-shadow .18s; resize: vertical;
    }
    .field input:focus, .field textarea:focus, .field select:focus {
      outline: none; border-color: var(--marsh); box-shadow: 0 0 0 3px rgba(37,63,53,.1);
    }
    .field textarea { min-height: 80px; line-height: 1.5; }
    .field .hint { font-size: .74rem; color: var(--ink-soft); }

    /* ── Toggle switch ── */
    .toggle-row {
      display: flex; align-items: center;
      justify-content: space-between;
      padding: 4px 0;
    }
    .toggle-row label { font-size: .88rem; color: var(--ink); font-weight: 600; cursor: pointer; }
    .toggle {
      position: relative; width: 40px; height: 22px; flex-shrink: 0;
    }
    .toggle input { opacity: 0; width: 0; height: 0; }
    .toggle-track {
      position: absolute; inset: 0;
      background: rgba(37,63,53,.18); border-radius: 999px;
      transition: background .2s var(--ease); cursor: pointer;
    }
    .toggle-track::after {
      content: ''; position: absolute;
      width: 16px; height: 16px; border-radius: 50%;
      background: white; top: 3px; left: 3px;
      transition: transform .2s var(--ease);
      box-shadow: 0 1px 4px rgba(0,0,0,.18);
    }
    .toggle input:checked + .toggle-track { background: var(--marsh); }
    .toggle input:checked + .toggle-track::after { transform: translateX(18px); }

    /* ── Theme / pref selects ── */
    .pref-row {
      display: flex; align-items: center; justify-content: space-between; gap: 12px;
      padding: 8px 0; border-bottom: 1px solid var(--line);
    }
    .pref-row:last-child { border-bottom: none; }
    .pref-row-label { font-size: .88rem; font-weight: 600; color: var(--ink); }
    .pref-row-sub { font-size: .76rem; color: var(--ink-soft); }
    .pref-select {
      background: rgba(255,250,240,.7); border: 1px solid var(--line); border-radius: 10px;
      color: var(--ink); font-family: var(--sans); font-size: .84rem; padding: 7px 12px;
      cursor: pointer; min-width: 130px; transition: border-color .18s, box-shadow .18s;
    }
    .pref-select:focus { outline: none; border-color: var(--marsh); box-shadow: 0 0 0 3px rgba(37,63,53,.1); }

    /* ── Buttons ── */
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 11px 26px; border-radius: 999px;
      font-size: .88rem; font-weight: 800; font-family: var(--sans);
      cursor: pointer; border: none; transition: all .2s;
    }
    .btn-primary { background: var(--marsh); color: var(--paper); box-shadow: 0 4px 20px rgba(37,63,53,.3); }
    .btn-primary:hover { background: #1f362e; transform: translateY(-2px); box-shadow: 0 8px 28px rgba(37,63,53,.45); }
    .btn-primary:disabled { opacity: .5; cursor: not-allowed; transform: none; }
    .btn-ghost { background: rgba(37,63,53,.07); color: var(--ink-soft); }
    .btn-ghost:hover { background: rgba(37,63,53,.12); transform: translateY(-1px); }
    .btn-danger { background: rgba(180,50,50,.08); color: #8f3b28; }
    .btn-danger:hover { background: rgba(180,50,50,.14); transform: translateY(-1px); }

    /* ── Save rows ── */
    .save-row { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
    .status-msg { font-size: .84rem; }
    .status-ok { color: var(--ok); }
    .status-err { color: var(--err); }

    /* ── Motto card ── */
    .motto-card {
      background: var(--marsh); border: none;
      border-radius: 20px; padding: 24px;
      display: flex; flex-direction: column; justify-content: center;
      box-shadow: 0 6px 28px rgba(37,63,53,.22);
    }
    .motto-text {
      font-family: var(--serif); font-size: 1.08rem; font-weight: 500;
      color: var(--cream); letter-spacing: -.01em; line-height: 1.55;
    }
    .motto-text em { color: var(--reed); font-style: normal; }

    /* ── Account section ── */
    .account-card {
      display: flex; align-items: center; justify-content: space-between;
      flex-wrap: wrap; gap: 14px;
    }
    .account-info { display: flex; flex-direction: column; gap: 3px; }
    .account-info strong { font-size: .92rem; font-weight: 700; color: var(--ink); }
    .account-info span { font-size: .78rem; color: var(--ink-soft); }

    /* ── Responsive ── */
    @media (max-width: 860px) {
      .grid-profile { grid-template-columns: 1fr; }
      .grid-3 { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 600px) {
      .page { padding: 100px 14px 60px; }
      .grid-2 { grid-template-columns: 1fr; }
      .grid-3 { grid-template-columns: 1fr; }
      .col-span-2 { grid-column: span 1; }
      .site-header { top: 10px; }
      .nav-island { border-radius: 28px; }
    }

    /* ── Footer ── */
    .footer { color: rgba(255,250,240,.72); background: #101c18; padding: 72px 0 34px; font-family: var(--sans); position: relative; z-index: 1; }
    .footer-container { width: min(100% - 44px, 1400px); margin: 0 auto; }
    .footer-grid { display: grid; grid-template-columns: minmax(0,.72fr) repeat(3,minmax(140px,.22fr)); gap: clamp(24px,5vw,76px); align-items: start; }
    .footer h3, .footer h4 { margin: 0 0 16px; color: var(--paper); letter-spacing: -.02em; }
    .footer h3 { font-family: var(--serif); font-size: clamp(2rem,4vw,4.8rem); line-height: .96; letter-spacing: -.055em; }
    .footer p { max-width: 540px; line-height: 1.66; }
    .footer-links { list-style: none; padding: 0; margin: 0; display: grid; gap: 10px; }
    .footer-links a { color: rgba(255,250,240,.68); font-weight: 750; text-decoration: none; }
    .footer-links a:hover { color: var(--paper); }
    .footer-bottom { display: flex; justify-content: space-between; flex-wrap: wrap; gap: 14px; margin-top: 64px; padding-top: 24px; border-top: 1px solid rgba(255,250,240,.12); font-size: .86rem; }
    @media (max-width: 760px) { .footer-grid { grid-template-columns: 1fr; } }
  </style>
  <link rel="stylesheet" href="/theme.css" />
</head>
<body>

<header class="site-header">
  <div class="nav-island">
    <a class="brand" href="/">
      <div class="logo-mark">
        <img src="/img/favicon.png" alt="Rivalta sul Mincio" width="42" height="42" />
      </div>
      <span class="brand-name">
        <strong>Rivalta sul Mincio</strong>
        <span>Parco del Mincio &middot; Mantova</span>
      </span>
    </a>
    <div></div>
    <div id="user-menu-wrap"></div>
  </div>
</header>

<main class="page">

  <div class="page-header">
    <h1>Preferenze</h1>
    <p>Personalizza il tuo profilo e l'aspetto del sito</p>
  </div>

  <!-- ── SEZIONE AVATAR ── -->
  <div class="section-label">Identità &amp; Avatar</div>

  <div class="grid-profile">

    <!-- Anteprima avatar -->
    <div class="bcard" style="min-height:220px">
      <div class="bcard-label">Anteprima</div>
      <div class="preview-wrap">
        <div class="preview-avatar" id="avatar-preview" style="background:#253f35">🌿</div>
        <div class="preview-username" id="prev-username">@...</div>
        <div class="preview-display" id="prev-display">—</div>
        <a href="#" class="preview-profile-link" id="public-profile-link">
          <span>Vedi profilo</span>
          <span aria-hidden="true">↗</span>
        </a>
      </div>
    </div>

    <!-- Colonna destra: emoji + colori + campi -->
    <div style="display:flex;flex-direction:column;gap:10px">

      <!-- Emoji e colore in riga -->
      <div class="grid-2">
        <div class="bcard">
          <div class="bcard-label">Emoji avatar</div>
          <div class="emoji-grid" id="emoji-grid"></div>
        </div>
        <div class="bcard">
          <div class="bcard-label">Colore sfondo</div>
          <div class="color-grid" id="color-grid"></div>
          <div class="save-row" style="margin-top:auto">
            <button class="btn btn-primary" id="save-avatar-btn">Salva avatar</button>
            <span class="status-msg" id="avatar-status"></span>
          </div>
        </div>
      </div>

      <!-- Dati profilo -->
      <div class="bcard">
        <div class="bcard-label">Dati profilo</div>
        <div class="grid-2">
          <div class="field">
            <label for="p-display">Nome visualizzato</label>
            <input type="text" id="p-display" maxlength="50" placeholder="Come vuoi essere chiamato/a?" />
          </div>
          <div class="field">
            <label for="p-username">Username</label>
            <input type="text" id="p-username" maxlength="30" placeholder="solo_lettere_e_numeri" autocomplete="off" />
            <span class="hint">Solo lettere, numeri e _</span>
          </div>
        </div>
        <div class="field">
          <label for="p-bio">Bio</label>
          <textarea id="p-bio" maxlength="200" placeholder="Raccontati in poche parole…"></textarea>
          <span class="hint">Massimo 200 caratteri</span>
        </div>
        <div class="save-row">
          <button class="btn btn-primary" id="save-profile-btn">Salva profilo</button>
          <span class="status-msg" id="profile-status"></span>
        </div>
      </div>

    </div>
  </div>

  <!-- ── SEZIONE ASPETTO UI ── -->
  <div class="section-label">Aspetto</div>

  <div class="bcard">
    <div class="pref-row">
      <div>
        <div class="pref-row-label">Tema</div>
        <div class="pref-row-sub">Chiaro, scuro o sistema</div>
      </div>
      <select class="pref-select" id="pref-theme">
        <option value="auto">Automatico</option>
        <option value="chiaro">Chiaro</option>
        <option value="scuro">Scuro</option>
      </select>
    </div>
    <div class="pref-row">
      <div>
        <div class="pref-row-label">Lingua</div>
        <div class="pref-row-sub">Lingua dell'interfaccia</div>
      </div>
      <select class="pref-select" id="pref-language">
        <option value="it">Italiano</option>
        <option value="en">English</option>
      </select>
    </div>
    <div class="pref-row">
      <div>
        <div class="pref-row-label">Densità UI</div>
        <div class="pref-row-sub">Spazio tra gli elementi</div>
      </div>
      <select class="pref-select" id="pref-density">
        <option value="comfortable">Standard</option>
        <option value="compact">Compatta</option>
      </select>
    </div>
    <div class="pref-row">
      <div>
        <div class="pref-row-label">Dimensione testo</div>
        <div class="pref-row-sub">Grandezza dei caratteri</div>
      </div>
      <select class="pref-select" id="pref-fontsize">
        <option value="sm">Piccolo</option>
        <option value="md">Normale</option>
        <option value="lg">Grande</option>
        <option value="xl">Molto grande</option>
      </select>
    </div>
    <div class="pref-row">
      <label for="pref-contrast" class="pref-row-label" style="cursor:pointer">Contrasto elevato</label>
      <label class="toggle">
        <input type="checkbox" id="pref-contrast" />
        <span class="toggle-track"></span>
      </label>
    </div>
    <div style="padding-top:8px">
      <div class="save-row">
        <button class="btn btn-primary" id="save-ui-btn">Salva aspetto</button>
        <span class="status-msg" id="ui-status"></span>
      </div>
