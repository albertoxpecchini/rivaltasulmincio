  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,650;1,9..144,550&display=swap" rel="stylesheet" media="print" onload="this.onload=null;this.media='all'" />
  <noscript><link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,650;1,9..144,550&display=swap" rel="stylesheet" /></noscript>
  <link rel="stylesheet" href="/theme.css" />
  <style>
    /* ───────── Preferenze · layout editoriale ───────── */
    .rsm-page {
      width: var(--rsm-container);
      margin: 0 auto;
      padding: var(--rsm-s-16) 0 var(--rsm-s-24);
      display: flex;
      flex-direction: column;
      gap: var(--rsm-s-24);
    }

    /* HERO */
    .prefs-hero {
      display: grid;
      gap: var(--rsm-s-12);
      grid-template-columns: 1fr;
      align-items: end;
    }
    @media (min-width: 920px) {
      .prefs-hero {
        grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
        gap: var(--rsm-s-16);
      }
    }
    .prefs-hero__left {
      display: flex;
      flex-direction: column;
      gap: var(--rsm-s-6);
      max-width: 60ch;
    }
    .prefs-hero__tags {
      list-style: none;
      padding: 0;
      margin: var(--rsm-s-2) 0 0;
      display: flex;
      flex-wrap: wrap;
      gap: var(--rsm-s-2);
    }
    .prefs-hero__preview {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: var(--rsm-s-4);
      text-align: center;
    }
    .prefs-preview-avatar {
      width: 132px;
      height: 132px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-size: 58px;
      color: #fff;
      background: #253f35;
      box-shadow: var(--rsm-sh-lg);
      transition: background var(--rsm-dur-base) var(--rsm-ease-out);
    }
    .prefs-preview-meta {
      display: flex;
      flex-direction: column;
      gap: 4px;
      align-items: center;
    }
    .prefs-preview-meta strong {
      font-family: var(--rsm-font-display);
      font-size: 1.4rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      color: var(--rsm-text-strong);
    }
    .prefs-preview-meta span {
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-eyebrow);
      letter-spacing: var(--rsm-tracking-loose);
      color: var(--rsm-text-soft);
    }

    /* SECTION HEAD */
    .prefs-section {
      display: flex;
      flex-direction: column;
      gap: var(--rsm-s-8);
    }
    .prefs-section__head {
      display: flex;
      flex-direction: column;
      gap: var(--rsm-s-4);
      max-width: 60ch;
    }
    .prefs-section__head .rsm-lead { color: var(--rsm-text-soft); }

    /* CARD COMPOSITIONS */
    .prefs-card-head {
      display: flex;
      flex-direction: column;
      gap: var(--rsm-s-2);
      margin-bottom: var(--rsm-s-6);
    }
    .prefs-grid-profile {
      display: grid;
      gap: var(--rsm-s-5);
      grid-template-columns: 1fr;
      margin-bottom: var(--rsm-s-5);
    }
    @media (min-width: 720px) {
      .prefs-grid-profile { grid-template-columns: 1fr 1fr; }
    }

    .prefs-grid-avatar {
      display: grid;
      gap: var(--rsm-s-6);
      grid-template-columns: 1fr;
    }
    @media (min-width: 720px) {
      .prefs-grid-avatar { grid-template-columns: 1.6fr 1fr; }
    }
    .prefs-picker {
      display: flex;
      flex-direction: column;
      gap: var(--rsm-s-3);
    }

    /* Emoji + color pickers */
    .prefs-emoji-grid,
    .prefs-color-grid {
      display: grid;
      gap: var(--rsm-s-2);
    }
    .prefs-emoji-grid { grid-template-columns: repeat(5, 1fr); }
    .prefs-color-grid { grid-template-columns: repeat(5, 1fr); }
    .prefs-emoji-grid input,
    .prefs-color-grid input {
      position: absolute;
      opacity: 0;
      pointer-events: none;
    }
    .prefs-emoji-grid label {
      display: grid;
      place-items: center;
      aspect-ratio: 1;
      border: 1px solid var(--rsm-line-2);
      border-radius: var(--rsm-r-md);
      background: rgba(255,255,255,0.66);
      backdrop-filter: var(--rsm-blur-sm);
      cursor: pointer;
      font-size: 22px;
      transition: transform var(--rsm-dur-fast) var(--rsm-ease-out),
                  border-color var(--rsm-dur-fast) var(--rsm-ease-out);
    }
    .prefs-color-grid label {
      display: block;
      aspect-ratio: 1;
      border-radius: 50%;
      cursor: pointer;
      border: 2px solid transparent;
      box-shadow: inset 0 0 0 1px var(--rsm-line-2), var(--rsm-sh-sm);
      transition: transform var(--rsm-dur-fast) var(--rsm-ease-out),
                  border-color var(--rsm-dur-fast) var(--rsm-ease-out);
    }
    .prefs-emoji-grid label:hover,
    .prefs-color-grid label:hover { transform: translateY(-1px); }
    .prefs-emoji-grid input:checked + label {
      border-color: var(--rsm-emerald);
      transform: scale(1.04);
      box-shadow: var(--rsm-sh-glow-emerald);
    }
    .prefs-color-grid input:checked + label {
      border-color: var(--rsm-text-strong);
      transform: scale(1.1);
    }
    .prefs-emoji-grid input:focus-visible + label,
    .prefs-color-grid input:focus-visible + label {
      outline: 2px solid var(--rsm-azure);
      outline-offset: 3px;
    }

    /* Pref rows */
    .prefs-row {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: var(--rsm-s-5);
      padding: var(--rsm-s-5) 0;
      border-bottom: 1px solid var(--rsm-line);
    }
    .prefs-row:first-of-type { padding-top: 0; }
    .prefs-row:last-of-type { border-bottom: none; padding-bottom: 0; }
    .prefs-row__label {
      display: flex;
      flex-direction: column;
      gap: 4px;
      min-width: 0;
    }
    .prefs-row__label .rsm-field-label { margin: 0; }
    .prefs-row__hint {
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-small);
      color: var(--rsm-text-soft);
      font-weight: 500;
      text-transform: none;
      letter-spacing: 0;
    }
    .prefs-row .rsm-select,
    .prefs-row .rsm-input { min-width: 180px; max-width: 220px; }

    /* Native select arrow */
    .rsm-select {
      appearance: none;
      -webkit-appearance: none;
      padding-right: 48px;
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none' stroke='%234d5266' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M1 1.5l5 5 5-5'/></svg>");
      background-repeat: no-repeat;
      background-position: right 22px center;
      cursor: pointer;
    }
    html[data-theme="scuro"] .rsm-select {
      background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='12' height='8' viewBox='0 0 12 8' fill='none' stroke='%238d92a3' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><path d='M1 1.5l5 5 5-5'/></svg>");
    }

    /* Switch toggle */
    .prefs-switch {
      position: relative;
      display: inline-flex;
      width: 52px;
      height: 30px;
      cursor: pointer;
      flex-shrink: 0;
    }
    .prefs-switch input {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      margin: 0;
      opacity: 0;
      cursor: pointer;
    }
    .prefs-switch-track {
      position: absolute;
      inset: 0;
      border-radius: var(--rsm-r-pill);
      background: var(--rsm-line-2);
      transition: background var(--rsm-dur-fast) var(--rsm-ease-out);
      pointer-events: none;
    }
    .prefs-switch-track::after {
      content: "";
      position: absolute;
      top: 3px;
      left: 3px;
      width: 24px;
      height: 24px;
      border-radius: 50%;
      background: #fff;
      box-shadow: var(--rsm-sh-sm);
      transition: transform var(--rsm-dur-fast) var(--rsm-ease-out);
    }
    .prefs-switch input:checked + .prefs-switch-track {
      background: var(--rsm-emerald);
    }
    .prefs-switch input:checked + .prefs-switch-track::after {
      transform: translateX(22px);
    }
    .prefs-switch input:focus-visible + .prefs-switch-track {
      outline: 2px solid var(--rsm-azure);
      outline-offset: 3px;
    }

    /* Section actions row */
    .prefs-actions {
      display: flex;
      align-items: center;
      gap: var(--rsm-s-4);
      flex-wrap: wrap;
      margin-top: var(--rsm-s-6);
      padding-top: var(--rsm-s-5);
      border-top: 1px solid var(--rsm-line);
    }
    .prefs-note {
      margin: var(--rsm-s-3) 0 0;
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-tiny);
      letter-spacing: var(--rsm-tracking-loose);
      text-transform: uppercase;
      color: var(--rsm-text-faint);
    }

    /* Accessibility summary */
    .prefs-summary {
      display: grid;
      gap: var(--rsm-s-3);
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      margin-top: var(--rsm-s-5);
    }
    .prefs-summary__tile {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding: var(--rsm-s-4) var(--rsm-s-5);
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-lg);
      background: var(--rsm-surface);
    }
    .prefs-summary__tile[data-active="on"] {
      border-color: rgba(31, 191, 125, 0.32);
      background: var(--rsm-emerald-4);
    }
    .prefs-summary__tile strong {
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-eyebrow);
      letter-spacing: var(--rsm-tracking-wide);
      text-transform: uppercase;
      color: var(--rsm-text-soft);
      font-weight: 500;
    }
    .prefs-summary__tile span {
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-body-lg);
      font-weight: 700;
      color: var(--rsm-text-strong);
      letter-spacing: -0.01em;
    }
    .prefs-summary__tile[data-active="on"] strong { color: rgba(12, 108, 71, 0.86); }
    .prefs-summary__tile[data-active="on"] span { color: #0c6c47; }
    html[data-theme="scuro"] .prefs-summary__tile[data-active="on"] {
      background: rgba(31, 191, 125, 0.14);
      border-color: rgba(31, 191, 125, 0.34);
    }
    html[data-theme="scuro"] .prefs-summary__tile[data-active="on"] strong { color: rgba(143, 240, 197, 0.78); }
    html[data-theme="scuro"] .prefs-summary__tile[data-active="on"] span { color: #8ff0c5; }

    /* Categories chip row */
    .prefs-chip-row {
      display: flex;
      flex-wrap: wrap;
      gap: var(--rsm-s-2);
      margin-top: var(--rsm-s-2);
    }
    .prefs-chip-row .rsm-chip { font-family: var(--rsm-font-sans); }
    .prefs-chip-hint {
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-small);
      color: var(--rsm-text-soft);
      margin: var(--rsm-s-3) 0 0;
    }

    /* Account block — asymmetric */
    .prefs-account {
      display: grid;
      gap: var(--rsm-s-5);
      grid-template-columns: 1fr;
    }
    @media (min-width: 860px) {
      .prefs-account { grid-template-columns: 1fr 1fr; }
    }
    .prefs-account__card {
      display: flex;
      flex-direction: column;
      gap: var(--rsm-s-5);
    }
    .prefs-account__chip {
      display: flex;
      align-items: center;
      gap: var(--rsm-s-4);
      padding-bottom: var(--rsm-s-5);
      border-bottom: 1px solid var(--rsm-line);
    }
    .prefs-account__chip-avatar {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      font-size: 28px;
      color: #fff;
      background: var(--rsm-ink);
      flex-shrink: 0;
      box-shadow: var(--rsm-sh-sm);
    }
    .prefs-account__chip-info { display: flex; flex-direction: column; gap: 4px; min-width: 0; }
    .prefs-account__chip-info strong {
      font-family: var(--rsm-font-display);
      font-size: 1.4rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      color: var(--rsm-text-strong);
    }
    .prefs-account__chip-info span {
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-eyebrow);
      letter-spacing: var(--rsm-tracking-wide);
      color: var(--rsm-text-soft);
      text-transform: uppercase;
    }
    .prefs-account__desc {
      max-width: 36ch;
      color: var(--rsm-text-soft);
      margin: 0;
    }
    .prefs-account__actions {
      display: flex;
      flex-wrap: wrap;
      gap: var(--rsm-s-3);
      margin-top: auto;
      padding-top: var(--rsm-s-4);
      border-top: 1px solid var(--rsm-line);
    }
    .prefs-motto {
      display: grid;
      place-items: center;
      text-align: center;
      min-height: 220px;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.6), rgba(245,248,252,0.7)) padding-box,
        var(--rsm-accent-grad) border-box;
      border: 1px solid transparent;
    }
    .prefs-motto__text {
      font-family: var(--rsm-font-display);
      font-size: clamp(1.4rem, 2.6vw, 1.9rem);
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: 1.18;
      max-width: 22ch;
      color: var(--rsm-text-strong);
    }
    .prefs-motto__text em {
      font-style: italic;
      background: var(--rsm-accent-grad);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent;
    }
    html[data-theme="scuro"] .prefs-motto {
      background:
        linear-gradient(180deg, rgba(14,18,30,0.7), rgba(10,14,24,0.78)) padding-box,
        var(--rsm-accent-grad) border-box;
    }

    /* Danger button */
    .rsm-btn--danger {
      color: var(--rsm-danger);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.96), rgba(252,238,238,0.94)) padding-box,
        linear-gradient(120deg, rgba(239,68,68,0.32), rgba(239,68,68,0.18)) border-box;
      border-color: rgba(239,68,68,0.32);
    }
    .rsm-btn--danger .rsm-btn-icon { color: var(--rsm-danger); background: rgba(255,255,255,0.95); }
    .rsm-btn--danger:hover {
      color: #fff;
      background:
        linear-gradient(180deg, var(--rsm-danger), #d93030) padding-box,
        linear-gradient(120deg, rgba(239,68,68,0.5), rgba(239,68,68,0.4)) border-box;
    }
    .rsm-btn--danger:hover .rsm-btn-icon { color: var(--rsm-danger); }
    html[data-theme="scuro"] .rsm-btn--danger {
      background:
        linear-gradient(180deg, rgba(20,22,32,0.92), rgba(34,18,18,0.92)) padding-box,
        linear-gradient(120deg, rgba(239,68,68,0.38), rgba(239,68,68,0.24)) border-box;
    }

    /* Status messages */
    .rsm-form-status.is-ok { color: var(--rsm-success); }
    .rsm-form-status.is-err { color: var(--rsm-danger); }

    /* Dark mode tweaks */
    html[data-theme="scuro"] .prefs-emoji-grid label {
      background: rgba(20, 22, 32, 0.58);
      border-color: var(--rsm-line-2);
    }

    /* Density compact: tighten the pref-rows */
    html[data-density="compact"] .prefs-row { padding: var(--rsm-s-3) 0; }
    html[data-density="compact"] .rsm-page { gap: var(--rsm-s-16); }
  </style>
</head>
<body>

<!--PARTIAL:nav-->

<main class="rsm-page">

  <!-- ───────── HERO ───────── -->
  <section class="prefs-hero">
    <div class="prefs-hero__left">
      <p class="rsm-kicker"><span>Profilo · Aspetto · Comunità</span></p>
      <h1 class="rsm-h1">Personalizza la tua <em>esperienza</em>.</h1>
      <p class="rsm-lead">Tipografia, tema, accessibilità e identità. Ogni scelta resta su questo dispositivo e si propaga su tutte le pagine del sito, senza passare dal cloud.</p>
      <ul class="prefs-hero__tags" aria-label="Stato corrente">
        <li class="rsm-tag rsm-tag--emerald" id="hero-tag-theme">Tema · automatico</li>
        <li class="rsm-tag rsm-tag--azure" id="hero-tag-fontsize">Testo · normale</li>
        <li class="rsm-tag rsm-tag--violet" id="hero-tag-animations">Animazioni · attive</li>
      </ul>
    </div>
    <aside class="rsm-card rsm-card--glass prefs-hero__preview" aria-label="Anteprima profilo">
      <p class="rsm-kicker rsm-kicker--center"><span>Anteprima</span></p>
      <div class="prefs-preview-avatar" id="avatar-preview">🌿</div>
      <div class="prefs-preview-meta">
        <strong id="prev-display">—</strong>
        <span id="prev-username">@...</span>
      </div>
      <a href="#" class="rsm-btn rsm-btn--ghost rsm-btn--sm" id="public-profile-link">
        <span>Vedi profilo</span>
        <span class="rsm-btn-icon" aria-hidden="true">↗</span>
      </a>
    </aside>
  </section>

  <!-- ───────── 01 · IDENTITÀ ───────── -->
  <section class="prefs-section">
    <header class="prefs-section__head">
      <p class="rsm-kicker"><span>01 · Identità</span></p>
      <h2 class="rsm-h2">Come ti vedono <span class="rsm-grad">gli altri</span>.</h2>
      <p class="rsm-lead">Nome, username e biografia restano sul dispositivo. Cambia avatar quando vuoi: anteprima a sinistra in tempo reale.</p>
    </header>

    <div class="rsm-card">
      <div class="prefs-grid-profile">
        <div class="rsm-field">
          <label for="p-display" class="rsm-field-label">Nome visualizzato</label>
          <input type="text" id="p-display" class="rsm-input" maxlength="50" placeholder="Mario Rossi" />
        </div>
        <div class="rsm-field">
          <label for="p-username" class="rsm-field-label">Username · solo a-z 0-9 _</label>
          <input type="text" id="p-username" class="rsm-input" maxlength="30" placeholder="lupo_del_mincio" autocomplete="off" />
        </div>
      </div>
      <div class="rsm-field">
        <label for="p-bio" class="rsm-field-label">Bio · max 200 caratteri</label>
        <textarea id="p-bio" class="rsm-textarea" maxlength="200" placeholder="Raccontati in poche parole…"></textarea>
      </div>
      <div class="prefs-actions">
        <button type="button" class="rsm-btn rsm-btn--brand" id="save-profile-btn">
          <span>Salva profilo</span>
          <span class="rsm-btn-icon" aria-hidden="true">↗</span>
        </button>
        <span class="rsm-form-status" id="profile-status" aria-live="polite"></span>
      </div>
    </div>

    <div class="rsm-card">
      <header class="prefs-card-head">
        <p class="rsm-kicker"><span>Avatar</span></p>
        <h3 class="rsm-h3">Emoji e tinta del cerchio</h3>
      </header>
      <div class="prefs-grid-avatar">
        <div class="prefs-picker">
          <span class="rsm-field-label">Emoji</span>
          <div class="prefs-emoji-grid" id="emoji-grid" role="radiogroup" aria-label="Scegli un'emoji"></div>
        </div>
        <div class="prefs-picker">
          <span class="rsm-field-label">Colore</span>
          <div class="prefs-color-grid" id="color-grid" role="radiogroup" aria-label="Scegli un colore"></div>
        </div>
      </div>
      <div class="prefs-actions">
        <button type="button" class="rsm-btn rsm-btn--brand" id="save-avatar-btn">
          <span>Salva avatar</span>
          <span class="rsm-btn-icon" aria-hidden="true">↗</span>
        </button>
        <span class="rsm-form-status" id="avatar-status" aria-live="polite"></span>
