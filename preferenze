      <div class="pref-row-block">
        <div>
          <div class="pref-row-label">Categorie preferite</div>
          <div class="pref-row-sub">Salva i temi che ti interessano di piu per personalizzare la tua esperienza</div>
        </div>
        <div class="pref-chip-row" id="pref-category-chips"></div>
