<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script src="supabase.config.js"></script>
<script>
(function () {
  const $ = (id) => document.getElementById(id);

  const PREF_KEY = 'rsm_prefs_v1';
  const EMOJIS = ['🌿','🌊','🦢','🚣','🎣','🌾','🏞️','🦆','🌙','✨','🧭','📍','🍃','🏰','🌸','🛶','🦋','🌤️','📸','🧡'];
  const COLORS = ['#253f35','#2f6b67','#2E7D32','#7CB342','#F9A825','#8D6E63','#5C6BC0','#EC407A','#607D8B','#37474F'];
  const CATEGORY_OPTIONS = ['Eventi', 'Territorio', 'Vita locale', 'Avvisi', 'Richieste', 'Storie'];

  const FONT_SIZE_MAP = { sm: '14px', md: '16px', lg: '18px', xl: '20px' };
  const UI_OPTIONS = {
    theme: new Set(['auto', 'chiaro', 'scuro']),
    language: new Set(['it', 'en']),
    uiDensity: new Set(['comfortable', 'compact']),
    fontsize: new Set(['sm', 'md', 'lg', 'xl']),
    commentPrivacy: new Set(['all', 'members', 'none']),
    notifFrequency: new Set(['instant', 'daily', 'weekly', 'off'])
  };

  const defaultPrefs = {
    theme: 'auto', language: 'it', uiDensity: 'comfortable', fontsize: 'md',
    contrast: false, animations: false,
    username: '', displayName: '', bio: '',
    avatarEmoji: '🌿', avatarColor: '#253f35',
    commentPrivacy: 'all', notifFrequency: 'daily', notifEmail: false,
    preferredCategories: []
  };

  const systemThemeQuery = window.matchMedia ? window.matchMedia('(prefers-color-scheme: dark)') : null;

  function normalizePreferredCategories(input) {
    const values = Array.isArray(input) ? input : [];
    const aliases = {
      'eventi':'Eventi','territorio':'Territorio','vita locale':'Vita locale',
      'avvisi':'Avvisi','richieste':'Richieste','storie':'Storie',
      'il luccio':'Storie','fauna':'Territorio','ambiente':'Territorio',
      'ecoturismo':'Territorio','storia':'Storie'
    };
    const allowed = new Set(CATEGORY_OPTIONS);
    const seen = new Set();
    const out = [];
    values.forEach((value) => {
      const raw = String(value || '').trim();
      const next = aliases[raw.toLowerCase()] || raw;
      if (!next || !allowed.has(next) || seen.has(next)) return;
      seen.add(next);
      out.push(next);
    });
    return out;
  }

  function sanitizeUsername(v) {
    return String(v || '').toLowerCase().replace(/[^a-z0-9_]/g, '');
  }

  function normalizePrefs(prefs) {
    const next = Object.assign({}, defaultPrefs, prefs || {});
    next.theme = UI_OPTIONS.theme.has(next.theme) ? next.theme : defaultPrefs.theme;
    next.language = UI_OPTIONS.language.has(next.language) ? next.language : defaultPrefs.language;
    next.uiDensity = UI_OPTIONS.uiDensity.has(next.uiDensity) ? next.uiDensity : defaultPrefs.uiDensity;
    next.fontsize = UI_OPTIONS.fontsize.has(next.fontsize) ? next.fontsize : defaultPrefs.fontsize;
    next.contrast = !!next.contrast;
    next.animations = next.animations === true;
    next.commentPrivacy = UI_OPTIONS.commentPrivacy.has(next.commentPrivacy) ? next.commentPrivacy : defaultPrefs.commentPrivacy;
    next.notifFrequency = UI_OPTIONS.notifFrequency.has(next.notifFrequency) ? next.notifFrequency : defaultPrefs.notifFrequency;
    next.notifEmail = !!next.notifEmail;
    next.preferredCategories = normalizePreferredCategories(next.preferredCategories);
    next.username = sanitizeUsername(next.username);
    next.displayName = String(next.displayName || '').slice(0, 50);
    next.bio = String(next.bio || '').slice(0, 200);
    next.avatarEmoji = EMOJIS.includes(next.avatarEmoji) ? next.avatarEmoji : defaultPrefs.avatarEmoji;
    next.avatarColor = COLORS.includes(next.avatarColor) ? next.avatarColor : defaultPrefs.avatarColor;
    return next;
  }

  function resolveThemePreference(theme) {
    const pref = UI_OPTIONS.theme.has(theme) ? theme : defaultPrefs.theme;
    if (pref !== 'auto') return pref;
    return systemThemeQuery && systemThemeQuery.matches ? 'scuro' : 'chiaro';
  }

  function loadPrefs() {
    try { return normalizePrefs(JSON.parse(localStorage.getItem(PREF_KEY)) || {}); }
    catch (_) { return normalizePrefs({}); }
  }
  function savePrefs(prefs) { localStorage.setItem(PREF_KEY, JSON.stringify(normalizePrefs(prefs))); }

  function applyUiPrefs(prefs) {
    const next = normalizePrefs(prefs);
    const root = document.documentElement;
    root.dataset.theme = resolveThemePreference(next.theme);
    root.dataset.themePref = next.theme;
    root.dataset.density = next.uiDensity;
    root.dataset.fontsize = next.fontsize;
    root.style.fontSize = FONT_SIZE_MAP[next.fontsize] || FONT_SIZE_MAP.md;
    if (next.contrast) root.dataset.contrast = 'high';
    else delete root.dataset.contrast;
    if (next.animations) root.dataset.animations = 'disabled';
    else delete root.dataset.animations;
  }

  function setStatus(id, msg, type) {
    const el = $(id);
    if (!el) return;
    el.textContent = msg || '';
    el.className = 'rsm-form-status' + (type ? (' is-' + type) : '');
  }

  function syncPreview() {
    const emoji = document.querySelector('input[name="pref-emoji"]:checked')?.value || '🌿';
    const color = document.querySelector('input[name="pref-color"]:checked')?.value || '#253f35';
    const display = $('p-display')?.value.trim() || '';
    const username = $('p-username')?.value.trim() || '';

    const prev = $('avatar-preview');
    const chip = $('user-chip-avatar');
    if (prev) { prev.textContent = emoji; prev.style.background = color; }
    if (chip) { chip.textContent = emoji; chip.style.background = color; }
    if ($('prev-display')) $('prev-display').textContent = display || '—';
    if ($('prev-username')) $('prev-username').textContent = username ? ('@' + username) : '@...';
  }

  function buildPickers(emoji, color) {
    const eg = $('emoji-grid');
    const cg = $('color-grid');
    if (!eg || !cg) return;
    eg.innerHTML = EMOJIS.map((e, i) =>
      `<input type="radio" id="em-${i}" name="pref-emoji" value="${e}" ${e === emoji ? 'checked' : ''}><label for="em-${i}">${e}</label>`
    ).join('');
    cg.innerHTML = COLORS.map((c, i) =>
      `<input type="radio" id="co-${i}" name="pref-color" value="${c}" ${c === color ? 'checked' : ''}><label for="co-${i}" style="background:${c}" aria-label="${c}"></label>`
    ).join('');
    eg.querySelectorAll('input').forEach(el => el.addEventListener('change', syncPreview));
    cg.querySelectorAll('input').forEach(el => el.addEventListener('change', syncPreview));
  }

  function getSelectedPreferredCategories() {
    const wrap = $('pref-category-chips');
    if (!wrap) return [];
    return Array.from(wrap.querySelectorAll('.pref-chip.on'))
      .map((node) => String(node.dataset.category || '').trim())
      .filter(Boolean);
  }
  function syncPreferredCategorySummary() {
    const summary = $('pref-category-summary');
    if (!summary) return;
    const selected = getSelectedPreferredCategories();
    summary.textContent = selected.length
      ? ('Categorie selezionate · ' + selected.join(', ') + '.')
      : 'Nessuna categoria selezionata · il sito resta neutro su tutti i temi.';
  }
  function renderPreferredCategoryChips(selected) {
    const wrap = $('pref-category-chips');
    if (!wrap) return;
    const chosen = new Set(normalizePreferredCategories(selected));
    wrap.innerHTML = CATEGORY_OPTIONS.map((category) => {
      const active = chosen.has(category);
      return '<button type="button" class="rsm-chip pref-chip' + (active ? ' on' : '') + '" data-category="' + category + '" aria-pressed="' + active + '">' + category + '</button>';
    }).join('');
    syncPreferredCategorySummary();
  }

  const THEME_LABELS = { auto: 'Automatico', chiaro: 'Chiaro', scuro: 'Scuro' };
  const FONT_LABELS  = { sm: 'Piccolo', md: 'Normale', lg: 'Grande', xl: 'Molto grande' };
  const DENSITY_LABELS = { comfortable: 'Standard', compact: 'Compatta' };

  function renderAccessibilitySummary(prefs) {
    const wrap = $('accessibility-summary');
    if (!wrap) return;
    const items = [
      { label: 'Tema',             value: THEME_LABELS[prefs.theme] || prefs.theme,         active: prefs.theme !== 'auto' },
      { label: 'Dimensione testo', value: FONT_LABELS[prefs.fontsize] || prefs.fontsize,    active: prefs.fontsize !== 'md' },
      { label: 'Densità UI',       value: DENSITY_LABELS[prefs.uiDensity] || prefs.uiDensity, active: prefs.uiDensity !== 'comfortable' },
      { label: 'Contrasto elevato', value: prefs.contrast ? 'Attivo' : 'Disattivato',       active: prefs.contrast },
      { label: 'Animazioni',       value: prefs.animations ? 'Disattivate' : 'Attive',      active: prefs.animations }
    ];
    wrap.innerHTML = items.map((it) =>
      '<div class="prefs-summary__tile" data-active="' + (it.active ? 'on' : 'off') + '">' +
        '<strong>' + it.label + '</strong>' +
        '<span>' + it.value + '</span>' +
      '</div>'
    ).join('');
  }

  function renderHeroTags(prefs) {
    const t = $('hero-tag-theme');
    const f = $('hero-tag-fontsize');
    const a = $('hero-tag-animations');
    if (t) t.textContent = 'Tema · ' + (THEME_LABELS[prefs.theme] || prefs.theme).toLowerCase();
    if (f) f.textContent = 'Testo · ' + (FONT_LABELS[prefs.fontsize] || prefs.fontsize).toLowerCase();
    if (a) a.textContent = 'Animazioni · ' + (prefs.animations ? 'disattivate' : 'attive');
  }

  /* ── Save handlers ── */
  function saveProfile() {
    setStatus('profile-status', '', '');
    const username = sanitizeUsername($('p-username')?.value || '');
    const displayName = String($('p-display')?.value || '').trim();
    const bio = String($('p-bio')?.value || '').trim();

    if (username.length < 3) {
      setStatus('profile-status', 'Username troppo corto: minimo 3 caratteri.', 'err');
      return;
    }

    const prefs = loadPrefs();
    prefs.username = username;
    prefs.displayName = displayName || username;
    prefs.bio = bio;
    savePrefs(prefs);

    if ($('user-chip-name')) $('user-chip-name').textContent = '@' + username;
    if ($('public-profile-link')) $('public-profile-link').href = '/profile?u=' + encodeURIComponent(username);
    syncPreview();
    setStatus('profile-status', 'Profilo aggiornato.', 'ok');
  }

  function saveAvatar() {
    setStatus('avatar-status', '', '');
    const emoji = document.querySelector('input[name="pref-emoji"]:checked')?.value || '🌿';
    const color = document.querySelector('input[name="pref-color"]:checked')?.value || '#253f35';

    const prefs = loadPrefs();
    prefs.avatarEmoji = emoji;
    prefs.avatarColor = color;
    savePrefs(prefs);

    if ($('user-chip-avatar')) {
      $('user-chip-avatar').textContent = emoji;
      $('user-chip-avatar').style.background = color;
    }
    setStatus('avatar-status', 'Avatar aggiornato.', 'ok');
  }

  function saveUiPreferences() {
    setStatus('ui-status', '', '');
    const next = loadPrefs();
    next.theme      = $('pref-theme')?.value      || next.theme;
    next.language   = $('pref-language')?.value   || next.language;
    next.uiDensity  = $('pref-density')?.value    || next.uiDensity;
    next.fontsize   = $('pref-fontsize')?.value   || next.fontsize;
    next.contrast   = !!$('pref-contrast')?.checked;
    next.animations = !!$('pref-animations')?.checked;
    savePrefs(next);
    applyUiPrefs(next);
    renderAccessibilitySummary(next);
    renderHeroTags(next);
    setStatus('ui-status', 'Aspetto salvato.', 'ok');
  }

  function saveCustomPreferences() {
    setStatus('custom-status', '', '');
    const next = loadPrefs();
    next.commentPrivacy = $('pref-comment-privacy')?.value || next.commentPrivacy;
    next.notifFrequency = $('pref-notif-frequency')?.value || next.notifFrequency;
    next.notifEmail = !!$('pref-notif-email')?.checked;
    next.preferredCategories = getSelectedPreferredCategories();
    savePrefs(next);
    setStatus('custom-status', 'Personalizzazioni salvate.', 'ok');
  }

  function init() {
    const prefs = loadPrefs();

    if ($('user-chip-name')) $('user-chip-name').textContent = prefs.username ? ('@' + prefs.username) : '@ospite';
    if ($('user-chip-avatar')) {
      $('user-chip-avatar').textContent = prefs.avatarEmoji;
      $('user-chip-avatar').style.background = prefs.avatarColor;
    }
    if ($('public-profile-link')) {
      $('public-profile-link').href = prefs.username ? ('/profile?u=' + encodeURIComponent(prefs.username)) : '#';
    }

    if ($('p-username')) $('p-username').value = prefs.username;
    if ($('p-display'))  $('p-display').value  = prefs.displayName || prefs.username;
    if ($('p-bio'))      $('p-bio').value      = prefs.bio;

    buildPickers(prefs.avatarEmoji, prefs.avatarColor);
    syncPreview();

    if ($('pref-theme'))     $('pref-theme').value     = prefs.theme;
    if ($('pref-language'))  $('pref-language').value  = prefs.language;
    if ($('pref-density'))   $('pref-density').value   = prefs.uiDensity;
    if ($('pref-fontsize'))  $('pref-fontsize').value  = prefs.fontsize;
    if ($('pref-contrast'))  $('pref-contrast').checked  = prefs.contrast;
    if ($('pref-animations'))$('pref-animations').checked = prefs.animations;

    if ($('pref-comment-privacy')) $('pref-comment-privacy').value = prefs.commentPrivacy;
    if ($('pref-notif-frequency')) $('pref-notif-frequency').value = prefs.notifFrequency;
    if ($('pref-notif-email'))     $('pref-notif-email').checked   = prefs.notifEmail;
    renderPreferredCategoryChips(prefs.preferredCategories);

    applyUiPrefs(prefs);
    renderAccessibilitySummary(prefs);
    renderHeroTags(prefs);

    if (systemThemeQuery) {
      const syncSystem = () => {
        const live = loadPrefs();
        if (live.theme === 'auto') applyUiPrefs(live);
      };
      if (systemThemeQuery.addEventListener) systemThemeQuery.addEventListener('change', syncSystem);
      else if (systemThemeQuery.addListener) systemThemeQuery.addListener(syncSystem);
    }

    $('save-profile-btn')?.addEventListener('click', saveProfile);
    $('save-avatar-btn')?.addEventListener('click', saveAvatar);
    $('save-ui-btn')?.addEventListener('click', saveUiPreferences);
    $('save-custom-btn')?.addEventListener('click', saveCustomPreferences);

    $('logout-btn')?.addEventListener('click', async () => {
      try {
        if (typeof supabase !== 'undefined' && typeof SUPABASE_URL !== 'undefined' && !String(SUPABASE_URL).includes('your-project')) {
          await supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY).auth.signOut();
        }
      } catch (_) {}
      location.href = '/login';
    });

    $('p-display')?.addEventListener('input', syncPreview);
    $('p-username')?.addEventListener('input', function () {
      this.value = sanitizeUsername(this.value);
      syncPreview();
    });

    ['pref-theme','pref-language','pref-density','pref-fontsize','pref-contrast','pref-animations'].forEach((id) => {
      $(id)?.addEventListener('change', () => {
        const live = loadPrefs();
        live.theme      = $('pref-theme')?.value    || live.theme;
        live.language   = $('pref-language')?.value || live.language;
        live.uiDensity  = $('pref-density')?.value  || live.uiDensity;
        live.fontsize   = $('pref-fontsize')?.value || live.fontsize;
        live.contrast   = !!$('pref-contrast')?.checked;
        live.animations = !!$('pref-animations')?.checked;
        savePrefs(live);
        applyUiPrefs(live);
        renderAccessibilitySummary(live);
        renderHeroTags(live);
      });
    });

    $('pref-category-chips')?.addEventListener('click', (event) => {
      const btn = event.target.closest('.pref-chip');
      if (!btn) return;
      const active = !btn.classList.contains('on');
      btn.classList.toggle('on', active);
      btn.setAttribute('aria-pressed', active);
      syncPreferredCategorySummary();
    });
  }

  init();
})();
</script>
