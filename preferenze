<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script src="supabase.config.js"></script>
<script>

(function () {
  if (typeof SUPABASE_URL === 'undefined' || SUPABASE_URL.includes('your-project')) return;

  const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  const $ = (id) => document.getElementById(id);

  const PREF_KEY = 'rsm_prefs_v1';
  const EMOJIS = ['🌿','🌊','🦢','🚣','🎣','🌾','🏞️','🦆','🌙','✨','🧭','📍','🍃','🏰','🌸','🛶','🦋','🌤️','📸','🧡'];
  const COLORS = ['#253f35','#2f6b67','#2E7D32','#7CB342','#F9A825','#8D6E63','#5C6BC0','#EC407A','#607D8B','#37474F'];

  const CATEGORY_OPTIONS = ['Eventi', 'Territorio', 'Vita locale', 'Avvisi', 'Richieste', 'Storie'];
  const defaultPrefs = {
    theme: 'chiaro',
    language: 'it',
    uiDensity: 'comfortable',
    fontsize: 'md',
    contrast: false,
    commentPrivacy: 'all',
    notifFrequency: 'daily',
    notifEmail: false,
    preferredCategories: []
  };

  let currentUser = null;
  let currentProfile = null;

  /* ── Prefs helpers ── */
  const FONT_SIZE_MAP = { sm: '14px', md: '16px', lg: '18px', xl: '20px' };
  const UI_OPTIONS = {
    theme: new Set(['auto', 'chiaro', 'scuro']),
    uiDensity: new Set(['comfortable', 'compact']),
    fontsize: new Set(['sm', 'md', 'lg', 'xl'])
  };
  const systemThemeQuery = window.matchMedia ? window.matchMedia('(prefers-color-scheme: dark)') : null;

  function normalizeUiPrefs(prefs) {
    const next = Object.assign({}, defaultPrefs, prefs || {});
    next.theme = UI_OPTIONS.theme.has(next.theme) ? next.theme : defaultPrefs.theme;
    next.uiDensity = UI_OPTIONS.uiDensity.has(next.uiDensity) ? next.uiDensity : defaultPrefs.uiDensity;
    next.fontsize = UI_OPTIONS.fontsize.has(next.fontsize) ? next.fontsize : defaultPrefs.fontsize;
    next.language = next.language === 'en' ? 'en' : 'it';
    next.contrast = !!next.contrast;
    next.preferredCategories = normalizePreferredCategories(next.preferredCategories);
    return next;
  }
  function resolveThemePreference(theme) {
    const pref = UI_OPTIONS.theme.has(theme) ? theme : defaultPrefs.theme;
    if (pref !== 'auto') return pref;
    return systemThemeQuery?.matches ? 'scuro' : 'chiaro';
  }
  function loadPrefs() {
    try { return normalizeUiPrefs(JSON.parse(localStorage.getItem(PREF_KEY)) || {}); }
    catch { return normalizeUiPrefs({}); }
  }
  function savePrefs(prefs) { localStorage.setItem(PREF_KEY, JSON.stringify(normalizeUiPrefs(prefs))); }
  function applyUiPrefs(prefs) {
    const next = normalizeUiPrefs(prefs);
    const root = document.documentElement;
    root.dataset.theme = resolveThemePreference(next.theme);
    root.dataset.themePref = next.theme;
    root.dataset.density = next.uiDensity;
    root.dataset.fontsize = next.fontsize;
    root.style.fontSize = FONT_SIZE_MAP[next.fontsize] || FONT_SIZE_MAP.md;
    root.style.filter = '';
    if (next.contrast) root.dataset.contrast = 'high';
    else delete root.dataset.contrast;
  }
  function isMissingSettingsError(error) {
    const msg = String(error?.message || '').toLowerCase();
    return error?.code === '42P01'
      || error?.code === 'PGRST205'
      || msg.includes('does not exist')
      || msg.includes('could not find the table');
  }
  function normalizePreferredCategories(input) {
    const values = Array.isArray(input) ? input : [];
    const aliases = {
      'eventi': 'Eventi',
      'territorio': 'Territorio',
      'vita locale': 'Vita locale',
      'avvisi': 'Avvisi',
      'richieste': 'Richieste',
      'storie': 'Storie',
      'il luccio': 'Storie',
      'fauna': 'Territorio',
      'ambiente': 'Territorio',
      'ecoturismo': 'Territorio',
      'storia': 'Storie'
    };
    const allowed = new Set(CATEGORY_OPTIONS);
    const seen = new Set();
    const normalized = [];
    values.forEach((value) => {
      const raw = String(value || '').trim();
      const next = aliases[raw.toLowerCase()] || raw;
      if (!next || !allowed.has(next) || seen.has(next)) return;
      seen.add(next);
      normalized.push(next);
    });
    return normalized;
  }
  function getSelectedPreferredCategories() {
    const wrap = $('pref-category-chips');
    if (!wrap) return [];
    return Array.from(wrap.querySelectorAll('.pref-chip.on'))
      .map((node) => String(node.dataset.category || '').trim())
      .filter(Boolean);
  }
  function syncPreferredCategorySummary() {
    const summary = $('pref-category-summary');
    if (!summary) return;
    const selected = getSelectedPreferredCategories();
    summary.textContent = selected.length
      ? ('Categorie selezionate: ' + selected.join(', ') + '.')
      : 'Nessuna categoria selezionata: il sito restera neutro su tutti i temi.';
  }
  function renderPreferredCategoryChips(selected) {
    const wrap = $('pref-category-chips');
    if (!wrap) return;
    const chosen = new Set(normalizePreferredCategories(selected));
    wrap.innerHTML = CATEGORY_OPTIONS.map((category) => {
      const active = chosen.has(category) ? ' on' : '';
      return '<button type="button" class="pref-chip' + active + '" data-category="' + category + '">' + category + '</button>';
    }).join('');
    syncPreferredCategorySummary();
  }

  /* ── Status helpers ── */
  function setStatus(id, msg, type) {
    const el = $(id);
    if (!el) return;
    el.textContent = msg || '';
    el.className = 'status-msg' + (type ? (' status-' + type) : '');
  }

  /* ── Sanitize username ── */
  function sanitizeUsername(v) { return String(v || '').toLowerCase().replace(/[^a-z0-9_]/g, ''); }

  /* ── Avatar preview ── */
  function syncPreview() {
    const emoji = document.querySelector('input[name="pref-emoji"]:checked')?.value || '🌿';
    const color = document.querySelector('input[name="pref-color"]:checked')?.value || '#253f35';
    const display = $('p-display')?.value.trim() || currentProfile?.display_name || currentProfile?.username || '';
    const username = $('p-username')?.value.trim() || currentProfile?.username || '';

    const prev = $('avatar-preview');
    const chip = $('user-chip-avatar');
    if (prev) { prev.textContent = emoji; prev.style.background = color; }
    if (chip) { chip.textContent = emoji; chip.style.background = color; }
    if ($('prev-display')) $('prev-display').textContent = display || '—';
    if ($('prev-username')) $('prev-username').textContent = username ? ('@' + username) : '—';
  }

  /* ── Build pickers ── */
  function buildPickers(emoji, color) {
    const eg = $('emoji-grid');
    const cg = $('color-grid');
    if (!eg || !cg) return;
    eg.innerHTML = EMOJIS.map((e, i) =>
      `<input type="radio" id="em-${i}" name="pref-emoji" value="${e}" ${e === emoji ? 'checked' : ''}><label for="em-${i}">${e}</label>`
    ).join('');
    cg.innerHTML = COLORS.map((c, i) =>
      `<input type="radio" id="co-${i}" name="pref-color" value="${c}" ${c === color ? 'checked' : ''}><label for="co-${i}" style="background:${c}"></label>`
    ).join('');
    eg.querySelectorAll('input').forEach(el => el.addEventListener('change', syncPreview));
    cg.querySelectorAll('input').forEach(el => el.addEventListener('change', syncPreview));
  }

  /* ── Save profile ── */
  async function saveProfile() {
    if (!currentUser || !currentProfile) return;
    setStatus('profile-status', '', '');

    const username = sanitizeUsername($('p-username')?.value || '');
    const displayName = String($('p-display')?.value || '').trim();
    const bio = String($('p-bio')?.value || '').trim();

    if (username.length < 3) {
      setStatus('profile-status', 'Username troppo corto: minimo 3 caratteri.', 'err');
      return;
    }

    const btn = $('save-profile-btn');
    if (btn) btn.disabled = true;

    const { error } = await sb.from('profiles').update({
      username,
      display_name: displayName || username,
      bio: bio || null,
    }).eq('id', currentUser.id);

    if (btn) btn.disabled = false;

    if (error) {
      const msg = error.code === '23505' ? 'Username già in uso. Prova con un altro.' : 'Salvataggio non riuscito: ' + error.message;
      setStatus('profile-status', msg, 'err');
      return;
    }

    currentProfile.username = username;
    currentProfile.display_name = displayName || username;
    currentProfile.bio = bio || null;
    if ($('user-chip-name')) $('user-chip-name').textContent = '@' + username;
    if ($('public-profile-link')) $('public-profile-link').href = 'profile?u=' + encodeURIComponent(username);
    syncPreview();
    setStatus('profile-status', 'Profilo aggiornato con successo.', 'ok');
  }

  /* ── Save avatar ── */
  async function saveAvatar() {
    if (!currentUser || !currentProfile) return;
    setStatus('avatar-status', '', '');

    const emoji = document.querySelector('input[name="pref-emoji"]:checked')?.value || '🌿';
    const color = document.querySelector('input[name="pref-color"]:checked')?.value || '#253f35';

    const btn = $('save-avatar-btn');
    if (btn) btn.disabled = true;

    const { error } = await sb.from('profiles').update({ avatar_emoji: emoji, avatar_color: color }).eq('id', currentUser.id);

    if (btn) btn.disabled = false;

    if (error) {
      setStatus('avatar-status', 'Aggiornamento non riuscito: ' + error.message, 'err');
      return;
    }

    currentProfile.avatar_emoji = emoji;
    currentProfile.avatar_color = color;
    setStatus('avatar-status', 'Avatar aggiornato.', 'ok');
  }

  /* ── Save UI prefs ── */
  async function saveUiPreferences() {
    if (!currentUser) return;
    setStatus('ui-status', '', '');

    const next = loadPrefs();
    next.theme     = $('pref-theme')?.value || 'auto';
    next.language  = $('pref-language')?.value || 'it';
    next.uiDensity = $('pref-density')?.value || 'comfortable';
    next.fontsize  = $('pref-fontsize')?.value || 'md';
    next.contrast  = !!$('pref-contrast')?.checked;

    savePrefs(next);
    applyUiPrefs(next);

    const btn = $('save-ui-btn');
    if (btn) btn.disabled = true;

    const { error } = await sb.from('user_settings').upsert({
      user_id: currentUser.id,
      accessibility_fontsize: next.fontsize,
      accessibility_high_contrast: next.contrast,
      updated_at: new Date().toISOString(),
    }, { onConflict: 'user_id' });

    if (btn) btn.disabled = false;

    if (error) {
      if (isMissingSettingsError(error)) {
        setStatus('ui-status', 'Preferenze locali salvate. Per il sync cloud applica supabase-security.sql.', 'ok');
      } else {
        setStatus('ui-status', 'Locale salvato, sync cloud fallita: ' + error.message, 'err');
      }
      return;
    }
    setStatus('ui-status', 'Aspetto salvato.', 'ok');
  }

  async function saveCustomPreferences() {
    if (!currentUser) return;
    setStatus('custom-status', '', '');

    const next = loadPrefs();
    next.commentPrivacy = $('pref-comment-privacy')?.value || 'all';
    next.notifFrequency = $('pref-notif-frequency')?.value || 'daily';
    next.notifEmail = !!$('pref-notif-email')?.checked;
    next.preferredCategories = getSelectedPreferredCategories();
    savePrefs(next);

    const btn = $('save-custom-btn');
    if (btn) btn.disabled = true;

    const { error } = await sb.from('user_settings').upsert({
      user_id: currentUser.id,
      comment_privacy: next.commentPrivacy,
      notif_frequency: next.notifFrequency,
      notif_email: next.notifEmail,
      preferred_categories: next.preferredCategories,
      updated_at: new Date().toISOString(),
    }, { onConflict: 'user_id' });

    if (btn) btn.disabled = false;

    if (error) {
      if (isMissingSettingsError(error)) {
        setStatus('custom-status', 'Personalizzazioni salvate in locale. Per il sync cloud applica supabase-security.sql.', 'ok');
      } else {
        setStatus('custom-status', 'Salvataggio non riuscito: ' + error.message, 'err');
      }
      return;
    }

    setStatus('custom-status', 'Personalizzazioni salvate.', 'ok');
  }

  /* ── Init ── */
  async function init() {
    const { data: { session } } = await sb.auth.getSession();
    if (!session?.user) { location.href = 'login'; return; }

    currentUser = session.user;

    const { data: profile, error } = await sb.from('profiles').select('*').eq('id', currentUser.id).single();
    if (error || !profile) { location.href = '/dashboard'; return; }

    currentProfile = profile;

    /* Populate chip */
    if ($('user-chip-name')) $('user-chip-name').textContent = '@' + (profile.username || 'utente');
    if ($('user-chip-avatar')) {
      $('user-chip-avatar').textContent = profile.avatar_emoji || '🌿';
      $('user-chip-avatar').style.background = profile.avatar_color || '#253f35';
    }
    if ($('public-profile-link')) $('public-profile-link').href = 'profile?u=' + encodeURIComponent(profile.username || '');

    /* Populate profile fields */
    if ($('p-username')) $('p-username').value = profile.username || '';
    if ($('p-display'))  $('p-display').value  = profile.display_name || profile.username || '';
    if ($('p-bio'))      $('p-bio').value       = profile.bio || '';

    /* Build pickers */
    buildPickers(profile.avatar_emoji || '🌿', profile.avatar_color || '#253f35');
    syncPreview();

    renderPreferredCategoryChips([]);

    /* Load UI prefs */
    const prefs = loadPrefs();

    const { data: remote } = await sb.from('user_settings')
      .select('comment_privacy,notif_frequency,notif_email,preferred_categories,accessibility_fontsize,accessibility_high_contrast')
      .eq('user_id', currentUser.id)
      .maybeSingle();

    if (remote) {
      if (remote.comment_privacy) prefs.commentPrivacy = remote.comment_privacy;
      if (remote.notif_frequency) prefs.notifFrequency = remote.notif_frequency;
      if (typeof remote.notif_email === 'boolean') prefs.notifEmail = remote.notif_email;
      if (Array.isArray(remote.preferred_categories)) prefs.preferredCategories = normalizePreferredCategories(remote.preferred_categories);
      if (remote.accessibility_fontsize) prefs.fontsize = remote.accessibility_fontsize;
      if (typeof remote.accessibility_high_contrast === 'boolean') prefs.contrast = remote.accessibility_high_contrast;
      savePrefs(prefs);
    }

    if ($('pref-theme'))    $('pref-theme').value    = prefs.theme || 'chiaro';
    if ($('pref-language')) $('pref-language').value = prefs.language || 'it';
    if ($('pref-density'))  $('pref-density').value  = prefs.uiDensity || 'comfortable';
    if ($('pref-fontsize')) $('pref-fontsize').value = prefs.fontsize || 'md';
    if ($('pref-contrast')) $('pref-contrast').checked = !!prefs.contrast;
    if ($('pref-comment-privacy')) $('pref-comment-privacy').value = prefs.commentPrivacy || 'all';
    if ($('pref-notif-frequency')) $('pref-notif-frequency').value = prefs.notifFrequency || 'daily';
    if ($('pref-notif-email')) $('pref-notif-email').checked = !!prefs.notifEmail;
    renderPreferredCategoryChips(prefs.preferredCategories || []);

    applyUiPrefs(prefs);
    if (systemThemeQuery) {
      const syncSystemTheme = () => {
        const live = loadPrefs();
        if (live.theme === 'auto') applyUiPrefs(live);
      };
      if (systemThemeQuery.addEventListener) systemThemeQuery.addEventListener('change', syncSystemTheme);
      else if (systemThemeQuery.addListener) systemThemeQuery.addListener(syncSystemTheme);
    }

    /* Bind save buttons */
    $('save-profile-btn')?.addEventListener('click', saveProfile);
    $('save-avatar-btn')?.addEventListener('click', saveAvatar);
    $('save-ui-btn')?.addEventListener('click', saveUiPreferences);
    $('save-custom-btn')?.addEventListener('click', saveCustomPreferences);
    $('logout-btn')?.addEventListener('click', async () => {
      await sb.auth.signOut();
      location.href = '/';
    });

    /* Live preview as user types */
    $('p-display')?.addEventListener('input', syncPreview);
    $('p-username')?.addEventListener('input', function () {
      this.value = sanitizeUsername(this.value);
      syncPreview();
    });

    /* Live UI preview on select change — also persists immediately to localStorage */
    ['pref-theme','pref-density','pref-fontsize','pref-contrast'].forEach((id) => {
      $(id)?.addEventListener('change', () => {
        const live = loadPrefs();
        live.theme     = $('pref-theme')?.value || live.theme;
        live.language  = $('pref-language')?.value || live.language;
        live.uiDensity = $('pref-density')?.value || live.uiDensity;
        live.fontsize  = $('pref-fontsize')?.value || live.fontsize;
        live.contrast  = !!$('pref-contrast')?.checked;
        savePrefs(live);
        applyUiPrefs(live);
      });
    });
    $('pref-language')?.addEventListener('change', () => {
      const live = loadPrefs();
      live.language = $('pref-language')?.value || live.language;
      savePrefs(live);
    });
    $('pref-category-chips')?.addEventListener('click', (event) => {
      const btn = event.target.closest('.pref-chip');
      if (!btn) return;
      btn.classList.toggle('on');
      syncPreferredCategorySummary();
    });
  }

  init();
})();
</script>
