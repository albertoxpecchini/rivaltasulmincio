          <span>Account attivo</span>
        </div>
        <span id="user-chip-avatar" style="width:42px;height:42px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;background:#253f35;flex-shrink:0">🌿</span>
      </div>
