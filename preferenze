<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script src="supabase.config.js"></script>
<script>

(function () {
  if (typeof SUPABASE_URL === 'undefined' || SUPABASE_URL.includes('your-project')) return;

  const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  const $ = (id) => document.getElementById(id);

  const PREF_KEY = 'rsm_prefs_v1';
  const EMOJIS = ['🌿','🌊','🦢','🚣','🎣','🌾','🏞️','🦆','🌙','✨','🧭','📍','🍃','🏰','🌸','🛶','🦋','🌤️','📸','🧡'];
  const COLORS = ['#253f35','#2f6b67','#2E7D32','#7CB342','#F9A825','#8D6E63','#5C6BC0','#EC407A','#607D8B','#37474F'];

  const defaultPrefs = { theme: 'chiaro', language: 'it', uiDensity: 'comfortable', fontsize: 'md', contrast: false };

  let currentUser = null;
  let currentProfile = null;

  /* ── Prefs helpers ── */
  function loadPrefs() {
    try { return Object.assign({}, defaultPrefs, JSON.parse(localStorage.getItem(PREF_KEY)) || {}); }
    catch { return Object.assign({}, defaultPrefs); }
  }
  function savePrefs(prefs) { localStorage.setItem(PREF_KEY, JSON.stringify(prefs)); }
  function applyUiPrefs(prefs) {
    const root = document.documentElement;
    if (prefs.theme === 'auto') {
      root.dataset.theme = window.matchMedia?.('(prefers-color-scheme: light)').matches ? 'chiaro' : 'scuro';
    } else {
      root.dataset.theme = prefs.theme || 'chiaro';
    }
    root.dataset.density = prefs.uiDensity || 'comfortable';
    const sizeMap = { sm: '14px', md: '16px', lg: '18px', xl: '20px' };
    root.style.fontSize = sizeMap[prefs.fontsize || 'md'] || '16px';
    root.style.filter = prefs.contrast ? 'contrast(1.16)' : '';
  }

  /* ── Status helpers ── */
  function setStatus(id, msg, type) {
    const el = $(id);
    if (!el) return;
    el.textContent = msg || '';
    el.className = 'status-msg' + (type ? (' status-' + type) : '');
  }

  /* ── Sanitize username ── */
  function sanitizeUsername(v) { return String(v || '').toLowerCase().replace(/[^a-z0-9_]/g, ''); }

  /* ── Avatar preview ── */
  function syncPreview() {
    const emoji = document.querySelector('input[name="pref-emoji"]:checked')?.value || '🌿';
    const color = document.querySelector('input[name="pref-color"]:checked')?.value || '#253f35';
    const display = $('p-display')?.value.trim() || currentProfile?.display_name || currentProfile?.username || '';
    const username = $('p-username')?.value.trim() || currentProfile?.username || '';

    const prev = $('avatar-preview');
    const chip = $('user-chip-avatar');
    if (prev) { prev.textContent = emoji; prev.style.background = color; }
    if (chip) { chip.textContent = emoji; chip.style.background = color; }
    if ($('prev-display')) $('prev-display').textContent = display || '—';
    if ($('prev-username')) $('prev-username').textContent = username ? ('@' + username) : '—';
  }

  /* ── Build pickers ── */
  function buildPickers(emoji, color) {
    const eg = $('emoji-grid');
    const cg = $('color-grid');
    if (!eg || !cg) return;
    eg.innerHTML = EMOJIS.map((e, i) =>
      `<input type="radio" id="em-${i}" name="pref-emoji" value="${e}" ${e === emoji ? 'checked' : ''}><label for="em-${i}">${e}</label>`
    ).join('');
    cg.innerHTML = COLORS.map((c, i) =>
      `<input type="radio" id="co-${i}" name="pref-color" value="${c}" ${c === color ? 'checked' : ''}><label for="co-${i}" style="background:${c}"></label>`
    ).join('');
    eg.querySelectorAll('input').forEach(el => el.addEventListener('change', syncPreview));
    cg.querySelectorAll('input').forEach(el => el.addEventListener('change', syncPreview));
  }

  /* ── Save profile ── */
  async function saveProfile() {
    if (!currentUser || !currentProfile) return;
    setStatus('profile-status', '', '');

    const username = sanitizeUsername($('p-username')?.value || '');
    const displayName = String($('p-display')?.value || '').trim();
    const bio = String($('p-bio')?.value || '').trim();

    if (username.length < 3) {
      setStatus('profile-status', 'Username troppo corto: minimo 3 caratteri.', 'err');
      return;
    }

    const btn = $('save-profile-btn');
    if (btn) btn.disabled = true;

    const { error } = await sb.from('profiles').update({
      username,
      display_name: displayName || username,
      bio: bio || null,
    }).eq('id', currentUser.id);

    if (btn) btn.disabled = false;

    if (error) {
      const msg = error.code === '23505' ? 'Username già in uso. Prova con un altro.' : 'Salvataggio non riuscito: ' + error.message;
      setStatus('profile-status', msg, 'err');
      return;
    }

    currentProfile.username = username;
    currentProfile.display_name = displayName || username;
    currentProfile.bio = bio || null;
    if ($('user-chip-name')) $('user-chip-name').textContent = '@' + username;
    if ($('public-profile-link')) $('public-profile-link').href = 'profile?u=' + encodeURIComponent(username);
    syncPreview();
    setStatus('profile-status', 'Profilo aggiornato con successo.', 'ok');
  }

  /* ── Save avatar ── */
  async function saveAvatar() {
    if (!currentUser || !currentProfile) return;
    setStatus('avatar-status', '', '');

    const emoji = document.querySelector('input[name="pref-emoji"]:checked')?.value || '🌿';
    const color = document.querySelector('input[name="pref-color"]:checked')?.value || '#253f35';

    const btn = $('save-avatar-btn');
    if (btn) btn.disabled = true;

    const { error } = await sb.from('profiles').update({ avatar_emoji: emoji, avatar_color: color }).eq('id', currentUser.id);

    if (btn) btn.disabled = false;

    if (error) {
      setStatus('avatar-status', 'Aggiornamento non riuscito: ' + error.message, 'err');
      return;
    }

    currentProfile.avatar_emoji = emoji;
    currentProfile.avatar_color = color;
    setStatus('avatar-status', 'Avatar aggiornato.', 'ok');
  }

  /* ── Save UI prefs ── */
  async function saveUiPreferences() {
    if (!currentUser) return;
    setStatus('ui-status', '', '');

    const next = loadPrefs();
    next.theme     = $('pref-theme')?.value || 'auto';
    next.language  = $('pref-language')?.value || 'it';
    next.uiDensity = $('pref-density')?.value || 'comfortable';
    next.fontsize  = $('pref-fontsize')?.value || 'md';
    next.contrast  = !!$('pref-contrast')?.checked;

    savePrefs(next);
    applyUiPrefs(next);

    const btn = $('save-ui-btn');
    if (btn) btn.disabled = true;

    const { error } = await sb.from('user_settings').upsert({
      user_id: currentUser.id,
      accessibility_fontsize: next.fontsize,
      accessibility_high_contrast: next.contrast,
      updated_at: new Date().toISOString(),
    }, { onConflict: 'user_id' });

    if (btn) btn.disabled = false;

    if (error) {
      const msg = String(error.message || '').toLowerCase();
      const missing = error.code === '42P01' || error.code === 'PGRST205' || msg.includes('does not exist') || msg.includes('could not find the table');
      if (missing) {
        setStatus('ui-status', 'Preferenze locali salvate. Per il sync cloud applica supabase-security.sql.', 'ok');
      } else {
        setStatus('ui-status', 'Locale salvato, sync cloud fallita: ' + error.message, 'err');
      }
      return;
    }
    setStatus('ui-status', 'Aspetto salvato.', 'ok');
  }

  /* ── Nav dropdown ── */
  function buildUserMenu(profile) {
    const wrap = $('user-menu-wrap');
    if (!wrap) return;
    const username = profile.username || 'utente';
    const emoji    = profile.avatar_emoji || '🌿';
    const color    = profile.avatar_color || '#253f35';
    const safe     = String(username).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    const profileHref = 'profile?u=' + encodeURIComponent(username);
    const cur = window.location.pathname;

    function item(label, href, active, primary) {
      return '<a href="' + href + '" role="menuitem" class="' + (active ? 'active ' : '') + (primary ? 'item-primary' : '') + '"><span>' + label + '</span><span aria-hidden="true">&rarr;</span></a>';
    }

    wrap.innerHTML =
      '<div class="profile-menu" id="profileMenu">' +
        '<button class="profile-btn" id="profileBtn" type="button" aria-haspopup="true" aria-expanded="false">' +
          '<span class="profile-avatar" style="background:' + color + '">' + emoji + '</span>' +
          '<span>@' + safe + '</span>' +
        '</button>' +
        '<div class="profile-dropdown" id="profileDropdown" role="menu">' +
          '<div class="profile-dropdown__section-title">Navigazione</div>' +
          item('Profilo', profileHref, false, false) +
          item('Dashboard', '/dashboard', false, false) +
          item('Modifica profilo', 'modifica-profilo?u=' + encodeURIComponent(username), false, false) +
          item('Scrivi', 'write', false, true) +
          item('Categorie', '/category', false, false) +
          item('Aspetto', 'preferenze', true, false) +
          item('Reimposta Password', 'reset', false, false) +
          '<div class="profile-dropdown__sep"></div>' +
          '<button type="button" data-action="logout" class="danger" role="menuitem"><span>Esci</span><span aria-hidden="true">&rarr;</span></button>' +
        '</div>' +
      '</div>';

    const btn = $('profileBtn');
    const dd  = $('profileDropdown');
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = dd.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
    dd.querySelector('[data-action="logout"]').addEventListener('click', async () => {
      await sb.auth.signOut();
      window.location.href = '/';
    });
    dd.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      dd.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    }));
    document.addEventListener('click', (e) => {
      if (!$('profileMenu')?.contains(e.target)) {
        dd.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }
    }, { capture: true });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { dd.classList.remove('open'); btn.setAttribute('aria-expanded', 'false'); }
    });
  }

  /* ── Init ── */
  async function init() {
    const { data: { session } } = await sb.auth.getSession();
    if (!session?.user) { location.href = 'login'; return; }

    currentUser = session.user;

    const { data: profile, error } = await sb.from('profiles').select('*').eq('id', currentUser.id).single();
    if (error || !profile) { location.href = '/dashboard'; return; }

    currentProfile = profile;

    buildUserMenu(profile);

    /* Populate chip */
    if ($('user-chip-name')) $('user-chip-name').textContent = '@' + (profile.username || 'utente');
    if ($('user-chip-avatar')) {
      $('user-chip-avatar').textContent = profile.avatar_emoji || '🌿';
      $('user-chip-avatar').style.background = profile.avatar_color || '#253f35';
    }
    if ($('public-profile-link')) $('public-profile-link').href = 'profile?u=' + encodeURIComponent(profile.username || '');

    /* Populate profile fields */
    if ($('p-username')) $('p-username').value = profile.username || '';
    if ($('p-display'))  $('p-display').value  = profile.display_name || profile.username || '';
    if ($('p-bio'))      $('p-bio').value       = profile.bio || '';

    /* Build pickers */
    buildPickers(profile.avatar_emoji || '🌿', profile.avatar_color || '#253f35');
    syncPreview();

    /* Load UI prefs */
    const prefs = loadPrefs();

    const { data: remote } = await sb.from('user_settings')
      .select('accessibility_fontsize,accessibility_high_contrast')
      .eq('user_id', currentUser.id)
      .maybeSingle();

    if (remote) {
      if (remote.accessibility_fontsize) prefs.fontsize = remote.accessibility_fontsize;
      if (typeof remote.accessibility_high_contrast === 'boolean') prefs.contrast = remote.accessibility_high_contrast;
      savePrefs(prefs);
    }

    if ($('pref-theme'))    $('pref-theme').value    = prefs.theme || 'chiaro';
    if ($('pref-language')) $('pref-language').value = prefs.language || 'it';
    if ($('pref-density'))  $('pref-density').value  = prefs.uiDensity || 'comfortable';
    if ($('pref-fontsize')) $('pref-fontsize').value = prefs.fontsize || 'md';
    if ($('pref-contrast')) $('pref-contrast').checked = !!prefs.contrast;

    applyUiPrefs(prefs);

    /* Bind save buttons */
    $('save-profile-btn')?.addEventListener('click', saveProfile);
    $('save-avatar-btn')?.addEventListener('click', saveAvatar);
    $('save-ui-btn')?.addEventListener('click', saveUiPreferences);
    $('logout-btn')?.addEventListener('click', async () => {
      await sb.auth.signOut();
      location.href = '/';
    });

    /* Live preview as user types */
    $('p-display')?.addEventListener('input', syncPreview);
    $('p-username')?.addEventListener('input', function () {
      this.value = sanitizeUsername(this.value);
      syncPreview();
    });

    /* Live UI preview on select change — also persists immediately to localStorage */
    ['pref-theme','pref-density','pref-fontsize','pref-contrast'].forEach((id) => {
      $(id)?.addEventListener('change', () => {
        const live = loadPrefs();
        live.theme     = $('pref-theme')?.value || live.theme;
        live.language  = $('pref-language')?.value || live.language;
        live.uiDensity = $('pref-density')?.value || live.uiDensity;
        live.fontsize  = $('pref-fontsize')?.value || live.fontsize;
        live.contrast  = !!$('pref-contrast')?.checked;
        savePrefs(live);
        applyUiPrefs(live);
      });
    });
    $('pref-language')?.addEventListener('change', () => {
      const live = loadPrefs();
      live.language = $('pref-language')?.value || live.language;
      savePrefs(live);
    });
  }

  init();
})();
</script>
