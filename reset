<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script src="supabase.config.js"></script>
<script>
(function () {
  function $(id) { return document.getElementById(id); }
  function escapeHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  var nav = $('nav-auth');
  if (!nav) return;
  if (typeof supabase === 'undefined' || typeof SUPABASE_URL === 'undefined' || SUPABASE_URL.indexOf('your-project') >= 0) {
    nav.innerHTML = '<a href="login" class="nav-login">Accedi</a>'; return;
  }
  var client = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  var outsideBound = false;
  function closeDropdown() {
    var d = $('profileDropdown'), b = $('profileBtn');
    if (d) d.classList.remove('open');
    if (b) b.setAttribute('aria-expanded','false');
  }
  function item(label, href, active, primary) {
    return '<a href="'+href+'" role="menuitem" class="'+(active?'active ':'')+(primary?'item-primary':'')+'"><span>'+label+'</span><span aria-hidden="true">&rarr;</span></a>';
  }
  function buildMenu(username, color, emoji) {
    emoji = emoji || '\uD83C\uDF3F';
    var safe = escapeHtml(username);
    var current = window.location.pathname;
    var profileHref = 'profile?u='+encodeURIComponent(username);
    var isProfile = current.indexOf('profile') >= 0;
    var isDashboard = current.toLowerCase().indexOf('/dashboard') >= 0 || current.toLowerCase().indexOf('/me') >= 0;
    var isWrite = current.indexOf('write') >= 0;
    var editItem = isProfile && new URLSearchParams(window.location.search).get('u') === username ? item('Modifica profilo','modifica-profilo',false,false) : '';
    return '<div class="profile-menu" id="profileMenu">'+
      '<button class="profile-btn" id="profileBtn" type="button" aria-haspopup="true" aria-expanded="false">'+
      '<span class="profile-avatar" style="background:'+escapeHtml(color||'#2f6b67')+'">'+escapeHtml(emoji)+'</span>'+
      '<span>@'+safe+'</span></button>'+
      '<div class="profile-dropdown" id="profileDropdown" role="menu" aria-label="Menu navigazione">'+
      '<div class="profile-dropdown__section-title">Navigazione</div>'+
      item('Profilo',profileHref,isProfile,false)+
      item('Dashboard','/dashboard',isDashboard,false)+
      editItem+
      item('Scrivi','write',isWrite,true)+
      item('Categorie','/category',current.indexOf('/category')>=0,false)+
      item('Aspetto','preferenze',current.indexOf('preferenze')>=0,false)+
      item('Reimposta Password','reset',current.indexOf('reset')>=0,false)+
      '<div class="profile-dropdown__sep"></div>'+
      '<button type="button" data-action="logout" class="danger" role="menuitem"><span>Esci</span><span aria-hidden="true">&rarr;</span></button>'+
      '</div></div>';
  }
  function bindMenu() {
    var btn = $('profileBtn'), dd = $('profileDropdown');
    if (!btn || !dd) return;
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var open = !dd.classList.contains('open');
      dd.classList.toggle('open', open);
      btn.setAttribute('aria-expanded', String(open));
    });
    dd.querySelectorAll('[data-action="logout"]').forEach(function(b) {
      b.addEventListener('click', function() { client.auth.signOut().then(function(){ window.location.reload(); }); });
    });
    dd.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', closeDropdown); });
    if (!outsideBound) {
      document.addEventListener('click', function(e) { var m=$('profileMenu'); if(m&&!m.contains(e.target)) closeDropdown(); }, {capture:true});
      document.addEventListener('keydown', function(e) { if(e.key==='Escape') closeDropdown(); });
      outsideBound = true;
    }
  }
  function render(session) {
    if (!session) { nav.innerHTML = '<a href="login" class="nav-login">Accedi</a>'; return; }
    client.from('profiles').select('username,avatar_emoji,avatar_color').eq('id',session.user.id).single().then(function(r) {
      var p = r&&r.data?r.data:{};
      var username = p.username || (session.user.email||'profilo').split('@')[0];
      nav.innerHTML = buildMenu(username, p.avatar_color||'#2f6b67', p.avatar_emoji||'\uD83C\uDF3F');
      bindMenu();
    });
  }
  client.auth.onAuthStateChange(function(_e,s){ render(s); });
  client.auth.getSession().then(function(r){ render(r&&r.data?r.data.session:null); });
})();
</script>
<script>
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

// ── Particles ──
(function(){
  const c = document.getElementById('particles');
  const ctx = c.getContext('2d');
  let W, H, pts = [];
  function resize(){W=c.width=innerWidth;H=c.height=innerHeight}
  resize(); window.addEventListener('resize',resize);
  for(let i=0;i<22;i++) pts.push({x:Math.random()*1e4,y:Math.random()*1e4,vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3,r:Math.random()*1.8+.6,a:Math.random()*.6+.2});
  function frame(){
    ctx.clearRect(0,0,W,H);
    pts.forEach(p=>{
      p.x+=p.vx;p.y+=p.vy;
      if(p.x<0)p.x=W;if(p.x>W)p.x=0;
      if(p.y<0)p.y=H;if(p.y>H)p.y=0;
      ctx.beginPath();ctx.arc(p.x%W,p.y%H,p.r,0,6.28);
      ctx.fillStyle=`rgba(198,164,98,${p.a})`;ctx.fill();
    });
    requestAnimationFrame(frame);
  }
  frame();
})();

// ── Eye toggle ──
function toggleEye(id, btn){
  const el = document.getElementById(id);
  el.type = el.type==='password' ? 'text' : 'password';
  btn.textContent = el.type==='password' ? '👁' : '🙈';
}

// ── Strength meter ──
document.getElementById('pwd1').addEventListener('input', function(){
  const v = this.value;
  let s = 0;
  if(v.length>=8) s++;
  if(/[A-Z]/.test(v)) s++;
  if(/[0-9]/.test(v)) s++;
  if(/[^A-Za-z0-9]/.test(v)) s++;
  const labels=['','Debole','Discreta','Buona','Ottima'];
  const cls=['','s1','s2','s3','s4'];
  for(let i=0;i<4;i++){
    const seg=document.getElementById('seg'+i);
    seg.className='seg'+(i<s?' '+cls[s]:'');
  }
  document.getElementById('str-label').textContent = v.length ? labels[s] : '';
});

// ── Show state ──
function showState(id){
  document.querySelectorAll('.state').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ── Error ──
function showErr(msg){
  const b=document.getElementById('err-banner');
  document.getElementById('err-text').textContent=msg;
  b.classList.add('show');
  setTimeout(()=>b.classList.remove('show'),5000);
}

// ── Auth state listener ──
let _session = null;
let _ready = false;

sb.auth.onAuthStateChange((event, session) => {
  if(event === 'PASSWORD_RECOVERY'){
    _session = session;
    showState('s-form');
    _ready = true;
  } else if(event === 'SIGNED_IN' && session) {
    // already signed in (token in hash), treat as recovery ready
    _session = session;
    if(!_ready) {
      showState('s-form');
      _ready = true;
    }
  }
});

// Check for hash params from Supabase email link
// Supabase puts access_token in the URL hash; the SDK handles it automatically.
// If after a short delay no recovery event fired, the token is invalid.
setTimeout(()=>{
  if(!_ready){
    // also check if there's any session at all via getSession
    sb.auth.getSession().then(({data:{session}})=>{
      if(session){
        _session = session;
        showState('s-form');
        _ready = true;
      } else {
        // check URL hash manually — Supabase may have already consumed it
        const hash = window.location.hash;
        if(hash && hash.includes('access_token')){
          // still waiting, give more time
          setTimeout(()=>{
            if(!_ready) showState('s-invalid');
          }, 2000);
        } else if(!hash || (!hash.includes('type=recovery') && !hash.includes('access_token'))){
          showState('s-invalid');
        }
      }
    });
  }
}, 1500);

// ── Submit ──
async function doReset(){
  const p1 = document.getElementById('pwd1').value;
  const p2 = document.getElementById('pwd2').value;
  if(!p1 || p1.length < 8){ showErr('La password deve essere di almeno 8 caratteri.'); return; }
  if(p1 !== p2){ showErr('Le password non coincidono.'); return; }

  const btn = document.getElementById('reset-btn');
  btn.classList.add('loading');
  btn.disabled = true;

  const {error} = await sb.auth.updateUser({password: p1});

  btn.classList.remove('loading');
  btn.disabled = false;

  if(error){
    showErr(error.message || 'Errore durante l\'aggiornamento della password.');
    return;
  }

  showState('s-success');
  // Auto-redirect after 3s
  setTimeout(()=>{ window.location.href='login'; }, 3000);
}

// Allow Enter key
document.addEventListener('keydown', e=>{
  if(e.key==='Enter' && document.getElementById('s-form').classList.contains('active')) doReset();
});
