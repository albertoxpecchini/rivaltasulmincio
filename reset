  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,650;1,9..144,550&display=swap" rel="stylesheet">
  <link href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@400,500,700,800,900&display=swap" rel="stylesheet">
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

    :root{
      --ink: #17221d;
      --ink-soft: #31453b;
      --cream: #f7f0e4;
      --paper: #fffaf0;
      --marsh: #253f35;
      --water: #2f6b67;
      --reed: #c6a462;
      --line: rgba(37,63,53,0.15);
      --ok: #2E7D32;
      --err: #b53838;
      --sans: "Cabinet Grotesk", system-ui, sans-serif;
      --serif: "Fraunces", Georgia, serif;
    }

    html,body{
      height:100%;
      font-family: var(--sans);
      background:
        radial-gradient(ellipse 80% 50% at 20% 10%, rgba(198,164,98,.18) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 80% 80%, rgba(47,107,103,.14) 0%, transparent 55%),
        linear-gradient(160deg, #fdf6e8 0%, #f5ede0 40%, #ede4d6 100%);
      color: var(--ink);
      overflow-x:hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background-image: radial-gradient(circle, rgba(37,63,53,.08) 1px, transparent 1px);
      background-size: 18px 18px;
      mix-blend-mode: multiply;
      opacity: 0.16;
    }

    #particles{position:fixed;inset:0;pointer-events:none;z-index:0}

    /* ── Nav Island ── */
    .site-header {
      position: fixed;
      top: 20px; left: 0; right: 0;
      z-index: 70;
      pointer-events: none;
    }
    .nav-island {
      position: relative;
      width: min(100% - 28px, 1240px);
      margin: 0 auto;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 18px;
      padding: 8px 10px 8px 12px;
      border: 1px solid rgba(255, 250, 240, 0.68);
      border-radius: 999px;
      background: rgba(247, 240, 228, 0.82);
      box-shadow: 0 18px 48px rgba(23, 34, 29, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      pointer-events: auto;
    }
    .brand {
      display: inline-flex; align-items: center; gap: 11px;
      min-width: 0; color: var(--ink); text-decoration: none;
    }
    .brand:hover { text-decoration: none; }
    .logo-mark {
      width: 42px; height: 42px; flex: 0 0 42px;
      border-radius: 14px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }
    .logo-mark img { width: 42px; height: 42px; object-fit: cover; display: block; }
    .brand-name { display: grid; line-height: 1.02; letter-spacing: -0.02em; }
    .brand-name strong { font-size: 0.98rem; font-weight: 800; }
    .brand-name span { font-size: 0.72rem; color: rgba(23, 34, 29, 0.55); font-weight: 600; }
    #nav-auth { display: flex; align-items: center; }
    .nav-login {
      border: 0; border-radius: 999px;
      background: var(--marsh); color: var(--paper);
      min-height: 42px; padding: 0 16px;
      display: inline-flex; align-items: center; justify-content: center;
      gap: 9px; font-weight: 500; font-family: var(--sans);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
      transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), background 420ms cubic-bezier(0.32, 0.72, 0, 1);
      text-decoration: none; cursor: pointer;
    }
    .nav-login:hover { transform: translateY(-1px); background: #1f362e; text-decoration: none; }
    .profile-btn {
      border: 0; border-radius: 999px;
      background: #253f35; color: #fffaf0;
      min-height: 42px; padding: 0 16px;
      display: inline-flex; align-items: center; justify-content: center;
      gap: 9px; font-weight: 500;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
      transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), background 420ms cubic-bezier(0.32, 0.72, 0, 1), box-shadow 420ms cubic-bezier(0.32, 0.72, 0, 1);
      cursor: pointer; font-family: var(--sans);
    }
    .profile-btn:hover { transform: translateY(-1px); background: #1f362e; box-shadow: 0 14px 30px rgba(23, 34, 29, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.20); }
    .profile-btn:active { transform: scale(0.98); }
    .profile-menu { position: relative; }
    .profile-avatar {
      width: 26px; height: 26px;
      display: inline-flex; align-items: center; justify-content: center;
      border-radius: 8px; background: #2f6b67; color: #fffaf0;
      font-size: 1rem; line-height: 1;
    }
    .profile-dropdown {
      position: absolute; right: 0; top: calc(100% + 12px);
      width: 230px; padding: 10px;
      border: 1px solid rgba(255, 250, 240, 0.58);
      border-radius: 24px;
      background: rgba(255, 250, 240, 0.94);
      box-shadow: 0 26px 80px rgba(37, 63, 53, 0.16);
      backdrop-filter: blur(20px);
      opacity: 0; visibility: hidden;
      transform: translateY(10px) scale(0.98);
      transition: opacity 360ms cubic-bezier(0.32, 0.72, 0, 1), transform 360ms cubic-bezier(0.32, 0.72, 0, 1), visibility 360ms cubic-bezier(0.32, 0.72, 0, 1);
    }
    .profile-dropdown.open { opacity: 1; visibility: visible; transform: translateY(0) scale(1); }
    .profile-dropdown__section-title {
      padding: 8px 10px; font-size: 0.66rem;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: rgba(23, 34, 29, 0.5); font-weight: 900;
    }
    .profile-dropdown a, .profile-dropdown button {
      width: 100%; border: 0; background: transparent; color: #17221d;
      display: flex; align-items: center; justify-content: space-between;
      min-height: 38px; padding: 0 10px; border-radius: 14px;
      font-weight: 750; text-align: left; text-decoration: none; cursor: pointer;
      transition: background 300ms cubic-bezier(0.32, 0.72, 0, 1), transform 300ms cubic-bezier(0.32, 0.72, 0, 1);
    }
    .profile-dropdown a:hover, .profile-dropdown button:hover, .profile-dropdown .active {
      background: rgba(37, 63, 53, 0.08); transform: translateX(2px);
    }
    .profile-dropdown .danger { color: #8f3b28; }
    .profile-dropdown__sep { height: 1px; background: rgba(37, 63, 53, 0.15); margin: 8px 4px; }
    @media (max-width: 760px) { .brand-name span { display: none; } }

    /* ── Layout ── */
    .page{position:relative;z-index:1;min-height:100vh;display:flex;align-items:center;justify-content:center;padding:100px 24px 48px}

    /* ── Card ── */
    .card{
      width:100%;max-width:440px;
      background:rgba(255,250,240,.92);
      border:1px solid var(--line);
      border-radius:24px;
      backdrop-filter:blur(28px);-webkit-backdrop-filter:blur(28px);
      padding:48px 44px 44px;
      box-shadow:0 32px 80px rgba(37,63,53,.10),0 0 0 1px rgba(37,63,53,.06);
      animation:cardIn .6s cubic-bezier(.22,1,.36,1) both
    }
    @keyframes cardIn{from{opacity:0;transform:translateY(32px) scale(.97)}to{opacity:1;transform:none}}

    /* ── Brand ── */
    .brand-card{display:flex;align-items:center;gap:12px;margin-bottom:40px}
    .brand-card-img{width:40px;height:40px;border-radius:12px;object-fit:cover}
    .brand-card-name{font-size:.8rem;font-weight:600;letter-spacing:.08em;text-transform:uppercase;color:var(--ink-soft)}

    /* ── Headings ── */
    .card-title{font-family:var(--serif);font-size:1.9rem;font-weight:650;line-height:1.2;margin-bottom:8px}
    .card-sub{font-size:.9rem;color:var(--ink-soft);line-height:1.6;margin-bottom:32px}

    /* ── Form ── */
    .field{margin-bottom:20px}
    label{display:block;font-size:.78rem;font-weight:600;letter-spacing:.06em;text-transform:uppercase;color:var(--ink-soft);margin-bottom:8px}
    .input-wrap{position:relative}
    input[type=password],input[type=text]{
      width:100%;padding:14px 48px 14px 16px;
      background:var(--paper);border:1px solid var(--line);border-radius:12px;
      color:var(--ink);font-size:.95rem;font-family:var(--sans);
      transition:border-color .2s,box-shadow .2s;outline:none
    }
    input:focus{border-color:rgba(47,107,103,.6);box-shadow:0 0 0 3px rgba(47,107,103,.12)}
    .eye-btn{position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;cursor:pointer;color:var(--ink-soft);font-size:1.1rem;padding:2px;transition:color .2s}
    .eye-btn:hover{color:var(--ink)}

    /* ── Strength meter ── */
    .strength-bar{display:flex;gap:4px;margin-top:8px}
    .seg{flex:1;height:3px;border-radius:99px;background:rgba(37,63,53,.10);transition:background .3s}
    .seg.s1{background:#c0392b}
    .seg.s2{background:#e67e22}
    .seg.s3{background:#e6c040}
    .seg.s4{background:#27ae60}
    .strength-label{font-size:.72rem;color:var(--ink-soft);margin-top:5px;height:14px}

    /* ── Button ── */
    .btn-main{
      width:100%;padding:15px;margin-top:8px;
      background:var(--marsh);
      border:none;border-radius:12px;
      color:var(--cream);font-size:1rem;font-weight:700;font-family:var(--sans);
      cursor:pointer;letter-spacing:.03em;
      box-shadow:0 8px 28px rgba(37,63,53,.22);
      transition:opacity .2s,transform .15s,box-shadow .2s;
      position:relative;overflow:hidden
    }
    .btn-main:hover{opacity:.88;transform:translateY(-1px);box-shadow:0 12px 36px rgba(37,63,53,.30)}
    .btn-main:active{transform:translateY(0)}
    .btn-main:disabled{opacity:.5;cursor:not-allowed;transform:none}
    .btn-main .spinner{display:none;width:18px;height:18px;border:2px solid rgba(255,255,255,.3);border-top-color:#fff;border-radius:50%;animation:spin .7s linear infinite;margin:0 auto}
    .btn-main.loading .btn-text{display:none}
    .btn-main.loading .spinner{display:block}
    @keyframes spin{to{transform:rotate(360deg)}}

    /* ── States ── */
    .state{display:none}
    .state.active{display:block;animation:fadeIn .4s ease both}
    @keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:none}}

    /* ── Success / Error ── */
    .big-icon{font-size:3.5rem;margin-bottom:16px;animation:pop .5s cubic-bezier(.34,1.56,.64,1) both}
    @keyframes pop{from{transform:scale(0) rotate(-20deg)}to{transform:scale(1) rotate(0)}}
    .success-title{font-family:var(--serif);font-size:1.7rem;font-weight:650;margin-bottom:10px}
    .success-sub{font-size:.9rem;color:var(--ink-soft);line-height:1.6;margin-bottom:28px}
    .btn-outline{
      display:inline-flex;align-items:center;gap:8px;
      padding:12px 24px;border-radius:10px;
      border:1px solid var(--line);background:rgba(37,63,53,.05);
      color:var(--ink);font-size:.9rem;font-family:var(--sans);cursor:pointer;
      transition:background .2s,border-color .2s;text-decoration:none
    }
    .btn-outline:hover{background:rgba(37,63,53,.09);border-color:rgba(37,63,53,.22)}

    /* ── Error banner ── */
    .err-banner{
      display:none;
      background:rgba(181,56,56,.08);border:1px solid rgba(181,56,56,.25);
      border-radius:10px;padding:12px 14px;
      font-size:.85rem;color:#b53838;margin-bottom:20px;
      animation:fadeIn .3s ease
    }
    .err-banner.show{display:flex;gap:10px;align-items:flex-start}

    /* ── Back link ── */
    .back-link{
      display:inline-flex;align-items:center;gap:6px;
      font-size:.82rem;color:var(--ink-soft);text-decoration:none;
      margin-top:24px;transition:color .2s
    }
    .back-link:hover{color:var(--ink)}

    .token-err{text-align:center;padding:8px 0}
  </style>
