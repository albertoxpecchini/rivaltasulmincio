<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>Nuova Password — Pro Loco Rivalta sul Mincio</title>
  <link rel="icon" href="/img/favicon.png" type="image/png" />
  <meta name="robots" content="noindex" />
</head>
<body>

<!--PARTIAL:nav-->

<main class="container rsm-page">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6 col-lg-5">
      <div class="card-wrapper">
        <div class="card card-bg">
          <div class="card-body">

            <p class="text-muted text-uppercase small mb-3">Rivalta sul Mincio · Parco del Mincio · Mantova</p>

            <!-- State: loading -->
            <div class="state active text-center py-4" id="s-loading">
              <div class="progress-spinner progress-spinner-active" role="status">
                <span class="visually-hidden">Caricamento…</span>
              </div>
              <p class="text-muted mt-3">Verifica del link in corso…</p>
            </div>

            <!-- State: invalid token -->
            <div class="state text-center" id="s-invalid">
              <h1 class="h4 text-danger">Link non valido</h1>
              <p class="text-muted">Il link di recupero è scaduto o non è valido. Richiedi un nuovo link dalla pagina di accesso.</p>
              <a href="/login" class="btn btn-outline-primary">← Torna al login</a>
            </div>

            <!-- State: reset form -->
            <div class="state" id="s-form">
              <h1 class="h4">Nuova password</h1>
              <p class="text-muted">Scegli una password sicura per il tuo account.</p>

              <div class="alert alert-danger err-banner" role="alert" id="err-banner">
                <span id="err-text"></span>
              </div>

              <div class="form-group">
                <label for="pwd1">Nuova password</label>
                <div class="input-group">
                  <input type="password" id="pwd1" class="form-control" placeholder="Almeno 8 caratteri" autocomplete="new-password">
                  <button class="btn btn-outline-secondary" type="button" onclick="toggleEye('pwd1',this)" tabindex="-1" aria-label="Mostra password">Mostra</button>
                </div>
                <div class="progress mt-2" style="height:6px">
                  <div class="progress-bar" role="progressbar" id="strBar" style="width:0%"></div>
                </div>
                <small class="form-text" id="str-label"></small>
              </div>

              <div class="form-group">
                <label for="pwd2">Conferma password</label>
                <div class="input-group">
                  <input type="password" id="pwd2" class="form-control" placeholder="Ripeti la password" autocomplete="new-password">
                  <button class="btn btn-outline-secondary" type="button" onclick="toggleEye('pwd2',this)" tabindex="-1" aria-label="Mostra password">Mostra</button>
                </div>
              </div>

              <button class="btn btn-primary w-100" id="reset-btn" onclick="doReset()">
                <span class="btn-text">Imposta nuova password</span>
              </button>

              <div class="mt-3">
                <a href="/login" class="link-dark">← Torna al login</a>
              </div>
            </div>

            <!-- State: success -->
            <div class="state text-center" id="s-success">
              <h1 class="h4">Password aggiornata!</h1>
              <p class="text-muted">La tua password è stata cambiata con successo. Puoi ora accedere al tuo account.</p>
              <a href="/login" class="btn btn-primary">Vai al login →</a>
            </div>

          </div>
        </div>
      </div>
    </div>
  </div>
</main>

<!--PARTIAL:footer-->

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script src="/supabase.config.js"></script>
<script>
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

// ── Eye toggle ──
function toggleEye(id, btn){
  const el = document.getElementById(id);
  el.type = el.type==='password' ? 'text' : 'password';
  btn.textContent = el.type==='password' ? 'Mostra' : 'Nascondi';
  btn.setAttribute('aria-label', el.type==='password' ? 'Mostra password' : 'Nascondi password');
}

// ── Strength meter ──
document.getElementById('pwd1').addEventListener('input', function(){
  const v = this.value;
  let s = 0;
  if(v.length>=8) s++;
  if(/[A-Z]/.test(v)) s++;
  if(/[0-9]/.test(v)) s++;
  if(/[^A-Za-z0-9]/.test(v)) s++;
  const labels=['','Debole','Discreta','Buona','Ottima'];
  const colors=['bg-secondary','bg-danger','bg-warning','bg-warning','bg-success'];
  const bar = document.getElementById('strBar');
  bar.className = 'progress-bar ' + (v.length ? colors[s] : '');
  bar.style.width = (v.length ? (s*25) : 0) + '%';
  document.getElementById('str-label').textContent = v.length ? labels[s] : '';
});

// ── Show state ──
function showState(id){
  document.querySelectorAll('.state').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ── Error ──
function showErr(msg){
  const b=document.getElementById('err-banner');
  document.getElementById('err-text').textContent=msg;
  b.classList.add('show');
  setTimeout(()=>b.classList.remove('show'),5000);
}

// ── Auth state listener ──
let _session = null;
let _ready = false;

sb.auth.onAuthStateChange((event, session) => {
  if(event === 'PASSWORD_RECOVERY'){
    _session = session;
    showState('s-form');
    _ready = true;
  } else if(event === 'SIGNED_IN' && session) {
    _session = session;
    if(!_ready) {
      showState('s-form');
      _ready = true;
    }
  }
});

setTimeout(()=>{
  if(!_ready){
    sb.auth.getSession().then(({data:{session}})=>{
      if(session){
        _session = session;
        showState('s-form');
        _ready = true;
      } else {
        const hash = window.location.hash;
        if(hash && hash.includes('access_token')){
          setTimeout(()=>{
            if(!_ready) showState('s-invalid');
          }, 2000);
        } else if(!hash || (!hash.includes('type=recovery') && !hash.includes('access_token'))){
          showState('s-invalid');
        }
      }
    });
  }
}, 1500);

// ── Submit ──
async function doReset(){
  const p1 = document.getElementById('pwd1').value;
  const p2 = document.getElementById('pwd2').value;
  if(!p1 || p1.length < 8){ showErr('La password deve essere di almeno 8 caratteri.'); return; }
  if(p1 !== p2){ showErr('Le password non coincidono.'); return; }

  const btn = document.getElementById('reset-btn');
  btn.disabled = true;

  const {error} = await sb.auth.updateUser({password: p1});

  btn.disabled = false;

  if(error){
    showErr(error.message || 'Errore durante l\'aggiornamento della password.');
    return;
  }

  showState('s-success');
  setTimeout(()=>{ window.location.href='/login'; }, 3000);
}

// Allow Enter key
document.addEventListener('keydown', e=>{
  if(e.key==='Enter' && document.getElementById('s-form').classList.contains('active')) doReset();
});
</script>

</body>
</html>
