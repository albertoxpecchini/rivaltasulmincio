<script>
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

// ── Particles ──
(function(){
  const c = document.getElementById('particles');
  const ctx = c.getContext('2d');
  let W, H, pts = [];
  function resize(){W=c.width=innerWidth;H=c.height=innerHeight}
  resize(); window.addEventListener('resize',resize);
  for(let i=0;i<22;i++) pts.push({x:Math.random()*1e4,y:Math.random()*1e4,vx:(Math.random()-.5)*.3,vy:(Math.random()-.5)*.3,r:Math.random()*1.8+.6,a:Math.random()*.6+.2});
  function frame(){
    ctx.clearRect(0,0,W,H);
    pts.forEach(p=>{
      p.x+=p.vx;p.y+=p.vy;
      if(p.x<0)p.x=W;if(p.x>W)p.x=0;
      if(p.y<0)p.y=H;if(p.y>H)p.y=0;
      ctx.beginPath();ctx.arc(p.x%W,p.y%H,p.r,0,6.28);
      ctx.fillStyle=`rgba(198,164,98,${p.a})`;ctx.fill();
    });
    requestAnimationFrame(frame);
  }
  frame();
})();

// ── Eye toggle ──
function toggleEye(id, btn){
  const el = document.getElementById(id);
  el.type = el.type==='password' ? 'text' : 'password';
  btn.textContent = el.type==='password' ? 'Mostra' : 'Nascondi';
  btn.setAttribute('aria-label', el.type==='password' ? 'Mostra password' : 'Nascondi password');
}

// ── Strength meter ──
document.getElementById('pwd1').addEventListener('input', function(){
  const v = this.value;
  let s = 0;
  if(v.length>=8) s++;
  if(/[A-Z]/.test(v)) s++;
  if(/[0-9]/.test(v)) s++;
  if(/[^A-Za-z0-9]/.test(v)) s++;
  const labels=['','Debole','Discreta','Buona','Ottima'];
  const cls=['','s1','s2','s3','s4'];
  for(let i=0;i<4;i++){
    const seg=document.getElementById('seg'+i);
    seg.className='seg'+(i<s?' '+cls[s]:'');
  }
  document.getElementById('str-label').textContent = v.length ? labels[s] : '';
});

// ── Show state ──
function showState(id){
  document.querySelectorAll('.state').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

// ── Error ──
function showErr(msg){
  const b=document.getElementById('err-banner');
  document.getElementById('err-text').textContent=msg;
  b.classList.add('show');
  setTimeout(()=>b.classList.remove('show'),5000);
}

// ── Auth state listener ──
let _session = null;
let _ready = false;

sb.auth.onAuthStateChange((event, session) => {
  if(event === 'PASSWORD_RECOVERY'){
    _session = session;
    showState('s-form');
    _ready = true;
  } else if(event === 'SIGNED_IN' && session) {
    // already signed in (token in hash), treat as recovery ready
    _session = session;
    if(!_ready) {
      showState('s-form');
      _ready = true;
    }
  }
});

// Check for hash params from Supabase email link
// Supabase puts access_token in the URL hash; the SDK handles it automatically.
// If after a short delay no recovery event fired, the token is invalid.
setTimeout(()=>{
  if(!_ready){
    // also check if there's any session at all via getSession
    sb.auth.getSession().then(({data:{session}})=>{
      if(session){
        _session = session;
        showState('s-form');
        _ready = true;
      } else {
        // check URL hash manually — Supabase may have already consumed it
        const hash = window.location.hash;
        if(hash && hash.includes('access_token')){
          // still waiting, give more time
          setTimeout(()=>{
            if(!_ready) showState('s-invalid');
          }, 2000);
        } else if(!hash || (!hash.includes('type=recovery') && !hash.includes('access_token'))){
          showState('s-invalid');
        }
      }
    });
  }
}, 1500);

// ── Submit ──
async function doReset(){
  const p1 = document.getElementById('pwd1').value;
  const p2 = document.getElementById('pwd2').value;
  if(!p1 || p1.length < 8){ showErr('La password deve essere di almeno 8 caratteri.'); return; }
  if(p1 !== p2){ showErr('Le password non coincidono.'); return; }

  const btn = document.getElementById('reset-btn');
  btn.classList.add('loading');
  btn.disabled = true;

  const {error} = await sb.auth.updateUser({password: p1});

  btn.classList.remove('loading');
  btn.disabled = false;

  if(error){
    showErr(error.message || 'Errore durante l\'aggiornamento della password.');
    return;
  }

  showState('s-success');
  // Auto-redirect after 3s
  setTimeout(()=>{ window.location.href='login'; }, 3000);
}

// Allow Enter key
document.addEventListener('keydown', e=>{
  if(e.key==='Enter' && document.getElementById('s-form').classList.contains('active')) doReset();
});
</script>
