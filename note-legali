      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,250,240,.74);
      color: var(--ink-soft);
      font-size: .76rem;
      font-weight: 800;
      letter-spacing: .02em;
    }

    /* ── TOC ── */
