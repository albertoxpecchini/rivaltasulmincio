  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <script src="/supabase.config.js"></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:      #10192b;
      --ink-soft: #5a6882;
      --cream:    #f4f7ff;
      --paper:    #fbfdff;
      --marsh:    #12203a;
      --water:    #4a9bff;
      --clay:     #8b5cf6;
      --reed:     #1fbf7d;
      --line:         rgba(18, 32, 58, 0.14);
      --sans:         "Cabinet Grotesk", system-ui, sans-serif;
      --serif:        "Fraunces", Georgia, serif;
      --ease:         cubic-bezier(0.32, 0.72, 0, 1);
      --shadow-strong: 0 42px 110px rgba(16, 25, 43, 0.22);
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--sans);
      background:
        radial-gradient(ellipse 80% 52% at 18% 8%, rgba(31, 191, 125, 0.16) 0%, transparent 60%),
        radial-gradient(ellipse 60% 44% at 82% 10%, rgba(74, 155, 255, 0.18) 0%, transparent 58%),
        radial-gradient(ellipse 56% 42% at 84% 84%, rgba(139, 92, 246, 0.12) 0%, transparent 60%),
        linear-gradient(160deg, #f8fbff 0%, #eef4ff 46%, #e8eefb 100%);
      color: var(--ink);
      font-size: 15px;
      line-height: 1.78;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    body::before {
      content: '';
      position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.14;
      background-image:
        radial-gradient(circle at 12% 18%, rgba(16,25,43,0.11) 0 1px, transparent 1px),
        radial-gradient(circle at 77% 54%, rgba(16,25,43,0.08) 0 1px, transparent 1px);
      background-size: 23px 23px, 31px 31px;
      mix-blend-mode: multiply;
    }

    a { color: var(--water); text-decoration: none; }
    a:hover { color: var(--clay); text-decoration: underline; }

    .skip-link {
      position: fixed; left: 16px; top: 12px; z-index: 90;
      padding: 10px 14px; border-radius: 999px;
      background: var(--ink); color: var(--paper);
      transform: translateY(-160%);
      transition: transform 360ms var(--ease);
      font-size: 0.85rem; font-weight: 600;
    }
    .skip-link:focus { transform: translateY(0); }

    /* ── Hero ── */
    .hero {
      position: relative; z-index: 1;
      padding: 128px 24px 56px;
      text-align: center; overflow: hidden;
    }
    .hero-eyebrow {
      display: inline-flex; align-items: center; gap: 8px;
      font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; color: var(--clay);
      background: rgba(184,102,63,0.10);
      border: 1px solid rgba(184,102,63,0.22);
      padding: 5px 14px; border-radius: 999px;
      margin-bottom: 20px;
    }
    .hero-eyebrow::before {
      content: ''; width: 6px; height: 6px;
      border-radius: 50%; background: var(--clay);
      animation: pulse-dot 2s ease-in-out infinite;
    }
    @keyframes pulse-dot {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.4; transform: scale(0.7); }
    }
    .hero-title {
      font-family: var(--serif); font-size: clamp(2.2rem, 5vw, 4.4rem);
      font-weight: 650; line-height: 1.08; color: var(--marsh);
      margin-bottom: 14px; letter-spacing: -0.02em;
    }
    .hero-title em { font-style: italic; color: var(--water); }
    .hero-subtitle {
      max-width: 600px; margin: 0 auto 30px;
      font-size: 1rem; color: var(--ink-soft); line-height: 1.62;
    }
    .hero-stats {
      display: flex; justify-content: center; gap: 8px;
      flex-wrap: wrap; margin-bottom: 0;
    }
    .stat-pill {
      display: flex; align-items: center; gap: 8px;
      background: rgba(37,63,53,0.07);
      border: 1px solid rgba(37,63,53,0.15);
      border-radius: 999px; padding: 7px 14px;
      font-size: 0.78rem; font-weight: 600; color: var(--ink-soft);
    }
    .stat-pill strong { color: var(--marsh); font-size: 0.98rem; font-weight: 800; }
    .stat-pill .sep { opacity: 0.3; }

    /* ── Wrapper ── */
    .page-wrap {
      position: relative; z-index: 1;
      width: min(100% - 48px, 1160px);
      margin: 0 auto;
      padding-bottom: 88px;
    }

    /* ── Section title ── */
    .section-label {
      display: flex; align-items: center; gap: 12px;
      font-size: 0.72rem; font-weight: 800; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--clay);
      margin-bottom: 18px; padding-top: 38px;
    }
    .section-label::before, .section-label::after {
      content: ''; flex: 1; height: 1px; background: var(--line);
    }
    .section-label::before { max-width: 32px; }

    /* ── Timeline ── */
    .timeline {
      position: relative;
      padding-left: 30px;
      max-width: 720px;
    }
    .timeline::before {
      content: '';
      position: absolute; left: 10px; top: 0; bottom: 0;
      width: 2px;
      background: linear-gradient(to bottom, var(--reed), var(--water) 50%, var(--marsh));
      border-radius: 2px;
    }

    .timeline-entry {
      position: relative; margin-bottom: 40px;
      opacity: 0; transform: translateY(18px);
      transition: opacity 0.5s ease, transform 0.5s ease;
    }
    .timeline-entry.visible { opacity: 1; transform: none; }

    .timeline-dot {
      position: absolute; left: -30px; top: 6px;
      width: 14px; height: 14px; border-radius: 50%;
      background: var(--cream);
      border: 2.5px solid var(--reed);
      box-shadow: 0 0 0 4px rgba(198,164,98,0.18);
    }
    .timeline-dot.milestone {
      width: 18px; height: 18px; left: -32px;
      border-color: var(--marsh);
      background: var(--marsh);
      box-shadow: 0 0 0 5px rgba(37,63,53,0.16);
    }

    .timeline-date {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.09em;
      text-transform: uppercase; color: var(--reed);
      margin-bottom: 6px;
    }
    .timeline-heading {
      font-family: var(--serif); font-size: 1.22rem; font-weight: 650;
      color: var(--marsh); line-height: 1.22; margin-bottom: 8px;
    }
    .timeline-body {
      color: var(--ink-soft); font-size: 0.92rem; line-height: 1.72;
    }
    .timeline-body p + p { margin-top: 10px; }

    /* ── Card funzioni ── */
    .functions-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 12px;
      margin-top: 8px;
    }
    .fn-card--wide { grid-column: span 2; }
    .fn-card {
      background: rgba(255,250,240,0.72);
      border: 1px solid rgba(37,63,53,0.12);
      border-radius: 16px;
      padding: 18px 18px;
      backdrop-filter: blur(8px);
      transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    }
    .fn-card:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 32px rgba(37,63,53,0.12);
      border-color: rgba(37,63,53,0.22);
    }
    .fn-card-icon {
      font-size: 1.6rem; margin-bottom: 10px; line-height: 1;
    }
    .fn-card-title {
      font-weight: 800; font-size: 0.9rem; color: var(--marsh);
      margin-bottom: 4px; letter-spacing: -0.01em;
    }
    .fn-card-route {
      font-size: 0.72rem; font-weight: 600; font-family: monospace;
      color: var(--water); background: rgba(47,107,103,0.10);
      border-radius: 4px; padding: 1px 6px;
      display: inline-block; margin-bottom: 8px;
    }
    .fn-card-desc {
      font-size: 0.82rem; color: var(--ink-soft); line-height: 1.65;
    }
    .fn-card-lines {
      margin-top: 10px; font-size: 0.72rem; color: var(--reed);
      font-weight: 600;
    }

    /* ── Stack table ── */
    .stack-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px; margin-top: 8px;
    }
    .stack-item {
      background: rgba(255,250,240,0.65);
      border: 1px solid var(--line); border-radius: 12px;
      padding: 16px 18px;
      display: flex; flex-direction: column; gap: 4px;
    }
    .stack-layer {
      font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
      letter-spacing: 0.1em; color: var(--clay);
    }
    .stack-name {
      font-weight: 800; font-size: 0.95rem; color: var(--marsh);
    }
    .stack-note {
      font-size: 0.78rem; color: var(--ink-soft);
    }

    /* ── Commit block ── */
    .commit-block {
      background: var(--marsh);
      color: var(--cream);
      border-radius: 18px;
      padding: 32px 36px;
      font-family: monospace;
      position: relative; overflow: hidden;
      margin: 8px 0;
    }
    .commit-block::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(circle at 80% 20%, rgba(198,164,98,0.14), transparent 60%);
      pointer-events: none;
    }
    .commit-line { font-size: 0.82rem; line-height: 2; opacity: 0.85; }
    .commit-line .key { color: var(--reed); }
    .commit-line .val { color: #d4f0d4; }
    .commit-line .hash { color: #a8d8b0; font-size: 0.78rem; }

    /* ── Numbers bento ── */
    .numbers-bento {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px; margin-top: 8px;
    }
    .number-tile {
      background: rgba(255,250,240,0.7);
      border: 1px solid var(--line); border-radius: 16px;
      padding: 22px 20px; text-align: center;
      transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
      display: flex; flex-direction: column;
      align-items: center; justify-content: center;
    }
    .number-tile:hover {
      transform: translateY(-2px);
      box-shadow: 0 6px 24px rgba(37,63,53,0.10);
      border-color: rgba(37,63,53,0.20);
    }
    .number-tile .num {
      font-family: var(--serif); font-size: 2.4rem; font-weight: 650;
      color: var(--marsh); line-height: 1; display: block;
      font-variant-numeric: tabular-nums;
    }
    .number-tile .label {
      font-size: 0.72rem; font-weight: 700; color: var(--ink-soft);
      text-transform: uppercase; letter-spacing: 0.07em; margin-top: 8px;
    }
    /* Bento grid positions */
    #tile-deploy { grid-column: 1; grid-row: 1 / 3;
      background: rgba(37,63,53,0.07); border-color: rgba(37,63,53,0.18); }
    #tile-deploy .num { font-size: 4.2rem; }
    #tile-lines  { grid-column: 2 / 4; grid-row: 1;
      background: rgba(47,107,103,0.07); border-color: rgba(47,107,103,0.18); }
    #tile-lines .num  { font-size: 3.2rem; }
    #tile-files  { grid-column: 4; grid-row: 1; }
    #tile-pages  { grid-column: 2; grid-row: 2; }
    #tile-videos { grid-column: 3; grid-row: 2; }
    #tile-images { grid-column: 4; grid-row: 2; }
    #tile-posts  { grid-column: 1 / 3; grid-row: 3; }
    #tile-posts .num  { font-size: 3rem; }
    #tile-members { grid-column: 3; grid-row: 3; }
    #tile-npm    { grid-column: 4; grid-row: 3; }
    #tile-words  { grid-column: 1 / 3; grid-row: 4; }
    #tile-words .num  { font-size: 3rem; }
    #tile-comments { grid-column: 3; grid-row: 4; }
    #tile-likes  { grid-column: 4; grid-row: 4; }

    /* ── Security list ── */
    .security-list {
      list-style: none;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 10px;
    }
    .security-list li {
      display: flex; align-items: flex-start; gap: 12px;
      font-size: 0.9rem; color: var(--ink-soft); line-height: 1.6;
    }
    .security-list li::before {
      content: '↳';
      color: var(--clay); font-weight: 700; flex-shrink: 0; margin-top: 2px;
    }

    /* ── Color swatches ── */
    .color-row {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 10px; margin-top: 8px;
    }
    .swatch {
      display: flex; align-items: center; gap: 10px;
      background: rgba(255,250,240,0.7);
      border: 1px solid var(--line); border-radius: 10px;
      padding: 10px 14px;
    }
    .swatch-dot {
      width: 24px; height: 24px; border-radius: 6px; flex-shrink: 0;
      border: 1px solid rgba(0,0,0,0.08);
    }
    .swatch-info { display: flex; flex-direction: column; gap: 1px; }
    .swatch-name { font-weight: 700; font-size: 0.82rem; color: var(--marsh); }
    .swatch-hex  { font-family: monospace; font-size: 0.75rem; color: var(--ink-soft); }
    .swatch-use  { font-size: 0.72rem; color: var(--reed); }

    .container {
      width: min(100% - 44px, 1400px);
      margin: 0 auto;
    }

    /* ── Release card ── */
    .release-card {
      background: rgba(255,250,240,0.75);
      border: 1px solid rgba(37,63,53,0.13);
      border-radius: 20px;
      padding: 28px 30px 24px;
      backdrop-filter: blur(8px);
      transition: box-shadow 0.2s;
    }
    .release-card:hover {
      box-shadow: 0 8px 36px rgba(37,63,53,0.10);
    }
    .release-header {
      display: flex; align-items: flex-start;
      justify-content: space-between; flex-wrap: wrap;
      gap: 12px; margin-bottom: 14px;
    }
    .release-version-block {
      display: flex; align-items: center; gap: 10px;
    }
    .release-v-badge {
      font-size: 0.68rem; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.12em; color: var(--water);
      background: rgba(47,107,103,0.11);
      border: 1px solid rgba(47,107,103,0.22);
      padding: 3px 10px; border-radius: 999px;
    }
    .release-vname {
      font-family: var(--serif); font-size: 1.55rem; font-weight: 650;
      color: var(--marsh); line-height: 1;
    }
    .release-date-text {
      font-size: 0.8rem; font-weight: 600; color: var(--ink-soft);
      padding-top: 4px;
    }
    .release-commit-row {
      display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
      padding: 9px 14px;
      background: rgba(37,63,53,0.055);
      border-radius: 10px; margin-bottom: 20px;
      font-size: 0.82rem;
    }
    .release-commit-row code {
      font-family: monospace; font-weight: 700;
      color: var(--water); font-size: 0.8rem;
    }
    .release-commit-row .rel-msg {
      color: var(--ink-soft); flex: 1; min-width: 0;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    }
    .release-commit-row .rel-author {
      color: var(--reed); font-weight: 600; font-size: 0.78rem;
    }
    .release-commit-row a {
      color: var(--marsh); font-weight: 800;
      flex-shrink: 0; font-size: 0.9rem;
    }
    .release-commit-row a:hover { color: var(--water); text-decoration: none; }
    .release-changes-title {
      font-size: 0.72rem; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.12em; color: var(--clay); margin-bottom: 12px;
    }
    .release-changes-list {
      list-style: none; padding: 0; margin: 0;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
      gap: 8px;
    }
    .release-changes-list li {
      display: flex; align-items: flex-start; gap: 8px;
      font-size: 0.87rem; color: var(--ink-soft); line-height: 1.55;
    }
    .release-changes-list li::before {
      content: '+'; color: var(--water); font-weight: 800;
      flex-shrink: 0; margin-top: 1px;
    }
    .release-commits-list {
      list-style: none;
      margin: 10px 0 0;
      padding: 0;
      display: grid;
      gap: 10px;
    }
    .release-commits-list li {
      border: 1px solid rgba(37, 63, 53, 0.18);
      background: rgba(255, 255, 255, 0.55);
      border-radius: 12px;
      padding: 10px 12px;
      display: grid;
      gap: 4px;
    }
    .release-commits-list .row-top {
      display: flex;
      align-items: baseline;
      gap: 8px;
      flex-wrap: wrap;
      font-size: 0.84rem;
      color: var(--ink-soft);
    }
    .release-commits-list .row-top code {
      color: var(--water);
      font-weight: 700;
      font-size: 0.78rem;
    }
    .release-commits-list .row-msg {
      font-size: 0.87rem;
      color: var(--ink);
      line-height: 1.45;
    }
    .release-commits-list .row-files {
      font-size: 0.78rem;
      color: var(--ink-soft);
      opacity: 0.85;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .release-skeleton {
      color: var(--reed); font-size: 0.82rem; font-style: italic; opacity: 0.65;
    }

    /* ── Live ── */
    .live-bar {
      display: flex; align-items: center; gap: 14px;
      flex-wrap: wrap; margin-bottom: 28px;
    }
    .live-dot-badge {
      display: inline-flex; align-items: center; gap: 7px;
      font-size: 0.72rem; font-weight: 800; letter-spacing: 0.13em;
      text-transform: uppercase; color: #2a7a3b;
      background: rgba(42,122,59,0.10);
      border: 1px solid rgba(42,122,59,0.24);
      padding: 5px 13px; border-radius: 999px;
    }
    .live-dot-badge::before {
      content: ''; width: 7px; height: 7px; border-radius: 50%;
      background: #2a7a3b;
      animation: blink-live 1s step-start infinite;
    }
    @keyframes blink-live {
      0%, 100% { opacity: 1; }
      50%       { opacity: 0; }
    }
    .live-since {
      font-size: 0.82rem; color: var(--ink-soft); font-weight: 600;
    }

    .uptime-row {
      display: flex; gap: 8px; flex-wrap: wrap;
      align-items: center; margin-bottom: 36px;
    }
    .uptime-unit {
      display: flex; flex-direction: column; align-items: center;
      background: rgba(255,250,240,0.72);
      border: 1px solid var(--line); border-radius: 14px;
      padding: 14px 18px; min-width: 76px;
    }
    .uptime-unit .u-val {
      font-family: var(--serif); font-size: 2rem; font-weight: 650;
      color: var(--marsh); line-height: 1;
      font-variant-numeric: tabular-nums;
      min-width: 2ch; text-align: center;
    }
    .uptime-unit .u-lbl {
      font-size: 0.65rem; font-weight: 800; text-transform: uppercase;
      letter-spacing: 0.10em; color: var(--ink-soft); margin-top: 5px;
    }
    .uptime-sep {
      font-family: var(--serif); font-size: 1.8rem; font-weight: 650;
      color: var(--reed); line-height: 1; padding-bottom: 10px;
      user-select: none;
    }

    .number-tile[data-live] { position: relative; overflow: visible; }
    .number-tile[data-live]::after {
      content: '●';
      position: absolute; top: 8px; right: 10px;
      font-size: 0.5rem; color: #2a7a3b;
      animation: blink-live 1s step-start infinite;
    }
    .number-tile .num.loading { color: var(--reed); font-size: 1rem; }

    /* ── Footer ── */
    .footer {
      color: rgba(255, 250, 240, 0.72);
      background: #101c18;
      padding: 72px 0 34px;
    }

    .footer-grid {
      display: grid;
      grid-template-columns: minmax(0, 0.72fr) repeat(3, minmax(140px, 0.22fr));
      gap: clamp(24px, 5vw, 76px);
      align-items: start;
    }

    .footer h3,
    .footer h4 {
      margin: 0 0 16px;
      color: var(--paper);
      letter-spacing: -0.02em;
    }

    .footer h3 {
      max-width: 520px;
      font-family: var(--serif);
      font-size: clamp(2rem, 4vw, 4.8rem);
      line-height: 0.96;
      letter-spacing: -0.055em;
    }

    .footer p {
      max-width: 540px;
      line-height: 1.66;
    }

    .footer-links {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 10px;
    }

    .footer-links a {
      color: rgba(255, 250, 240, 0.68);
