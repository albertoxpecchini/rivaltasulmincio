  <style>
    *, *::before, *::after { box-sizing: border-box; }
    * { margin: 0; }

    :root {
      --story-bg: #f7fafe;
      --story-ink: #08111f;
      --story-ink-2: #172033;
      --story-muted: #65728a;
      --story-muted-2: #93a0b4;
      --story-card: rgba(255, 255, 255, 0.72);
      --story-card-strong: rgba(255, 255, 255, 0.9);
      --story-line: rgba(12, 20, 35, 0.12);
      --story-line-strong: rgba(12, 20, 35, 0.2);
      --story-emerald: #1fbf7d;
      --story-azure: #4a9bff;
      --story-violet: #8b5cf6;
      --story-grad: linear-gradient(100deg, var(--story-emerald) 0%, var(--story-azure) 50%, var(--story-violet) 100%);
      --story-grad-soft: linear-gradient(135deg, rgba(31,191,125,0.14), rgba(74,155,255,0.12), rgba(139,92,246,0.14));
      --story-shadow: 0 28px 90px rgba(9, 17, 31, 0.12);
      --story-shadow-soft: 0 14px 42px rgba(9, 17, 31, 0.08);
      --story-radius-xl: 34px;
      --story-radius-lg: 24px;
      --story-radius-md: 16px;
      --story-sans: "Cabinet Grotesk", var(--rsm-font-sans, system-ui, sans-serif);
      --story-serif: "Fraunces", var(--rsm-font-display, Georgia, serif);
      --story-mono: var(--rsm-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
      --story-ease: cubic-bezier(0.16, 1, 0.3, 1);
    }

    html { scroll-behavior: smooth; }

    body {
      min-height: 100vh;
      font-family: var(--story-sans);
      color: var(--story-ink);
      background:
        radial-gradient(circle at 12% 8%, rgba(31, 191, 125, 0.22), transparent 28rem),
        radial-gradient(circle at 85% 12%, rgba(74, 155, 255, 0.24), transparent 30rem),
        radial-gradient(circle at 72% 82%, rgba(139, 92, 246, 0.18), transparent 34rem),
        linear-gradient(180deg, #ffffff 0%, var(--story-bg) 42%, #eef4ff 100%);
      font-size: 16px;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.58;
      background:
        linear-gradient(90deg, rgba(12,20,35,0.035) 1px, transparent 1px),
        linear-gradient(180deg, rgba(12,20,35,0.035) 1px, transparent 1px),
        radial-gradient(circle at 1px 1px, rgba(255,255,255,0.6) 0.8px, transparent 1.3px);
      background-size: 72px 72px, 72px 72px, 3px 3px;
      mask-image: linear-gradient(180deg, #000 0%, rgba(0,0,0,0.74) 58%, transparent 100%);
    }

    body::after {
      content: '';
      position: fixed;
      inset: auto -15vw -32vw -15vw;
      height: 48vw;
      min-height: 420px;
      z-index: 0;
      pointer-events: none;
      background: radial-gradient(closest-side, rgba(74,155,255,0.12), transparent 70%);
      filter: blur(10px);
    }

    a { color: var(--story-azure); text-decoration: none; }
    a:hover { color: var(--story-violet); }
    code { font-family: var(--story-mono); font-size: 0.92em; }

    .skip-link {
      position: fixed;
      left: 18px;
      top: 14px;
      z-index: 100;
      padding: 11px 16px;
      border-radius: 999px;
      background: var(--story-ink);
      color: #fff;
      box-shadow: var(--story-shadow-soft);
      transform: translateY(-180%);
      transition: transform 360ms var(--story-ease);
      font-size: 0.86rem;
      font-weight: 800;
    }
    .skip-link:focus { transform: translateY(0); }

    .hero {
      position: relative;
      z-index: 1;
      isolation: isolate;
      width: min(100% - 40px, 1320px);
      margin: 0 auto;
      padding: clamp(132px, 16vw, 220px) 0 clamp(64px, 8vw, 110px);
      text-align: left;
    }
    .hero::before {
      content: '';
      position: absolute;
      right: min(-9vw, -90px);
      top: 18%;
      width: min(46vw, 620px);
      aspect-ratio: 1;
      z-index: -1;
      border-radius: 48% 52% 42% 58%;
      background:
        radial-gradient(circle at 34% 26%, rgba(255,255,255,0.78), transparent 24%),
        conic-gradient(from 140deg, rgba(31,191,125,0.22), rgba(74,155,255,0.28), rgba(139,92,246,0.24), rgba(31,191,125,0.22));
      filter: blur(0.2px);
      opacity: 0.95;
      animation: story-orb 18s ease-in-out infinite alternate;
    }
    .hero::after {
      content: '';
      position: absolute;
      left: -9vw;
      bottom: 9%;
      width: 260px;
      height: 260px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(31,191,125,0.2), transparent 68%);
      z-index: -1;
    }
    @keyframes story-orb {
      from { transform: translate3d(0, 0, 0) rotate(0deg); border-radius: 48% 52% 42% 58%; }
      to { transform: translate3d(-18px, 22px, 0) rotate(12deg); border-radius: 56% 44% 60% 40%; }
    }

    .hero-eyebrow,
    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-family: var(--story-mono);
      font-size: clamp(0.68rem, 0.78vw, 0.78rem);
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--story-muted);
    }
    .hero-eyebrow::before,
    .section-label::before {
      content: '';
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--story-grad);
      box-shadow: 0 0 0 7px rgba(74,155,255,0.10);
    }
    .hero-eyebrow { margin-bottom: 22px; }

    .hero-title {
      max-width: 980px;
      font-family: var(--story-sans);
      font-size: clamp(4rem, 10vw, 10.5rem);
      font-weight: 900;
      line-height: 0.86;
      letter-spacing: -0.085em;
      color: var(--story-ink);
      text-wrap: balance;
    }
    .hero-title em {
      font-family: var(--story-serif);
      font-weight: 500;
      font-style: italic;
      background: var(--story-grad);
      background-size: 220% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: story-grad 8s ease-in-out infinite alternate;
    }
    @keyframes story-grad { to { background-position: 100% 50%; } }

    .hero-subtitle {
      max-width: 760px;
      margin: clamp(26px, 4vw, 42px) 0 0;
      font-size: clamp(1.08rem, 1.5vw, 1.34rem);
      font-weight: 500;
      line-height: 1.55;
      color: var(--story-muted);
    }
    .hero-subtitle span { color: var(--story-ink-2); font-weight: 900; }
    .hero-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      max-width: 980px;
      margin-top: clamp(28px, 4vw, 48px);
    }
    .stat-pill {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      min-height: 44px;
      padding: 8px 15px;
      border: 1px solid rgba(255,255,255,0.68);
      border-radius: 999px;
      background: rgba(255,255,255,0.58);
      color: var(--story-muted);
      font-weight: 800;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.72), 0 12px 36px rgba(9,17,31,0.06);
      backdrop-filter: blur(18px);
    }
    .stat-pill strong { color: var(--story-ink); font-size: 1.02rem; }
    .stat-pill .sep { color: var(--story-muted-2); }

    .page-wrap {
      position: relative;
      z-index: 1;
      width: min(100% - 40px, 1240px);
      margin: 0 auto;
      padding: 0 0 100px;
    }
    .section-label {
      display: flex;
      margin: clamp(54px, 8vw, 92px) 0 18px;
    }

    .release-card,
    .fn-card,
    .stack-item,
    .swatch,
    .uptime-unit,
    .number-tile,
    .release-commits-list li {
      position: relative;
      border: 1px solid var(--story-line);
      background:
        linear-gradient(145deg, rgba(255,255,255,0.86), rgba(255,255,255,0.56)) padding-box,
        var(--story-grad) border-box;
      box-shadow: var(--story-shadow-soft);
      backdrop-filter: blur(20px);
    }

    .release-card {
      overflow: hidden;
      border-radius: var(--story-radius-xl);
      padding: clamp(24px, 4vw, 44px);
      box-shadow: var(--story-shadow);
    }
    .release-card::before {
      content: '';
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: radial-gradient(circle at 85% 0%, rgba(74,155,255,0.16), transparent 36%), radial-gradient(circle at 0% 100%, rgba(31,191,125,0.12), transparent 38%);
    }
    .release-card > * { position: relative; }
    .release-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 18px;
      flex-wrap: wrap;
      margin-bottom: 18px;
    }
    .release-version-block { display: flex; align-items: center; gap: 13px; flex-wrap: wrap; }
    .release-v-badge,
    .release-changes-title {
      font-family: var(--story-mono);
      font-size: 0.7rem;
      font-weight: 900;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--story-violet);
    }
    .release-v-badge {
      padding: 7px 11px;
      border-radius: 999px;
      background: rgba(139,92,246,0.11);
      border: 1px solid rgba(139,92,246,0.2);
    }
    .release-vname {
      font-family: var(--story-serif);
      font-size: clamp(1.55rem, 3vw, 2.5rem);
      font-weight: 650;
      line-height: 1;
      color: var(--story-ink);
    }
    .release-date-text { color: var(--story-muted); font-weight: 800; padding-top: 8px; }
    .release-commit-row {
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
      min-height: 52px;
      margin: 18px 0 26px;
      padding: 12px 16px;
      border: 1px solid var(--story-line);
      border-radius: 18px;
      background: rgba(9,17,31,0.045);
    }
    .release-commit-row code { color: var(--story-azure); font-weight: 900; }
    .release-commit-row .rel-msg { color: var(--story-ink-2); font-weight: 700; flex: 1; min-width: 220px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .release-commit-row .rel-author { color: var(--story-muted); font-size: 0.86rem; font-weight: 800; }
    .release-commit-row a { display: inline-flex; align-items: center; justify-content: center; width: 34px; height: 34px; border-radius: 50%; color: #fff; background: var(--story-ink); }
    .release-changes-list,
    .release-commits-list,
    .security-list { list-style: none; padding: 0; }
    .release-changes-list {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 10px;
      margin-top: 12px;
    }
    .release-changes-list li,
    .security-list li {
      display: flex;
      gap: 10px;
      color: var(--story-muted);
      font-weight: 600;
      line-height: 1.55;
    }
    .release-changes-list li::before,
    .security-list li::before {
      content: '+';
      flex: 0 0 auto;
      color: var(--story-emerald);
      font-weight: 900;
    }
    .release-commits-list { display: grid; gap: 10px; margin-top: 12px; }
    .release-commits-list li {
      border-radius: 18px;
      padding: 14px 16px;
      box-shadow: none;
    }
    .release-commits-list .row-top { display: flex; align-items: baseline; gap: 10px; flex-wrap: wrap; color: var(--story-muted); font-size: 0.86rem; }
    .release-commits-list .row-top code { color: var(--story-azure); font-weight: 900; }
    .release-commits-list .row-msg { color: var(--story-ink-2); font-weight: 800; line-height: 1.35; }
    .release-commits-list .row-files { color: var(--story-muted-2); font-size: 0.82rem; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .release-skeleton { color: var(--story-muted); font-style: italic; }

    .live-bar { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; margin-bottom: 18px; }
    .live-dot-badge {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(31,191,125,0.12);
      color: #0d8a5a;
      border: 1px solid rgba(31,191,125,0.22);
      font-family: var(--story-mono);
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
    }
    .live-dot-badge::before,
    .number-tile[data-live]::after {
      content: '';
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--story-emerald);
      box-shadow: 0 0 0 6px rgba(31,191,125,0.14);
      animation: story-pulse 1.4s ease-in-out infinite;
    }
    @keyframes story-pulse { 50% { opacity: 0.35; transform: scale(0.7); } }
    .live-since { color: var(--story-muted); font-weight: 800; }

    .uptime-row { display: flex; align-items: stretch; flex-wrap: wrap; gap: 10px; margin-bottom: 20px; }
    .uptime-unit {
      min-width: 104px;
      border-radius: 22px;
      padding: 18px 20px;
      text-align: center;
    }
    .uptime-unit .u-val,
    .number-tile .num {
      display: block;
      font-family: var(--story-sans);
      font-weight: 900;
      line-height: 0.9;
      letter-spacing: -0.06em;
      color: var(--story-ink);
      font-variant-numeric: tabular-nums;
    }
    .uptime-unit .u-val { font-size: clamp(2rem, 4vw, 3rem); }
    .uptime-unit .u-lbl,
    .number-tile .label {
      display: block;
      margin-top: 10px;
      font-family: var(--story-mono);
      color: var(--story-muted);
      font-size: 0.68rem;
      font-weight: 900;
      letter-spacing: 0.13em;
      text-transform: uppercase;
    }
    .uptime-sep { align-self: center; color: var(--story-muted-2); font-size: 2rem; font-family: var(--story-serif); }

    .numbers-bento {
      display: grid;
      grid-template-columns: repeat(6, 1fr);
      gap: 14px;
    }
    .number-tile {
      min-height: 160px;
      border-radius: var(--story-radius-lg);
      padding: 22px;
      overflow: hidden;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      transition: transform 360ms var(--story-ease), box-shadow 360ms var(--story-ease), border-color 360ms var(--story-ease);
    }
    .number-tile:hover { transform: translateY(-5px); box-shadow: var(--story-shadow); border-color: rgba(74,155,255,0.26); }
    .number-tile[data-live]::after { position: absolute; top: 18px; right: 18px; width: 7px; height: 7px; }
    .number-tile .num { font-size: clamp(2.2rem, 5vw, 4.7rem); }
    .number-tile .num.loading { font-size: 1.4rem; letter-spacing: 0; color: var(--story-muted); }
    #tile-deploy { grid-column: span 2; grid-row: span 2; min-height: 334px; background: linear-gradient(145deg, rgba(31,191,125,0.16), rgba(255,255,255,0.68)); }
    #tile-lines { grid-column: span 3; background: linear-gradient(145deg, rgba(74,155,255,0.16), rgba(255,255,255,0.68)); }
    #tile-files, #tile-pages, #tile-videos, #tile-images, #tile-npm, #tile-words, #tile-members, #tile-comments, #tile-likes { grid-column: span 1; }
    #tile-posts { grid-column: span 2; background: linear-gradient(145deg, rgba(139,92,246,0.14), rgba(255,255,255,0.68)); }

    .timeline {
      position: relative;
      display: grid;
      gap: 18px;
      max-width: 980px;
      margin-top: 4px;
    }
    .timeline::before {
      content: '';
      position: absolute;
      left: 16px;
      top: 20px;
      bottom: 20px;
      width: 2px;
      background: linear-gradient(180deg, var(--story-emerald), var(--story-azure), var(--story-violet));
      opacity: 0.45;
    }
    .timeline-entry {
      position: relative;
      padding: 22px 24px 22px 58px;
      border: 1px solid transparent;
      border-radius: var(--story-radius-lg);
      background: rgba(255,255,255,0.52);
      opacity: 0;
      transform: translateY(22px);
      transition: opacity 640ms var(--story-ease), transform 640ms var(--story-ease), background 360ms var(--story-ease), box-shadow 360ms var(--story-ease);
    }
    .timeline-entry.visible { opacity: 1; transform: none; }
    .timeline-entry:hover { background: rgba(255,255,255,0.82); box-shadow: var(--story-shadow-soft); }
    .timeline-dot {
      position: absolute;
      left: 8px;
      top: 30px;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: #fff;
      border: 5px solid var(--story-azure);
      box-shadow: 0 0 0 8px rgba(74,155,255,0.12);
      z-index: 1;
    }
    .timeline-dot.milestone { border-color: var(--story-emerald); box-shadow: 0 0 0 8px rgba(31,191,125,0.14); }
    .timeline-date { font-family: var(--story-mono); font-size: 0.72rem; font-weight: 900; letter-spacing: 0.14em; text-transform: uppercase; color: var(--story-violet); margin-bottom: 8px; }
    .timeline-heading { font-family: var(--story-sans); font-size: clamp(1.45rem, 2.3vw, 2.1rem); line-height: 1.04; letter-spacing: -0.04em; color: var(--story-ink); margin-bottom: 12px; }
    .timeline-body { color: var(--story-muted); font-size: 1rem; font-weight: 500; line-height: 1.72; }
    .timeline-body p + p { margin-top: 12px; }

    .functions-grid,
    .stack-grid,
    .color-row {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 14px;
    }
    .fn-card {
      grid-column: span 3;
      min-height: 218px;
      border-radius: var(--story-radius-lg);
      padding: 24px;
      overflow: hidden;
      transition: transform 360ms var(--story-ease), box-shadow 360ms var(--story-ease);
    }
    .fn-card--wide { grid-column: span 6; }
    .fn-card:hover { transform: translateY(-5px); box-shadow: var(--story-shadow); }
    .fn-card-icon { font-size: 2rem; line-height: 1; margin-bottom: 18px; }
    .fn-card-title { color: var(--story-ink); font-size: 1.08rem; font-weight: 900; letter-spacing: -0.02em; }
    .fn-card-route { display: inline-flex; margin: 8px 0 12px; padding: 5px 9px; border-radius: 999px; background: rgba(74,155,255,0.1); color: var(--story-azure); font-family: var(--story-mono); font-size: 0.72rem; font-weight: 900; }
    .fn-card-desc { color: var(--story-muted); font-weight: 600; line-height: 1.56; }
    .fn-card-lines { margin-top: 14px; color: var(--story-violet); font-family: var(--story-mono); font-size: 0.72rem; font-weight: 900; letter-spacing: 0.08em; text-transform: uppercase; }

    .stack-item,
    .swatch {
      grid-column: span 3;
      border-radius: 20px;
      padding: 18px;
      box-shadow: none;
    }
    .stack-layer { font-family: var(--story-mono); color: var(--story-violet); font-size: 0.68rem; font-weight: 900; letter-spacing: 0.14em; text-transform: uppercase; }
    .stack-name { margin-top: 4px; color: var(--story-ink); font-weight: 900; letter-spacing: -0.02em; }
    .stack-note { margin-top: 3px; color: var(--story-muted); font-weight: 600; }

    .security-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(310px, 1fr)); gap: 12px 22px; padding: 28px; border-radius: var(--story-radius-lg); border: 1px solid var(--story-line); background: rgba(255,255,255,0.52); }
