<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <script>!function(){try{var p=JSON.parse(localStorage.getItem('rsm_prefs_v1'))||{},r=document.documentElement,s={sm:'14px',md:'16px',lg:'18px',xl:'20px'};if(p.theme&&p.theme!=='auto')r.dataset.theme=p.theme;if(p.fontsize)r.style.fontSize=s[p.fontsize]||'16px';if(p.uiDensity)r.dataset.density=p.uiDensity;if(p.contrast)r.style.filter='contrast(1.16)';}catch(e){}}();</script>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Articolo – Pro Loco Rivalta sul Mincio</title>
  <link rel="icon" href="/img/favicon.png" type="image/png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,650;1,9..144,550&display=swap" rel="stylesheet" />
  <link href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@400,500,700,800,900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #17221d;
      --ink-soft: #31453b;
      --cream: #f7f0e4;
      --paper: #fffaf0;
      --marsh: #253f35;
      --marsh-2: #3d6353;
      --water: #2f6b67;
      --clay: #b8663f;
      --reed: #c6a462;
      --line: rgba(37,63,53,0.15);
      --sans: "Cabinet Grotesk", system-ui, sans-serif;
      --serif: "Fraunces", Georgia, serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background:
        radial-gradient(ellipse 80% 50% at 20% 10%, rgba(198,164,98,.18) 0%, transparent 60%),
        radial-gradient(ellipse 60% 40% at 80% 80%, rgba(47,107,103,.14) 0%, transparent 55%),
        linear-gradient(160deg, #fdf6e8 0%, #f5ede0 40%, #ede4d6 100%);
      color: var(--ink);
      font-family: var(--sans);
      line-height: 1.75;
      min-height: 100vh;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background-image: radial-gradient(circle, rgba(37,63,53,.08) 1px, transparent 1px);
      background-size: 18px 18px;
      mix-blend-mode: multiply;
      opacity: 0.16;
    }

    a { color: var(--water); text-decoration: none; }

    /* ── Nav Island ── */
    .site-header {
      position: fixed;
      top: 20px; left: 0; right: 0;
      z-index: 70;
      pointer-events: none;
    }
    .nav-island {
      position: relative;
      width: min(100% - 28px, 1240px);
      margin: 0 auto;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 18px;
      padding: 8px 10px 8px 12px;
      border: 1px solid rgba(255, 250, 240, 0.68);
      border-radius: 999px;
      background: rgba(247, 240, 228, 0.82);
      box-shadow: 0 18px 48px rgba(23, 34, 29, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      pointer-events: auto;
    }
    .brand {
      display: inline-flex; align-items: center; gap: 11px;
      min-width: 0; color: var(--ink); text-decoration: none;
    }
    .brand:hover { text-decoration: none; }
    .logo-mark {
      width: 42px; height: 42px; flex: 0 0 42px;
      border-radius: 14px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }
    .logo-mark img { width: 42px; height: 42px; object-fit: cover; display: block; }
    .brand-name { display: grid; line-height: 1.02; letter-spacing: -0.02em; }
    .brand-name strong { font-size: 0.98rem; font-weight: 800; }
    .brand-name span { font-size: 0.72rem; color: rgba(23, 34, 29, 0.55); font-weight: 600; }
    #nav-auth { display: flex; align-items: center; }
    .nav-login {
      border: 0; border-radius: 999px;
      background: var(--marsh); color: var(--paper);
      min-height: 42px; padding: 0 16px;
      display: inline-flex; align-items: center; justify-content: center;
      gap: 9px; font-weight: 500; font-family: var(--sans);
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
      transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), background 420ms cubic-bezier(0.32, 0.72, 0, 1);
      text-decoration: none; cursor: pointer;
    }
    .nav-login:hover { transform: translateY(-1px); background: #1f362e; text-decoration: none; }
    .profile-btn {
      border: 0; border-radius: 999px;
      background: #253f35; color: #fffaf0;
      min-height: 42px; padding: 0 16px;
      display: inline-flex; align-items: center; justify-content: center;
      gap: 9px; font-weight: 500;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
      transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), background 420ms cubic-bezier(0.32, 0.72, 0, 1), box-shadow 420ms cubic-bezier(0.32, 0.72, 0, 1);
      cursor: pointer; font-family: var(--sans);
    }
    .profile-btn:hover { transform: translateY(-1px); background: #1f362e; box-shadow: 0 14px 30px rgba(23, 34, 29, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.20); }
    .profile-btn:active { transform: scale(0.98); }
    .profile-menu { position: relative; }
    .profile-avatar {
      width: 26px; height: 26px;
      display: inline-flex; align-items: center; justify-content: center;
      border-radius: 8px; background: #2f6b67; color: #fffaf0;
      font-size: 1rem; line-height: 1;
    }
    .profile-dropdown {
      position: absolute; right: 0; top: calc(100% + 12px);
      width: 230px; padding: 10px;
      border: 1px solid rgba(255, 250, 240, 0.58);
      border-radius: 24px;
      background: rgba(255, 250, 240, 0.94);
      box-shadow: 0 26px 80px rgba(37, 63, 53, 0.16);
      backdrop-filter: blur(20px);
      opacity: 0; visibility: hidden;
      transform: translateY(10px) scale(0.98);
      transition: opacity 360ms cubic-bezier(0.32, 0.72, 0, 1), transform 360ms cubic-bezier(0.32, 0.72, 0, 1), visibility 360ms cubic-bezier(0.32, 0.72, 0, 1);
    }
    .profile-dropdown.open { opacity: 1; visibility: visible; transform: translateY(0) scale(1); }
    .profile-dropdown__section-title {
      padding: 8px 10px; font-size: 0.66rem;
      letter-spacing: 0.16em; text-transform: uppercase;
      color: rgba(23, 34, 29, 0.5); font-weight: 900;
    }
    .profile-dropdown a, .profile-dropdown button {
      width: 100%; border: 0; background: transparent; color: #17221d;
      display: flex; align-items: center; justify-content: space-between;
      min-height: 38px; padding: 0 10px; border-radius: 14px;
      font-weight: 750; text-align: left; text-decoration: none; cursor: pointer;
      transition: background 300ms cubic-bezier(0.32, 0.72, 0, 1), transform 300ms cubic-bezier(0.32, 0.72, 0, 1);
    }
    .profile-dropdown a:hover, .profile-dropdown button:hover, .profile-dropdown .active {
      background: rgba(37, 63, 53, 0.08); transform: translateX(2px);
    }
    .profile-dropdown .danger { color: #8f3b28; }
    .profile-dropdown__sep { height: 1px; background: rgba(37, 63, 53, 0.15); margin: 8px 4px; }
    @media (max-width: 760px) { .brand-name span { display: none; } }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 18px;
      border-radius: 999px;
      font-size: .84rem;
      font-weight: 600;
      font-family: var(--sans);
      cursor: pointer;
      border: none;
      transition: all .2s;
      text-decoration: none;
    }
    .btn-primary { background: var(--marsh); color: var(--cream); box-shadow: 0 4px 16px rgba(37,63,53,.25); }
    .btn-primary:hover { opacity: .88; transform: translateY(-1px); color: var(--cream); }
    .btn-ghost { background: rgba(37,63,53,.06); color: var(--ink-soft); border: 1px solid var(--line); }
    .btn-ghost:hover { color: var(--ink); background: rgba(37,63,53,.10); border-color: rgba(37,63,53,.22); }
    .btn-sm { padding: 7px 14px; font-size: .8rem; }

    /* ── Page layout ── */
    .page { position: relative; z-index: 1; }
    .container { max-width: 740px; margin: 0 auto; padding: 0 24px; }

    /* ── Article ── */
    .post-wrap { padding: 100px 0 100px; }

    .post-nav { display: flex; align-items: center; justify-content: space-between; margin-bottom: 44px; flex-wrap: wrap; gap: 10px; }

    .post-badges { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 18px; }
    .badge { display: inline-block; padding: 4px 12px; border-radius: 20px; font-size: .74rem; font-weight: 700; }
    .badge-default { background: rgba(47,107,103,.14); color: var(--water); border: 1px solid rgba(47,107,103,.22); }
    .badge-green  { background: rgba(46,125,50,.14); color: #2E7D32; border: 1px solid rgba(46,125,50,.25); }

    .post-meta { display: flex; gap: 10px; align-items: center; font-size: .82rem; color: var(--ink-soft); margin-bottom: 20px; flex-wrap: wrap; }
    .meta-dot { width: 3px; height: 3px; border-radius: 50%; background: var(--line); }

    h1.post-title {
      font-family: var(--serif);
      font-size: clamp(1.7rem, 4vw, 2.6rem);
      font-weight: 650;
      line-height: 1.2;
      margin-bottom: 24px;
      color: var(--ink);
    }
    .post-lead {
      font-size: 1.05rem;
      color: var(--ink-soft);
      line-height: 1.7;
      border-left: 3px solid var(--water);
      padding-left: 18px;
      margin-bottom: 40px;
    }

    .content-divider { height: 1px; background: linear-gradient(90deg, transparent, var(--line), transparent); margin-bottom: 36px; }

    .content { font-size: 1.01rem; color: var(--ink); }
    .content p { margin-bottom: 1.4em; }
    .content h2 { font-family: var(--serif); font-size: 1.5rem; font-weight: 650; margin: 2.4em 0 .7em; color: var(--ink); }
    .content h3 { font-size: 1.1rem; font-weight: 600; margin: 1.8em 0 .5em; color: var(--ink); }
    .content strong { color: var(--ink); font-weight: 600; }
    .content em { color: var(--ink-soft); font-style: italic; }
    .content ul, .content ol { padding-left: 1.5em; margin-bottom: 1.4em; }
    .content li { margin-bottom: .5em; }
    .content a { color: var(--water); border-bottom: 1px solid rgba(47,107,103,.35); transition: border-color .2s; }
    .content a:hover { border-color: var(--water); }

    .post-footer { margin-top: 60px; padding-top: 32px; border-top: 1px solid var(--line); display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 14px; }
    .author-card { display: flex; align-items: center; gap: 12px; }
    .author-av { width: 40px; height: 40px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; flex-shrink: 0; }
    .author-name { font-size: .9rem; font-weight: 600; }
    .author-label { font-size: .76rem; color: var(--ink-soft); }

    .post-reactions {
      margin-top: 18px;
      display: flex;
      align-items: center;
      gap: 12px;
      flex-wrap: wrap;
    }
    .like-btn {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      border: 1px solid var(--line);
      background: rgba(255,250,240,.6);
      color: var(--ink-soft);
      border-radius: 999px;
      padding: 8px 14px;
      font-size: .82rem;
      font-weight: 700;
      cursor: pointer;
      transition: all .2s;
    }
    .like-btn:hover {
      color: var(--ink);
      border-color: rgba(47,107,103,.35);
      transform: translateY(-1px);
    }
    .like-btn.on {
      color: #c0002a;
      border-color: rgba(192,0,42,.35);
      background: rgba(192,0,42,.08);
      box-shadow: 0 7px 22px rgba(192,0,42,.12);
    }
    .like-btn:disabled { opacity: .55; cursor: not-allowed; transform: none; }
    .like-count {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-width: 22px;
      padding: 0 6px;
      height: 22px;
      border-radius: 999px;
      background: rgba(37,63,53,.08);
      color: var(--ink);
      font-size: .74rem;
      font-weight: 700;
    }

    /* Discussion */
    .discussion {
      margin-top: 48px;
      border-top: 1px solid var(--line);
      padding-top: 28px;
      display: grid;
      gap: 16px;
    }
    .discussion-head { display: flex; align-items: center; justify-content: space-between; gap: 10px; flex-wrap: wrap; }
    .discussion-head h2 { font-family: var(--serif); font-size: 1.25rem; }
    .discussion-note { color: var(--ink-soft); font-size: .8rem; line-height: 1.5; }
    .discussion-msg {
      padding: 10px 12px;
      border-radius: 10px;
      font-size: .82rem;
      border: 1px solid var(--line);
      background: rgba(255,250,240,.5);
      color: var(--ink-soft);
    }
    .discussion-msg.err { border-color: rgba(181,56,56,.3); color: #b53838; background: rgba(181,56,56,.08); }
    .discussion-msg.ok  { border-color: rgba(46,125,50,.35); color: #2E7D32; background: rgba(46,125,50,.09); }
    .comment-form { display: grid; gap: 10px; }
    .comment-form textarea {
      width: 100%;
      min-height: 110px;
      resize: vertical;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: var(--paper);
      color: var(--ink);
      padding: 12px;
      font-family: var(--sans);
      font-size: .92rem;
      line-height: 1.55;
    }
    .comment-form textarea:focus {
      outline: none;
      border-color: rgba(47,107,103,.6);
      box-shadow: 0 0 0 3px rgba(47,107,103,.12);
    }
    .comments-list { display: grid; gap: 10px; }
    .comment-card {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--paper);
      padding: 12px;
      display: grid;
      gap: 8px;
    }
    .comment-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap;
      font-size: .78rem;
      color: var(--ink-soft);
    }
    .comment-body { font-size: .9rem; color: var(--ink); line-height: 1.6; white-space: pre-wrap; word-break: break-word; }
    .comment-actions { display: flex; gap: 8px; flex-wrap: wrap; }
    .mini-btn {
      background: rgba(37,63,53,.05);
      border: 1px solid var(--line);
      color: var(--ink-soft);
      border-radius: 18px;
      padding: 4px 10px;
      font-size: .73rem;
      cursor: pointer;
    }
    .mini-btn:hover { color: var(--ink); border-color: rgba(37,63,53,.25); }
    .community-rules {
      border: 1px dashed rgba(47,107,103,.32);
      border-radius: 12px;
      background: rgba(47,107,103,.06);
      padding: 11px 12px;
      display: grid;
      gap: 6px;
    }
    .community-rules strong { font-size: .81rem; color: var(--marsh); }
    .community-rules ul { margin: 0; padding-left: 17px; color: var(--ink-soft); font-size: .79rem; line-height: 1.45; }
    .community-rules li { margin-bottom: 3px; }

    /* ── Skeleton ── */
    .skel {
      background: linear-gradient(90deg, rgba(37,63,53,.06) 25%, rgba(37,63,53,.10) 50%, rgba(37,63,53,.06) 75%);
      background-size: 400% 100%;
      animation: shimmer 1.4s ease-in-out infinite;
      border-radius: 8px;
    }
    @keyframes shimmer { to { background-position: -400% 0; } }

    /* ── Error ── */
    .error-wrap { text-align: center; padding: 100px 20px; }
    .error-wrap h2 { font-family: var(--serif); font-size: 1.5rem; margin-bottom: 10px; }
    .error-wrap p { color: var(--ink-soft); margin-bottom: 28px; }
  </style>
</head>
