<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script src="supabase.config.js"></script>
<script src="security.client.js"></script>
<script src="categories.client.js"></script>
<script>
(async function() {
  const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  const id = new URLSearchParams(location.search).get('id');
  const wrap = document.getElementById('post-content');
  const nav = document.getElementById('nav-auth');

  let viewerSession = null;
  let viewerProfile = null;
  let activePost = null;
  let commentsCache = [];
  let commentPrivacy = 'all';
  let likesCount = 0;
  let viewerLikedPost = false;

  const COMMENT_RATE_CFG = { maxAttempts: 6, windowMs: 10 * 60 * 1000, lockMs: 30 * 60 * 1000 };
  const REPORT_RATE_CFG = { maxAttempts: 4, windowMs: 24 * 60 * 60 * 1000, lockMs: 24 * 60 * 60 * 1000 };
  const LIKE_RATE_CFG = { maxAttempts: 20, windowMs: 10 * 60 * 1000, lockMs: 10 * 60 * 1000 };

  function isMissingRelationError(error) {
    const msg = String(error?.message || '').toLowerCase();
    return !!error && (
      error.code === '42P01'
      || error.code === 'PGRST205'
      || msg.includes('does not exist')
      || msg.includes('could not find the table')
    );
  }

  function escapeHtml(text) {
    return String(text || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  const canonicalCategory = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.canonical(value)
    : String(value || '').trim();
  const categoryHref = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.categoryHref(value)
    : ('category?name=' + encodeURIComponent(canonicalCategory(value)));
  const badgeColorByCategory = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.badgeColor(value)
    : 'default';

  function showDiscussionMessage(message, type) {
    const box = document.getElementById('discussion-msg');
    if (!box) return;
    if (!message) {
      box.style.display = 'none';
      box.className = 'discussion-msg';
      box.textContent = '';
      return;
    }
    box.style.display = '';
    box.className = 'discussion-msg ' + (type || '');
    box.textContent = message;
  }

  function syncLikeUi() {
    const btn = document.getElementById('like-btn');
    const icon = document.getElementById('like-icon');
    const count = document.getElementById('like-count');
    const hint = document.getElementById('like-hint');
    if (!btn || !icon || !count) return;

    btn.classList.toggle('on', viewerLikedPost);
    icon.textContent = viewerLikedPost ? '❤️' : '🤍';
    count.textContent = String(Math.max(0, likesCount));

    if (hint) {
      if (!viewerSession) {
        hint.textContent = 'Accedi per mettere Mi piace e interagire con il post.';
      } else if (viewerLikedPost) {
        hint.textContent = 'Hai messo Mi piace a questo articolo.';
      } else {
        hint.textContent = 'Un singolo Mi piace per utente (toggle).';
      }
    }
  }

  function disableLikeUi(reason) {
    const btn = document.getElementById('like-btn');
    const hint = document.getElementById('like-hint');
    if (btn) btn.disabled = true;
    if (hint && reason) hint.textContent = reason;
  }

  async function createInteractionNotification(type, commentId) {
    if (!viewerSession?.user?.id || !activePost?.id || !activePost?.user_id) return;
    if (activePost.user_id === viewerSession.user.id) return;

    const actor = viewerProfile?.username ? ('@' + viewerProfile.username) : 'Un utente';
    const message = type === 'comment'
      ? actor + ' ha commentato il tuo articolo.'
      : actor + ' ha messo Mi piace al tuo articolo.';

    const payload = {
      user_id: activePost.user_id,
      actor_id: viewerSession.user.id,
      actor_username: viewerProfile?.username || null,
      post_id: activePost.id,
      comment_id: commentId || null,
      type: type,
      message: message,
      is_read: false,
    };

    const { error } = await sb.from('notifications').insert(payload);
    if (!error) return;

    const errMsg = String(error.message || '').toLowerCase();
    if (isMissingRelationError(error) || errMsg.includes('duplicate key')) return;
    console.warn('[notifications] insert failed:', error.message);
  }

  async function loadLikes() {
    const likeBtn = document.getElementById('like-btn');
    if (!likeBtn || !activePost?.id) return;

    const { count, error: countError } = await sb.from('post_likes')
      .select('id', { count: 'exact', head: true })
      .eq('post_id', activePost.id);

    if (countError) {
      if (isMissingRelationError(countError)) {
        disableLikeUi('Like non attivi: applica supabase-security.sql su Supabase.');
        return;
      }
      disableLikeUi('Like temporaneamente non disponibili.');
      return;
    }

    likesCount = count || 0;
    viewerLikedPost = false;

    if (viewerSession?.user?.id) {
      const { data: likeRow, error: likeError } = await sb.from('post_likes')
        .select('id')
        .eq('post_id', activePost.id)
        .eq('user_id', viewerSession.user.id)
        .maybeSingle();

      if (!likeError) viewerLikedPost = !!likeRow;
    }

    syncLikeUi();
  }

  async function toggleLike() {
    const likeBtn = document.getElementById('like-btn');
    if (likeBtn?.disabled) return;

    if (!viewerSession || !viewerProfile) {
      showDiscussionMessage('Accedi per mettere Mi piace.', 'err');
      return;
    }
    if (!activePost?.id) return;

    if (window.RSM_SECURITY) {
      const likeLimit = window.RSM_SECURITY.checkRateLimit('like_toggle', viewerSession.user.id, LIKE_RATE_CFG);
      if (!likeLimit.ok) {
        showDiscussionMessage('Troppi click su Mi piace. Riprova tra ' + window.RSM_SECURITY.formatRetry(likeLimit.retryAfterMs) + '.', 'err');
        return;
      }
    }

    if (viewerLikedPost) {
      const { error } = await sb.from('post_likes')
        .delete()
        .eq('post_id', activePost.id)
        .eq('user_id', viewerSession.user.id);
      if (error) {
        showDiscussionMessage('Operazione Mi piace non riuscita: ' + error.message, 'err');
        return;
      }
      viewerLikedPost = false;
      likesCount = Math.max(0, likesCount - 1);
      syncLikeUi();
      showDiscussionMessage('Mi piace rimosso.', 'ok');
      return;
    }

    const payload = {
      post_id: activePost.id,
      user_id: viewerSession.user.id,
      actor_username: viewerProfile.username || null,
    };

    const { error } = await sb.from('post_likes').insert(payload);
    if (error) {
      const errMsg = String(error.message || '').toLowerCase();
      if (errMsg.includes('duplicate key')) {
        viewerLikedPost = true;
        await loadLikes();
        return;
      }
      if (isMissingRelationError(error)) {
        disableLikeUi('Like non attivi: applica supabase-security.sql su Supabase.');
        showDiscussionMessage('Like non attivi nel database. Esegui supabase-security.sql.', 'err');
        return;
      }
      showDiscussionMessage('Operazione Mi piace non riuscita: ' + error.message, 'err');
      return;
    }

    viewerLikedPost = true;
    likesCount += 1;
    syncLikeUi();
    showDiscussionMessage('Mi piace registrato.', 'ok');
    await createInteractionNotification('like', null);
  }

  async function loadViewerContext() {
    const { data: sessionData } = await sb.auth.getSession();
    viewerSession = sessionData?.session || null;

    if (!viewerSession) {
      viewerProfile = null;
      return;
    }

    const { data: profile } = await sb.from('profiles')
      .select('id,username,role,avatar_emoji,avatar_color')
      .eq('id', viewerSession.user.id)
      .single();

    viewerProfile = profile || null;
  }

  function escapeHtmlNav(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
  var navOutsideBound = false;
  function closeNavDropdown() {
    var d = document.getElementById('profileDropdown'), b = document.getElementById('profileBtn');
    if (d) d.classList.remove('open');
    if (b) b.setAttribute('aria-expanded','false');
  }
  function navItem(label, href, active, primary) {
    return '<a href="'+href+'" role="menuitem" class="'+(active?'active ':'')+(primary?'item-primary':'')+'" ><span>'+label+'</span><span aria-hidden="true">&rarr;</span></a>';
  }
  function buildNavMenu(username, color, emoji) {
    emoji = emoji || '\uD83C\uDF3F';
    var safe = escapeHtmlNav(username);
    var current = window.location.pathname;
    var profileHref = 'profile?u='+encodeURIComponent(username);
    var isProfile = current.indexOf('profile') >= 0;
    var isDashboard = current.toLowerCase().indexOf('/dashboard') >= 0 || current.toLowerCase().indexOf('/me') >= 0;
    var isWrite = current.indexOf('write') >= 0;
    var editItem = isProfile && new URLSearchParams(window.location.search).get('u') === username ? navItem('Modifica profilo','modifica-profilo',false,false) : '';
    return '<div class="profile-menu" id="profileMenu">'+
      '<button class="profile-btn" id="profileBtn" type="button" aria-haspopup="true" aria-expanded="false">'+
      '<span class="profile-avatar" style="background:'+escapeHtmlNav(color||'#2f6b67')+'">'+escapeHtmlNav(emoji)+'</span>'+
      '<span>@'+safe+'</span></button>'+
      '<div class="profile-dropdown" id="profileDropdown" role="menu" aria-label="Menu navigazione">'+
      '<div class="profile-dropdown__section-title">Navigazione</div>'+
      navItem('Profilo',profileHref,isProfile,false)+
      navItem('Dashboard','/dashboard',isDashboard,false)+
      editItem+
      navItem('Scrivi','write',isWrite,true)+
      navItem('Categorie','/category',current.indexOf('/category')>=0,false)+
      navItem('Aspetto','preferenze',current.indexOf('preferenze')>=0,false)+
      navItem('Reimposta Password','reset',current.indexOf('reset')>=0,false)+
      '<div class="profile-dropdown__sep"></div>'+
      '<button type="button" data-action="logout" class="danger" role="menuitem"><span>Esci</span><span aria-hidden="true">&rarr;</span></button>'+
      '</div></div>';
  }
  function bindNavMenu() {
    var btn = document.getElementById('profileBtn'), dd = document.getElementById('profileDropdown');
    if (!btn || !dd) return;
    btn.addEventListener('click', function(e) {
      e.stopPropagation();
      var open = !dd.classList.contains('open');
      dd.classList.toggle('open', open);
      btn.setAttribute('aria-expanded', String(open));
    });
    dd.querySelectorAll('[data-action="logout"]').forEach(function(b) {
      b.addEventListener('click', function() { sb.auth.signOut().then(function(){ window.location.reload(); }); });
    });
    dd.querySelectorAll('a').forEach(function(a) { a.addEventListener('click', closeNavDropdown); });
    if (!navOutsideBound) {
      document.addEventListener('click', function(e) { var m=document.getElementById('profileMenu'); if(m&&!m.contains(e.target)) closeNavDropdown(); }, {capture:true});
      document.addEventListener('keydown', function(e) { if(e.key==='Escape') closeNavDropdown(); });
      navOutsideBound = true;
    }
  }
  function renderNavAuth() {
    if (!nav) return;
    if (viewerSession && viewerProfile) {
      nav.innerHTML = buildNavMenu(viewerProfile.username, viewerProfile.avatar_color||'#2f6b67', viewerProfile.avatar_emoji||'\uD83C\uDF3F');
      bindNavMenu();
      return;
    }
    nav.innerHTML = '<a href="login" class="nav-login">Accedi</a>';
  }

  function renderContent(text) {
    if (!text) return '';
    var safe = escapeHtml(text);
    return safe
      .replace(/^### (.+)$/gm, '<h3>$1</h3>')
      .replace(/^## (.+)$/gm, '<h2>$1</h2>')
      .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
      .replace(/\*(.+?)\*/g, '<em>$1</em>')
      .replace(/\n\n+/g, '</p><p>')
      .replace(/^/, '<p>') + '</p>';
  }

  function canViewerComment() {
    if (commentPrivacy === 'none') {
      return { ok: false, reason: 'I commenti per questo autore sono disattivati.' };
    }
    if (!viewerSession || !viewerProfile) {
      return { ok: false, reason: 'Accedi per poter commentare.' };
    }
    if (commentPrivacy === 'members' && !['user', 'admin'].includes(viewerProfile.role || '')) {
      return { ok: false, reason: 'Solo i membri verificati possono commentare questo post.' };
    }
    return { ok: true, reason: '' };
  }

  function syncCommentComposerState() {
    const status = canViewerComment();
    const textarea = document.getElementById('comment-text');
    const submitBtn = document.getElementById('comment-submit');
    if (!textarea || !submitBtn) return;

    textarea.disabled = !status.ok;
    submitBtn.disabled = !status.ok;

    if (!status.ok) {
      textarea.placeholder = status.reason;
      showDiscussionMessage(status.reason, '');
    } else {
      textarea.placeholder = 'Scrivi un commento rispettoso e costruttivo...';
      showDiscussionMessage('', '');
    }
  }

  async function resolveCommentPrivacy() {
    if (!activePost?.user_id) {
      commentPrivacy = 'all';
      return;
    }

    const { data, error } = await sb.from('user_settings')
      .select('comment_privacy')
      .eq('user_id', activePost.user_id)
      .maybeSingle();

    if (error) {
      commentPrivacy = 'all';
      return;
    }

    commentPrivacy = data?.comment_privacy || 'all';
  }

  function renderComments() {
    const list = document.getElementById('comments-list');
    if (!list) return;

    if (!commentsCache.length) {
      list.innerHTML = '<p class="discussion-note">Nessun commento ancora. Inizia tu la discussione.</p>';
      return;
    }

    const nowTs = Date.now();
    list.innerHTML = commentsCache.map((comment) => {
      const author = comment.author_username ? '@' + escapeHtml(comment.author_username) : 'Utente';
      const ownComment = !!viewerSession && comment.user_id === viewerSession.user.id;
      const createdAt = new Date(comment.created_at).getTime();
      const canEdit = ownComment && (nowTs - createdAt) <= (10 * 60 * 1000);

      return `
        <article class="comment-card">
          <div class="comment-meta">
            <span>${author}</span>
            <time>${new Date(comment.created_at).toLocaleString('it-IT')}</time>
          </div>
          <div class="comment-body">${escapeHtml(comment.content)}</div>
          <div class="comment-actions">
            ${canEdit ? `<button class="mini-btn" type="button" onclick="editComment('${comment.id}')">Modifica</button>` : ''}
            ${ownComment ? `<button class="mini-btn" type="button" onclick="deleteComment('${comment.id}')">Elimina</button>` : ''}
          </div>
        </article>`;
    }).join('');
  }

  async function loadComments() {
    const list = document.getElementById('comments-list');
    if (!list || !activePost?.id) return;

    const { data, error } = await sb.from('comments')
      .select('id,post_id,user_id,author_username,content,created_at,is_hidden')
      .eq('post_id', activePost.id)
      .eq('is_hidden', false)
      .order('created_at', { ascending: true });

    if (error) {
      if (isMissingRelationError(error)) {
        list.innerHTML = '<p class="discussion-note">Commenti non disponibili: applica supabase-security.sql su Supabase.</p>';
        return;
      }
      list.innerHTML = `<p class="discussion-note">Errore caricamento commenti: ${escapeHtml(error.message)}</p>`;
      return;
    }

    commentsCache = data || [];
    renderComments();
  }

  async function submitComment(event) {
    event.preventDefault();
    const textarea = document.getElementById('comment-text');
    if (!textarea || !viewerSession || !viewerProfile || !activePost?.id) {
      showDiscussionMessage('Accedi per poter commentare.', 'err');
      return;
    }

    const access = canViewerComment();
    if (!access.ok) {
      showDiscussionMessage(access.reason, 'err');
      return;
    }

    const content = textarea.value.trim();
    if (!content) {
      showDiscussionMessage('Il commento non puo essere vuoto.', 'err');
      return;
    }

    if (window.RSM_SECURITY) {
      const commentLimit = window.RSM_SECURITY.checkRateLimit('comment_write', viewerSession.user.id, COMMENT_RATE_CFG);
      if (!commentLimit.ok) {
        showDiscussionMessage('Stai commentando troppo velocemente. Riprova tra ' + window.RSM_SECURITY.formatRetry(commentLimit.retryAfterMs) + '.', 'err');
        return;
      }

      const safety = window.RSM_SECURITY.evaluateTextSafety(content, {
        minChars: 3,
        maxChars: 1200,
        maxLinks: 2,
        maxRepeatedChar: 6,
        maxRepeatedLine: 3,
      });
      if (!safety.ok) {
        window.RSM_SECURITY.recordRateFailure('comment_write', viewerSession.user.id, COMMENT_RATE_CFG);
        showDiscussionMessage(safety.message, 'err');
        return;
      }
    }

    const payload = {
      post_id: activePost.id,
      user_id: viewerSession.user.id,
      author_username: viewerProfile.username || null,
      content: content,
      is_hidden: false,
    };
    const { data: insertedComment, error } = await sb.from('comments').insert(payload).select('id').single();

    if (error) {
      if (window.RSM_SECURITY) {
        window.RSM_SECURITY.recordRateFailure('comment_write', viewerSession.user.id, COMMENT_RATE_CFG);
      }
      if (isMissingRelationError(error)) {
        showDiscussionMessage('Commenti non attivi nel database. Esegui supabase-security.sql.', 'err');
        return;
      }
      showDiscussionMessage('Commento non salvato: ' + error.message, 'err');
      return;
    }

    if (window.RSM_SECURITY) {
      window.RSM_SECURITY.clearRateFailures('comment_write', viewerSession.user.id);
    }

    await createInteractionNotification('comment', insertedComment?.id || null);
    textarea.value = '';
    showDiscussionMessage('Commento pubblicato.', 'ok');
    await loadComments();
  }

  async function editComment(commentId) {
    if (!viewerSession) return;
    const comment = commentsCache.find((item) => item.id === commentId);
    if (!comment || comment.user_id !== viewerSession.user.id) return;

    const ageMs = Date.now() - new Date(comment.created_at).getTime();
    if (ageMs > 10 * 60 * 1000) {
      showDiscussionMessage('Puoi modificare un commento solo entro 10 minuti.', 'err');
      return;
    }

    const next = prompt('Modifica commento:', comment.content || '');
    if (next === null) return;
    const content = String(next).trim();
    if (!content) {
      showDiscussionMessage('Il commento non puo essere vuoto.', 'err');
      return;
    }

    if (window.RSM_SECURITY) {
      const safety = window.RSM_SECURITY.evaluateTextSafety(content, {
        minChars: 3,
        maxChars: 1200,
        maxLinks: 2,
        maxRepeatedChar: 6,
        maxRepeatedLine: 3,
      });
      if (!safety.ok) {
        showDiscussionMessage(safety.message, 'err');
        return;
      }
    }

    const { error } = await sb.from('comments').update({ content: content }).eq('id', commentId);
    if (error) {
      showDiscussionMessage('Modifica non riuscita: ' + error.message, 'err');
      return;
    }

    showDiscussionMessage('Commento aggiornato.', 'ok');
    await loadComments();
  }

  async function deleteComment(commentId) {
    if (!viewerSession) return;
    const comment = commentsCache.find((item) => item.id === commentId);
    if (!comment || comment.user_id !== viewerSession.user.id) return;
    if (!confirm('Eliminare questo commento?')) return;

    const { error } = await sb.from('comments').delete().eq('id', commentId);
    if (error) {
      showDiscussionMessage('Eliminazione non riuscita: ' + error.message, 'err');
      return;
    }

    showDiscussionMessage('Commento eliminato.', 'ok');
    await loadComments();
  }

  async function reportPost() {
    if (!viewerSession || !activePost?.id) {
      showDiscussionMessage('Accedi per inviare una segnalazione.', 'err');
      return;
    }

    if (window.RSM_SECURITY) {
      const reportLimit = window.RSM_SECURITY.checkRateLimit('report_write', viewerSession.user.id, REPORT_RATE_CFG);
      if (!reportLimit.ok) {
        showDiscussionMessage('Hai inviato troppe segnalazioni. Riprova tra ' + window.RSM_SECURITY.formatRetry(reportLimit.retryAfterMs) + '.', 'err');
        return;
      }
    }

    const reason = prompt('Motivo segnalazione (es: spam, offese, disinformazione):', 'spam');
    if (reason === null) return;
    const reasonText = String(reason || '').trim();
    if (!reasonText) {
      showDiscussionMessage('Inserisci un motivo valido per la segnalazione.', 'err');
      return;
    }

    const details = prompt('Dettagli (opzionale):', '') || '';
    const detailsText = String(details).trim();

    if (reasonText.length < 3) {
      showDiscussionMessage('Motivo troppo breve.', 'err');
      return;
    }
    if (reasonText.length > 120) {
      showDiscussionMessage('Motivo troppo lungo.', 'err');
      return;
    }
    if (detailsText.length > 1000) {
      showDiscussionMessage('Dettagli troppo lunghi.', 'err');
      return;
    }

    const reportLinks = (reasonText + '\n' + detailsText).match(/https?:\/\/|www\./gi);
    if (reportLinks && reportLinks.length > 1) {
      showDiscussionMessage('Segnalazione bloccata: troppi link.', 'err');
      return;
    }

    const payload = {
      post_id: activePost.id,
      reporter_id: viewerSession.user.id,
      reason: reasonText,
      details: detailsText || null,
      status: 'pending',
    };

    const { error } = await sb.from('reports').insert(payload);
    if (error) {
      if (window.RSM_SECURITY) {
        window.RSM_SECURITY.recordRateFailure('report_write', viewerSession.user.id, REPORT_RATE_CFG);
      }

      const errMsg = String(error.message || '').toLowerCase();
      if (errMsg.includes('duplicate key')) {
        showDiscussionMessage('Hai gia segnalato questo contenuto.', 'err');
        return;
      }
      if (isMissingRelationError(error)) {
        showDiscussionMessage('Segnalazioni non attive nel database. Esegui supabase-security.sql.', 'err');
        return;
      }
      showDiscussionMessage('Segnalazione non inviata: ' + error.message, 'err');
      return;
    }

    if (window.RSM_SECURITY) {
      window.RSM_SECURITY.clearRateFailures('report_write', viewerSession.user.id);
    }
    showDiscussionMessage('Segnalazione inviata alla moderazione. Grazie.', 'ok');
  }

  function bindDiscussionHandlers() {
    const form = document.getElementById('comment-form');
    if (form) form.addEventListener('submit', submitComment);

    const reportBtn = document.getElementById('report-post-btn');
    if (reportBtn) reportBtn.addEventListener('click', reportPost);

    const likeBtn = document.getElementById('like-btn');
    if (likeBtn) likeBtn.addEventListener('click', toggleLike);
  }

  await loadViewerContext();
  renderNavAuth();

  if (!id || typeof SUPABASE_URL === 'undefined' || SUPABASE_URL.includes('your-project')) {
    wrap.innerHTML = `<div class="error-wrap"><h2>Articolo non trovato</h2><p>Nessun ID specificato.</p><a href="/#news" class="btn btn-primary">← Torna alle notizie</a></div>`;
    return;
  }

  const { data: post, error } = await sb.from('posts').select('*').eq('id', id).eq('published', true).single();

  if (error || !post) {
    wrap.innerHTML = `<div class="error-wrap"><h2>Articolo non trovato</h2><p>L'articolo non esiste o non è ancora pubblicato.</p><a href="/#news" class="btn btn-primary">← Torna alle notizie</a></div>`;
    return;
  }

  document.title = post.title + ' – Pro Loco Rivalta sul Mincio';
  const fmt = iso => new Date(iso).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' });

  const badgeCls = c => c === 'green' ? 'badge badge-green' : 'badge badge-default';

  activePost = {
    ...post,
    category: canonicalCategory(post.category) || 'Territorio',
    badge_color: post.badge_color || badgeColorByCategory(post.category)
  };
  const safeTitle = escapeHtml(activePost.title || 'Articolo');
  const safeExcerpt = escapeHtml(activePost.excerpt || '');
  const safeCategory = escapeHtml(activePost.category || '');
  const safeBadge = escapeHtml(activePost.badge || activePost.category || '');
  const safeAuthor = escapeHtml(activePost.author_username || '');
  const safeCategoryHref = categoryHref(activePost.category);
  const authorHref = activePost.author_username ? `profile?u=${encodeURIComponent(activePost.author_username)}` : '';

  wrap.innerHTML = `
    <div class="post-badges">
      <span class="${badgeCls(activePost.badge_color)}">${safeBadge}</span>
      ${activePost.category && activePost.badge && activePost.category !== activePost.badge ? `<a class="badge badge-default" href="${safeCategoryHref}">${safeCategory}</a>` : ''}
    </div>
    <div class="post-meta">
      <time>${fmt(activePost.published_at)}</time>
      <span class="meta-dot"></span>
      <a href="${safeCategoryHref}" style="color:var(--water)">${safeCategory}</a>
      ${activePost.author_username ? `<span class="meta-dot"></span><a href="${authorHref}" style="color:var(--water)">@${safeAuthor}</a>` : ''}
    </div>
    <h1 class="post-title">${safeTitle}</h1>
    ${activePost.excerpt ? `<p class="post-lead">${safeExcerpt}</p>` : ''}
    <div class="content-divider"></div>
    <div class="content">${renderContent(activePost.content)}</div>
    <div class="post-footer">
      <a href="/#news" class="btn btn-primary">← Tutte le notizie</a>
      ${activePost.author_username ? `<a href="${authorHref}" class="btn btn-ghost">Autore: @${safeAuthor} →</a>` : ''}
    </div>
    <div class="post-reactions">
      <button class="like-btn" id="like-btn" type="button">
        <span id="like-icon">🤍</span>
        <span>Mi piace</span>
        <span class="like-count" id="like-count">0</span>
      </button>
      <span class="discussion-note" id="like-hint">Un singolo Mi piace per utente (toggle).</span>
    </div>
    <section class="discussion" id="discussion">
      <div class="discussion-head">
        <h2>Discussione</h2>
      </div>
      <p class="discussion-note">Commenti con filtro anti-spam e moderazione. Modifica consentita entro 10 minuti.</p>
      <div id="discussion-msg" class="discussion-msg" style="display:none"></div>
      <form class="comment-form" id="comment-form">
        <textarea id="comment-text" placeholder="Scrivi un commento rispettoso e costruttivo..."></textarea>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <button class="btn btn-primary btn-sm" id="comment-submit" type="submit">Pubblica commento</button>
          <button class="btn btn-ghost btn-sm" id="report-post-btn" type="button">Segnala post</button>
        </div>
      </form>
      <div class="community-rules">
        <strong>Regole di convivenza</strong>
        <ul>
          <li>Rispetta persone e opinioni: niente insulti o attacchi personali.</li>
          <li>Resta sul tema del post e usa un linguaggio costruttivo.</li>
          <li>Evita spam, link ripetuti e contenuti offensivi.</li>
        </ul>
      </div>
      <div id="comments-list" class="comments-list">
        <p class="discussion-note">Caricamento commenti...</p>
      </div>
    </section>
  `;

  await resolveCommentPrivacy();
  bindDiscussionHandlers();
  await loadLikes();
  syncCommentComposerState();
  await loadComments();

  window.editComment = editComment;
  window.deleteComment = deleteComment;
})();
</script>
</body>
</html>
