    <!-- Avatar emoji -->
    <div class="bcard">
      <div class="bcard-label">Emoji avatar</div>
      <div class="emoji-grid" id="emoji-grid"></div>
    </div>

    <!-- Colore -->
    <div class="bcard">
      <div class="bcard-label">Colore sfondo</div>
      <div class="color-grid" id="color-grid"></div>
