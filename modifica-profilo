<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script src="supabase.config.js"></script>
<script>
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
const $ = id => document.getElementById(id);

const EMOJIS = ['🌿','🌊','🦢','🚣','🎣','🌾','🏞️','🦆','🌙','✨','🧭','📍','🍃','🏰','🌸','🛶','🦋','🌤️','📸','🧡'];
const COLORS = ['#1F6F8B','#3a8c8a','#2E7D32','#7CB342','#F9A825','#8D6E63','#5C6BC0','#EC407A','#607D8B','#37474F'];

let currentUser = null;
let currentProfile = null;

function buildPickers(emoji, color) {
  const eg = $('emoji-grid');
  const cg = $('color-grid');
  eg.innerHTML = EMOJIS.map((e, i) =>
    `<input type="radio" id="em-${i}" name="pref-emoji" value="${e}" ${e === emoji ? 'checked' : ''}><label for="em-${i}">${e}</label>`
  ).join('');
  cg.innerHTML = COLORS.map((c, i) =>
    `<input type="radio" id="co-${i}" name="pref-color" value="${c}" ${c === color ? 'checked' : ''}><label for="co-${i}" style="background:${c}"></label>`
  ).join('');

  eg.querySelectorAll('input').forEach(el => el.addEventListener('change', updatePreview));
  cg.querySelectorAll('input').forEach(el => el.addEventListener('change', updatePreview));
}

function updatePreview() {
  const emoji = document.querySelector('input[name="pref-emoji"]:checked')?.value || '🌿';
  const color = document.querySelector('input[name="pref-color"]:checked')?.value || '#1F6F8B';
  const display = $('p-display').value.trim() || (currentProfile?.username || '');
  const bio = $('p-bio').value.trim();

  const av = $('prev-avatar');
  av.textContent = emoji;
  av.style.background = color;
  $('prev-display').textContent = display || '—';
  $('prev-bio').textContent = bio;
}

function setStatus(msg, type) {
  const el = $('save-status');
  el.textContent = msg;
  el.className = 'status-msg ' + (type === 'ok' ? 'status-ok' : type === 'err' ? 'status-err' : '');
}

async function save() {
  if (!currentUser || !currentProfile) return;
  setStatus('', '');

  const emoji  = document.querySelector('input[name="pref-emoji"]:checked')?.value || '🌿';
  const color  = document.querySelector('input[name="pref-color"]:checked')?.value || '#1F6F8B';
  const display = String($('p-display').value || '').trim();
  const bio     = String($('p-bio').value || '').trim();
  const comune  = String($('p-comune').value || '').trim();

  const btn = $('save-btn');
  btn.disabled = true;

  const { error } = await sb.from('profiles').update({
    display_name:  display || currentProfile.username,
    bio:           bio || null,
    comune:        comune || null,
    avatar_emoji:  emoji,
    avatar_color:  color,
  }).eq('id', currentUser.id);

  btn.disabled = false;

  if (error) {
    setStatus('Salvataggio non riuscito: ' + error.message, 'err');
    return;
  }

  currentProfile.display_name = display || currentProfile.username;
  currentProfile.bio = bio || null;
  currentProfile.comune = comune || null;
  currentProfile.avatar_emoji = emoji;
  currentProfile.avatar_color = color;

  setStatus('Profilo aggiornato con successo.', 'ok');
}

(async function init() {
  const { data: { session } } = await sb.auth.getSession();
  if (!session?.user) { location.href = 'login'; return; }

  currentUser = session.user;

  const { data: profile, error } = await sb.from('profiles').select('*').eq('id', currentUser.id).single();
  if (error || !profile) { location.href = '/dashboard'; return; }

  currentProfile = profile;

  /* ── Build user dropdown ── */
  (function buildUserMenu() {
    const wrap = $('user-menu-wrap');
    if (!wrap) return;
    const username    = profile.username || 'utente';
    const emoji       = profile.avatar_emoji || '🌿';
    const color       = profile.avatar_color || '#1F6F8B';
    const safe        = String(username).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    const profileHref = 'profile?u=' + encodeURIComponent(username);

    function initials(value) {
      return String(value || 'utente').trim().slice(0, 2).toUpperCase();
    }

    function item(label, href, active, primary) {
      return '<a href="' + href + '" role="menuitem" class="' + (active ? 'active ' : '') + (primary ? 'item-primary' : '') + '"><span>' + label + '</span><span aria-hidden="true">&rarr;</span></a>';
    }

    wrap.innerHTML =
      '<div class="profile-menu" id="profileMenu">' +
        '<button class="profile-btn" id="profileBtn" type="button" aria-haspopup="true" aria-expanded="false">' +
          '<span class="profile-avatar" style="background:' + color + '">' + emoji + '</span>' +
          '<span>@' + safe + '</span>' +
        '</button>' +
        '<div class="profile-dropdown" id="profileDropdown" role="menu" aria-label="Menu navigazione">' +
          '<div class="profile-dropdown__section-title">Navigazione</div>' +
          item('Profilo', profileHref, false, false) +
          item('Dashboard', '/dashboard', false, false) +
          item('Modifica profilo', 'modifica-profilo?u=' + encodeURIComponent(username), true, false) +
          item('Scrivi', 'write', false, true) +
          item('Categorie', '/category', false, false) +
          item('Aspetto', 'preferenze', false, false) +
          item('Reimposta Password', 'reset', false, false) +
          '<div class="profile-dropdown__sep"></div>' +
          '<button type="button" data-action="logout" class="danger" role="menuitem"><span>Esci</span><span aria-hidden="true">&rarr;</span></button>' +
        '</div>' +
      '</div>';

    const btn = $('profileBtn');
    const dd  = $('profileDropdown');
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = dd.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
    dd.querySelector('[data-action="logout"]').addEventListener('click', async () => {
      await sb.auth.signOut();
      window.location.href = '/';
    });
    dd.querySelectorAll('a').forEach(a => a.addEventListener('click', () => {
      dd.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    }));
    document.addEventListener('click', (e) => {
      if (!$('profileMenu')?.contains(e.target)) {
        dd.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }
    }, { capture: true });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dd.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
      }
    });
  })();

  /* Populate preview username */
  $('prev-username').textContent = '@' + (profile.username || '');

  /* Populate form */
  $('p-display').value = profile.display_name || profile.username || '';
  $('p-bio').value     = profile.bio || '';
  $('p-comune').value  = profile.comune || '';

  buildPickers(profile.avatar_emoji || '🌿', profile.avatar_color || '#1F6F8B');
  updatePreview();

  /* Live preview on typing */
  $('p-display').addEventListener('input', updatePreview);
  $('p-bio').addEventListener('input', updatePreview);

  $('save-btn').addEventListener('click', save);
})();
</script>

