<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Categoria - Rivalta sul Mincio</title>
  <link rel="icon" href="/img/favicon.png" type="image/png" />
</head>
<body>

<!--PARTIAL:nav-->

<main class="container rsm-page">

  <p class="text-primary fw-semibold text-uppercase small mb-1">Archivio Rivalta sul Mincio</p>
  <h1 id="cat-title">Tutti i post</h1>
  <p class="text-muted lead" id="cat-sub">Archivio completo di tutti i post pubblicati: eventi, territorio, vita locale, avvisi, richieste e storie della comunità.</p>

  <nav class="d-flex flex-wrap gap-2 my-3" id="category-tools" aria-label="Categorie principali">
    <a class="chip chip-simple chip-primary" href="/category" data-category-link="all"><span class="chip-label">Tutto</span></a>
  </nav>

  <div class="d-flex justify-content-between align-items-center border-bottom pb-2 mb-3">
    <h2 class="h5 mb-0" id="feed-title">Ultimi articoli</h2>
    <span class="badge bg-secondary" id="feed-count">In caricamento</span>
  </div>

  <div class="row g-3" id="posts"></div>
  <div class="callout note" id="empty" style="display:none"></div>

</main>

<!--PARTIAL:footer-->

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script src="/supabase.config.js"></script>
<script>
(function () {
  const SPRITES = '/vendor/bootstrap-italia/svg/sprites.svg';
  const postsEl = document.getElementById('posts');
  const emptyEl = document.getElementById('empty');
  const titleEl = document.getElementById('cat-title');
  const subEl = document.getElementById('cat-sub');
  const feedTitleEl = document.getElementById('feed-title');
  const feedCountEl = document.getElementById('feed-count');
  const toolsEl = document.getElementById('category-tools');

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  const categories = window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.all()
    : ['Eventi', 'Territorio', 'Vita locale', 'Avvisi', 'Richieste', 'Storie'];
  const canonical = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.canonical(value)
    : String(value || '').trim();
  const badgeColor = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.badgeColor(value)
    : 'default';

  const params = new URLSearchParams(window.location.search);
  const requested = canonical(params.get('name') || '');
  const activeCategory = categories.includes(requested) ? requested : 'all';
  const isAllView = activeCategory === 'all';

  function categoryUrl(category) {
    return category === 'all' ? '/category' : '/category?name=' + encodeURIComponent(category);
  }

  function renderCategoryLinks() {
    const links = [{ label: 'Tutto', value: 'all' }].concat(categories.map(function (c) {
      return { label: c, value: c };
    }));
    toolsEl.innerHTML = links.map(function (item) {
      const active = item.value === activeCategory ? ' chip-primary' : '';
      return '<a class="chip chip-simple' + active + '" href="' + categoryUrl(item.value) + '" data-category-link="' + escapeHtml(item.value) + '"><span class="chip-label">' + escapeHtml(item.label) + '</span></a>';
    }).join('');
  }

  document.title = (isAllView ? 'Tutti i post' : activeCategory) + ' - Rivalta sul Mincio';
  titleEl.textContent = isAllView ? 'Tutti i post' : activeCategory;
  subEl.textContent = isAllView
    ? 'Archivio completo di tutti i post pubblicati: eventi, territorio, vita locale, avvisi, richieste e storie della comunità.'
    : 'Articoli pubblicati nella categoria ' + activeCategory + '.';
  feedTitleEl.textContent = isAllView ? 'Ultimi articoli' : 'Archivio ' + activeCategory;

  renderCategoryLinks();

  const fmt = function (iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleDateString('it-IT', { day: 'numeric', month: 'short', year: 'numeric' });
  };

  function isValidHttpsUrl(url) {
    if (!url || typeof url !== 'string') return false;
    try { return new URL(url).protocol === 'https:'; } catch (_) { return false; }
  }

  function setCount(count) {
    const label = count === 1 ? 'articolo' : 'articoli';
    feedCountEl.textContent = count + ' ' + label;
  }

  function showEmpty(message) {
    postsEl.innerHTML = '';
    emptyEl.style.display = 'block';
    emptyEl.textContent = message;
    setCount(0);
  }

  if (typeof SUPABASE_URL === 'undefined' || SUPABASE_URL.includes('your-project') || typeof supabase === 'undefined') {
    showEmpty('Configura Supabase per visualizzare gli articoli pubblicati.');
    return;
  }

  const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  sb.from('posts')
    .select('id,title,excerpt,category,badge,badge_color,image_url,published_at')
    .eq('published', true)
    .order('published_at', { ascending: false })
    .then(function (res) {
      if (res.error) {
        showEmpty('Errore caricamento post: ' + res.error.message);
        return;
      }

      const rows = (res.data || []).map(function (post) {
        return {
          ...post,
          category: canonical(post.category) || 'Territorio',
          badge_color: post.badge_color || badgeColor(post.category)
        };
      }).filter(function (post) {
        return isAllView || post.category === activeCategory;
      });

      if (!rows.length) {
        showEmpty(isAllView
          ? 'Nessun articolo disponibile al momento.'
          : 'Nessun articolo disponibile in questa categoria.');
        return;
      }

      emptyEl.style.display = 'none';
      setCount(rows.length);
      postsEl.innerHTML = rows.map(function (post) {
        const badgeClass = post.badge_color === 'green' ? 'badge bg-success' : 'badge bg-primary';
        const href = '/post?id=' + encodeURIComponent(post.id);
        const media = isValidHttpsUrl(post.image_url)
          ? '<a href="' + href + '" aria-label="Apri ' + escapeHtml(post.title || 'articolo') + '"><img class="rsm-post-thumb" src="' + escapeHtml(post.image_url) + '" alt="" loading="lazy" /></a>'
          : '<a href="' + href + '" aria-label="Apri ' + escapeHtml(post.title || 'articolo') + '"><span class="rsm-post-thumb rsm-post-thumb--empty"></span></a>';
        return '<div class="col-12 col-sm-6 col-lg-4">' +
          '<div class="card-wrapper h-100">' +
            '<div class="card card-bg h-100">' +
              media +
              '<div class="card-body">' +
                '<div class="d-flex align-items-center gap-2 mb-2">' +
                  '<span class="' + badgeClass + '">' + escapeHtml(post.badge || post.category || '') + '</span>' +
                  '<span class="text-muted small">' + escapeHtml(fmt(post.published_at)) + '</span>' +
                '</div>' +
                '<h3 class="card-title h5"><a href="' + href + '">' + escapeHtml(post.title || 'Articolo') + '</a></h3>' +
                '<p class="card-text">' + escapeHtml(post.excerpt || '') + '</p>' +
                '<a class="read-more" href="' + href + '"><span class="text">Leggi articolo</span>' +
                  '<svg class="icon"><use href="' + SPRITES + '#it-arrow-right"></use></svg></a>' +
              '</div>' +
            '</div>' +
          '</div>' +
        '</div>';
      }).join('');
    });
})();
</script>

</body>
</html>
