<script>
(function () {
  const postsEl = document.getElementById('posts');
  const emptyEl = document.getElementById('empty');
  const titleEl = document.getElementById('cat-title');
  const subEl = document.getElementById('cat-sub');
  const feedTitleEl = document.getElementById('feed-title');
  const feedSubtitleEl = document.getElementById('feed-subtitle');
  const feedCountEl = document.getElementById('feed-count');
  const panelCountEl = document.getElementById('cat-count');
  const panelLabelEl = document.getElementById('cat-count-label');
  const toolsEl = document.getElementById('category-tools');
  const navEl = document.getElementById('category-nav');

  const categories = window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.all()
    : ['Eventi', 'Territorio', 'Vita locale', 'Avvisi', 'Richieste', 'Storie'];
  const canonical = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.canonical(value)
    : String(value || '').trim();
  const badgeColor = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.badgeColor(value)
    : 'default';

  const params = new URLSearchParams(window.location.search);
  const requested = canonical(params.get('name') || '');
  const activeCategory = categories.includes(requested) ? requested : 'all';
  const isAllView = activeCategory === 'all';

  function categoryUrl(category) {
    return category === 'all' ? '/category' : '/category?name=' + encodeURIComponent(category);
  }

  function categoryCode(category) {
    return category === 'all' ? 'All' : category.split(/\s+/).map(function (part) { return part.charAt(0); }).join('').slice(0, 3);
  }

  function renderCategoryLinks() {
    const heroLinks = [{ label: 'Tutto', value: 'all' }].concat(categories.map(function (category) {
      return { label: category, value: category };
    }));

    toolsEl.innerHTML = heroLinks.map(function (item) {
      const active = item.value === activeCategory ? ' is-active' : '';
      return '<a class="rsm-category-chip' + active + '" href="' + categoryUrl(item.value) + '" data-category-link="' + escapeHtml(item.value) + '">' + escapeHtml(item.label) + '</a>';
    }).join('');

    navEl.innerHTML = heroLinks.map(function (item) {
      const active = item.value === activeCategory ? ' is-active' : '';
      const label = item.value === 'all' ? 'Tutte' : item.label;
      return '<a class="rsm-category-nav__link' + active + '" href="' + categoryUrl(item.value) + '" data-category-link="' + escapeHtml(item.value) + '"><span>' + escapeHtml(label) + '</span><span>' + escapeHtml(categoryCode(item.value)) + '</span></a>';
    }).join('');
  }

  document.title = (isAllView ? 'Tutti i post' : activeCategory) + ' - Rivalta sul Mincio';
  titleEl.innerHTML = isAllView ? 'Tutti i <span>post</span>' : escapeHtml(activeCategory);
  subEl.textContent = isAllView
    ? 'Archivio completo di tutti i post pubblicati: eventi, territorio, vita locale, avvisi, richieste e storie della comunità.'
    : 'Articoli pubblicati nella categoria ' + activeCategory + ', raccolti in una vista più ampia, visiva e leggibile.';
  feedTitleEl.textContent = isAllView ? 'Ultimi articoli' : 'Archivio ' + activeCategory;
  feedSubtitleEl.textContent = isAllView
    ? 'La categoria corrente resta in evidenza, con l\'archivio subito sotto.'
    : 'Una selezione aggiornata dei contenuti pubblicati in questa categoria.';

  renderCategoryLinks();

  const fmt = function (iso) {
    if (!iso) return '';
    return new Date(iso).toLocaleDateString('it-IT', { day: 'numeric', month: 'short', year: 'numeric' });
  };

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function isValidHttpsUrl(url) {
    if (!url || typeof url !== 'string') return false;
    try {
      return new URL(url).protocol === 'https:';
    } catch (_) {
      return false;
    }
  }

  function setCount(count) {
    const label = count === 1 ? 'articolo' : 'articoli';
    panelCountEl.textContent = String(count);
    panelLabelEl.textContent = isAllView
      ? 'Articoli pubblicati in tutte le categorie dell\'archivio.'
      : 'Articoli pubblicati nella categoria selezionata.';
    feedCountEl.textContent = count + ' ' + label;
  }

  function showEmpty(message) {
    postsEl.innerHTML = '';
    emptyEl.style.display = 'block';
    emptyEl.textContent = message;
    setCount(0);
  }

  if (typeof SUPABASE_URL === 'undefined' || SUPABASE_URL.includes('your-project') || typeof supabase === 'undefined') {
    showEmpty('Configura Supabase per visualizzare gli articoli pubblicati.');
    return;
  }

  const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

  sb.from('posts')
    .select('id,title,excerpt,category,badge,badge_color,image_url,published_at')
    .eq('published', true)
    .order('published_at', { ascending: false })
    .then(function (res) {
      if (res.error) {
        showEmpty('Errore caricamento post: ' + res.error.message);
        return;
      }

      const rows = (res.data || []).map(function (post) {
        return {
          ...post,
          category: canonical(post.category) || 'Territorio',
          badge_color: post.badge_color || badgeColor(post.category)
        };
      }).filter(function (post) {
        return isAllView || post.category === activeCategory;
      });

      if (!rows.length) {
        showEmpty(isAllView
          ? 'Nessun articolo disponibile al momento.'
          : 'Nessun articolo disponibile in questa categoria.');
        return;
      }

      emptyEl.style.display = 'none';
      setCount(rows.length);
      postsEl.innerHTML = rows.map(function (post) {
        const badgeClass = post.badge_color === 'green' ? 'badge green' : 'badge';
        const href = 'post?id=' + encodeURIComponent(post.id);
        const media = isValidHttpsUrl(post.image_url)
          ? '<a class="post-media" href="' + href + '" aria-label="Apri ' + escapeHtml(post.title || 'articolo') + '"><img class="post-thumb" src="' + escapeHtml(post.image_url) + '" alt="" loading="lazy" /></a>'
          : '<a class="post-media is-empty" href="' + href + '" aria-label="Apri ' + escapeHtml(post.title || 'articolo') + '"></a>';
        return '<article class="post-card">' +
          media +
          '<div class="post-body">' +
            '<div class="post-meta">' +
              '<time>' + escapeHtml(fmt(post.published_at)) + '</time>' +
              '<span class="' + badgeClass + '">' + escapeHtml(post.badge || post.category || '') + '</span>' +
            '</div>' +
            '<h3 class="post-title"><a href="' + href + '">' + escapeHtml(post.title || 'Articolo') + '</a></h3>' +
            '<p class="post-excerpt">' + escapeHtml(post.excerpt || '') + '</p>' +
            '<a class="post-cta" href="' + href + '">Leggi articolo</a>' +
          '</div>' +
        '</article>';
      }).join('');
    });
})();
</script>
