  <link rel="stylesheet" href="/theme.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }

    :root {
      --dash-bg: var(--rsm-bg, #ffffff);
      --dash-paper: var(--rsm-paper, #fbfbfd);
      --dash-surface: rgba(255, 255, 255, 0.70);
      --dash-surface-strong: rgba(255, 255, 255, 0.88);
      --dash-line: var(--rsm-line-2, rgba(11, 13, 20, 0.14));
      --dash-line-soft: var(--rsm-line, rgba(11, 13, 20, 0.08));
      --dash-text: var(--rsm-text, #1d2030);
      --dash-text-strong: var(--rsm-text-strong, #0b0d14);
      --dash-text-soft: var(--rsm-text-soft, #4d5266);
      --dash-text-faint: var(--rsm-text-faint, #828799);
      --dash-emerald: var(--rsm-emerald, #1fbf7d);
      --dash-azure: var(--rsm-azure, #4a9bff);
      --dash-violet: var(--rsm-violet, #8b5cf6);
      --dash-warning: var(--rsm-warning, #f59e0b);
      --dash-danger: var(--rsm-danger, #ef4444);
      --dash-radius-sm: 16px;
      --dash-radius: 24px;
      --dash-radius-lg: 34px;
      --dash-shadow: 0 24px 70px rgba(11, 13, 20, 0.10), 0 1px 0 rgba(255, 255, 255, 0.66) inset;
      --dash-shadow-soft: 0 14px 36px rgba(11, 13, 20, 0.08);
      --dash-grad: linear-gradient(120deg, var(--dash-emerald) 0%, var(--dash-azure) 52%, var(--dash-violet) 100%);
      --dash-dark: linear-gradient(145deg, rgba(7, 12, 22, 0.96), rgba(15, 26, 44, 0.94) 50%, rgba(38, 22, 69, 0.92));
      --dash-font-sans: 'Syne', var(--rsm-font-sans, 'Cabinet Grotesk', system-ui, sans-serif);
      --dash-font-display: var(--rsm-font-display, 'Fraunces', Georgia, serif);
      --dash-font-mono: var(--rsm-font-mono, 'JetBrains Mono', ui-monospace, monospace);
      --ease: var(--rsm-ease-quick, cubic-bezier(0.32, 0.72, 0, 1));
    }

    html[data-theme="scuro"] {
      --dash-surface: rgba(20, 22, 32, 0.68);
      --dash-surface-strong: rgba(20, 22, 32, 0.88);
      --dash-shadow: 0 24px 70px rgba(0, 0, 0, 0.34), 0 1px 0 rgba(255, 255, 255, 0.06) inset;
      --dash-shadow-soft: 0 14px 36px rgba(0, 0, 0, 0.26);
    }

    body[data-page="dashboard"] {
      min-height: 100vh;
      margin: 0;
      color: var(--dash-text);
      font-family: var(--dash-font-sans);
      line-height: 1.5;
      overflow-x: hidden;
      background:
        radial-gradient(circle at 14% 18%, rgba(31, 191, 125, 0.16), transparent 30%),
        radial-gradient(circle at 86% 16%, rgba(74, 155, 255, 0.16), transparent 34%),
        radial-gradient(circle at 78% 76%, rgba(139, 92, 246, 0.14), transparent 36%),
        linear-gradient(180deg, var(--dash-bg) 0%, var(--dash-paper) 48%, var(--dash-bg) 100%);
      -webkit-font-smoothing: antialiased;
    }

    body[data-page="dashboard"]::before,
    body[data-page="dashboard"]::after {
      content: '';
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
    }

    body[data-page="dashboard"]::before {
      opacity: 0.18;
      background-image:
        radial-gradient(circle at 1px 1px, rgba(11, 13, 20, 0.14) 0.6px, transparent 1.2px),
        radial-gradient(circle at 1px 1px, rgba(11, 13, 20, 0.08) 0.6px, transparent 1.2px);
      background-size: 24px 24px, 36px 36px;
      background-position: 0 0, 12px 14px;
      mix-blend-mode: multiply;
    }

    body[data-page="dashboard"]::after {
      opacity: 0.92;
      background:
        radial-gradient(ellipse at 22% 24%, rgba(31, 191, 125, 0.14), transparent 42%),
        radial-gradient(ellipse at 74% 20%, rgba(74, 155, 255, 0.14), transparent 44%),
        radial-gradient(ellipse at 66% 78%, rgba(139, 92, 246, 0.10), transparent 46%);
      animation: dashAurora 26s ease-in-out infinite;
    }

    body[data-page="dashboard"] button,
    body[data-page="dashboard"] input,
    body[data-page="dashboard"] select,
    body[data-page="dashboard"] textarea { font: inherit; }

    a { color: inherit; text-decoration: none; }

    .layout {
      position: relative;
      z-index: 1;
      min-height: 100vh;
      isolation: isolate;
    }

    .main {
      width: min(100% - 36px, 1480px);
      margin: 0 auto;
      padding: clamp(88px, 8vw, 118px) 0 clamp(40px, 5vw, 78px);
      display: grid;
      gap: clamp(14px, 2vw, 22px);
    }

    .mobile-nav {
      position: sticky;
      top: 72px;
      z-index: 20;
      display: flex;
      gap: 8px;
      align-items: center;
      overflow-x: auto;
      padding: 7px;
      border: 1px solid var(--dash-line-soft);
      border-radius: 999px;
      background: color-mix(in srgb, var(--dash-surface-strong) 88%, transparent);
      box-shadow: var(--dash-shadow-soft);
      backdrop-filter: blur(22px);
    }

    .mobile-nav button,
    .mobile-nav a,
    .btn,
    .switch-btn {
      border: 0;
      cursor: pointer;
      white-space: nowrap;
      transition: transform .2s var(--ease), box-shadow .2s var(--ease), background .2s var(--ease), color .2s var(--ease), border-color .2s var(--ease);
    }

    .mobile-nav button,
    .mobile-nav a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 38px;
      padding: 0 15px;
      border-radius: 999px;
      color: var(--dash-text-soft);
      font-size: .78rem;
      font-weight: 800;
      letter-spacing: .01em;
      background: transparent;
    }

    .mobile-nav button:hover,
    .mobile-nav a:hover,
    .mobile-nav button.on {
      color: var(--dash-text-strong);
      background: rgba(255, 255, 255, 0.72);
      box-shadow: 0 10px 24px rgba(11, 13, 20, 0.08);
    }

    .bento {
      display: grid;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      grid-auto-rows: minmax(150px, auto);
      gap: clamp(12px, 1.5vw, 20px);
      grid-template-areas:
        'hero hero hero hero hero hero posts posts stat stat stat stat'
        'hero hero hero hero hero hero views views stat stat stat stat'
        'chart chart chart chart chart chart chart chart draft draft draft draft'
        'recent recent recent recent notif notif notif notif motto motto motto motto';
    }

    .bc,
    .card,
    .kpi,
    .ops-card {
      position: relative;
      overflow: hidden;
      isolation: isolate;
      border: 1px solid var(--dash-line-soft);
      border-radius: var(--dash-radius-lg);
      background: linear-gradient(180deg, var(--dash-surface-strong), var(--dash-surface));
      box-shadow: var(--dash-shadow);
      backdrop-filter: blur(24px);
    }

    .bc::before,
    .modal::before {
      content: '';
      position: absolute;
      inset: 0 0 auto 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,.82), transparent);
      opacity: .78;
      z-index: 2;
    }

    .bc { padding: clamp(18px, 2vw, 30px); }
    .bc-hero { grid-area: hero; min-height: 520px; display: grid; align-content: space-between; gap: 24px; }
    .bc-kpi--posts { grid-area: posts; }
    .bc-kpi--comments { grid-area: views; }
    .bc-stat { grid-area: stat; }
    .bc-chart { grid-area: chart; }
    .bc-motto { grid-area: motto; }

    .bc-hero::after {
      content: '';
      position: absolute;
      width: 78%;
      aspect-ratio: 1;
      right: -28%;
      top: -22%;
      border-radius: 50%;
      background:
        radial-gradient(circle, rgba(31, 191, 125, .28), transparent 58%),
        radial-gradient(circle at 72% 72%, rgba(74, 155, 255, .24), transparent 54%);
      filter: blur(2px);
      z-index: -1;
      animation: dashFloat 18s ease-in-out infinite;
    }

    .bc-hero-head,
    .bc-hero-foot,
    .period-row,
    .hero-stats,
    .head-meta,
    .kpi-meta,
    .bc-kpi-meta,
    .chart-head,
    .list-item__top,
    .list-item__footer,
    .mini-meta,
    .modal-actions,
    .section-title,
    .group-switch {
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }

    .bc-hero-head,
    .section-title,
    .chart-head,
    .list-item__top,
    .list-item__footer,
    .modal-actions { justify-content: space-between; }

    .bc-hero-foot { align-items: stretch; flex-direction: column; gap: 14px; }

    .bc-kicker,
    .section-kicker,
    .bc-kpi-lbl,
    .bc-stat-label,
    .hero-stat-label,
    .kpi-label,
    .field label {
      color: var(--dash-text-soft);
      font-family: var(--dash-font-mono);
      font-size: .70rem;
      font-weight: 800;
      letter-spacing: .14em;
      text-transform: uppercase;
    }

    .bc-orbit,
    .sync-badge {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      width: fit-content;
      max-width: 100%;
      padding: 8px 12px;
      border: 1px solid rgba(31, 191, 125, .16);
      border-radius: 999px;
      background: rgba(31, 191, 125, .08);
      color: var(--dash-text-soft);
      font-size: .74rem;
      font-weight: 800;
    }

    .bc-orbit::before,
    .sync-badge::before {
      content: '';
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--dash-emerald);
      box-shadow: 0 0 0 6px rgba(31, 191, 125, .15);
      animation: dashPulse 2.8s ease-in-out infinite;
    }

    .bc-title {
      max-width: 10ch;
      color: var(--dash-text-strong);
      font-family: var(--dash-font-display);
      font-size: clamp(3.2rem, 7.2vw, 7.4rem);
      font-weight: 700;
      line-height: .88;
      letter-spacing: -.065em;
      text-wrap: balance;
    }

    .bc-sub {
      max-width: 58ch;
      color: var(--dash-text-soft);
      font-size: clamp(1rem, 1.2vw, 1.18rem);
      line-height: 1.65;
      text-wrap: pretty;
    }

    .hero-map { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; }

    .chip,
    .pill {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      min-height: 30px;
      border: 1px solid var(--dash-line-soft);
      border-radius: 999px;
      background: rgba(255, 255, 255, .58);
      color: var(--dash-text-soft);
      font-size: .73rem;
      font-weight: 800;
      letter-spacing: .01em;
      padding: 5px 10px;
      box-shadow: inset 0 1px 0 rgba(255,255,255,.58);
    }

    .chip strong { color: var(--dash-text-strong); }

    .select,
    .field input,
    .field textarea,
    .field select {
      width: 100%;
      border: 1px solid var(--dash-line-soft);
      border-radius: 18px;
      background: rgba(255, 255, 255, .70);
      color: var(--dash-text-strong);
      outline: none;
      transition: border-color .2s var(--ease), box-shadow .2s var(--ease), background .2s var(--ease);
    }

    .select {
      width: auto;
      min-height: 28px;
      padding: 0 26px 0 4px;
      border: 0;
      border-radius: 999px;
      background: transparent;
      color: var(--dash-text-strong);
      font-size: .76rem;
      font-weight: 800;
    }

    .select option,
    .field select option { background: var(--dash-paper); color: var(--dash-text-strong); }

    .select:focus,
    .field input:focus,
    .field textarea:focus,
    .field select:focus {
      border-color: rgba(74, 155, 255, .62);
      box-shadow: 0 0 0 4px rgba(74, 155, 255, .14);
      background: rgba(255, 255, 255, .88);
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 42px;
      border: 1px solid var(--dash-line-soft);
      border-radius: 999px;
      background: rgba(255, 255, 255, .74);
      color: var(--dash-text-strong);
      font-size: .82rem;
      font-weight: 900;
      padding: 0 18px;
      box-shadow: 0 10px 24px rgba(11, 13, 20, .06);
    }

    .btn:hover { transform: translateY(-1px); box-shadow: 0 16px 34px rgba(11, 13, 20, .10); }
    .btn:disabled { opacity: .55; cursor: not-allowed; transform: none; box-shadow: none; }

    .btn-primary {
      border-color: transparent;
      color: #fff;
      background: var(--dash-grad);
      box-shadow: 0 18px 44px rgba(74, 155, 255, .24);
    }

    .btn-ghost { color: var(--dash-text-soft); }

    .hero-stats { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 12px; }

    .hero-stat {
      min-height: 116px;
      display: grid;
      align-content: end;
      gap: 8px;
      padding: 16px;
      border: 1px solid var(--dash-line-soft);
      border-radius: 24px;
      background: rgba(255, 255, 255, .54);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.7);
    }

    .hero-stat-value,
    .bc-kpi-val,
    .bc-stat-num,
    .kpi-value { font-variant-numeric: tabular-nums; }

    .hero-stat-value {
      color: var(--dash-text-strong);
      font-family: var(--dash-font-display);
      font-size: clamp(1.55rem, 2.2vw, 2.25rem);
      line-height: 1;
      font-weight: 700;
    }

    .bc-kpi {
      min-height: 210px;
      display: grid;
      align-content: space-between;
      gap: 18px;
    }

    .bc-kpi::after {
      content: '';
      position: absolute;
      width: 128px;
      height: 128px;
      right: -34px;
      top: -32px;
      border-radius: 50%;
      background: rgba(74, 155, 255, .18);
      z-index: -1;
    }

    .bc-kpi--posts::after { background: rgba(31, 191, 125, .18); }
    .bc-kpi--comments::after { background: rgba(139, 92, 246, .18); }

    .bc-kpi-val {
      color: var(--dash-text-strong);
      font-family: var(--dash-font-display);
      font-size: clamp(3rem, 5vw, 4.4rem);
      font-weight: 750;
      letter-spacing: -.06em;
      line-height: .88;
    }

    .bc-kpi-meta,
    .kpi-meta,
    .tiny,
    .note-line,
    .chart-head,
    .chart-label,
    .mini-meta,
    .empty-state p,
    .bc-list-head p,
    .section-title p { color: var(--dash-text-soft); }

    .bc-kpi-meta { font-size: .82rem; line-height: 1.45; }

    .delta { font-weight: 900; }
    .delta.up { color: var(--dash-emerald); }
    .delta.down { color: var(--dash-danger); }
    .delta.same { color: var(--dash-text-faint); }

    .bc-stat {
      min-height: 440px;
      display: grid;
      align-content: end;
      gap: 14px;
      color: #fff;
      background: var(--dash-dark);
      box-shadow: 0 34px 80px rgba(16, 24, 40, .28);
    }

    .bc-stat::after {
      content: '';
      position: absolute;
      width: 340px;
      height: 340px;
      right: -130px;
      bottom: -130px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(31, 191, 125, .24), rgba(74, 155, 255, .12), transparent 66%);
      z-index: -1;
    }

    .bc-stat-label { color: rgba(236, 246, 255, .62); }
    .bc-stat-num { font-family: var(--dash-font-display); font-size: clamp(5rem, 9vw, 8rem); font-weight: 750; letter-spacing: -.07em; line-height: .82; }
    .bc-stat-sub,
    .bc-stat-foot { max-width: 30ch; color: rgba(236, 246, 255, .74); }
    .bc-stat-foot { display: grid; gap: 10px; font-size: .86rem; }
    .bc-stat-foot p { margin: 0; }

    .bc-chart { min-height: 440px; }
    .section-title { align-items: end; margin-bottom: 18px; }
    .section-title h2,
    .bc-list-head h3,
    .dash-head h1,
    .modal-head h3,
    .ops-card h3 {
      margin: 0;
      color: var(--dash-text-strong);
      font-family: var(--dash-font-display);
      font-weight: 700;
      letter-spacing: -.04em;
      line-height: 1;
      text-wrap: balance;
    }
    .section-title h2,
    .bc-list-head h3 { font-size: clamp(1.45rem, 2vw, 2rem); }
    .section-title p,
    .bc-list-head p { margin: 6px 0 0; max-width: 46ch; font-size: .9rem; line-height: 1.6; }

    .group-switch {
      gap: 4px;
      padding: 5px;
      border: 1px solid var(--dash-line-soft);
      border-radius: 999px;
      background: rgba(255,255,255,.46);
    }

    .switch-btn {
      min-height: 34px;
      padding: 0 13px;
      border-radius: 999px;
      background: transparent;
      color: var(--dash-text-soft);
      font-size: .74rem;
      font-weight: 900;
    }

    .switch-btn.on { color: #fff; background: var(--dash-grad); box-shadow: 0 12px 24px rgba(74, 155, 255, .20); }

    .chart-wrap {
      padding: clamp(14px, 2vw, 22px);
      border: 1px solid var(--dash-line-soft);
      border-radius: 28px;
      background: rgba(255, 255, 255, .50);
      box-shadow: inset 0 1px 0 rgba(255,255,255,.65);
    }

    .chart-bars {
      height: 258px;
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(10px, 1fr);
      align-items: end;
      gap: 7px;
      padding: 18px 4px 12px;
      border-bottom: 1px solid var(--dash-line-soft);
    }

    .bar {
      position: relative;
      min-height: 4px;
      border-radius: 999px 999px 8px 8px;
      background: linear-gradient(180deg, var(--dash-azure), var(--dash-emerald));
      box-shadow: 0 18px 32px rgba(31, 191, 125, .18);
    }

    .bar:nth-child(3n+2) { background: linear-gradient(180deg, var(--dash-violet), var(--dash-azure)); }
    .bar::after {
      content: attr(data-v);
      position: absolute;
      left: 50%;
      top: -24px;
      transform: translateX(-50%);
      color: var(--dash-text-soft);
      font-size: .7rem;
      font-weight: 900;
      opacity: 0;
      transition: opacity .2s var(--ease);
    }
    .bar:hover::after { opacity: 1; }

    .chart-labels {
      margin-top: 8px;
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(10px, 1fr);
      gap: 7px;
    }
    .chart-label { overflow: hidden; text-align: center; text-overflow: ellipsis; white-space: nowrap; font-size: .68rem; }

    .bc-list { display: grid; gap: 14px; align-content: start; min-height: 340px; }
    .bc-list-head { display: grid; gap: 8px; }
    .list { display: grid; gap: 10px; }

    .list-item {
      display: grid;
      gap: 10px;
      padding: 14px;
      border: 1px solid var(--dash-line-soft);
      border-radius: 22px;
      background: rgba(255, 255, 255, .56);
      box-shadow: 0 12px 28px rgba(11, 13, 20, .055);
      transition: transform .2s var(--ease), box-shadow .2s var(--ease), background .2s var(--ease);
    }
    .list-item:hover { transform: translateY(-2px); background: rgba(255,255,255,.76); box-shadow: 0 18px 38px rgba(11, 13, 20, .08); }
    .list-item__title,
    .list-item strong { color: var(--dash-text-strong); font-size: .95rem; line-height: 1.38; }
    .mini-meta { font-size: .72rem; }

    .pill { min-height: 24px; padding: 3px 8px; font-size: .66rem; }
    .pill.draft { color: var(--dash-warning); border-color: rgba(245, 158, 11, .28); background: rgba(245, 158, 11, .10); }
    .pill.pub,
    .pill-live { color: var(--dash-emerald); border-color: rgba(31, 191, 125, .28); background: rgba(31, 191, 125, .10); }
    .list-link { color: var(--dash-azure); font-size: .78rem; font-weight: 900; }
    .list-link:hover { color: var(--dash-violet); }

    .note-line {
      padding-top: 12px;
      border-top: 1px solid var(--dash-line-soft);
      font-size: .82rem;
      line-height: 1.6;
    }

    .bc-motto {
      display: grid;
      align-content: space-between;
      min-height: 340px;
      color: #fff;
      background: var(--dash-dark);
    }
    .bc-motto-text { font-family: var(--dash-font-display); font-size: clamp(1.7rem, 2.7vw, 3rem); font-weight: 650; letter-spacing: -.05em; line-height: 1; text-wrap: balance; }
    .bc-motto-text em { color: #8ff0c5; font-style: italic; }

    .empty-state {
      display: grid;
      gap: 8px;
      padding: 18px;
      border: 1px dashed rgba(74, 155, 255, .32);
      border-radius: 24px;
      background: rgba(255, 255, 255, .58);
      text-align: center;
      box-shadow: var(--dash-shadow-soft);
    }
    .empty-state p { margin: 0; font-size: .9rem; line-height: 1.55; }
    .tiny { font-size: .74rem; }

    .toast {
      position: fixed;
      right: 22px;
      bottom: 22px;
      z-index: 120;
      max-width: min(360px, calc(100% - 44px));
      padding: 13px 16px;
      border: 1px solid var(--dash-line-soft);
      border-radius: 18px;
      background: rgba(10, 13, 24, .92);
      color: #fff;
      box-shadow: 0 24px 70px rgba(0,0,0,.26);
      opacity: 0;
      transform: translateY(12px);
      pointer-events: none;
      transition: opacity .2s var(--ease), transform .2s var(--ease);
      backdrop-filter: blur(18px);
    }
    .toast.show { opacity: 1; transform: none; }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      z-index: 100;
      display: none;
      align-items: center;
      justify-content: center;
      padding: 22px;
      background: rgba(8, 11, 18, .48);
      backdrop-filter: blur(18px);
    }
    .modal-backdrop.open { display: flex; }
    .modal {
      position: relative;
      overflow: hidden;
      width: min(620px, 100%);
      border: 1px solid rgba(255,255,255,.18);
      border-radius: 34px;
      background: linear-gradient(180deg, var(--dash-surface-strong), var(--dash-surface));
      box-shadow: 0 34px 90px rgba(0,0,0,.30);
      backdrop-filter: blur(24px);
    }
    .modal-head,
    .modal-actions { padding: 16px; display: flex; align-items: center; justify-content: space-between; gap: 10px; }
    .modal-head { border-bottom: 1px solid var(--dash-line-soft); }
    .modal-body { display: grid; gap: 12px; padding: 16px; }
    .modal-msg { min-height: 20px; padding: 0 16px; color: var(--dash-danger); font-size: .84rem; font-weight: 800; }
    .field { display: grid; gap: 7px; }
    .field input,
    .field select { min-height: 46px; padding: 0 14px; }
    .field textarea { min-height: 150px; resize: vertical; padding: 13px 14px; }

    .kpi-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px; }
    .kpi { padding: 16px; display: grid; gap: 10px; }
    .kpi-value { color: var(--dash-text-strong); font-family: var(--dash-font-display); font-size: 2rem; font-weight: 700; line-height: 1; }
    .ops-grid { display: grid; grid-template-columns: 1.1fr 1fr 1fr; gap: 12px; }
    .ops-card { padding: 16px; display: grid; gap: 12px; }
    .ops-card p { color: var(--dash-text-soft); font-size: .86rem; line-height: 1.55; }

    @keyframes dashAurora {
      0%, 100% { transform: translate3d(0,0,0) scale(1); }
      50% { transform: translate3d(1.5%, -1%, 0) scale(1.03); }
    }
    @keyframes dashFloat {
      0%, 100% { transform: translate3d(0,0,0) rotate(0deg); }
      50% { transform: translate3d(-4%, 5%, 0) rotate(8deg); }
    }
    @keyframes dashPulse {
      0%, 100% { transform: scale(1); box-shadow: 0 0 0 5px rgba(31, 191, 125, .14); }
      50% { transform: scale(.86); box-shadow: 0 0 0 9px rgba(31, 191, 125, .06); }
    }

    @media (max-width: 1180px) {
      .bento {
        grid-template-columns: repeat(8, minmax(0, 1fr));
        grid-template-areas:
          'hero hero hero hero hero hero hero hero'
          'posts posts views views stat stat stat stat'
          'chart chart chart chart chart chart chart chart'
          'draft draft draft draft recent recent recent recent'
          'notif notif notif notif motto motto motto motto';
      }
      .bc-hero { min-height: 480px; }
      .bc-stat { min-height: 300px; }
    }

    @media (max-width: 780px) {
      .main { width: min(100% - 24px, 1480px); padding-top: 82px; }
      .mobile-nav { top: 64px; border-radius: 22px; }
      .bento {
        grid-template-columns: 1fr;
        grid-auto-rows: auto;
        grid-template-areas:
          'hero'
          'posts'
          'views'
          'stat'
          'chart'
          'draft'
          'recent'
          'notif'
          'motto';
