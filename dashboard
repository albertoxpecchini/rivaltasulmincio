<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <script>!function(){try{var p=JSON.parse(localStorage.getItem('rsm_prefs_v1'))||{},r=document.documentElement,s={sm:'14px',md:'16px',lg:'18px',xl:'20px'};if(p.theme&&p.theme!=='auto')r.dataset.theme=p.theme;if(p.fontsize)r.style.fontSize=s[p.fontsize]||'16px';if(p.uiDensity)r.dataset.density=p.uiDensity;if(p.contrast)r.style.filter='contrast(1.16)';}catch(e){}}();</script>
  <link rel="icon" href="/img/favicon.png" type="image/png" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard - Rivalta sul Mincio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link href="https://api.fontshare.com/v2/css?f[]=cabinet-grotesk@400,500,700,800,900&display=swap" rel="stylesheet" />
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,650;1,9..144,550&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:        #17221d;
      --ink-soft:   #31453b;
      --cream:      #f7f0e4;
      --paper:      #fffaf0;
      --mist:       #e4ddcf;
      --marsh:      #253f35;
      --marsh-2:    #3d6353;
      --water:      #2f6b67;
      --clay:       #b8663f;
      --reed:       #c6a462;
      --white:      #fffdf8;
      --line:       rgba(37, 63, 53, 0.15);
      --ok:         #2f6b67;
      --err:        #b83232;
      --warn:       #b16b12;
      --radius:     14px;
      --shadow-card: 0 2px 24px rgba(37, 63, 53, 0.09), 0 0 0 1px rgba(37, 63, 53, 0.07);
      --sans:       "Cabinet Grotesk", system-ui, sans-serif;
      --serif:      "Fraunces", Georgia, serif;
      --ease:       cubic-bezier(0.32, 0.72, 0, 1);
    }

    body {
      font-family: var(--sans);
      background:
        radial-gradient(circle at 14% 8%, rgba(198, 164, 98, 0.28), transparent 28rem),
        radial-gradient(circle at 88% 2%, rgba(47, 107, 103, 0.16), transparent 34rem),
        linear-gradient(135deg, var(--cream), #efe5d2 54%, #f8f2e8);
      color: var(--ink);
      min-height: 100vh;
      line-height: 1.5;
      overflow-x: hidden;
      -webkit-font-smoothing: antialiased;
    }
    body::before {
      content: '';
      position: fixed; inset: 0;
      z-index: 0; pointer-events: none;
      opacity: 0.16;
      background-image:
        radial-gradient(circle at 12% 18%, rgba(23, 34, 29, 0.11) 0 1px, transparent 1px),
        radial-gradient(circle at 77% 54%, rgba(23, 34, 29, 0.08) 0 1px, transparent 1px);
      background-size: 23px 23px, 31px 31px;
      mix-blend-mode: multiply;
    }
    a { color: var(--marsh); text-decoration: none; }
    a:hover { color: var(--water); }

    .layout {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr;
      min-height: 100vh;
    }

    .sidebar { display: none; }

    .sb-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--surface-2);
    }

    .sb-logo {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg,#1F6F8B,#3a8c8a);
      font-size: 1rem;
      color: #fff;
    }

    .sb-name {
      font-family: 'Sora', sans-serif;
      background: linear-gradient(135deg,#163748,#3a8c8a);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
    }

    .sb-menu {
      display: grid;
      gap: 6px;
      margin-top: 4px;
    }

    .sb-item {
      width: 100%;
      text-align: left;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 10px 11px;
      border-radius: 10px;
      border: 1px solid transparent;
      background: transparent;
      color: var(--muted);
      font-size: .87rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      transition: all .2s;
    }

    .sb-item:hover {
      color: var(--text);
      border-color: #bfd0da;
      background: #eef5f9;
    }

    .sb-item.on {
      color: var(--text);
      border-color: rgba(58,140,138,.33);
      background: rgba(58,140,138,.12);
    }

    .sidebar-foot {
      margin-top: auto;
      display: grid;
      gap: 6px;
    }

    .main {
      padding: 108px 20px 80px;
      width: min(1360px, 100%);
      margin: 0 auto;
      display: grid;
      gap: 16px;
      position: relative;
      z-index: 1;
    }

    /* ── Nav Island ── */
    .site-header {
      position: fixed;
      top: 20px; left: 0; right: 0;
      z-index: 70;
      pointer-events: none;
    }
    .nav-island {
      position: relative;
      width: min(100% - 28px, 1240px);
      margin: 0 auto;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 18px;
      padding: 8px 10px 8px 12px;
      border: 1px solid rgba(255, 250, 240, 0.68);
      border-radius: 999px;
      background: rgba(247, 240, 228, 0.82);
      box-shadow: 0 18px 48px rgba(23, 34, 29, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      pointer-events: auto;
    }
    .brand {
      display: inline-flex; align-items: center; gap: 11px;
      min-width: 0; color: var(--ink); text-decoration: none;
    }
    .logo-mark {
      width: 42px; height: 42px; flex: 0 0 42px;
      border-radius: 14px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }
    .logo-mark img { width: 42px; height: 42px; object-fit: cover; display: block; }
    .brand-name { display: grid; line-height: 1.02; letter-spacing: -0.02em; }
    .brand-name strong { font-size: 0.98rem; font-weight: 800; }
    .brand-name span { font-size: 0.72rem; color: rgba(23, 34, 29, 0.55); font-weight: 600; }
    #user-menu-wrap { display: flex; align-items: center; }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: var(--paper);
      color: var(--ink);
      font-family: var(--sans);
      font-size: .82rem;
      font-weight: 700;
      padding: 8px 18px;
      cursor: pointer;
      text-decoration: none;
      transition: all .15s;
    }

    .btn:hover {
      background: var(--mist);
    }
    .btn:disabled { opacity: .55; cursor: not-allowed; }

    .btn-primary {
      border-color: transparent;
      background: var(--marsh);
      color: var(--paper);
      box-shadow: 0 4px 16px rgba(37,63,53,.28);
    }
    .btn-primary:hover { background: #1f362e; box-shadow: 0 6px 22px rgba(37,63,53,.4); border-color: transparent; }

    .btn-ghost {
      color: var(--ink-soft);
    }

    .card {
      border: 1px solid var(--line);
      border-radius: 20px;
      background: var(--paper);
      padding: 16px;
      box-shadow: var(--shadow-card);
    }

    .dash-head {
      display: grid;
      gap: 12px;
    }

    .dash-head-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 14px;
      flex-wrap: wrap;
    }

    .dash-head h1 {
      font-family: var(--serif);
      font-size: clamp(1.45rem, 2.7vw, 2rem);
      font-weight: 650;
      line-height: 1.1;
      letter-spacing: -.02em;
      margin-bottom: 6px;
    }

    .dash-head p {
      color: var(--ink-soft);
      font-size: .86rem;
      max-width: 720px;
    }

    .head-meta {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }

    .chip {
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255, 250, 240, 0.9);
      color: var(--ink-soft);
      padding: 6px 10px;
      font-size: .75rem;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 7px;
    }

    .select {
      border: 1px solid var(--line);
      border-radius: 999px;
      appearance: none;
      background: rgba(255, 250, 240, 0.95);
      background-image:
        linear-gradient(45deg, transparent 50%, var(--ink-soft) 50%),
        linear-gradient(135deg, var(--ink-soft) 50%, transparent 50%);
      background-position:
        calc(100% - 16px) calc(50% - 2px),
        calc(100% - 11px) calc(50% - 2px);
      background-size: 5px 5px, 5px 5px;
      background-repeat: no-repeat;
      color: var(--ink);
      padding: 7px 32px 7px 12px;
      font-family: var(--sans);
      font-size: .8rem;
      font-weight: 700;
    }

    .select:focus,
    .field select:focus {
      outline: none;
      border-color: var(--marsh);
      box-shadow: 0 0 0 3px rgba(37,63,53,.1);
    }

    .select option,
    .field select option {
      background: var(--paper);
      color: var(--ink);
    }

    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .kpi {
      border: 1px solid var(--line);
      border-radius: 20px;
      background: var(--paper);
      padding: 12px;
      display: grid;
      gap: 7px;
      box-shadow: var(--shadow-card);
    }

    .kpi-label {
      color: var(--ink-soft);
      font-size: .74rem;
      text-transform: uppercase;
      letter-spacing: .1em;
      font-weight: 800;
    }

    .kpi-value {
      font-family: var(--serif);
      font-size: 1.8rem;
      font-weight: 650;
      line-height: 1;
      color: var(--marsh);
    }

    .kpi-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap;
      font-size: .75rem;
      color: var(--ink-soft);
    }

    .delta {
      font-weight: 700;
      letter-spacing: .02em;
    }

    .delta.up { color: var(--ok); }
    .delta.down { color: var(--err); }
    .delta.same { color: var(--ink-soft); }

    .section-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }

    .section-title h2 {
      font-family: var(--serif);
      font-size: 1.2rem;
      font-weight: 650;
      color: var(--ink);
    }

    .section-title p {
      color: var(--ink-soft);
      font-size: .8rem;
    }

    .group-switch {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .switch-btn {
      border: 1px solid var(--line);
      border-radius: 999px;
      background: rgba(255, 250, 240, 0.9);
      color: var(--ink-soft);
      font-size: .75rem;
      font-weight: 700;
      padding: 6px 11px;
      cursor: pointer;
      transition: transform .2s ease, box-shadow .2s ease, background .2s ease;
    }

    .switch-btn.on {
      color: var(--paper);
      border-color: transparent;
      background: var(--marsh);
      box-shadow: 0 10px 24px rgba(37,63,53,.28);
    }

    .chart-wrap {
      border: 1px solid var(--line);
      border-radius: 18px;
      background: rgba(255, 250, 240, 0.7);
      padding: 14px;
    }

    .chart-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 10px;
      font-size: .78rem;
      color: var(--ink-soft);
    }

    .chart-bars {
      height: 210px;
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(10px, 1fr);
      align-items: end;
      gap: 4px;
      border-bottom: 1px solid rgba(105,124,168,.22);
      padding: 12px 2px 10px;
    }

    .bar {
      border-radius: 6px 6px 3px 3px;
      background: linear-gradient(180deg, var(--marsh), var(--water));
      min-height: 3px;
      position: relative;
      box-shadow: 0 8px 16px rgba(37,63,53,.18);
    }

    .bar::after {
      content: attr(data-v);
      position: absolute;
      top: -20px;
      left: 50%;
      transform: translateX(-50%);
      font-size: .66rem;
      color: var(--ink-soft);
      opacity: 0;
      transition: opacity .2s;
      pointer-events: none;
    }

    .bar:hover::after { opacity: 1; }

    .chart-labels {
      margin-top: 6px;
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(10px, 1fr);
      gap: 4px;
    }

    .chart-label {
      text-align: center;
      font-size: .65rem;
      color: var(--ink-soft);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .ops-grid {
      display: grid;
      grid-template-columns: 1.1fr 1fr 1fr;
      gap: 10px;
    }

    .ops-card {
      border: 1px solid var(--line);
      border-radius: 20px;
      background: var(--paper);
      padding: 12px;
      display: grid;
      gap: 10px;
      min-height: 240px;
      align-content: start;
      box-shadow: var(--shadow-card);
    }

    .ops-card h3 {
      font-family: var(--serif);
      font-size: .98rem;
      font-weight: 650;
      color: var(--ink);
      margin-bottom: 2px;
    }

    .ops-card p {
      color: var(--ink-soft);
      font-size: .76rem;
      line-height: 1.45;
    }

    .list {
      display: grid;
      gap: 8px;
    }

    .list-item {
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--paper);
      padding: 9px;
      display: grid;
      gap: 4px;
      box-shadow: 0 1px 6px rgba(37,63,53,.05);
    }

    .list-item strong {
      font-size: .84rem;
      line-height: 1.35;
      color: var(--ink);
      font-weight: 700;
    }

    .mini-meta {
      font-size: .72rem;
      color: var(--ink-soft);
      display: inline-flex;
      align-items: center;
      gap: 7px;
      flex-wrap: wrap;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      border-radius: 999px;
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .03em;
      padding: 3px 8px;
      border: 1px solid var(--line);
      color: var(--ink-soft);
      background: rgba(255, 250, 240, 0.66);
    }

    .pill.draft {
      color: var(--warn);
      border-color: rgba(177,107,18,.28);
      background: rgba(177,107,18,.1);
    }

    .pill.pub {
      color: var(--ok);
      border-color: rgba(47,107,103,.3);
      background: rgba(47,107,103,.1);
    }

    .note-line {
      font-size: .73rem;
      color: var(--ink-soft);
      line-height: 1.45;
      border-top: 1px solid var(--line);
      padding-top: 8px;
    }

    .empty-state {
      border: 1px dashed rgba(37,63,53,.24);
      border-radius: 16px;
      background: rgba(255, 250, 240, 0.82);
      padding: 14px;
      text-align: center;
      display: grid;
      gap: 7px;
    }

    .empty-state p {
      color: var(--ink-soft);
      font-size: .83rem;
      line-height: 1.45;
    }

    .tiny {
      font-size: .7rem;
      color: var(--ink-soft);
    }

    .toast {
      position: fixed;
      bottom: 22px;
      right: 22px;
      z-index: 70;
      border: 1px solid var(--line);
      border-radius: 14px;
      background: var(--paper);
      color: var(--ink);
      padding: 10px 14px;
      font-size: .82rem;
      transform: translateY(12px);
      opacity: 0;
      transition: all .22s;
      pointer-events: none;
      box-shadow: 0 10px 25px rgba(37,63,53,.18);
    }

    .toast.show {
      opacity: 1;
      transform: none;
    }

    .toast.err { color: var(--err); }
    .toast.ok { color: var(--ok); }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      z-index: 60;
      background: rgba(23,34,29,.3);
      backdrop-filter: blur(4px);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    .modal-backdrop.open { display: flex; }

    .modal {
      width: min(760px, 100%);
      border: 1px solid var(--line);
      border-radius: 20px;
      background: var(--paper);
      box-shadow: 0 20px 60px rgba(37,63,53,.2);
      overflow: hidden;
    }

    .modal-head {
      padding: 13px 14px;
      border-bottom: 1px solid var(--line);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .modal-head h3 {
      font-family: var(--serif);
      font-size: 1rem;
      font-weight: 650;
      color: var(--ink);
    }

    .modal-body {
      padding: 14px;
      display: grid;
      gap: 10px;
    }

    .field {
      display: grid;
      gap: 5px;
    }

    .field label {
      font-size: .75rem;
      text-transform: uppercase;
      letter-spacing: .08em;
      color: var(--ink-soft);
      font-weight: 800;
    }

    .field input,
    .field textarea,
    .field select {
      width: 100%;
      border-radius: 12px;
      border: 1px solid var(--line);
      background: rgba(255, 250, 240, 0.7);
      color: var(--ink);
      font-family: var(--sans);
      font-size: .88rem;
      padding: 11px 16px;
    }

    .field input:focus,
    .field textarea:focus,
    .field select:focus {
      outline: none;
      border-color: var(--marsh);
      box-shadow: 0 0 0 3px rgba(37,63,53,.1);
    }

    .field textarea {
      min-height: 120px;
      resize: vertical;
      line-height: 1.55;
    }

    .field select {
      appearance: none;
      background-image:
        linear-gradient(45deg, transparent 50%, var(--ink-soft) 50%),
        linear-gradient(135deg, var(--ink-soft) 50%, transparent 50%);
      background-position:
        calc(100% - 16px) calc(50% - 2px),
        calc(100% - 11px) calc(50% - 2px);
      background-size: 5px 5px, 5px 5px;
      background-repeat: no-repeat;
      padding-right: 30px;
    }

    .modal-actions {
      padding: 0 14px 14px;
      display: flex;
      gap: 9px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .modal-msg {
      min-height: 18px;
      color: var(--err);
      font-size: .8rem;
      padding: 0 14px 4px;
    }

    .mobile-nav {
      display: none;
      position: sticky;
      top: 8px;
      z-index: 21;
      border: 1px solid var(--line);
      border-radius: 20px;
      background: rgba(255, 250, 240, 0.88);
      backdrop-filter: blur(14px);
      padding: 8px;
      gap: 6px;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      box-shadow: 0 12px 28px rgba(37,63,53,.12);
    }

    .mobile-nav button,
    .mobile-nav a {
      border: 1px solid var(--line);
      background: rgba(255, 250, 240, 0.9);
      color: var(--ink-soft);
      border-radius: 14px;
      padding: 8px 6px;
      text-align: center;
      font-size: .7rem;
      font-weight: 700;
      text-decoration: none;
      font-family: var(--sans);
      cursor: pointer;
    }

    .mobile-nav button.on {
      color: var(--paper);
      border-color: rgba(37,63,53,.4);
      background: var(--marsh);
      box-shadow: 0 10px 20px rgba(37,63,53,.25);
    }

    /* ====== BENTO GRID ====== */
    .bento {
      display: grid;
      gap: 12px;
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-areas:
        "hero  posts  stat"
        "hero  views  stat"
        "chart chart  draft"
        "recent notif motto";
    }

    .bc {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 26px;
      padding: 22px 24px;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      box-shadow: var(--shadow-card);
      transition: transform .3s ease, box-shadow .3s ease;
      opacity: 0;
      animation: cardIn .58s cubic-bezier(.2,.7,.2,1) forwards;
    }

    .bc:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 36px rgba(37,63,53,.16);
    }

    .bc:nth-of-type(1) { animation-delay: .03s; }
    .bc:nth-of-type(2) { animation-delay: .08s; }
    .bc:nth-of-type(3) { animation-delay: .12s; }
    .bc:nth-of-type(4) { animation-delay: .16s; }
    .bc:nth-of-type(5) { animation-delay: .2s; }
    .bc:nth-of-type(6) { animation-delay: .24s; }
    .bc:nth-of-type(7) { animation-delay: .28s; }
    .bc:nth-of-type(8) { animation-delay: .32s; }

    @keyframes cardIn {
      from { opacity: 0; transform: translateY(16px) scale(.99); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .bc-hero {
      grid-area: hero;
      justify-content: flex-start;
      padding: 30px;
      background:
        radial-gradient(circle at 86% 14%, rgba(47,107,103,.18), transparent 34%),
