      .bc { border-radius: 28px; padding: 18px; }
      .bc-hero { min-height: 0; }
      .bc-title { max-width: 9ch; font-size: clamp(2.85rem, 18vw, 4.7rem); }
      .period-row { align-items: stretch; flex-direction: column; }
      .period-row .btn,
      .period-row .chip,
      .period-row .select { width: 100%; }
      .hero-stats { grid-template-columns: 1fr; }
      .bc-stat { min-height: 280px; }
      .section-title { align-items: stretch; flex-direction: column; }
      .group-switch { width: 100%; }
      .switch-btn { flex: 1; }
      .chart-bars { height: 210px; gap: 4px; }
      .bc-motto { min-height: 260px; }
      .modal-backdrop { align-items: end; padding: 12px; }
      .modal { border-radius: 28px; }
      .modal-actions { flex-direction: column-reverse; align-items: stretch; }
      .modal-actions .btn { width: 100%; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after { animation-duration: .01ms !important; animation-iteration-count: 1 !important; scroll-behavior: auto !important; transition-duration: .01ms !important; }
    }
  </style>
