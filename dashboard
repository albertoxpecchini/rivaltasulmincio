<script>
(function () {
  if (typeof SUPABASE_URL === 'undefined' || SUPABASE_URL.includes('your-project')) return;

  const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  const $ = (id) => document.getElementById(id);

  const STATE = {
    period: '7d',
    group: 'day',
    session: null,
    profile: null,
    posts: [],
    comments: [],
    likes: [],
    notifications: [],
    totals: {
      comments: 0,
      likes: 0,
    },
    missing: {
      comments: false,
      likes: false,
      notifications: false,
    },
  };

  const PERIOD_DAYS = { '7d': 7, '30d': 30, '90d': 90 };
  const CATEGORIES = window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.all()
    : ['Eventi', 'Territorio', 'Vita locale', 'Avvisi', 'Richieste', 'Storie'];

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function toast(message, type) {
    const box = $('toast');
    if (!box) return;
    box.textContent = message;
    box.className = 'toast show ' + (type || '');
    window.clearTimeout(box._to);
    box._to = window.setTimeout(() => { box.className = 'toast'; }, 2600);
  }

  function isMissingRelationError(error) {
    const msg = String(error?.message || '').toLowerCase();
    return !!error && (
      error.code === '42P01'
      || error.code === 'PGRST205'
      || msg.includes('does not exist')
      || msg.includes('could not find the table')
    );
  }

  function fmtDate(iso) {
    if (!iso) return '-';
    return new Date(iso).toLocaleDateString('it-IT', { day: '2-digit', month: 'short' });
  }

  function relativeTime(iso) {
    if (!iso) return 'ora';
    const ts = new Date(iso).getTime();
    const diff = Date.now() - ts;
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return 'adesso';
    if (mins < 60) return mins + ' min fa';
    const hours = Math.floor(mins / 60);
    if (hours < 24) return hours + ' h fa';
    const days = Math.floor(hours / 24);
    if (days < 7) return days + ' g fa';
    return fmtDate(iso);
  }

  function startOfDay(date) {
    const x = new Date(date);
    x.setHours(0, 0, 0, 0);
    return x;
  }

  function rangeBounds(days) {
    const end = new Date();
    const start = new Date(end.getTime() - days * 24 * 60 * 60 * 1000);
    return { start, end };
  }

  function inRange(ts, start, end) {
    const value = new Date(ts).getTime();
    return value >= start.getTime() && value <= end.getTime();
  }

  function countByRange(items, getDate, start, end) {
    return items.filter((item) => {
      const d = getDate(item);
      if (!d) return false;
      return inRange(d, start, end);
    }).length;
  }

  function percentChange(curr, prev) {
    if (prev <= 0 && curr <= 0) return 0;
    if (prev <= 0 && curr > 0) return 100;
    return Math.round(((curr - prev) / prev) * 100);
  }

  function deltaBadge(value) {
    if (value > 0) return `<span class="delta up">+${value}%</span>`;
    if (value < 0) return `<span class="delta down">-${Math.abs(value)}%</span>`;
    return '<span class="delta same">=0%</span>';
  }

  function fmtNum(value) {
    return Number(value || 0).toLocaleString('it-IT');
  }

  function buildKpi(label, value, delta, periodText) {
    return `
      <article class="kpi">
        <div class="kpi-label">${label}</div>
        <div class="kpi-value">${value}</div>
        <div class="kpi-meta">
          ${deltaBadge(delta)}
          <span>${periodText}</span>
        </div>
      </article>`;
  }

  function renderKpis() {
    const days = PERIOD_DAYS[STATE.period] || 7;
    const periodText = days === 7 ? 'ultimi 7 giorni' : (days === 30 ? 'ultimi 30 giorni' : 'ultimi 90 giorni');

    const curr = rangeBounds(days);
    const prev = {
      end: new Date(curr.start.getTime() - 1),
      start: new Date(curr.start.getTime() - days * 24 * 60 * 60 * 1000),
    };

    const currPublished = countByRange(STATE.posts.filter(p => p.published), p => p.published_at || p.created_at, curr.start, curr.end);
    const prevPublished = countByRange(STATE.posts.filter(p => p.published), p => p.published_at || p.created_at, prev.start, prev.end);

    const currLikes = countByRange(STATE.likes, x => x.created_at, curr.start, curr.end);
    const prevLikes = countByRange(STATE.likes, x => x.created_at, prev.start, prev.end);

    const currComments = countByRange(STATE.comments, x => x.created_at, curr.start, curr.end);
    const prevComments = countByRange(STATE.comments, x => x.created_at, prev.start, prev.end);

    const currInteractions = currLikes + currComments;
    const prevInteractions = prevLikes + prevComments;

    const totalPublished = STATE.posts.filter((p) => p.published).length;
    const totalDrafts = STATE.posts.filter((p) => !p.published).length;
    const totalLikes = STATE.totals.likes || 0;

    function setKpi(valId, metaId, value, delta) {
      const valEl = $(valId);
      const metaEl = $(metaId);
      if (valEl) valEl.textContent = typeof value === 'number' ? value.toLocaleString('it-IT') : value;
      if (metaEl) metaEl.innerHTML = deltaBadge(delta) + ' <span>' + periodText + '</span>';
    }

    setKpi('bc-val-posts', 'bc-meta-posts', currPublished, percentChange(currPublished, prevPublished));
    setKpi('bc-val-comments', 'bc-meta-comments', currComments, percentChange(currComments, prevComments));

    const interEl = $('bc-val-inter');
    const interMetaEl = $('bc-meta-inter');
    if (interEl) interEl.textContent = fmtNum(currInteractions);
    if (interMetaEl) interMetaEl.innerHTML = deltaBadge(percentChange(currInteractions, prevInteractions));

    const heroPublished = $('hero-published');
    const heroDrafts = $('hero-drafts');
    const heroLikes = $('hero-likes');
    if (heroPublished) heroPublished.textContent = fmtNum(totalPublished);
    if (heroDrafts) heroDrafts.textContent = fmtNum(totalDrafts);
    if (heroLikes) heroLikes.textContent = fmtNum(totalLikes);
  }

  function buildBuckets(start, end, group) {
    const items = [];
    let stepMs = 24 * 60 * 60 * 1000;
    if (group === 'week') stepMs = 7 * 24 * 60 * 60 * 1000;
    if (group === 'month') stepMs = 30 * 24 * 60 * 60 * 1000;

    let cursor = startOfDay(start);
    while (cursor.getTime() < end.getTime()) {
      const next = new Date(cursor.getTime() + stepMs);
      items.push({ start: new Date(cursor), end: next });
      cursor = next;
      if (items.length > 120) break;
    }

    if (!items.length) items.push({ start: startOfDay(start), end: end });
    return items;
  }

  function renderChart() {
    const bars = $('chart-bars');
    const labels = $('chart-labels');
    const totalNode = $('chart-total');
    if (!bars || !labels || !totalNode) return;

    const days = PERIOD_DAYS[STATE.period] || 7;
    const { start, end } = rangeBounds(days);
    const buckets = buildBuckets(start, end, STATE.group);

    const events = [];
    STATE.likes.forEach((x) => { if (x.created_at) events.push(new Date(x.created_at).getTime()); });
    STATE.comments.forEach((x) => { if (x.created_at) events.push(new Date(x.created_at).getTime()); });

    const values = buckets.map((bucket) => {
      const count = events.filter((ts) => ts >= bucket.start.getTime() && ts < bucket.end.getTime()).length;
      return count;
    });

    const sum = values.reduce((a, b) => a + b, 0);
    totalNode.textContent = 'Totale: ' + sum.toLocaleString('it-IT');

    const max = Math.max(1, ...values);
    bars.innerHTML = values.map((v) => {
      const h = Math.max(3, Math.round((v / max) * 100));
      return `<div class="bar" style="height:${h}%" data-v="${v}"></div>`;
    }).join('');

    labels.innerHTML = buckets.map((bucket, idx) => {
      let label = fmtDate(bucket.start);
      if (STATE.group === 'week') label = 'W' + (idx + 1);
      if (STATE.group === 'month') label = new Date(bucket.start).toLocaleDateString('it-IT', { month: 'short' });
      return `<div class="chart-label">${label}</div>`;
    }).join('');
  }

  function renderRecent() {
    const wrap = $('recent-list');
    if (!wrap) return;

    const recent = STATE.posts
      .slice()
      .sort((a, b) => new Date(b.updated_at || b.created_at).getTime() - new Date(a.updated_at || a.created_at).getTime())
      .slice(0, 6);

    if (!recent.length) {
      wrap.innerHTML = '<div class="empty-state"><p>Nessun movimento recente.</p><span class="tiny">Le prossime modifiche compariranno qui in ordine cronologico.</span></div>';
      return;
    }

    wrap.innerHTML = recent.map((p) => {
      const statePill = p.published
        ? '<span class="pill pub">Online</span>'
        : '<span class="pill draft">Bozza</span>';
      const safeTitle = escapeHtml(p.title || '(Senza titolo)');
      const safeCategory = escapeHtml(p.category || 'Contenuto');
      const href = p.published ? 'post?id=' + encodeURIComponent(p.id) : 'write?id=' + encodeURIComponent(p.id);
      const actionLabel = p.published ? 'Apri articolo' : 'Apri bozza';
      return `
        <article class="list-item">
          <div class="list-item__top">
            <div class="mini-meta">
              ${statePill}
              <span class="pill">${safeCategory}</span>
            </div>
            <span class="tiny">${relativeTime(p.updated_at || p.created_at)}</span>
          </div>
          <strong class="list-item__title">${safeTitle}</strong>
          <div class="list-item__footer">
            <div class="mini-meta">
              <span>${p.published ? 'Ultima pubblicazione' : 'Ultima modifica'}</span>
            </div>
            <a class="list-link" href="${href}">${actionLabel}</a>
          </div>
        </article>`;
    }).join('');
  }

  function fillCreateModal(post) {
    $('create-id').value = post?.id || '';
    $('create-title').value = post?.title || '';
    $('create-excerpt').value = post?.excerpt || '';
    $('create-content').value = post?.content || '';
    $('create-category').value = post?.category || CATEGORIES[0] || 'Territorio';
    $('create-msg').textContent = '';
  }

  function openCreateModal(post) {
    fillCreateModal(post || null);
    $('create-modal-backdrop').classList.add('open');
    $('create-modal-backdrop').setAttribute('aria-hidden', 'false');
  }

  function closeCreateModal() {
    $('create-modal-backdrop').classList.remove('open');
    $('create-modal-backdrop').setAttribute('aria-hidden', 'true');
  }

  function autoTitleFromContent(content) {
    const clean = String(content || '').replace(/\s+/g, ' ').trim();
    if (!clean) return 'Nuovo post';
    if (clean.length <= 64) return clean;
    return clean.slice(0, 61).trim() + '...';
  }

  async function savePost(publish) {
    const msg = $('create-msg');
    const draftBtn = $('save-draft');
    const pubBtn = $('publish-post');

    const id = $('create-id').value;
    const titleInput = String($('create-title').value || '').trim();
    const excerpt = String($('create-excerpt').value || '').trim();
    const content = String($('create-content').value || '').trim();
    const category = String($('create-category').value || '').trim();

    if (!content) {
      msg.textContent = 'Il contenuto e obbligatorio.';
      return;
    }
    if (!category) {
      msg.textContent = 'Seleziona una categoria.';
      return;
    }

    draftBtn.disabled = true;
    pubBtn.disabled = true;
    msg.textContent = '';

    const badgeColor = window.RSM_CATEGORIES
      ? window.RSM_CATEGORIES.badgeColor(category)
      : 'default';

    const payload = {
      title: titleInput || autoTitleFromContent(content),
      excerpt: excerpt || null,
      content: content,
      category: category,
      badge: null,
      badge_color: badgeColor,
      image_type: null,
      published: publish,
      published_at: publish ? new Date().toISOString() : null,
    };

    let error = null;
    if (id) {
      ({ error } = await sb.from('posts').update(payload).eq('id', id).eq('user_id', STATE.session.user.id));
    } else {
      ({ error } = await sb.from('posts').insert({
        ...payload,
        user_id: STATE.session.user.id,
        author_username: STATE.profile.username || null,
      }));
    }

    draftBtn.disabled = false;
    pubBtn.disabled = false;

    if (error) {
      msg.textContent = 'Salvataggio non riuscito: ' + error.message;
      return;
    }

    closeCreateModal();
    toast(publish ? 'Post pubblicato.' : 'Bozza salvata.', 'ok');
    await refreshData();
  }

  function renderDrafts() {
    const wrap = $('drafts-list');
    if (!wrap) return;

    const drafts = STATE.posts.filter((p) => !p.published).slice(0, 6);
    if (!drafts.length) {
      wrap.innerHTML = '<div class="empty-state"><p>Nessuna bozza aperta.</p><span class="tiny">Quando salvi una bozza, la ritrovi subito qui.</span></div>';
      return;
    }

    wrap.innerHTML = drafts.map((p) => {
      const safeTitle = escapeHtml(p.title || '(Senza titolo)');
      const safeCategory = escapeHtml(p.category || 'Contenuto');
      return `
        <article class="list-item">
          <div class="list-item__top">
            <div class="mini-meta">
              <span class="pill draft">Bozza</span>
              <span class="pill">${safeCategory}</span>
            </div>
            <span class="tiny">${relativeTime(p.updated_at || p.created_at)}</span>
          </div>
          <strong class="list-item__title">${safeTitle}</strong>
          <div class="list-item__footer">
            <div class="mini-meta">
              <span>Pronta per essere completata o pubblicata</span>
            </div>
            <a class="list-link" href="write?id=${encodeURIComponent(p.id)}">Riprendi</a>
          </div>
        </article>`;
    }).join('');
  }

  function renderNotifications() {
    const wrap = $('notif-list');
    if (!wrap) return;

    if (STATE.missing.notifications) {
      wrap.innerHTML = '<div class="empty-state"><p>Centro notifiche non attivo.</p><span class="tiny">Per abilitarlo applica lo script Supabase completo o il layer sicurezza.</span></div>';
      return;
    }

    const notifs = STATE.notifications.slice(0, 6);
    if (!notifs.length) {
      wrap.innerHTML = '<div class="empty-state"><p>Nessun segnale da mostrare.</p><span class="tiny">Quando arrivano like o commenti li vedrai comparire qui.</span></div>';
      return;
    }

    wrap.innerHTML = notifs.map((n) => {
      const type = n.type === 'comment' ? 'Commento' : 'Mi piace';
      const safeMsg = escapeHtml(n.message || 'Nuova notifica');
      const state = n.is_read ? '<span class="pill">Letta</span>' : '<span class="pill pill-live">Nuova</span>';
      return `
        <article class="list-item">
          <div class="list-item__top">
            <div class="mini-meta">
              <span class="pill">${type}</span>
              ${state}
            </div>
            <span class="tiny">${relativeTime(n.created_at)}</span>
          </div>
          <strong class="list-item__title">${safeMsg}</strong>
          <div class="list-item__footer">
            <div class="mini-meta">
              <span>${n.is_read ? 'Gia vista' : 'Richiede attenzione'}</span>
            </div>
          </div>
        </article>`;
    }).join('');
  }

  function renderEmptyState() {
    const empty = $('empty-dashboard');
    if (!empty) return;
    empty.style.display = STATE.posts.length ? 'none' : '';
  }

  function renderAll() {
    renderKpis();
    renderChart();
    renderRecent();
    renderDrafts();
    renderNotifications();
    renderEmptyState();

    const note = $('sync-note');
    if (note) {
      const warnings = [];
      if (STATE.missing.likes) warnings.push('like');
      if (STATE.missing.comments) warnings.push('commenti');
      if (STATE.missing.notifications) warnings.push('notifiche');
      if (warnings.length) {
        note.textContent = 'Vista parziale: mancano le tabelle ' + warnings.join(', ') + '.';
      } else {
        note.textContent = 'Allineato alle ' + new Date().toLocaleTimeString('it-IT', { hour: '2-digit', minute: '2-digit' }) + '.';
      }
    }
  }

  async function fetchPosts() {
    const { data, error } = await sb.from('posts')
      .select('id,title,excerpt,content,category,published,published_at,created_at,updated_at')
      .eq('user_id', STATE.session.user.id)
      .order('created_at', { ascending: false });
    if (error) throw error;
    STATE.posts = data || [];
  }

  async function fetchCommentsAndLikes() {
    STATE.comments = [];
    STATE.likes = [];
    STATE.totals.comments = 0;
    STATE.totals.likes = 0;
    STATE.missing.comments = false;
    STATE.missing.likes = false;

    const ids = STATE.posts.map((p) => p.id).filter(Boolean);
    if (!ids.length) return;

    const analyticsSince = new Date(Date.now() - (180 * 24 * 60 * 60 * 1000)).toISOString();

    const [commentsCountRes, likesCountRes] = await Promise.all([
      sb.from('comments')
        .select('id', { count: 'exact', head: true })
        .in('post_id', ids)
        .eq('is_hidden', false),
      sb.from('post_likes')
        .select('id', { count: 'exact', head: true })
        .in('post_id', ids)
    ]);

    if (commentsCountRes.error) {
      if (isMissingRelationError(commentsCountRes.error)) STATE.missing.comments = true;
      else console.warn('[dashboard] comments count error:', commentsCountRes.error.message);
    } else {
      STATE.totals.comments = commentsCountRes.count || 0;
    }

    if (likesCountRes.error) {
      if (isMissingRelationError(likesCountRes.error)) STATE.missing.likes = true;
      else console.warn('[dashboard] likes count error:', likesCountRes.error.message);
    } else {
      STATE.totals.likes = likesCountRes.count || 0;
    }

    const commentsRes = await sb.from('comments')
      .select('id,post_id,created_at,is_hidden')
      .in('post_id', ids)
      .eq('is_hidden', false)
      .gte('created_at', analyticsSince)
      .order('created_at', { ascending: false })
      .limit(5000);

    if (commentsRes.error) {
      if (isMissingRelationError(commentsRes.error)) STATE.missing.comments = true;
      else console.warn('[dashboard] comments error:', commentsRes.error.message);
    } else {
      STATE.comments = commentsRes.data || [];
    }

    const likesRes = await sb.from('post_likes')
      .select('id,post_id,created_at')
      .in('post_id', ids)
      .gte('created_at', analyticsSince)
      .order('created_at', { ascending: false })
      .limit(5000);

    if (likesRes.error) {
      if (isMissingRelationError(likesRes.error)) STATE.missing.likes = true;
      else console.warn('[dashboard] likes error:', likesRes.error.message);
    } else {
      STATE.likes = likesRes.data || [];
    }
  }

  async function fetchNotifications() {
    STATE.notifications = [];
    STATE.missing.notifications = false;

    const res = await sb.from('notifications')
      .select('id,type,message,is_read,created_at')
      .eq('user_id', STATE.session.user.id)
      .order('created_at', { ascending: false })
      .limit(30);

    if (res.error) {
      if (isMissingRelationError(res.error)) STATE.missing.notifications = true;
      else console.warn('[dashboard] notifications error:', res.error.message);
      return;
    }

    STATE.notifications = res.data || [];
  }

  async function refreshData() {
    await fetchPosts();
    await fetchCommentsAndLikes();
    await fetchNotifications();
    renderAll();
  }

  function buildCategoryOptions() {
    const select = $('create-category');
    if (!select) return;
    select.innerHTML = CATEGORIES.map((x) => `<option value="${escapeHtml(x)}">${escapeHtml(x)}</option>`).join('');
  }

  function bindHashRouting() {
    const hash = (window.location.hash || '').replace('#', '');
    if (hash === 'write') {
      window.location.href = 'write';
      return;
    }
    if (hash === 'posts') {
      $('contenuti')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      return;
    }
    if (hash === 'profile') {
      window.location.href = 'preferenze';
    }
    if (hash === 'write') {
      window.location.href = 'write';
    }
  }

  function bindNavigation() {
    const jump = (target) => {
      if (target === 'dashboard') $('dashboard')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (target === 'contenuti') $('contenuti')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (target === 'media') $('media')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      if (target === 'analytics') $('analytics')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    document.querySelectorAll('[data-go]').forEach((node) => {
      node.addEventListener('click', () => {
        const t = node.getAttribute('data-go');
        jump(t);

        document.querySelectorAll('.sb-item').forEach((x) => x.classList.remove('on'));
        document.querySelectorAll('.mobile-nav button').forEach((x) => x.classList.remove('on'));
        document.querySelectorAll(`[data-go="${t}"]`).forEach((x) => x.classList.add('on'));
      });
    });
  }

  function bindUi() {
    $('global-period')?.addEventListener('change', () => {
      STATE.period = $('global-period').value;
      renderKpis();
      renderChart();
    });

    document.querySelectorAll('[data-group]').forEach((btn) => {
      btn.addEventListener('click', () => {
        STATE.group = btn.getAttribute('data-group');
        document.querySelectorAll('[data-group]').forEach((x) => x.classList.remove('on'));
        btn.classList.add('on');
        renderChart();
      });
    });

    $('open-create')?.addEventListener('click', () => openCreateModal(null));
    $('empty-create')?.addEventListener('click', () => openCreateModal(null));
    $('close-create')?.addEventListener('click', closeCreateModal);
    $('create-modal-backdrop')?.addEventListener('click', (event) => {
      if (event.target.id === 'create-modal-backdrop') closeCreateModal();
    });

    $('save-draft')?.addEventListener('click', () => savePost(false));
    $('publish-post')?.addEventListener('click', () => savePost(true));

    $('logout-side')?.addEventListener('click', async () => {
      await sb.auth.signOut();
      window.location.href = '/';
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeCreateModal();
    });
  }

  async function init() {
    const { data: sessionData } = await sb.auth.getSession();
    STATE.session = sessionData?.session || null;
    if (!STATE.session) {
      window.location.href = 'login';
      return;
    }

    const { data: profile, error } = await sb.from('profiles')
      .select('id,username,display_name,avatar_emoji,avatar_color')
      .eq('id', STATE.session.user.id)
      .single();

    if (error || !profile) {
      window.location.href = 'login';
      return;
    }

    STATE.profile = profile;
    const chip = $('chip-user');
    if (chip) {
      const name = '@' + (profile.username || 'utente');
      chip.textContent = name;
    }

    buildCategoryOptions();
    bindNavigation();
    bindUi();

    await refreshData();
    bindHashRouting();
  }

  init();
})();
</script>

