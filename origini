  <link rel="stylesheet" href="/theme.css" />
  <style>
    *, *::before, *::after { box-sizing: border-box; }
    * { margin: 0; }

    :root {
      --story-bg: #f7fafe;
      --story-ink: #08111f;
      --story-ink-2: #172033;
      --story-muted: #65728a;
      --story-muted-2: #93a0b4;
      --story-card: rgba(255, 255, 255, 0.72);
      --story-card-strong: rgba(255, 255, 255, 0.9);
      --story-line: rgba(12, 20, 35, 0.12);
      --story-line-strong: rgba(12, 20, 35, 0.2);
      --story-emerald: #1fbf7d;
      --story-azure: #4a9bff;
      --story-violet: #8b5cf6;
      --story-amber: #f59e0b;
      --story-grad: linear-gradient(100deg, var(--story-emerald) 0%, var(--story-azure) 50%, var(--story-violet) 100%);
      --story-grad-warm: linear-gradient(100deg, #f59e0b 0%, #ef4444 50%, var(--story-violet) 100%);
      --story-grad-soft: linear-gradient(135deg, rgba(31,191,125,0.14), rgba(74,155,255,0.12), rgba(139,92,246,0.14));
      --story-shadow: 0 28px 90px rgba(9, 17, 31, 0.12);
      --story-shadow-soft: 0 14px 42px rgba(9, 17, 31, 0.08);
      --story-radius-xl: 34px;
      --story-radius-lg: 24px;
      --story-radius-md: 16px;
      --story-sans: "Cabinet Grotesk", var(--rsm-font-sans, system-ui, sans-serif);
      --story-serif: "Fraunces", var(--rsm-font-display, Georgia, serif);
      --story-mono: var(--rsm-font-mono, ui-monospace, SFMono-Regular, Menlo, monospace);
      --story-ease: cubic-bezier(0.16, 1, 0.3, 1);
    }

    html { scroll-behavior: smooth; }

    body {
      min-height: 100vh;
      font-family: var(--story-sans);
      color: var(--story-ink);
      background:
        radial-gradient(circle at 12% 8%, rgba(31, 191, 125, 0.22), transparent 28rem),
        radial-gradient(circle at 85% 12%, rgba(74, 155, 255, 0.24), transparent 30rem),
        radial-gradient(circle at 72% 82%, rgba(139, 92, 246, 0.18), transparent 34rem),
        linear-gradient(180deg, #ffffff 0%, var(--story-bg) 42%, #eef4ff 100%);
      font-size: 16px;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      overflow-x: hidden;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      opacity: 0.58;
      background:
        linear-gradient(90deg, rgba(12,20,35,0.035) 1px, transparent 1px),
        linear-gradient(180deg, rgba(12,20,35,0.035) 1px, transparent 1px),
        radial-gradient(circle at 1px 1px, rgba(255,255,255,0.6) 0.8px, transparent 1.3px);
      background-size: 72px 72px, 72px 72px, 3px 3px;
      mask-image: linear-gradient(180deg, #000 0%, rgba(0,0,0,0.74) 58%, transparent 100%);
    }

    body::after {
      content: '';
      position: fixed;
      inset: auto -15vw -32vw -15vw;
      height: 48vw;
      min-height: 420px;
      z-index: 0;
      pointer-events: none;
      background: radial-gradient(closest-side, rgba(74,155,255,0.12), transparent 70%);
      filter: blur(10px);
    }

    a { color: var(--story-azure); text-decoration: none; }
    a:hover { color: var(--story-violet); }

    .skip-link {
      position: fixed;
      left: 18px;
      top: 14px;
      z-index: 100;
      padding: 11px 16px;
      border-radius: 999px;
      background: var(--story-ink);
      color: #fff;
      box-shadow: var(--story-shadow-soft);
      transform: translateY(-180%);
      transition: transform 360ms var(--story-ease);
      font-size: 0.86rem;
      font-weight: 800;
    }
    .skip-link:focus { transform: translateY(0); }

    /* ── Hero ─────────────────────────────────────────────── */
    .hero {
      position: relative;
      z-index: 1;
      isolation: isolate;
      width: min(100% - 40px, 1320px);
      margin: 0 auto;
      padding: clamp(132px, 16vw, 220px) 0 clamp(64px, 8vw, 110px);
      text-align: left;
    }
    .hero::before {
      content: '';
      position: absolute;
      right: min(-9vw, -90px);
      top: 18%;
      width: min(46vw, 620px);
      aspect-ratio: 1;
      z-index: -1;
      border-radius: 48% 52% 42% 58%;
      background:
        radial-gradient(circle at 34% 26%, rgba(255,255,255,0.78), transparent 24%),
        conic-gradient(from 140deg, rgba(31,191,125,0.22), rgba(74,155,255,0.28), rgba(139,92,246,0.24), rgba(31,191,125,0.22));
      filter: blur(0.2px);
      opacity: 0.95;
      animation: story-orb 18s ease-in-out infinite alternate;
    }
    .hero::after {
      content: '';
      position: absolute;
      left: -9vw;
      bottom: 9%;
      width: 260px;
      height: 260px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(31,191,125,0.2), transparent 68%);
      z-index: -1;
    }
    @keyframes story-orb {
      from { transform: translate3d(0, 0, 0) rotate(0deg); border-radius: 48% 52% 42% 58%; }
      to { transform: translate3d(-18px, 22px, 0) rotate(12deg); border-radius: 56% 44% 60% 40%; }
    }

    .hero-eyebrow,
    .section-label {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      font-family: var(--story-mono);
      font-size: clamp(0.68rem, 0.78vw, 0.78rem);
      font-weight: 800;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--story-muted);
    }
    .hero-eyebrow::before,
    .section-label::before {
      content: '';
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--story-grad);
      box-shadow: 0 0 0 7px rgba(74,155,255,0.10);
    }
    .hero-eyebrow { margin-bottom: 22px; }

    .hero-title {
      max-width: 980px;
      font-family: var(--story-sans);
      font-size: clamp(4rem, 10vw, 10.5rem);
      font-weight: 900;
      line-height: 0.86;
      letter-spacing: -0.085em;
      color: var(--story-ink);
      text-wrap: balance;
    }
    .hero-title em {
      font-family: var(--story-serif);
      font-weight: 550;
      font-style: italic;
      background: var(--story-grad);
      background-size: 220% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      animation: story-grad 8s ease-in-out infinite alternate;
    }
    @keyframes story-grad { to { background-position: 100% 50%; } }

    .hero-subtitle {
      max-width: 760px;
      margin: clamp(26px, 4vw, 42px) 0 0;
      font-size: clamp(1.08rem, 1.5vw, 1.34rem);
      font-weight: 500;
      line-height: 1.55;
      color: var(--story-muted);
    }
    .hero-subtitle span { color: var(--story-ink-2); font-weight: 900; }

    .hero-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      max-width: 980px;
      margin-top: clamp(28px, 4vw, 48px);
    }
    .stat-pill {
      display: inline-flex;
      align-items: center;
      gap: 9px;
      min-height: 44px;
      padding: 8px 15px;
      border: 1px solid rgba(255,255,255,0.68);
      border-radius: 999px;
      background: rgba(255,255,255,0.58);
      color: var(--story-muted);
      font-weight: 800;
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.72), 0 12px 36px rgba(9,17,31,0.06);
      backdrop-filter: blur(18px);
    }
    .stat-pill strong { color: var(--story-ink); font-size: 1.02rem; }
    .stat-pill .sep { color: var(--story-muted-2); }

    /* ── Page wrap ──────────────────────────────────────────── */
    .page-wrap {
      position: relative;
      z-index: 1;
      width: min(100% - 40px, 1240px);
      margin: 0 auto;
      padding: 0 0 100px;
    }
    .section-label {
      display: flex;
      margin: clamp(54px, 8vw, 92px) 0 18px;
    }

    /* ── Internal navigation ───────────────────────────────── */
    .origini-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin: clamp(32px, 5vw, 56px) 0 0;
      padding: clamp(20px, 3vw, 32px);
      border: 1px solid var(--story-line);
      border-radius: var(--story-radius-lg);
      background:
        linear-gradient(145deg, rgba(255,255,255,0.86), rgba(255,255,255,0.56)) padding-box,
        var(--story-grad) border-box;
      box-shadow: var(--story-shadow-soft);
      backdrop-filter: blur(20px);
    }
    .origini-nav-label {
      width: 100%;
      font-family: var(--story-mono);
      font-size: 0.68rem;
      font-weight: 900;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--story-muted-2);
      margin-bottom: 4px;
    }
    .origini-nav a {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      padding: 9px 15px;
      border: 1px solid var(--story-line);
      border-radius: 999px;
      background: rgba(255,255,255,0.58);
      color: var(--story-ink-2);
      font-weight: 800;
      font-size: 0.86rem;
      text-decoration: none;
      transition: background 240ms var(--story-ease), border-color 240ms var(--story-ease), color 240ms var(--story-ease);
    }
    .origini-nav a:hover {
      background: rgba(74,155,255,0.1);
      border-color: rgba(74,155,255,0.3);
      color: var(--story-azure);
    }
    .origini-nav a .nav-num {
      font-family: var(--story-mono);
      font-size: 0.68rem;
      color: var(--story-muted-2);
    }

    /* ── Timeline ───────────────────────────────────────────── */
    .timeline {
      position: relative;
      display: grid;
      gap: 18px;
      max-width: 980px;
      margin-top: 4px;
    }
    .timeline::before {
      content: '';
      position: absolute;
      left: 16px;
      top: 20px;
      bottom: 20px;
      width: 2px;
      background: linear-gradient(180deg, var(--story-emerald), var(--story-azure), var(--story-violet));
      opacity: 0.45;
    }
    .timeline-entry {
      position: relative;
      padding: 22px 24px 22px 58px;
      border: 1px solid transparent;
      border-radius: var(--story-radius-lg);
      background: rgba(255,255,255,0.52);
      opacity: 0;
      transform: translateY(22px);
      transition: opacity 640ms var(--story-ease), transform 640ms var(--story-ease), background 360ms var(--story-ease), box-shadow 360ms var(--story-ease);
    }
    .timeline-entry.visible { opacity: 1; transform: none; }
    .timeline-entry:hover { background: rgba(255,255,255,0.82); box-shadow: var(--story-shadow-soft); }
    .timeline-dot {
      position: absolute;
      left: 8px;
      top: 30px;
      width: 18px;
      height: 18px;
      border-radius: 50%;
      background: #fff;
      border: 5px solid var(--story-azure);
      box-shadow: 0 0 0 8px rgba(74,155,255,0.12);
      z-index: 1;
    }
    .timeline-dot.milestone { border-color: var(--story-emerald); box-shadow: 0 0 0 8px rgba(31,191,125,0.14); }
    .timeline-dot.amber { border-color: var(--story-amber); box-shadow: 0 0 0 8px rgba(245,158,11,0.14); }
    .timeline-date { font-family: var(--story-mono); font-size: 0.72rem; font-weight: 900; letter-spacing: 0.14em; text-transform: uppercase; color: var(--story-violet); margin-bottom: 8px; }
    .timeline-heading { font-family: var(--story-sans); font-size: clamp(1.45rem, 2.3vw, 2.1rem); line-height: 1.04; letter-spacing: -0.04em; color: var(--story-ink); margin-bottom: 12px; }
    .timeline-body { color: var(--story-muted); font-size: 1rem; font-weight: 500; line-height: 1.72; }
    .timeline-body p + p { margin-top: 12px; }
    .timeline-body strong { color: var(--story-ink-2); font-weight: 800; }
    .timeline-body em { font-family: var(--story-serif); font-style: italic; color: var(--story-ink-2); }

    /* ── Inline back-link button ───────────────────────────── */
    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-top: 18px;
      padding: 9px 16px 9px 14px;
      border: 1px solid var(--story-line);
      border-radius: 999px;
      background: rgba(255,255,255,0.58);
      color: var(--story-azure);
      font-weight: 800;
      font-size: 0.86rem;
      text-decoration: none;
      transition: background 240ms, border-color 240ms, transform 240ms var(--story-ease);
      backdrop-filter: blur(12px);
    }
    .back-link:hover {
      background: rgba(74,155,255,0.1);
      border-color: rgba(74,155,255,0.3);
      color: var(--story-azure);
      transform: translateX(3px);
    }
    .back-link .arrow { font-style: normal; }

    /* ── Carousel wrapper ──────────────────────────────────── */
    .carousel-block {
      margin: clamp(36px, 6vw, 64px) 0;
      border-radius: var(--story-radius-xl);
      overflow: hidden;
      box-shadow: var(--story-shadow);
    }
    .carousel-block [data-rsm-carousel] {
      aspect-ratio: 16 / 7;
      width: 100%;
    }
    .carousel-caption {
      padding: 14px 20px;
      background: rgba(255,255,255,0.72);
      backdrop-filter: blur(12px);
      border: 1px solid var(--story-line);
      border-top: none;
      border-radius: 0 0 var(--story-radius-xl) var(--story-radius-xl);
      font-family: var(--story-mono);
      font-size: 0.72rem;
      font-weight: 800;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--story-muted);
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .carousel-caption::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--story-grad);
      flex: 0 0 auto;
    }

    /* ── Quote block ───────────────────────────────────────── */
    .quote-block {
      position: relative;
      margin: clamp(28px, 5vw, 48px) 0;
      padding: clamp(24px, 4vw, 40px) clamp(24px, 4vw, 40px) clamp(24px, 4vw, 40px) clamp(32px, 5vw, 56px);
      border-radius: var(--story-radius-lg);
      background:
        linear-gradient(145deg, rgba(255,255,255,0.86), rgba(255,255,255,0.56)) padding-box,
        var(--story-grad) border-box;
      border: 1.5px solid transparent;
      box-shadow: var(--story-shadow-soft);
    }
    .quote-block::before {
      content: '\201C';
      position: absolute;
      left: clamp(10px, 2vw, 18px);
      top: clamp(10px, 2vw, 16px);
      font-family: var(--story-serif);
      font-size: clamp(3rem, 6vw, 5rem);
      line-height: 1;
      background: var(--story-grad);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      font-weight: 550;
    }
    .quote-text {
      font-family: var(--story-serif);
      font-size: clamp(1.15rem, 2vw, 1.55rem);
      font-weight: 550;
      font-style: italic;
      line-height: 1.55;
      color: var(--story-ink-2);
    }
    .quote-source {
      margin-top: 14px;
      font-family: var(--story-mono);
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.13em;
      text-transform: uppercase;
      color: var(--story-muted);
    }

    /* ── Fact grid ─────────────────────────────────────────── */
    .fact-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 14px;
      margin: clamp(24px, 4vw, 40px) 0;
    }
    .fact-card {
      padding: clamp(18px, 3vw, 28px);
      border: 1px solid var(--story-line);
      border-radius: var(--story-radius-md);
      background:
        linear-gradient(145deg, rgba(255,255,255,0.86), rgba(255,255,255,0.56)) padding-box,
        var(--story-grad) border-box;
      box-shadow: var(--story-shadow-soft);
      backdrop-filter: blur(16px);
    }
    .fact-card-icon {
      font-size: 1.6rem;
      margin-bottom: 10px;
      line-height: 1;
    }
    .fact-card-num {
      font-family: var(--story-sans);
      font-size: clamp(1.8rem, 3.5vw, 2.8rem);
      font-weight: 900;
      letter-spacing: -0.06em;
      line-height: 0.9;
      color: var(--story-ink);
    }
    .fact-card-num em {
      font-size: 0.55em;
      font-style: normal;
      font-weight: 900;
      background: var(--story-grad);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .fact-card-label {
      margin-top: 8px;
      font-family: var(--story-mono);
      font-size: 0.7rem;
      font-weight: 900;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--story-muted);
      line-height: 1.4;
    }

    /* ── Section intro (large text) ───────────────────────── */
    .section-intro {
      max-width: 860px;
      margin-bottom: clamp(28px, 5vw, 44px);
    }
    .section-intro-heading {
      font-family: var(--story-sans);
      font-size: clamp(1.9rem, 3.5vw, 3.2rem);
      font-weight: 900;
      line-height: 1.02;
      letter-spacing: -0.05em;
      color: var(--story-ink);
      margin-bottom: 16px;
    }
    .section-intro-heading em {
      font-family: var(--story-serif);
      font-style: italic;
      font-weight: 550;
      background: var(--story-grad);
      background-size: 200% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }
    .section-intro-body {
      font-size: clamp(1rem, 1.4vw, 1.18rem);
      font-weight: 500;
      line-height: 1.68;
      color: var(--story-muted);
    }
    .section-intro-body strong { color: var(--story-ink-2); font-weight: 800; }

    /* ── Dark callout (like commit-block in storia) ────────── */
    .dark-callout {
      position: relative;
      overflow: hidden;
      border-radius: var(--story-radius-xl);
      padding: clamp(28px, 5vw, 52px);
      color: rgba(236, 246, 255, 0.82);
      background:
        radial-gradient(circle at 10% 10%, rgba(31,191,125,0.24), transparent 30%),
        radial-gradient(circle at 92% 0%, rgba(74,155,255,0.25), transparent 34%),
        radial-gradient(circle at 70% 100%, rgba(139,92,246,0.22), transparent 32%),
        #08111f;
      box-shadow: var(--story-shadow);
      margin: clamp(28px, 5vw, 52px) 0;
    }
    .dark-callout::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: linear-gradient(rgba(255,255,255,0.035) 1px, transparent 1px);
      background-size: 100% 28px;
      pointer-events: none;
    }
    .dark-callout > * { position: relative; }
    .dark-callout-label {
      font-family: var(--story-mono);
      font-size: 0.68rem;
      font-weight: 900;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: var(--story-emerald);
      margin-bottom: 12px;
