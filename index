      --rsm-ink:    var(--rsm-text-on-dark);
      --rsm-ink-2:  var(--rsm-text-on-dark-soft);
      --rsm-ink-3:  var(--rsm-text-on-dark-soft);
      --rsm-ink-4:  var(--rsm-text-on-dark-dim);
      --rsm-ink-5:  rgba(255, 255, 255, 0.22);
      --rsm-text-strong: var(--rsm-text-on-dark);
      --rsm-text:        var(--rsm-text-on-dark-soft);
      --rsm-text-soft:   var(--rsm-text-on-dark-soft);
      --rsm-text-faint:  var(--rsm-text-on-dark-dim);
      --rsm-line:   rgba(255, 255, 255, 0.10);
      --rsm-line-2: rgba(255, 255, 255, 0.18);
      --rsm-line-3: rgba(255, 255, 255, 0.30);
