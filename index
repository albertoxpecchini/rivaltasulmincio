      color: var(--rsm-emerald);
    }

    @supports ((-webkit-background-clip: text) or (background-clip: text)) {
      .rsm-display-1 em,
      .rsm-display-2 em,
      .rsm-h1 em,
      .rsm-display-1 em .word,
      .rsm-display-1 em .char,
      .rsm-display-2 em .word,
      .rsm-display-2 em .char,
      .rsm-h1 em .word,
      .rsm-h1 em .char,
      .rsm-festa__title em,
      .rsm-festa__title em .word,
      .rsm-festa__title em .char,
      .rsm-valli__drop em,
      .rsm-valli__drop em .word,
      .rsm-valli__drop em .char {
        background-image: linear-gradient(120deg, var(--rsm-emerald) 0%, var(--rsm-azure) 50%, var(--rsm-violet) 100%);
        background-repeat: no-repeat;
        background-size: 100% 100%;
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
        color: transparent;
      }
    }

    .rsm-kicker {
      font-family: var(--rsm-font-mono);
      font-weight: 500;
      font-size: var(--rsm-text-eyebrow);
      letter-spacing: var(--rsm-tracking-wide);
      text-transform: uppercase;
      color: var(--rsm-ink-3);
      display: inline-flex;
      align-items: center;
      gap: var(--rsm-s-2);
      margin: 0;
    }
    .rsm-kicker::before {
      content: "";
      width: 28px;
      height: 1px;
      background: currentColor;
      opacity: 0.5;
    }
    .rsm-kicker--center { justify-content: center; }
    .rsm-kicker--center::before { display: none; }

    /* gradient text accent */
    .rsm-grad {
      background: linear-gradient(120deg, var(--rsm-emerald) 0%, var(--rsm-azure) 50%, var(--rsm-violet) 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }

    /* =========================================================
       BUTTONS
       ========================================================= */
    .rsm-btn {
      position: relative;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: var(--rsm-s-3);
      min-height: 54px;
      padding: 8px 8px 8px 22px;
      border: 1px solid transparent;
      border-radius: var(--rsm-r-pill);
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-body);
      font-weight: 800;
      letter-spacing: -0.01em;
      color: #fff;
      background: var(--rsm-ink);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), 0 16px 36px rgba(11,13,20,0.18);
      transition: transform var(--rsm-dur-base) var(--rsm-ease-out),
                  background var(--rsm-dur-base) var(--rsm-ease-out),
                  box-shadow var(--rsm-dur-base) var(--rsm-ease-out);
      overflow: hidden;
      will-change: transform;
      cursor: pointer;
    }
    .rsm-btn::before {
      content: "";
      position: absolute;
      inset: -50%;
      background: radial-gradient(circle at var(--mx, 50%) var(--my, 50%),
                  rgba(255,255,255,0.22), transparent 38%);
      opacity: 0;
      transition: opacity var(--rsm-dur-base) var(--rsm-ease-out);
      pointer-events: none;
    }
    .rsm-btn > span:not(.rsm-btn-icon) { position: relative; z-index: 1; }
    .rsm-btn-icon {
      position: relative;
      z-index: 1;
      width: 38px;
      height: 38px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      color: var(--rsm-ink);
      background: #fff;
      transition: transform var(--rsm-dur-base) var(--rsm-ease-out);
      font-weight: 700;
    }
    .rsm-btn:hover {
      transform: translateY(-2px);
      background: #1a1d2c;
      box-shadow: 0 24px 56px rgba(11,13,20,0.22), inset 0 1px 0 rgba(255,255,255,0.12);
    }
    .rsm-btn:hover::before { opacity: 1; }
    .rsm-btn:hover .rsm-btn-icon { transform: translate(3px, -1px); }
    .rsm-btn:active { transform: translateY(0) scale(0.98); }
    .rsm-btn:focus-visible {
      outline: 2px solid var(--rsm-azure);
      outline-offset: 3px;
    }

    .rsm-btn--ghost {
      color: var(--rsm-ink);
      background: rgba(255,255,255,0.6);
      border-color: var(--rsm-line-2);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.7), var(--rsm-sh-sm);
      backdrop-filter: var(--rsm-blur-sm);
      -webkit-backdrop-filter: var(--rsm-blur-sm);
    }
    .rsm-btn--ghost .rsm-btn-icon { background: var(--rsm-ink); color: #fff; }
    .rsm-btn--ghost:hover {
      background: #fff;
      box-shadow: var(--rsm-sh-md);
    }

    .rsm-btn--brand {
      background: linear-gradient(120deg, var(--rsm-emerald) 0%, var(--rsm-azure) 50%, var(--rsm-violet) 100%);
      box-shadow: var(--rsm-sh-glow-violet);
    }
    .rsm-btn--brand:hover {
      filter: brightness(1.04);
      box-shadow: 0 24px 80px rgba(139, 92, 246, 0.36), 0 8px 24px rgba(74, 155, 255, 0.28);
    }
    .rsm-btn--brand .rsm-btn-icon { color: var(--rsm-violet); }

    .rsm-btn--sm { min-height: 44px; padding: 6px 6px 6px 16px; font-size: var(--rsm-text-small); }
    .rsm-btn--sm .rsm-btn-icon { width: 32px; height: 32px; }

    .rsm-button-row {
      display: flex;
      flex-wrap: wrap;
      gap: var(--rsm-s-3);
      margin-top: var(--rsm-s-6);
    }

    /* compat alias: il vecchio .button */
    .button, .button.secondary { font-family: var(--rsm-font-sans); }
    .button { all: unset; }

    /* =========================================================
       INPUT & FORM
       ========================================================= */
    .rsm-field {
      display: grid;
      gap: var(--rsm-s-2);
    }
    .rsm-field > label,
    .rsm-field-label {
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-eyebrow);
      letter-spacing: var(--rsm-tracking-wide);
      text-transform: uppercase;
      color: var(--rsm-ink-3);
      font-weight: 500;
    }
    .rsm-input,
    .rsm-textarea,
    .rsm-select {
      width: 100%;
      min-height: 56px;
      padding: 0 22px;
      border: 1px solid var(--rsm-line-2);
      border-radius: var(--rsm-r-pill);
      background: rgba(255,255,255,0.78);
      color: var(--rsm-ink);
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-body);
      font-weight: 500;
      transition: border-color var(--rsm-dur-fast) var(--rsm-ease-out),
                  box-shadow var(--rsm-dur-fast) var(--rsm-ease-out),
                  background var(--rsm-dur-fast) var(--rsm-ease-out);
      backdrop-filter: var(--rsm-blur-sm);
      -webkit-backdrop-filter: var(--rsm-blur-sm);
    }
    .rsm-textarea {
      min-height: 144px;
      padding: 16px 22px;
      border-radius: var(--rsm-r-xl);
      resize: vertical;
    }
    .rsm-input::placeholder,
    .rsm-textarea::placeholder { color: var(--rsm-ink-4); }

    .rsm-input:hover,
    .rsm-textarea:hover { border-color: var(--rsm-line-3); }

    .rsm-input:focus,
    .rsm-textarea:focus,
    .rsm-select:focus {
      outline: none;
      border-color: var(--rsm-azure);
      background: #fff;
      box-shadow: 0 0 0 4px rgba(74, 155, 255, 0.18);
    }

    .rsm-input--lg { min-height: 64px; font-size: var(--rsm-text-body-lg); }

    .rsm-form-status {
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-small);
      color: var(--rsm-ink-3);
      margin: 0;
      min-height: 1em;
    }

    /* =========================================================
       CARDS
       ========================================================= */
    .rsm-card {
      position: relative;
      padding: var(--rsm-s-8);
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-2xl);
      background: rgba(255,255,255,0.85);
      box-shadow: var(--rsm-sh-md);
      backdrop-filter: var(--rsm-blur-sm);
      -webkit-backdrop-filter: var(--rsm-blur-sm);
      transition: transform var(--rsm-dur-base) var(--rsm-ease-out),
                  box-shadow var(--rsm-dur-base) var(--rsm-ease-out),
                  border-color var(--rsm-dur-base) var(--rsm-ease-out);
    }
    .rsm-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--rsm-sh-lg);
    }
    .rsm-card--glass {
      background: var(--rsm-glass);
      backdrop-filter: var(--rsm-blur-md);
      -webkit-backdrop-filter: var(--rsm-blur-md);
    }
    .rsm-card--flat {
      background: var(--rsm-paper);
      box-shadow: none;
    }
    .rsm-card--ink {
      background: var(--rsm-ink);
      color: #fff;
      border-color: rgba(255,255,255,0.08);
    }
    .rsm-card--ink .rsm-kicker { color: rgba(255,255,255,0.6); }

    /* =========================================================
       TAGS & BADGE & CHIP
       ========================================================= */
    .rsm-tag {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      border: 1px solid var(--rsm-line-2);
      border-radius: var(--rsm-r-pill);
      background: rgba(255,255,255,0.66);
      backdrop-filter: var(--rsm-blur-sm);
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-tiny);
      font-weight: 500;
      letter-spacing: 0.04em;
      color: var(--rsm-ink-2);
      text-transform: uppercase;
    }
    .rsm-tag--emerald { background: var(--rsm-emerald-4); border-color: rgba(31,191,125,0.30); color: #0c6c47; }
    .rsm-tag--azure   { background: var(--rsm-azure-4);   border-color: rgba(74,155,255,0.30); color: #1f4f99; }
    .rsm-tag--violet  { background: var(--rsm-violet-4);  border-color: rgba(139,92,246,0.30); color: #5b3aaa; }

    .rsm-chip {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 9px 16px;
      border: 1px solid var(--rsm-line-2);
      border-radius: var(--rsm-r-pill);
      background: rgba(255,255,255,0.7);
      backdrop-filter: var(--rsm-blur-sm);
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-small);
      font-weight: 700;
      color: var(--rsm-ink-2);
      cursor: pointer;
      transition: background var(--rsm-dur-fast), border-color var(--rsm-dur-fast), transform var(--rsm-dur-fast);
    }
    .rsm-chip:hover { background: #fff; border-color: var(--rsm-line-3); transform: translateY(-1px); }
    .rsm-chip[aria-pressed="true"], .rsm-chip.is-active, .rsm-chip.on {
      background: var(--rsm-ink);
      border-color: var(--rsm-ink);
      color: #fff;
    }

    .rsm-badge {
      display: inline-flex;
      align-items: center;
      padding: 4px 10px;
      border-radius: var(--rsm-r-pill);
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-tiny);
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      background: var(--rsm-surface);
      color: var(--rsm-ink-2);
    }
    .rsm-badge.green,
    .rsm-badge--emerald { background: var(--rsm-emerald-4); color: #0c6c47; }
    .rsm-badge--azure   { background: var(--rsm-azure-4);   color: #1f4f99; }
    .rsm-badge--violet  { background: var(--rsm-violet-4);  color: #5b3aaa; }

    /* compat alias usati dai post-card legacy */
    .badge { display: inline-flex; align-items: center; padding: 4px 10px; border-radius: var(--rsm-r-pill); font-family: var(--rsm-font-mono); font-size: var(--rsm-text-tiny); font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; background: var(--rsm-surface); color: var(--rsm-ink-2); }
    .badge.green { background: var(--rsm-emerald-4); color: #0c6c47; }
    .tag { display: inline-flex; align-items: center; padding: 5px 12px; border-radius: var(--rsm-r-pill); border: 1px solid var(--rsm-line-2); background: rgba(255,255,255,0.66); font-family: var(--rsm-font-mono); font-size: var(--rsm-text-tiny); font-weight: 500; letter-spacing: 0.04em; text-transform: uppercase; color: var(--rsm-ink-2); }

    /* =========================================================
       MODAL
       ========================================================= */
    .rsm-modal {
      position: fixed;
      inset: 0;
      z-index: var(--rsm-z-modal);
      display: grid;
      place-items: center;
      padding: var(--rsm-s-6);
      background: rgba(11, 13, 20, 0.42);
      backdrop-filter: var(--rsm-blur-md);
      -webkit-backdrop-filter: var(--rsm-blur-md);
      opacity: 0;
      visibility: hidden;
      transition: opacity var(--rsm-dur-base) var(--rsm-ease-out),
                  visibility var(--rsm-dur-base) var(--rsm-ease-out);
    }
    .rsm-modal.is-open { opacity: 1; visibility: visible; }
    .rsm-modal[hidden] { display: grid; }
    .rsm-modal__panel {
      position: relative;
      width: min(560px, 100%);
      padding: var(--rsm-s-12) var(--rsm-s-10);
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-3xl);
      background: rgba(255,255,255,0.94);
      box-shadow: var(--rsm-sh-xl);
      transform: translateY(20px) scale(0.96);
      opacity: 0;
      transition: transform var(--rsm-dur-base) var(--rsm-ease-spring),
                  opacity var(--rsm-dur-base) var(--rsm-ease-out);
    }
    .rsm-modal.is-open .rsm-modal__panel { transform: translateY(0) scale(1); opacity: 1; }
    .rsm-modal__close {
      position: absolute;
      top: 16px;
      right: 16px;
      width: 40px;
      height: 40px;
      border-radius: 50%;
      border: 1px solid var(--rsm-line-2);
      background: #fff;
      font-size: 20px;
      color: var(--rsm-ink);
      cursor: pointer;
    }
    .rsm-modal__title {
      margin: 0 0 var(--rsm-s-3);
      font-family: var(--rsm-font-display);
      font-size: clamp(1.6rem, 3vw, 2.4rem);
      font-weight: 600;
      letter-spacing: -0.03em;
    }

    /* =========================================================
       NAV — nessun override: stile gestito da /partials/topbar.css
       ========================================================= */

    /* =========================================================
       SECTION 1 — INTRO (HERO)
       ========================================================= */
    .rsm-hero {
      position: relative;
      padding: clamp(110px, 14vw, 200px) 0 clamp(64px, 8vw, 120px);
      overflow: hidden;
    }
    .rsm-hero__layout {
      display: grid;
      grid-template-columns: minmax(0, 1.05fr) minmax(360px, 1fr);
      align-items: center;
      gap: clamp(28px, 4vw, 64px);
    }
    .rsm-hero__title {
      margin: 0 0 var(--rsm-s-6);
      color: var(--rsm-ink);
    }
    .rsm-hero__main {
      min-width: 0;
      display: grid;
      gap: var(--rsm-s-5);
      align-content: start;
    }
    .rsm-hero__main .rsm-lead {
      max-width: 58ch;
    }
    .rsm-hero__media {
      position: relative;
      width: 100%;
      aspect-ratio: 4 / 5;
      max-height: clamp(360px, 56vh, 580px);
      min-height: 320px;
      margin-inline: auto;
      max-width: 520px;
      border-radius: var(--rsm-r-3xl);
      overflow: hidden;
      box-shadow: var(--rsm-sh-xl);
      isolation: isolate;
    }
    .rsm-hero__media::after {
      content: "";
      position: absolute;
      inset: 0;
      border-radius: inherit;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.45);
      pointer-events: none;
    }
    .rsm-hero__metrics {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
      gap: var(--rsm-s-5);
      margin-top: var(--rsm-s-12);
      padding-top: var(--rsm-s-7);
      border-top: 1px solid var(--rsm-line);
    }
    .rsm-metric strong {
      font-family: var(--rsm-font-display);
      font-size: clamp(2rem, 3vw, 2.8rem);
      font-weight: 600;
      line-height: 1;
      letter-spacing: -0.04em;
      display: block;
      color: var(--rsm-ink);
    }
    .rsm-metric span {
      display: block;
      margin-top: 6px;
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-tiny);
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--rsm-ink-3);
    }

    /* hero swiper (GIF) */
    .rsm-swiper--hero {
      width: 100%;
      height: 100%;
    }
    .rsm-swiper--hero .swiper-slide {
      overflow: hidden;
      border-radius: var(--rsm-r-3xl);
    }
    .rsm-swiper--hero img,
    .rsm-swiper--hero video {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
    }

    /* hero accent ring */
    .rsm-hero__accent {
      position: absolute;
      width: 140%;
      height: 140%;
      top: -20%;
      left: -20%;
      pointer-events: none;
      z-index: -1;
      background:
        radial-gradient(ellipse at 22% 30%, rgba(31,191,125,0.18), transparent 50%),
        radial-gradient(ellipse at 78% 70%, rgba(139,92,246,0.18), transparent 50%);
      animation: rsm-aurora-float 26s ease-in-out infinite;
    }

    /* =========================================================
       SECTION 2 — MAPPA DELLA PAGINA
       ========================================================= */
    .rsm-compass {
      position: relative;
    }
    .rsm-compass__inner {
      display: grid;
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.2fr);
      gap: clamp(24px, 4vw, 64px);
      padding: clamp(36px, 5vw, 64px);
      border-radius: var(--rsm-r-3xl);
      background:
        linear-gradient(135deg, rgba(255,255,255,0.92), rgba(255,255,255,0.72));
      border: 1px solid var(--rsm-line);
      backdrop-filter: var(--rsm-blur-md);
      -webkit-backdrop-filter: var(--rsm-blur-md);
      box-shadow: var(--rsm-sh-lg);
    }
    .rsm-compass__copy { display: grid; gap: var(--rsm-s-4); align-content: start; }
    .rsm-compass__nav {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--rsm-s-3);
    }
    .rsm-compass__link {
      display: flex;
      align-items: baseline;
      gap: var(--rsm-s-3);
      padding: 18px 22px;
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-xl);
      background: #fff;
      color: var(--rsm-ink);
      font-family: var(--rsm-font-sans);
      font-weight: 800;
      font-size: 1.05rem;
      letter-spacing: -0.015em;
      transition: transform var(--rsm-dur-fast), border-color var(--rsm-dur-fast), box-shadow var(--rsm-dur-fast);
      position: relative;
    }
    .rsm-compass__link strong {
      font-family: var(--rsm-font-mono);
      font-weight: 500;
      font-size: 0.78rem;
      letter-spacing: 0.16em;
      color: var(--rsm-ink-4);
    }
    .rsm-compass__link span { flex: 1; }
    .rsm-compass__link::after {
      content: "→";
      font-family: var(--rsm-font-mono);
      color: var(--rsm-ink-4);
      transition: transform var(--rsm-dur-fast), color var(--rsm-dur-fast);
    }
    .rsm-compass__link:hover {
      transform: translateY(-2px);
      border-color: var(--rsm-ink);
      box-shadow: var(--rsm-sh-md);
    }
    .rsm-compass__link:hover::after { transform: translateX(4px); color: var(--rsm-ink); }
    .rsm-compass__link:nth-child(1):hover { box-shadow: var(--rsm-sh-glow-emerald); }
    .rsm-compass__link:nth-child(2):hover { box-shadow: var(--rsm-sh-glow-azure); }
    .rsm-compass__link:nth-child(3):hover { box-shadow: var(--rsm-sh-glow-violet); }
    .rsm-compass__link:nth-child(4):hover { box-shadow: var(--rsm-sh-glow-emerald); }
    .rsm-compass__link:nth-child(5):hover { box-shadow: var(--rsm-sh-glow-azure); }
    .rsm-compass__link:nth-child(6):hover { box-shadow: var(--rsm-sh-glow-violet); }

    .rsm-compass__meta {
      display: flex;
      flex-wrap: wrap;
      gap: var(--rsm-s-2);
      margin-top: var(--rsm-s-3);
    }

    /* =========================================================
       SECTION 3 — FESTA DEL PESCE
       ========================================================= */
    .rsm-festa {
      position: relative;
      padding: clamp(80px, 10vw, 160px) 0;
    }
    .rsm-festa__head {
      display: grid;
      grid-template-columns: minmax(0, 1.3fr) minmax(280px, 1fr);
      gap: clamp(32px, 4vw, 64px);
      align-items: end;
      margin-bottom: var(--rsm-s-12);
    }
    .rsm-festa__title {
      font-family: var(--rsm-font-display);
      font-size: clamp(2.2rem, 5vw, 4.6rem);
      font-weight: 600;
      line-height: 0.96;
      letter-spacing: -0.04em;
      margin: var(--rsm-s-4) 0 var(--rsm-s-5);
    }
    .rsm-festa__title em {
    }
    .festa-pulse,
    .rsm-festa__pulse {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--rsm-emerald);
      box-shadow: 0 0 0 0 rgba(31,191,125, 0.6);
      animation: rsm-pulse 2s var(--rsm-ease-out) infinite;
      display: inline-block;
      margin-right: 6px;
    }
    @keyframes rsm-pulse {
      0%   { box-shadow: 0 0 0 0 rgba(31,191,125, 0.55); }
      70%  { box-shadow: 0 0 0 14px rgba(31,191,125, 0); }
      100% { box-shadow: 0 0 0 0 rgba(31,191,125, 0); }
    }

    .rsm-festa__poster {
      position: relative;
      width: 100%;
      max-width: 380px;
      aspect-ratio: 3 / 4;
      max-height: clamp(320px, 48vh, 480px);
      margin-left: auto;
      border-radius: var(--rsm-r-2xl);
      overflow: visible;
      box-shadow: var(--rsm-sh-xl);
    }
    .rsm-festa__poster img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      object-position: center;
      border-radius: inherit;
    }
    .rsm-festa__badge {
      position: absolute;
      bottom: -22px;
      right: -16px;
      width: clamp(86px, 12vw, 110px);
      height: clamp(86px, 12vw, 110px);
      border-radius: 50%;
      display: grid;
      place-items: center;
      text-align: center;
      font-family: var(--rsm-font-display);
      background: #fff;
      border: 1px solid var(--rsm-line);
      box-shadow: var(--rsm-sh-glow-violet);
      animation: rsm-spin 32s linear infinite;
    }
    .rsm-festa__badge strong {
      font-size: clamp(1.9rem, 3vw, 2.6rem);
      line-height: 1;
      font-weight: 600;
      background: linear-gradient(120deg, var(--rsm-emerald), var(--rsm-azure), var(--rsm-violet));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .rsm-festa__badge span {
      font-family: var(--rsm-font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--rsm-ink-3);
      margin-top: 4px;
      display: block;
    }
    @keyframes rsm-spin {
      to { transform: rotate(360deg); }
    }

    .rsm-festa__dates {
      display: grid;
      grid-template-columns: repeat(7, minmax(0, 1fr));
      gap: var(--rsm-s-3);
      margin: var(--rsm-s-10) 0 var(--rsm-s-12);
      padding: var(--rsm-s-6);
      border-radius: var(--rsm-r-2xl);
      background: rgba(255,255,255,0.72);
      backdrop-filter: var(--rsm-blur-md);
      border: 1px solid var(--rsm-line);
      box-shadow: var(--rsm-sh-md);
    }
    .rsm-festa__day,
    .festa-day {
      display: grid;
      place-items: center;
      gap: 4px;
      padding: 14px 8px;
      border-radius: var(--rsm-r-md);
      background: rgba(255,255,255,0.6);
      transition: background var(--rsm-dur-fast), transform var(--rsm-dur-fast);
    }
    .rsm-festa__day:hover,
    .festa-day:hover { background: #fff; transform: translateY(-2px); }
    .rsm-festa__day strong,
    .festa-day strong {
      font-family: var(--rsm-font-display);
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--rsm-ink);
    }
    .rsm-festa__day span,
    .festa-day span {
      font-family: var(--rsm-font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--rsm-ink-3);
    }
    .rsm-festa__day-divider {
      align-self: stretch;
      width: 1px;
      background: var(--rsm-line-2);
      margin: 0 auto;
    }

    .rsm-festa__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.7fr) minmax(0, 1fr);
      gap: clamp(20px, 3vw, 40px);
    }
    .rsm-festa__menu-list {
      list-style: none;
      padding: 0;
      margin: var(--rsm-s-5) 0 0;
      display: grid;
      gap: var(--rsm-s-2);
    }
    .rsm-festa__menu-list li {
      display: grid;
      grid-template-columns: 56px 1fr auto;
      align-items: center;
      gap: var(--rsm-s-4);
      padding: 14px 18px;
      border-radius: var(--rsm-r-lg);
      background: rgba(255,255,255,0.6);
      border: 1px solid var(--rsm-line);
      transition: transform var(--rsm-dur-fast), background var(--rsm-dur-fast), border-color var(--rsm-dur-fast);
    }
    .rsm-festa__menu-list li:hover {
      background: #fff;
      transform: translateX(4px);
      border-color: var(--rsm-line-2);
    }
    .rsm-festa__menu-num {
      font-family: var(--rsm-font-mono);
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      color: var(--rsm-ink-4);
    }
    .rsm-festa__menu-name {
      font-family: var(--rsm-font-sans);
      font-weight: 700;
      color: var(--rsm-ink);
    }
    .rsm-festa__menu-name em {
      font-style: italic;
      color: var(--rsm-violet);
    }
    .rsm-festa__menu-tag {
      font-family: var(--rsm-font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--rsm-ink-3);
    }

    .rsm-festa__wines ul {
      list-style: none;
      padding: 0;
      margin: var(--rsm-s-5) 0 0;
      display: grid;
      gap: var(--rsm-s-2);
    }
    .rsm-festa__wines li {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 16px;
      border-bottom: 1px dashed var(--rsm-line-2);
    }
    .rsm-festa__wines li strong { font-weight: 800; }
    .rsm-festa__wines li span { color: var(--rsm-ink-3); }

    .rsm-festa__foot {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--rsm-s-5);
      margin-top: var(--rsm-s-12);
    }

    /* =========================================================
       SECTION 4 — EVENTI (NEWS / Supabase)
       ========================================================= */
    .rsm-events { position: relative; }

    .news-filter-row,
    .rsm-events__filters {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: var(--rsm-s-8);
    }
    .news-filter-chip {
      display: inline-flex;
      align-items: center;
      padding: 9px 16px;
      border: 1px solid var(--rsm-line-2);
      border-radius: var(--rsm-r-pill);
      background: rgba(255,255,255,0.7);
      backdrop-filter: var(--rsm-blur-sm);
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-small);
      font-weight: 700;
      color: var(--rsm-ink-2);
      cursor: pointer;
      transition: all var(--rsm-dur-fast) var(--rsm-ease-out);
    }
    .news-filter-chip:hover { background: #fff; border-color: var(--rsm-line-3); transform: translateY(-1px); }
    .news-filter-chip.on {
      background: var(--rsm-ink);
      border-color: var(--rsm-ink);
      color: #fff;
    }

    .news-status {
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-small);
      color: var(--rsm-ink-3);
      margin: 0 0 var(--rsm-s-5);
    }

    .post-featured {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      gap: var(--rsm-s-8);
      align-items: center;
      padding: var(--rsm-s-6);
      margin-bottom: var(--rsm-s-8);
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-2xl);
      background: rgba(255,255,255,0.8);
      backdrop-filter: var(--rsm-blur-sm);
      box-shadow: var(--rsm-sh-md);
      transition: transform var(--rsm-dur-base), box-shadow var(--rsm-dur-base);
    }
    .post-featured:hover { transform: translateY(-3px); box-shadow: var(--rsm-sh-lg); }
    .post-featured.skeleton {
      min-height: 260px;
      background: linear-gradient(110deg, var(--rsm-surface) 30%, var(--rsm-mist) 50%, var(--rsm-surface) 70%);
      background-size: 200% 100%;
      animation: rsm-skeleton 1.6s ease infinite;
    }
    @keyframes rsm-skeleton { to { background-position: -200% 0; } }
    .post-featured__media,
    .news-card__media,
    .post-featured__media--photo,
    .news-card__media--photo {
      position: relative;
      aspect-ratio: 16 / 11;
      border-radius: var(--rsm-r-xl);
      overflow: hidden;
      background: var(--rsm-surface);
    }
    .post-featured__media .news-card__img,
    .news-card__media .news-card__img,
    .news-card__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--rsm-dur-slow) var(--rsm-ease-out);
    }
    .post-featured:hover .news-card__img,
    .post-card:hover .news-card__img { transform: scale(1.04); }

    .post-featured__body { display: grid; gap: var(--rsm-s-3); }
    .post-featured__title {
      font-family: var(--rsm-font-display);
      font-size: clamp(1.4rem, 2.4vw, 2rem);
      font-weight: 600;
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin: 0;
    }
    .post-featured__title a { color: var(--rsm-ink); transition: color var(--rsm-dur-fast); }
    .post-featured__title a:hover { color: var(--rsm-violet); }
    .post-featured__excerpt { color: var(--rsm-ink-3); line-height: 1.6; margin: 0; }
    .post-featured__footer { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .post-meta {
      display: flex; align-items: center; gap: var(--rsm-s-3);
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-tiny);
      color: var(--rsm-ink-3);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .post-meta a { color: var(--rsm-azure); transition: color var(--rsm-dur-fast); }
    .post-meta a:hover { color: var(--rsm-violet); }

    .post-card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: var(--rsm-s-5);
    }
    .post-card {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-2xl);
      overflow: hidden;
      background: rgba(255,255,255,0.85);
      backdrop-filter: var(--rsm-blur-sm);
      box-shadow: var(--rsm-sh-sm);
      transition: transform var(--rsm-dur-base), box-shadow var(--rsm-dur-base);
    }
    .post-card:hover { transform: translateY(-4px); box-shadow: var(--rsm-sh-lg); }
    .post-card__body { padding: var(--rsm-s-6); display: grid; gap: var(--rsm-s-3); }
    .post-card__title {
      font-family: var(--rsm-font-sans);
      font-size: 1.18rem;
      font-weight: 800;
      line-height: 1.25;
      letter-spacing: -0.02em;
      margin: 0;
    }
    .post-card__title a { color: var(--rsm-ink); transition: color var(--rsm-dur-fast); }
    .post-card__title a:hover { color: var(--rsm-violet); }
    .post-card__excerpt {
      color: var(--rsm-ink-3);
      font-size: var(--rsm-text-small);
      line-height: 1.55;
      margin: 0;
    }
    .post-card__footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: auto;
    }

    .btn-read {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--rsm-font-sans);
      font-weight: 800;
      color: var(--rsm-ink);
      transition: gap var(--rsm-dur-fast), color var(--rsm-dur-fast);
    }
    .btn-read:hover { gap: 10px; color: var(--rsm-violet); }

    .news-empty {
      padding: var(--rsm-s-10);
      border: 1px dashed var(--rsm-line-2);
      border-radius: var(--rsm-r-2xl);
      background: rgba(255,255,255,0.6);
      text-align: center;
      color: var(--rsm-ink-3);
    }
    .news-empty strong { display: block; color: var(--rsm-ink); font-family: var(--rsm-font-display); font-weight: 600; font-size: 1.4rem; margin-bottom: 8px; }
    .news-actions { display: flex; justify-content: flex-end; margin-top: var(--rsm-s-8); }

    /* =========================================================
       SECTION 5 — GALLERIA
       ========================================================= */
    .rsm-gallery { position: relative; }
    .rsm-gallery__stage {
      position: relative;
      border-radius: var(--rsm-r-3xl);
      overflow: hidden;
      box-shadow: var(--rsm-sh-xl);
      isolation: isolate;
    }
    .rsm-swiper {
      width: 100%;
      aspect-ratio: 16 / 9;
      max-height: clamp(280px, 56vh, 560px);
      min-height: 240px;
    }
    .rsm-swiper .swiper-slide {
      background-color: var(--rsm-surface);
      background-size: cover;
      background-position: center;
      overflow: hidden;
      position: relative;
    }
    .rsm-slide .slide-bg-blur {
      position: absolute;
      inset: -8%;
      background-size: cover;
      background-position: center;
      filter: blur(36px) saturate(1.1);
      opacity: 0.65;
      transform: scale(1.1);
    }
    .rsm-slide .slide-img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
    .rsm-swiper .swiper-button-prev,
    .rsm-swiper .swiper-button-next {
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: rgba(255,255,255,0.92);
      backdrop-filter: var(--rsm-blur-sm);
      box-shadow: var(--rsm-sh-md);
      color: var(--rsm-ink);
      transition: transform var(--rsm-dur-fast), background var(--rsm-dur-fast);
    }
    .rsm-swiper .swiper-button-prev::after,
    .rsm-swiper .swiper-button-next::after {
      font-size: 16px;
      font-weight: 800;
      color: var(--rsm-ink);
    }
    .rsm-swiper .swiper-button-prev:hover,
    .rsm-swiper .swiper-button-next:hover {
      background: #fff;
      transform: scale(1.06);
    }
    .rsm-swiper .swiper-pagination-bullet {
      background: rgba(255,255,255,0.9);
      opacity: 0.6;
    }
    .rsm-swiper .swiper-pagination-bullet-active {
      background: linear-gradient(120deg, var(--rsm-emerald), var(--rsm-azure), var(--rsm-violet));
      opacity: 1;
    }

    /* gallery scroll marquee */
    .rsm-gallery__marquee {
      margin-top: var(--rsm-s-8);
      overflow: hidden;
      mask-image: linear-gradient(90deg, transparent 0, #000 10%, #000 90%, transparent 100%);
    }
    .rsm-gallery__marquee-track {
      display: flex;
      gap: var(--rsm-s-5);
      animation: rsm-marquee 36s linear infinite;
      white-space: nowrap;
    }
    .rsm-gallery__marquee-track > span {
      font-family: var(--rsm-font-display);
      font-size: clamp(1.6rem, 3vw, 2.8rem);
      font-weight: 600;
      letter-spacing: -0.02em;
      color: var(--rsm-ink-4);
    }
    .rsm-gallery__marquee-track > span em {
      background: linear-gradient(120deg, var(--rsm-emerald), var(--rsm-azure), var(--rsm-violet));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      font-style: italic;
    }
    @keyframes rsm-marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* =========================================================
       SECTION 6 — TERRITORIO (Atlante + Valli + Esperienze)
       ========================================================= */
    .rsm-territory { position: relative; }

    .rsm-atlas-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      gap: clamp(20px, 3vw, 40px);
      margin-bottom: var(--rsm-s-16);
    }
    .rsm-atlas-photo {
      position: relative;
      width: 100%;
      aspect-ratio: 4 / 5;
      max-height: clamp(420px, 60vh, 640px);
      border-radius: var(--rsm-r-3xl);
      overflow: hidden;
      box-shadow: var(--rsm-sh-xl);
    }
    .rsm-swiper--atlas { width: 100%; height: 100%; aspect-ratio: auto; max-height: none; }
    .rsm-swiper--atlas .swiper-slide { aspect-ratio: auto; height: 100%; }
    .rsm-swiper--atlas .slide-img { object-position: center; }

    .rsm-atlas-copy {
      align-self: center;
      display: grid;
      gap: var(--rsm-s-5);
    }
    .rsm-fact-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--rsm-s-3);
      margin-top: var(--rsm-s-5);
    }
    .fact, .rsm-fact {
      padding: var(--rsm-s-5);
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-xl);
      background: rgba(255,255,255,0.78);
      backdrop-filter: var(--rsm-blur-sm);
    }
    .fact strong, .rsm-fact strong {
      font-family: var(--rsm-font-display);
      font-size: clamp(1.6rem, 2.4vw, 2.2rem);
      font-weight: 600;
      letter-spacing: -0.04em;
      line-height: 1;
      display: block;
      color: var(--rsm-ink);
    }
    .fact span, .rsm-fact span {
      display: block;
      margin-top: 8px;
      font-size: var(--rsm-text-small);
      color: var(--rsm-ink-3);
      line-height: 1.5;
    }
    .fact:nth-child(1) strong { color: var(--rsm-emerald); }
    .fact:nth-child(2) strong { color: var(--rsm-azure); }
    .fact:nth-child(3) strong { color: var(--rsm-violet); }

    /* Esperienze cards (3) */
    .rsm-xp-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--rsm-s-5);
      margin-bottom: var(--rsm-s-16);
    }
    .stack-card, .rsm-xp-card {
      position: relative;
      display: grid;
      grid-template-rows: auto 1fr;
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-2xl);
      overflow: hidden;
      background: rgba(255,255,255,0.85);
      backdrop-filter: var(--rsm-blur-sm);
      box-shadow: var(--rsm-sh-md);
      transition: transform var(--rsm-dur-base), box-shadow var(--rsm-dur-base);
    }
    .stack-card:hover, .rsm-xp-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--rsm-sh-lg);
    }
    .photo-slot, .rsm-xp-photo {
      position: relative;
      aspect-ratio: 4 / 3;
      background-image: var(--photo);
      background-size: cover;
      background-position: center;
      overflow: hidden;
    }
    .photo-slot::after, .rsm-xp-photo::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 60%, rgba(11,13,20,0.18) 100%);
    }
    .stack-card-inner, .rsm-xp-card-inner {
      display: contents;
    }
    .stack-card-copy, .rsm-xp-body {
      padding: var(--rsm-s-6);
      display: grid;
      gap: var(--rsm-s-3);
      align-content: start;
    }
    .stack-card-copy h3, .rsm-xp-body h3 {
      font-family: var(--rsm-font-sans);
      font-size: 1.3rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      margin: 0;
    }
    .stack-card-copy p, .rsm-xp-body p {
      color: var(--rsm-ink-3);
      font-size: var(--rsm-text-small);
      line-height: 1.55;
      margin: 0;
    }
    .stack-meta, .rsm-xp-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 4px;
    }
    .rsm-xp-card.is-emerald .photo-slot::before { background: linear-gradient(180deg, rgba(31,191,125,0.20), transparent 50%); content: ""; position:absolute; inset:0; mix-blend-mode: multiply; }
    .rsm-xp-card.is-azure .photo-slot::before   { background: linear-gradient(180deg, rgba(74,155,255,0.20), transparent 50%); content: ""; position:absolute; inset:0; mix-blend-mode: multiply; }
    .rsm-xp-card.is-violet .photo-slot::before  { background: linear-gradient(180deg, rgba(139,92,246,0.20), transparent 50%); content: ""; position:absolute; inset:0; mix-blend-mode: multiply; }

    /* Valli narrative */
    .rsm-valli {
      padding: clamp(40px, 5vw, 72px);
      border-radius: var(--rsm-r-3xl);
      background:
        linear-gradient(135deg, rgba(255,255,255,0.92), rgba(255,255,255,0.75));
      border: 1px solid var(--rsm-line);
      backdrop-filter: var(--rsm-blur-md);
      box-shadow: var(--rsm-sh-lg);
    }
    .rsm-valli__drop {
      font-family: var(--rsm-font-display);
      font-size: clamp(1.8rem, 3.5vw, 3rem);
      font-weight: 600;
      line-height: 1.05;
      letter-spacing: -0.035em;
      margin: 0;
      max-width: 22ch;
    }
    .rsm-valli__drop em {
    }
    .rsm-valli__row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: var(--rsm-s-5);
      margin: var(--rsm-s-10) 0;
      padding: var(--rsm-s-7) 0;
      border-top: 1px solid var(--rsm-line);
      border-bottom: 1px solid var(--rsm-line);
    }
    .rsm-valli__fact strong {
      font-family: var(--rsm-font-display);
      font-size: 2rem;
      font-weight: 600;
      letter-spacing: -0.04em;
      display: block;
    }
    .rsm-valli__fact span {
      font-family: var(--rsm-font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--rsm-ink-3);
    }
    .rsm-valli__summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--rsm-s-6);
      margin: var(--rsm-s-7) 0;
    }
    .rsm-valli__summary article p { color: var(--rsm-ink-3); line-height: 1.66; }
    .rsm-valli__summary article h3 {
      font-family: var(--rsm-font-display);
      font-weight: 600;
      font-size: 1.5rem;
      letter-spacing: -0.02em;
      margin: 0 0 12px;
    }
    .kw {
      position: relative;
      cursor: help;
      background: linear-gradient(180deg, transparent 60%, rgba(139,92,246,0.18) 60%);
      padding: 0 2px;
      border-radius: 2px;
    }

    /* =========================================================
       SECTION 7 — CONTATTI
       ========================================================= */
    .rsm-contact { position: relative; }
    .rsm-contact__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      gap: clamp(20px, 3vw, 40px);
      align-items: stretch;
    }
    .rsm-contact__map {
      border-radius: var(--rsm-r-3xl);
      overflow: hidden;
      box-shadow: var(--rsm-sh-xl);
      aspect-ratio: 4 / 3;
      max-height: clamp(320px, 50vh, 480px);
      background: var(--rsm-surface);
      margin: 0;
    }
    .rsm-contact__map .swiper,
    .rsm-contact__map .rsm-swiper {
      width: 100%;
      height: 100%;
      aspect-ratio: auto;
      max-height: none;
      min-height: 0;
    }
    .rsm-contact__map .swiper-slide { height: 100%; }
    .rsm-contact__map .swiper-slide video,
    .rsm-contact__map .swiper-slide img {
      width: 100%; height: 100%; object-fit: cover;
    }
    .rsm-contact__card {
      padding: var(--rsm-s-10);
      display: grid;
      gap: var(--rsm-s-6);
      align-content: space-between;
      border-radius: var(--rsm-r-3xl);
      background: rgba(255,255,255,0.92);
      border: 1px solid var(--rsm-line);
      box-shadow: var(--rsm-sh-md);
      backdrop-filter: var(--rsm-blur-sm);
    }
    .rsm-contact__lines { display: grid; gap: var(--rsm-s-3); }
    .rsm-contact__line {
      display: grid;
      grid-template-columns: 100px 1fr;
      gap: var(--rsm-s-4);
      padding: 12px 0;
      border-bottom: 1px solid var(--rsm-line);
    }
    .rsm-contact__line:last-child { border-bottom: none; }
    .rsm-contact__line strong {
      font-family: var(--rsm-font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--rsm-ink-3);
      align-self: center;
    }
    .rsm-contact__line a, .rsm-contact__line span {
      color: var(--rsm-ink);
      font-weight: 700;
    }
    .rsm-contact__line a { transition: color var(--rsm-dur-fast); }
    .rsm-contact__line a:hover { color: var(--rsm-violet); }

    /* Newsletter */
    .rsm-newsletter {
      margin-top: var(--rsm-s-12);
      padding: clamp(36px, 5vw, 72px);
      border-radius: var(--rsm-r-3xl);
      background:
        radial-gradient(circle at 80% 0, rgba(139,92,246,0.18), transparent 50%),
        radial-gradient(circle at 0 100%, rgba(31,191,125,0.18), transparent 50%),
        linear-gradient(135deg, var(--rsm-ink), #16182a);
      color: #fff;
      box-shadow: var(--rsm-sh-xl);
      overflow: hidden;
      position: relative;
    }
    .rsm-newsletter__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
      gap: clamp(20px, 3vw, 48px);
      align-items: end;
    }
    .rsm-newsletter h2 {
      font-family: var(--rsm-font-display);
      font-size: clamp(1.8rem, 3.4vw, 2.8rem);
      font-weight: 600;
      letter-spacing: -0.03em;
      line-height: 1.05;
      margin: var(--rsm-s-3) 0 var(--rsm-s-4);
    }
    .rsm-newsletter h2 em {
      font-style: italic;
      background: linear-gradient(120deg, var(--rsm-emerald-2), var(--rsm-azure-2), var(--rsm-violet-2));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .rsm-newsletter p { color: rgba(255,255,255,0.7); margin: 0; line-height: 1.6; }
    .rsm-newsletter .rsm-kicker { color: rgba(255,255,255,0.7); }
    .rsm-newsletter .rsm-input {
      background: rgba(255,255,255,0.14);
      border-color: rgba(255,255,255,0.18);
      color: #fff;
    }
    .rsm-newsletter .rsm-input::placeholder { color: rgba(255,255,255,0.5); }
    .rsm-newsletter .rsm-input:focus {
      background: rgba(255,255,255,0.22);
      border-color: var(--rsm-violet-2);
      box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.28);
    }
    .rsm-newsletter .rsm-form-status { color: rgba(255,255,255,0.7); }
    .rsm-newsletter .privacy-note {
      margin-top: 14px;
      color: rgba(255,255,255,0.55);
      font-size: 0.85rem;
    }
    .rsm-newsletter .privacy-note a { text-decoration: underline; }

    /* =========================================================
       BACK TO TOP
       ========================================================= */
    .back-to-top {
      position: fixed;
      bottom: 26px;
      right: 26px;
      z-index: var(--rsm-z-sticky);
      width: 52px;
      height: 52px;
      border-radius: 50%;
      display: grid;
      place-items: center;
      background: var(--rsm-ink);
      color: #fff;
      box-shadow: var(--rsm-sh-glow-violet);
      font-size: 22px;
      transition: transform var(--rsm-dur-base), background var(--rsm-dur-base);
    }
    .back-to-top:hover { transform: translateY(-3px) scale(1.05); }

    /* =========================================================
       REVEAL ANIMATIONS
       ========================================================= */
    [data-reveal] {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 760ms var(--rsm-ease-out),
                  transform 760ms var(--rsm-ease-out);
      transition-delay: var(--delay, 0ms);
    }
    [data-reveal].is-visible {
      opacity: 1;
      transform: none;
    }

    /* Splitting text */
    .char, .word { display: inline-block; will-change: transform, opacity; }

    /* Tippy custom theme */
    .tippy-box[data-theme~="rsm"] {
      background: var(--rsm-ink);
      color: #fff;
      border-radius: var(--rsm-r-md);
      box-shadow: var(--rsm-sh-lg);
      font-family: var(--rsm-font-sans);
    }
    .tippy-box[data-theme~="rsm"] .tippy-arrow { color: var(--rsm-ink); }
    .tippy-box[data-theme~="rsm"] .kw-pop-title {
      display: block;
      font-family: var(--rsm-font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--rsm-violet-2);
      margin-bottom: 6px;
    }
    .tippy-box[data-theme~="rsm"] .kw-pop-wiki { font-size: 0.92rem; line-height: 1.5; margin: 0; }
    .tippy-box[data-theme~="rsm"] .kw-pop-claude {
      margin: 8px 0 0;
      padding-top: 8px;
      border-top: 1px solid rgba(255,255,255,0.12);
      font-size: 0.86rem;
      line-height: 1.5;
      color: rgba(255,255,255,0.85);
    }
    .tippy-box[data-theme~="rsm"] .kw-pop-label {
      display: inline-block;
      margin-right: 6px;
      font-family: var(--rsm-font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--rsm-emerald-2);
    }

    /* =========================================================
       RESPONSIVE
       ========================================================= */
    @media (max-width: 980px) {
      .rsm-hero__layout {
        grid-template-columns: 1fr;
      }
      .rsm-compass__inner {
        grid-template-columns: 1fr;
      }
      .rsm-festa__head {
        grid-template-columns: 1fr;
      }
      .rsm-festa__grid {
        grid-template-columns: 1fr;
      }
      .rsm-atlas-grid {
        grid-template-columns: 1fr;
      }
      .rsm-contact__grid {
        grid-template-columns: 1fr;
      }
      .rsm-newsletter__grid {
        grid-template-columns: 1fr;
      }
      .post-featured {
        grid-template-columns: 1fr;
      }
      .rsm-festa__dates {
        grid-template-columns: repeat(3, 1fr);
      }
      .rsm-festa__day-divider { display: none; }
    }

    @media (max-width: 600px) {
      .rsm-compass__nav { grid-template-columns: 1fr; }
      .rsm-festa__dates { grid-template-columns: repeat(2, 1fr); }
      .rsm-contact__line { grid-template-columns: 1fr; }
      .rsm-contact__line strong { margin-bottom: 4px; }
      .rsm-festa__menu-list li {
        grid-template-columns: 40px 1fr;
        grid-template-rows: auto auto;
      }
      .rsm-festa__menu-tag { grid-column: 2; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.001ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.001ms !important;
        scroll-behavior: auto !important;
      }
      [data-reveal] { opacity: 1; transform: none; }
      .rsm-aurora__blob { animation: none; }
    }

    /* =========================================================
       DARK MODE compat (theme.css gestisce il resto)
       ========================================================= */
    html[data-theme="scuro"] {
      --rsm-bg: #0a0c14;
      --rsm-paper: #11141f;
      --rsm-surface: #161a27;
      --rsm-surface-2: #1e2230;
      --rsm-mist: #232636;
      --rsm-ink:    #ecedf3;
      --rsm-ink-2:  #c8cbd7;
      --rsm-ink-3:  #8d92a3;
      --rsm-ink-4:  #5d6273;
      --rsm-ink-5:  #3c4055;
      --rsm-line:   rgba(236, 237, 243, 0.08);
      --rsm-line-2: rgba(236, 237, 243, 0.16);
      --rsm-line-3: rgba(236, 237, 243, 0.28);
      --rsm-glass: rgba(20, 22, 32, 0.62);
      --rsm-glass-strong: rgba(20, 22, 32, 0.88);
      color-scheme: dark;
    }
    html[data-theme="scuro"] body { background: var(--rsm-bg); color: var(--rsm-ink); }
    html[data-theme="scuro"] .rsm-aurora::after {
      background:
        radial-gradient(circle at 50% 50%, rgba(0,0,0,0) 0%, rgba(10,12,20,0.65) 90%),
        linear-gradient(180deg, rgba(10,12,20,0.30), rgba(10,12,20,0.10));
    }
    html[data-theme="scuro"] .rsm-btn { color: var(--rsm-ink); background: var(--rsm-surface-2); }
    html[data-theme="scuro"] .rsm-btn-icon { background: var(--rsm-bg); color: var(--rsm-ink); }
    html[data-theme="scuro"] .rsm-btn--ghost { background: rgba(20,22,32,0.6); color: var(--rsm-ink); }
    html[data-theme="scuro"] .rsm-btn--ghost .rsm-btn-icon { background: var(--rsm-ink); color: var(--rsm-bg); }
    /* nav-island dark mode: gestito da /partials/topbar.css */
  </style>
</head>
