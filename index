    .back-to-top {
      position: fixed;
      right: 18px;
      bottom: 18px;
      z-index: 60;
      width: 46px;
      height: 46px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: var(--marsh);
      color: var(--paper);
      box-shadow: var(--shadow);
      border: 1px solid rgba(255, 250, 240, 0.18);
      transition: transform 420ms var(--ease), background 420ms var(--ease);
    }

    .back-to-top:hover {
      transform: translateY(-3px);
      background: #1f362e;
    }

    [data-reveal] {
      opacity: 0;
      transform: translate3d(0, 36px, 0);
      transition: opacity 900ms var(--ease), transform 900ms var(--ease);
      transition-delay: var(--delay, 0ms);
    }

    [data-reveal].is-visible {
      opacity: 1;
      transform: translate3d(0, 0, 0);
    }

    .skeleton {
      position: relative;
      overflow: hidden;
      background: rgba(37, 63, 53, 0.08);
    }

    .skeleton::after {
      content: "";
      position: absolute;
      inset: 0;
      transform: translateX(-100%);
      background: linear-gradient(90deg, transparent, rgba(255, 250, 240, 0.42), transparent);
      animation: shimmer 1.6s infinite;
    }

    @keyframes shimmer {
      to { transform: translateX(100%); }
    }

    @media (max-width: 1120px) {
      .nav-island {
        display: flex;
        justify-content: space-between;
      }

      .brand {
        grid-column: 1;
        grid-row: 1;
      }

      .nav-actions {
        margin-left: auto;
        justify-self: end;
      }

      .nav-links {
        grid-column: 1 / -1;
        grid-row: 2;
        position: fixed;
        inset: 78px 14px auto 14px;
        display: grid;
        grid-template-columns: 1fr;
        gap: 8px;
        padding: 16px;
        border-radius: 30px;
        background: rgba(247, 240, 228, 0.94);
        border: 1px solid rgba(255, 250, 240, 0.7);
        box-shadow: var(--shadow-strong);
        backdrop-filter: blur(24px);
        opacity: 0;
        visibility: hidden;
        transform: translateY(-10px) scale(0.98);
        transition: opacity 420ms var(--ease), transform 420ms var(--ease), visibility 420ms var(--ease);
      }

      .nav-links.open {
        opacity: 1;
        visibility: visible;
        transform: translateY(0) scale(1);
      }

      .nav-links a {
        min-height: 50px;
        justify-content: center;
      }

      .nav-toggle {
        display: inline-flex !important;
        flex: 0 0 44px;
        opacity: 1;
        visibility: visible;
      }
      .hero-layout,
      .atlas-grid,
      .experience-grid,
      .festa-head,
      .festa-grid,
      .festa-foot,
      .news-shell,
      .community-grid,
      .contact-grid,
      .newsletter-grid,
      .footer-grid {
        grid-template-columns: 1fr;
      }

      .festa-poster { justify-content: center; }
      .festa-poster-frame { transform: rotate(-1deg); width: min(100%, 420px); }
      .festa-dates-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
      .festa-day-divider {
        grid-column: 1 / -1;
        width: 100%;
        height: 1px;
        background: linear-gradient(to right, transparent, rgba(255, 250, 240, 0.34), transparent);
      }
      .festa-menu-list > li {
        grid-template-columns: 44px minmax(0, 1fr);
        row-gap: 4px;
      }
      .festa-menu-tag {
        grid-column: 2 / -1;
      }

      .sticky-copy { position: static; }
      .hero-media { order: -1; }
      .hero-photo-main { inset: 0 0 88px 72px; }
    }

    @media (max-width: 760px) {
