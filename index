      gap: var(--rsm-s-3);
      margin: var(--rsm-s-10) 0 var(--rsm-s-12);
      padding: var(--rsm-s-6);
      border-radius: var(--rsm-r-2xl);
      background: rgba(255,255,255,0.72);
      backdrop-filter: var(--rsm-blur-md);
      border: 1px solid var(--rsm-line);
      box-shadow: var(--rsm-sh-md);
    }
    .rsm-festa__day,
    .festa-day {
      display: grid;
      place-items: center;
      gap: 4px;
      padding: 14px 8px;
      border-radius: var(--rsm-r-md);
      background: rgba(255,255,255,0.6);
      transition: background var(--rsm-dur-fast), transform var(--rsm-dur-fast);
    }
    .rsm-festa__day:hover,
    .festa-day:hover { background: #fff; transform: translateY(-2px); }
    .rsm-festa__day strong,
    .festa-day strong {
      font-family: var(--rsm-font-display);
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--rsm-ink);
    }
    .rsm-festa__day span,
    .festa-day span {
      font-family: var(--rsm-font-mono);
      font-size: 0.68rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--rsm-ink-3);
    }
    .rsm-festa__day-divider {
      align-self: stretch;
      width: 1px;
      background: var(--rsm-line-2);
      margin: 0 auto;
    }

    .rsm-festa__grid {
      display: grid;
      grid-template-columns: minmax(0, 1.7fr) minmax(0, 1fr);
      gap: clamp(20px, 3vw, 40px);
    }
    .rsm-festa__menu-list {
      list-style: none;
      padding: 0;
      margin: var(--rsm-s-5) 0 0;
      display: grid;
      gap: var(--rsm-s-2);
    }
    .rsm-festa__menu-list li {
      display: grid;
      grid-template-columns: 56px 1fr auto;
      align-items: center;
      gap: var(--rsm-s-4);
      padding: 14px 18px;
      border-radius: var(--rsm-r-lg);
      background: rgba(255,255,255,0.6);
      border: 1px solid var(--rsm-line);
      transition: transform var(--rsm-dur-fast), background var(--rsm-dur-fast), border-color var(--rsm-dur-fast);
    }
    .rsm-festa__menu-list li:hover {
      background: #fff;
      transform: translateX(4px);
      border-color: var(--rsm-line-2);
    }
    .rsm-festa__menu-num {
      font-family: var(--rsm-font-mono);
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      color: var(--rsm-ink-4);
    }
    .rsm-festa__menu-name {
      font-family: var(--rsm-font-sans);
      font-weight: 700;
      color: var(--rsm-ink);
    }
    .rsm-festa__menu-name em {
      font-style: italic;
      color: var(--rsm-violet);
    }
    .rsm-festa__menu-tag {
      font-family: var(--rsm-font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--rsm-ink-3);
    }

    .rsm-festa__wines ul:not(.rsm-festa__menu-list) {
      list-style: none;
      padding: 0;
      margin: var(--rsm-s-5) 0 0;
      display: grid;
      gap: var(--rsm-s-2);
    }
    .rsm-festa__wines ul:not(.rsm-festa__menu-list) li {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      padding: 12px 16px;
      border-bottom: 1px dashed var(--rsm-line-2);
    }
    .rsm-festa__wines ul:not(.rsm-festa__menu-list) li strong { font-weight: 800; }
    .rsm-festa__wines ul:not(.rsm-festa__menu-list) li span { color: var(--rsm-ink-3); }

    .rsm-festa__foot {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: var(--rsm-s-5);
      margin-top: var(--rsm-s-12);
    }

    /* =========================================================
       SECTION 4 — EVENTI (NEWS / Supabase)
       ========================================================= */
    .rsm-events {
      position: relative;
      background:
        radial-gradient(ellipse at 100% 0%, rgba(139,92,246,0.07) 0%, transparent 50%),
        linear-gradient(180deg, rgba(74,155,255,0.04) 0%, transparent 100%);
    }

    .news-filter-row,
    .rsm-events__filters {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-bottom: var(--rsm-s-8);
    }
    .news-filter-chip {
      display: inline-flex;
      align-items: center;
      padding: 9px 16px;
      border: 1px solid var(--rsm-line-2);
      border-radius: var(--rsm-r-pill);
      background: rgba(255,255,255,0.7);
      backdrop-filter: var(--rsm-blur-sm);
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-small);
      font-weight: 700;
      color: var(--rsm-ink-2);
      cursor: pointer;
      transition: all var(--rsm-dur-fast) var(--rsm-ease-out);
    }
    .news-filter-chip:hover { background: #fff; border-color: var(--rsm-line-3); transform: translateY(-1px); }
    .news-filter-chip.on {
      background: var(--rsm-ink);
      border-color: var(--rsm-ink);
      color: #fff;
    }

    .news-status {
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-small);
      color: var(--rsm-ink-3);
      margin: 0 0 var(--rsm-s-5);
    }

    .post-featured {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(0, 1fr);
      gap: var(--rsm-s-8);
      align-items: center;
      padding: var(--rsm-s-6);
      margin-bottom: var(--rsm-s-8);
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-2xl);
      background: rgba(255,255,255,0.8);
      backdrop-filter: var(--rsm-blur-sm);
      box-shadow: var(--rsm-sh-md);
      transition: transform var(--rsm-dur-base), box-shadow var(--rsm-dur-base);
    }
    .post-featured:hover { transform: translateY(-3px); box-shadow: var(--rsm-sh-lg); }
    .post-featured.skeleton {
      min-height: 260px;
      background: linear-gradient(110deg, var(--rsm-surface) 30%, var(--rsm-mist) 50%, var(--rsm-surface) 70%);
      background-size: 200% 100%;
      animation: rsm-skeleton 1.6s ease infinite;
    }
    @keyframes rsm-skeleton { to { background-position: -200% 0; } }
    .post-featured__media,
    .news-card__media,
    .post-featured__media--photo,
    .news-card__media--photo {
      position: relative;
      aspect-ratio: 16 / 11;
      border-radius: var(--rsm-r-xl);
      overflow: hidden;
      background: var(--rsm-surface);
    }
    .post-featured__media .news-card__img,
    .news-card__media .news-card__img,
    .news-card__img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform var(--rsm-dur-slow) var(--rsm-ease-out);
    }
    .post-featured:hover .news-card__img,
    .post-card:hover .news-card__img { transform: scale(1.04); }

    .post-featured__body { display: grid; gap: var(--rsm-s-3); }
    .post-featured__title {
      font-family: var(--rsm-font-display);
      font-size: clamp(1.4rem, 2.4vw, 2rem);
      font-weight: 600;
      line-height: 1.05;
      letter-spacing: -0.03em;
      margin: 0;
    }
    .post-featured__title a { color: var(--rsm-ink); transition: color var(--rsm-dur-fast); }
    .post-featured__title a:hover { color: var(--rsm-violet); }
    .post-featured__excerpt { color: var(--rsm-ink-3); line-height: 1.6; margin: 0; }
    .post-featured__footer { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
    .post-meta {
      display: flex; align-items: center; gap: var(--rsm-s-3);
      font-family: var(--rsm-font-mono);
      font-size: var(--rsm-text-tiny);
      color: var(--rsm-ink-3);
      letter-spacing: 0.04em;
      text-transform: uppercase;
    }
    .post-meta a { color: var(--rsm-azure); transition: color var(--rsm-dur-fast); }
    .post-meta a:hover { color: var(--rsm-violet); }

    .post-card-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: var(--rsm-s-5);
    }
    .post-card {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-2xl);
      overflow: hidden;
      background: rgba(255,255,255,0.85);
      backdrop-filter: var(--rsm-blur-sm);
      box-shadow: var(--rsm-sh-sm);
      transition: transform var(--rsm-dur-base), box-shadow var(--rsm-dur-base);
    }
    .post-card:hover { transform: translateY(-4px); box-shadow: var(--rsm-sh-lg); }
    .post-card__body { padding: var(--rsm-s-6); display: grid; gap: var(--rsm-s-3); }
    .post-card__title {
      font-family: var(--rsm-font-sans);
      font-size: 1.18rem;
      font-weight: 800;
      line-height: 1.25;
      letter-spacing: -0.02em;
      margin: 0;
    }
    .post-card__title a { color: var(--rsm-ink); transition: color var(--rsm-dur-fast); }
    .post-card__title a:hover { color: var(--rsm-violet); }
    .post-card__excerpt {
      color: var(--rsm-ink-3);
      font-size: var(--rsm-text-small);
      line-height: 1.55;
      margin: 0;
    }
    .post-card__footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      margin-top: auto;
    }

    .btn-read {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-family: var(--rsm-font-sans);
      font-weight: 800;
      color: var(--rsm-ink);
      transition: gap var(--rsm-dur-fast), color var(--rsm-dur-fast);
    }
    .btn-read:hover { gap: 10px; color: var(--rsm-violet); }

    .news-empty {
      padding: var(--rsm-s-10);
      border: 1px dashed var(--rsm-line-2);
      border-radius: var(--rsm-r-2xl);
      background: rgba(255,255,255,0.6);
      text-align: center;
      color: var(--rsm-ink-3);
    }
    .news-empty strong { display: block; color: var(--rsm-ink); font-family: var(--rsm-font-display); font-weight: 600; font-size: 1.4rem; margin-bottom: 8px; }
    .news-actions { display: flex; justify-content: flex-end; margin-top: var(--rsm-s-8); }

    /* =========================================================
       SECTION 5 — GALLERIA
       ========================================================= */
    .rsm-gallery {
      position: relative;
      background:
        radial-gradient(ellipse at 50% 0%, rgba(74,155,255,0.06) 0%, transparent 50%),
        linear-gradient(180deg, rgba(139,92,246,0.03) 0%, transparent 100%);
    }
    .rsm-gallery__stage {
      position: relative;
      border-radius: var(--rsm-r-3xl);
      overflow: hidden;
      box-shadow: var(--rsm-sh-xl);
      isolation: isolate;
    }
    /* gallery scroll marquee */
    .rsm-gallery__marquee {
      margin-top: var(--rsm-s-8);
      overflow: hidden;
      mask-image: linear-gradient(90deg, transparent 0, #000 10%, #000 90%, transparent 100%);
    }
    .rsm-gallery__marquee-track {
      display: flex;
      gap: var(--rsm-s-5);
      animation: rsm-marquee 36s linear infinite;
      white-space: nowrap;
    }
    .rsm-gallery__marquee-track > span {
      font-family: var(--rsm-font-display);
      font-size: clamp(1.6rem, 3vw, 2.8rem);
      font-weight: 600;
      letter-spacing: -0.02em;
      color: var(--rsm-ink-4);
    }
    .rsm-gallery__marquee-track > span em {
      background: linear-gradient(120deg, var(--rsm-emerald), var(--rsm-azure), var(--rsm-violet));
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      font-style: italic;
    }
    @keyframes rsm-marquee {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* =========================================================
       FRAME KIT — CORNICI SOBRIE + DIVISORIE LEGGERE
       ========================================================= */
    .rsm-frame-kit {
      --rsm-frame-radius: var(--rsm-r-2xl);
      --rsm-frame-bg: rgba(255,255,255,0.03);
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-frame-radius);
      background: var(--rsm-frame-bg);
      box-shadow: inset 0 1px 0 rgba(255,255,255,0.04);
    }
    .rsm-frame-kit--pad {
      padding: clamp(16px, 2.3vw, 28px);
    }
    .rsm-frame-kit--soft {
      --rsm-frame-radius: var(--rsm-r-xl);
    }
    .rsm-divider-kit > * + * {
      padding-top: var(--rsm-s-4);
      border-top: 1px solid var(--rsm-line);
    }

    .rsm-compass__inner.rsm-frame-kit > .rsm-compass__copy {
      padding-right: clamp(14px, 2vw, 26px);
      border-right: 1px solid var(--rsm-line);
    }
    .rsm-compass__inner.rsm-frame-kit > .rsm-compass__nav {
      padding-left: clamp(14px, 2vw, 26px);
    }

    .rsm-newsletter__grid.rsm-frame-kit > :first-child {
      padding-right: clamp(14px, 2vw, 26px);
      border-right: 1px solid var(--rsm-line);
    }
    .rsm-newsletter__grid.rsm-frame-kit > :last-child {
      padding-left: clamp(14px, 2vw, 26px);
    }

    /* =========================================================
       SECTION 6 — TERRITORIO (Atlante + Valli + Esperienze)
       ========================================================= */
    .rsm-territory {
      position: relative;
      background: transparent;
      border-top: 1px solid var(--rsm-line);
      border-bottom: 1px solid var(--rsm-line);
    }

    .rsm-territory .rsm-section-head {
      max-width: 980px;
    }

    .rsm-atlas-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: clamp(20px, 2.8vw, 34px);
      align-items: start;
      margin-bottom: var(--rsm-s-10);
    }
    .rsm-atlas-photo {
      position: relative;
      width: 100%;
      aspect-ratio: 4 / 5;
      max-height: clamp(420px, 58vh, 620px);
      border-radius: var(--rsm-r-2xl);
      overflow: hidden;
      border: 1px solid var(--rsm-line);
      background: rgba(255,255,255,0.03);
    }
    .rsm-atlas-copy {
      display: grid;
      gap: var(--rsm-s-4);
      align-content: start;
    }
    .rsm-atlas-note {
      margin: 0;
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-body);
      line-height: 1.68;
      color: var(--rsm-text);
    }
    .rsm-atlas-note strong {
      color: var(--rsm-text-strong);
      font-weight: 700;
    }
    .rsm-atlas-guide {
      margin: 0;
      font-family: var(--rsm-font-mono);
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--rsm-ink-4);
    }
    .rsm-atlas-bullets {
      list-style: none;
      margin: 0;
      padding: 0;
      display: grid;
      gap: 10px;
    }
    .rsm-atlas-bullets li {
      display: grid;
      grid-template-columns: 34px minmax(0, 1fr);
      gap: 10px;
      align-items: start;
    }
    .rsm-atlas-bullets li > span {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 28px;
      height: 28px;
      border-radius: 999px;
      font-family: var(--rsm-font-mono);
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      border: 1px solid var(--rsm-line);
      color: var(--rsm-ink-3);
    }
    .rsm-atlas-bullets p {
      margin: 0;
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-small);
      line-height: 1.62;
      color: var(--rsm-text);
    }
    .rsm-territory-stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
      gap: var(--rsm-s-3);
    }
    .rsm-territory-stat {
      padding: var(--rsm-s-4);
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-lg);
      background: rgba(255,255,255,0.03);
    }
    .rsm-territory-stat strong {
      display: block;
      font-family: var(--rsm-font-sans);
      font-size: clamp(1.45rem, 2vw, 1.9rem);
      font-weight: 800;
      line-height: 1;
      letter-spacing: -0.02em;
      color: var(--rsm-text-strong);
    }
    .rsm-territory-stat span {
      display: block;
      margin-top: 8px;
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-small);
      line-height: 1.5;
      color: var(--rsm-text-soft);
    }

    .rsm-xp-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: var(--rsm-s-5);
      margin-bottom: var(--rsm-s-8);
    }
    .stack-card, .rsm-xp-card {
      position: relative;
      display: grid;
      grid-template-rows: auto 1fr;
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-xl);
      overflow: hidden;
      background: rgba(255,255,255,0.03);
      transition: transform var(--rsm-dur-base), box-shadow var(--rsm-dur-base);
    }
    .stack-card:hover, .rsm-xp-card:hover {
      transform: translateY(-2px);
    }
    .photo-slot, .rsm-xp-photo {
      position: relative;
      aspect-ratio: 4 / 3;
      background-image: var(--photo);
      background-size: cover;
      background-position: center;
      overflow: hidden;
    }
    .photo-slot::after, .rsm-xp-photo::after {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(180deg, transparent 52%, rgba(11,13,20,0.22) 100%);
    }
    .stack-card-copy, .rsm-xp-body {
      padding: var(--rsm-s-6);
      display: grid;
      gap: var(--rsm-s-3);
      align-content: start;
      border-top: 1px solid var(--rsm-line);
    }
    .rsm-xp-step {
      margin: 0;
      font-family: var(--rsm-font-mono);
      font-size: 0.64rem;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--rsm-ink-3);
    }
    .stack-card-copy h3, .rsm-xp-body h3 {
      margin: 0;
      font-family: var(--rsm-font-sans);
      font-size: 1.26rem;
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--rsm-text-strong);
    }
    .stack-card-copy p, .rsm-xp-body p {
      margin: 0;
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-small);
      line-height: 1.62;
      color: var(--rsm-text);
    }
    .stack-meta, .rsm-xp-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 4px;
    }

    .rsm-valli {
      padding: 0;
      margin-top: var(--rsm-s-8);
      background: transparent;
      border: 1px solid var(--rsm-line);
      border-radius: var(--rsm-r-2xl);
      color: var(--rsm-text-strong);
      overflow: hidden;
    }
    .rsm-valli-frame {
      padding: clamp(22px, 3.6vw, 42px);
      display: grid;
      gap: var(--rsm-s-6);
    }
    .rsm-valli__drop {
      margin: 0;
      max-width: 42ch;
      font-family: var(--rsm-font-sans);
      font-size: clamp(1.28rem, 2.2vw, 1.95rem);
      font-weight: 700;
      line-height: 1.3;
      letter-spacing: -0.012em;
      color: var(--rsm-text-strong);
    }
    .rsm-valli__drop em {
      font-family: var(--rsm-font-display);
      font-style: italic;
      font-weight: 520;
    }
    .rsm-valli__drop .word {
      display: inline-block;
      padding-bottom: 0.04em;
    }
    .rsm-valli__row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
      gap: var(--rsm-s-4);
      padding: var(--rsm-s-5) 0;
      border-top: 1px solid var(--rsm-line);
      border-bottom: 1px solid var(--rsm-line);
    }
    .rsm-valli__fact strong {
      display: block;
      font-family: var(--rsm-font-sans);
      font-size: clamp(1.4rem, 2vw, 1.9rem);
      font-weight: 800;
      letter-spacing: -0.02em;
      color: var(--rsm-text-strong);
    }
    .rsm-valli__fact span {
      display: block;
      margin-top: 7px;
      font-family: var(--rsm-font-sans);
      font-size: 0.72rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--rsm-text-soft);
    }
    .rsm-valli__summary {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: var(--rsm-s-5);
    }
    .rsm-valli__summary article {
      padding-top: var(--rsm-s-3);
      border-top: 1px solid var(--rsm-line);
    }
    .rsm-valli__summary article h3 {
      margin: 0 0 12px;
      font-family: var(--rsm-font-sans);
      font-size: 1.14rem;
      font-weight: 800;
      letter-spacing: -0.01em;
      color: var(--rsm-text-strong);
    }
    .rsm-valli__summary article p {
      margin: 0;
      font-family: var(--rsm-font-sans);
      font-size: var(--rsm-text-small);
      line-height: 1.64;
      color: var(--rsm-text);
    }

    @media (max-width: 980px) {
