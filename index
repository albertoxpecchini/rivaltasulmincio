/* ── Nav auth state ───────────────────────────────────────────────── */
(function() {
  if(typeof SUPABASE_URL==='undefined'||SUPABASE_URL.includes('your-project')) return;
  const _sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  const nav = document.getElementById('nav-auth');
  if(!nav) return;

  let outsideCloseBound = false;

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function closeDropdown() {
    document.getElementById('profileDropdown')?.classList.remove('open');
    document.getElementById('profileBtn')?.setAttribute('aria-expanded', 'false');
  }

  function buildUserMenu(username, emoji, color) {
    const safe = escapeHtml(username);
    const profileHref = 'profile?u=' + encodeURIComponent(username);
    const path = window.location.pathname;

    const isProfile   = path.includes('profile');
    const isDashboard = path.includes('me');
    const isWrite     = path.includes('write');
    const isOwnProfile = isProfile &&
      new URLSearchParams(window.location.search).get('u') === username;

    const cls = (condition, extra) =>
      condition ? ` class="active${extra ? ' ' + extra : ''}"` : (extra ? ` class="${extra}"` : '');

    const editItem = isOwnProfile
      ? `<a href="modifica-profilo?u=${encodeURIComponent(username)}" role="menuitem">✏️&nbsp; Modifica profilo</a>`
      : '';

    return `
      <div class="profile-menu" id="profileMenu">
        <button class="profile-btn" id="profileBtn" aria-haspopup="true" aria-expanded="false">
          <span class="profile-avatar" style="background:${color}">${emoji}</span>
          @${safe}
        </button>
        <div class="profile-dropdown" id="profileDropdown" role="menu" aria-label="Menu navigazione">
          <div class="profile-dropdown__section-title">Navigazione</div>
          <a href="${profileHref}" role="menuitem"${cls(isProfile)}>👤&nbsp; Profilo</a>
          <a href="me" role="menuitem"${cls(isDashboard)}>📊&nbsp; Dashboard</a>
          ${editItem}
          <a href="write" role="menuitem"${cls(isWrite, 'item-primary')}>✍&nbsp; Scrivi</a>
          <div class="profile-dropdown__sep"></div>
          <button data-action="logout" class="danger" role="menuitem">🚪&nbsp; Esci</button>
        </div>
      </div>`;
  }

  function bindMenuActions() {
    const menu = document.getElementById('profileMenu');
    const btn = document.getElementById('profileBtn');
    const dd = document.getElementById('profileDropdown');
    if(!menu || !btn || !dd) return;

    btn.addEventListener('click', (event) => {
      event.stopPropagation();
      const open = dd.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });

    dd.querySelectorAll('[data-action="logout"]').forEach((logoutBtn) => {
      logoutBtn.addEventListener('click', async () => {
        await _sb.auth.signOut();
        window.location.reload();
      });
    });

    dd.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        closeDropdown();
      });
    });

    if(!outsideCloseBound) {
      document.addEventListener('click', (event) => {
        const activeMenu = document.getElementById('profileMenu');
        if(!activeMenu) return;
        if(activeMenu.contains(event.target)) return;
        closeDropdown();
      }, { capture: true });

      document.addEventListener('keydown', (event) => {
        if(event.key === 'Escape') closeDropdown();
      });

      outsideCloseBound = true;
    }
  }

  async function renderAuth(session) {
    if(session) {
      const {data:p} = await _sb.from('profiles').select('username,avatar_emoji,avatar_color').eq('id',session.user.id).single();
      const emoji = p?.avatar_emoji || '👤';
      const color = p?.avatar_color || '#1F6F8B';
      const username = p?.username || session.user.email?.split('@')[0] || 'profilo';

      nav.innerHTML = buildUserMenu(username, emoji, color);
      bindMenuActions();

    } else {
      nav.innerHTML = `<a href="login" class="nav-accedi-btn">Accedi</a>`;
    }
  }

  _sb.auth.onAuthStateChange((_event, session) => { renderAuth(session); });
  _sb.auth.getSession().then(({data:{session}}) => renderAuth(session));
})();

