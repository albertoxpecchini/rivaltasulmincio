      color: var(--rsm-ink-3) !important;
    }
    .rsm-hero .rsm-kicker::before { display: none !important; }

    .rsm-hero .rsm-kicker .festa-pulse {
      width: 7px;
      height: 7px;
      background: var(--rsm-emerald);
      box-shadow: 0 0 0 4px rgba(31, 191, 125, 0.18);
      animation: rsm-edit-pulse 2.6s ease-in-out infinite;
    }

    .rsm-hero__title {
      font-family: 'Syne', 'Cabinet Grotesk', system-ui, sans-serif !important;
      font-weight: 700 !important;
      letter-spacing: -0.05em !important;
      line-height: 0.94 !important;
    }

    .rsm-hero__title em,
    .rsm-hero__title .rsm-edit-em {
      font-style: italic;
      font-family: 'Fraunces', Georgia, serif !important;
      font-weight: 500 !important;
      background: linear-gradient(95deg, var(--rsm-emerald) 0%, var(--rsm-azure) 50%, var(--rsm-violet) 100%);
      background-size: 220% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent !important;
      animation: rsm-edit-grad-flow 9s ease-in-out infinite alternate;
    }

    .rsm-hero__main .rsm-lead {
      font-family: 'Space Grotesk', system-ui, sans-serif;
      font-size: clamp(1.05rem, 1.2vw, 1.18rem);
      line-height: 1.62;
    }

    /* Hero metrics — premium stagger reveal */
    .rsm-hero__metrics {
      gap: clamp(20px, 2.5vw, 32px) !important;
    }
    .rsm-metric {
      position: relative;
      padding: 14px 0 0;
      border-top: 0;
      opacity: 0;
      transform: translateY(20px);
      transition:
        opacity 700ms var(--rsm-edit-ease),
        transform 700ms var(--rsm-edit-ease);
    }
    .rsm-metric::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      width: 36px;
      height: 2px;
      border-radius: 2px;
      background: var(--rsm-edit-grad);
      transform: scaleX(0);
      transform-origin: left;
      transition: transform 720ms var(--rsm-edit-ease) 220ms;
    }
    .rsm-hero__main.is-visible .rsm-metric { opacity: 1; transform: translateY(0); }
    .rsm-hero__main.is-visible .rsm-metric::before { transform: scaleX(1); }
    .rsm-hero__main.is-visible .rsm-metric:nth-child(1) { transition-delay: 360ms; }
    .rsm-hero__main.is-visible .rsm-metric:nth-child(2) { transition-delay: 440ms; }
    .rsm-hero__main.is-visible .rsm-metric:nth-child(3) { transition-delay: 520ms; }
    .rsm-hero__main.is-visible .rsm-metric:nth-child(4) { transition-delay: 600ms; }
    .rsm-hero__main.is-visible .rsm-metric:nth-child(1)::before { transition-delay: 540ms; }
    .rsm-hero__main.is-visible .rsm-metric:nth-child(2)::before { transition-delay: 620ms; }
    .rsm-hero__main.is-visible .rsm-metric:nth-child(3)::before { transition-delay: 700ms; }
    .rsm-hero__main.is-visible .rsm-metric:nth-child(4)::before { transition-delay: 780ms; }

    .rsm-metric strong {
      font-family: 'Syne', system-ui, sans-serif !important;
      font-weight: 800 !important;
      font-size: clamp(2.2rem, 3.4vw, 3.2rem) !important;
      letter-spacing: -0.05em !important;
      line-height: 0.96 !important;
    }
    .rsm-metric span {
      font-family: 'Space Grotesk', system-ui, sans-serif !important;
      font-size: 0.7rem !important;
      font-weight: 500 !important;
      letter-spacing: 0.18em !important;
      color: var(--rsm-ink-4) !important;
    }

    /* Hero media (Swiper GIF) — refined ring */
    .rsm-hero__media {
      box-shadow:
        0 32px 80px rgba(11, 13, 20, 0.16),
        0 12px 24px rgba(11, 13, 20, 0.08),
        inset 0 0 0 1px rgba(255, 255, 255, 0.5);
    }

    /* ═════════════════ MARQUEE BAND ═════════════════ */
    .rsm-edit-band {
      position: relative;
      width: 100vw;
      margin-left: calc(-50vw + 50%);
      padding: clamp(16px, 2vw, 22px) 0;
      border-top: 1px solid rgba(11, 13, 20, 0.08);
      border-bottom: 1px solid rgba(11, 13, 20, 0.08);
      overflow: hidden;
      background: linear-gradient(90deg, rgba(255, 255, 255, 0) 0%, rgba(247, 250, 254, 0.68) 50%, rgba(255, 255, 255, 0) 100%);
      -webkit-mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
      mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
    }
    .rsm-edit-band-track {
      display: flex;
      gap: 0;
      width: max-content;
      animation: rsm-edit-marquee 38s linear infinite;
    }
    .rsm-edit-band:hover .rsm-edit-band-track { animation-play-state: paused; }
    .rsm-edit-band-group {
      display: inline-flex;
      align-items: center;
      gap: 28px;
      padding-right: 28px;
      font-family: 'Fraunces', Georgia, serif;
      font-style: italic;
      font-weight: 400;
      font-size: clamp(1.1rem, 1.7vw, 1.6rem);
      letter-spacing: -0.02em;
      white-space: nowrap;
      color: rgba(11, 13, 20, 0.62);
    }
    .rsm-edit-band-item { flex-shrink: 0; }
    .rsm-edit-band-dot {
      display: inline-block;
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: linear-gradient(95deg, var(--rsm-emerald), var(--rsm-azure), var(--rsm-violet));
      flex-shrink: 0;
      opacity: 0.85;
    }
    @keyframes rsm-edit-marquee {
      from { transform: translate3d(0, 0, 0); }
      to { transform: translate3d(-50%, 0, 0); }
    }

    html[data-theme="scuro"] .rsm-edit-band {
      background: linear-gradient(90deg, transparent 0%, rgba(20, 32, 48, 0.4) 50%, transparent 100%);
      border-color: rgba(150, 190, 175, 0.13);
    }
    html[data-theme="scuro"] .rsm-edit-band-group { color: rgba(214, 232, 255, 0.72); }

    /* ═════════════════ COMPASS — dark editorial glass ═════════════════ */
    .rsm-compass {
      position: relative;
      isolation: isolate;
      background:
        radial-gradient(ellipse at 14% -10%, rgba(102, 255, 214, 0.16), transparent 38%),
        radial-gradient(ellipse at 80% -8%, rgba(126, 188, 255, 0.20), transparent 42%),
        radial-gradient(ellipse at 100% 100%, rgba(196, 122, 255, 0.18), transparent 48%),
        linear-gradient(160deg, #051c2c 0%, #082649 50%, #2a1147 100%) !important;
      color: rgba(220, 234, 255, 0.78);
      width: 100vw;
      margin-left: calc(-50vw + 50%);
      overflow: hidden;
      padding: clamp(60px, 8vw, 100px) 0 !important;
      border-top: 1px solid rgba(160, 208, 255, 0.16);
      border-bottom: 1px solid rgba(160, 208, 255, 0.16);
    }

    .rsm-compass::before {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      z-index: 1;
      opacity: 0.10;
      mix-blend-mode: overlay;
      background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.55) 0.6px, transparent 1.2px);
      background-size: 3px 3px;
    }

    .rsm-compass__hairline {
      position: absolute;
      inset: 0 0 auto 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(180, 220, 255, 0.55) 30%, rgba(220, 200, 255, 0.55) 70%, transparent);
      z-index: 3;
      pointer-events: none;
    }

    .rsm-compass__aurora {
      position: absolute;
      inset: -10%;
      z-index: 0;
      pointer-events: none;
      overflow: hidden;
      --mx: 50%;
      --my: 50%;
    }
    .rsm-compass__aurora::after {
      content: "";
      position: absolute;
      inset: 0;
      background: radial-gradient(circle at var(--mx) var(--my), rgba(146, 196, 255, 0.18), transparent 38%);
      opacity: 0;
      transition: opacity 600ms ease;
    }
    .rsm-compass:hover .rsm-compass__aurora::after { opacity: 1; }
    .rsm-compass__blob {
      position: absolute;
      width: 38vmax;
      height: 38vmax;
      border-radius: 50%;
      filter: blur(110px);
      opacity: 0.30;
      animation: rsm-edit-float 30s ease-in-out infinite;
    }
    .rsm-compass__blob--a {
      top: -22vmax;
      left: -10vmax;
      background: radial-gradient(circle, rgba(46, 224, 170, 0.55), transparent 65%);
    }
    .rsm-compass__blob--b {
      bottom: -22vmax;
      right: -12vmax;
      background: radial-gradient(circle, rgba(167, 119, 255, 0.55), transparent 65%);
      animation-delay: -14s;
      animation-duration: 36s;
    }

    .rsm-compass__inner {
      position: relative;
      z-index: 2;
    }

    .rsm-compass__copy .rsm-kicker {
      font-family: 'Space Grotesk', system-ui, sans-serif !important;
      font-size: 0.72rem !important;
      letter-spacing: 0.22em !important;
      color: rgba(196, 222, 255, 0.6) !important;
    }

    .rsm-compass__copy .rsm-h1 {
      font-family: 'Syne', system-ui, sans-serif !important;
      font-weight: 700 !important;
      letter-spacing: -0.045em !important;
      color: #fff !important;
      line-height: 0.96 !important;
    }

    .rsm-compass__copy .rsm-h1 em {
      font-style: italic;
      font-family: 'Fraunces', Georgia, serif !important;
      font-weight: 500 !important;
      background: var(--rsm-edit-grad);
      background-size: 220% 100%;
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
      color: transparent !important;
      animation: rsm-edit-grad-flow 9s ease-in-out infinite alternate;
    }

    .rsm-compass__copy .rsm-lead {
      color: rgba(220, 234, 255, 0.78) !important;
    }

    .rsm-compass__meta .rsm-tag {
      background: rgba(255, 255, 255, 0.06) !important;
      border-color: rgba(180, 220, 255, 0.22) !important;
      color: rgba(232, 244, 255, 0.92) !important;
      backdrop-filter: blur(12px);
    }

    /* Compass nav — editorial typographic links */
    .rsm-compass__nav {
      gap: 8px !important;
      grid-template-columns: 1fr !important;
    }

    .rsm-compass__link {
      position: relative;
      display: grid !important;
      grid-template-columns: 44px 1fr auto !important;
      align-items: center !important;
      gap: 18px !important;
      padding: 18px 22px !important;
      border: 1px solid rgba(160, 208, 255, 0.14) !important;
      border-radius: 16px !important;
      background: rgba(255, 255, 255, 0.04) !important;
      color: rgba(232, 244, 255, 0.88) !important;
      font-family: 'Syne', system-ui, sans-serif !important;
      font-weight: 600 !important;
      font-size: 1rem !important;
      letter-spacing: -0.01em !important;
      overflow: hidden;
      isolation: isolate;
      transition:
        border-color 320ms var(--rsm-edit-ease),
        background 320ms var(--rsm-edit-ease),
        transform 320ms var(--rsm-edit-ease),
        box-shadow 320ms var(--rsm-edit-ease) !important;
    }

    .rsm-compass__link::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(135deg, rgba(146, 196, 255, 0.16), rgba(207, 156, 255, 0.10));
      opacity: 0;
      z-index: -1;
      transition: opacity 320ms var(--rsm-edit-ease);
    }

    .rsm-compass__link:hover {
      transform: translateY(-2px) !important;
      border-color: rgba(180, 220, 255, 0.4) !important;
      background: rgba(255, 255, 255, 0.07) !important;
      box-shadow: 0 18px 36px rgba(4, 10, 34, 0.32) !important;
      color: #fff !important;
    }
    .rsm-compass__link:hover::before { opacity: 1; }

    .rsm-compass__link strong {
      display: inline-grid !important;
      place-items: center !important;
      width: 36px !important;
      height: 36px !important;
      border-radius: 10px !important;
      background: rgba(146, 196, 255, 0.16) !important;
      border: 1px solid rgba(146, 196, 255, 0.18) !important;
      color: rgba(196, 222, 255, 0.96) !important;
      font-family: 'Space Grotesk', system-ui, sans-serif !important;
      font-size: 0.78rem !important;
      font-weight: 700 !important;
      letter-spacing: 0 !important;
      transition: background 320ms var(--rsm-edit-ease), color 320ms var(--rsm-edit-ease) !important;
    }
    .rsm-compass__link:hover strong {
      background: rgba(146, 196, 255, 0.28) !important;
      color: #fff !important;
    }

    .rsm-compass__link span {
      flex: 1;
    }
    .rsm-compass__link::after {
      content: "↗" !important;
      font-family: 'Space Grotesk', system-ui, sans-serif !important;
      font-size: 1.1rem !important;
      color: rgba(180, 210, 255, 0.4) !important;
      transform: translate(-4px, 4px) !important;
      opacity: 0 !important;
      transition: transform 320ms var(--rsm-edit-ease), opacity 320ms var(--rsm-edit-ease), color 320ms var(--rsm-edit-ease) !important;
    }
    .rsm-compass__link:hover::after {
      transform: translate(0, 0) !important;
      opacity: 1 !important;
      color: var(--rsm-edit-emerald) !important;
    }

    /* Disabilita le glow per-child esistenti (le sostituiamo con la nuova grammatica) */
    .rsm-compass__link:nth-child(1):hover,
    .rsm-compass__link:nth-child(2):hover,
    .rsm-compass__link:nth-child(3):hover,
    .rsm-compass__link:nth-child(4):hover,
    .rsm-compass__link:nth-child(5):hover,
    .rsm-compass__link:nth-child(6):hover {
      box-shadow: 0 18px 36px rgba(4, 10, 34, 0.32) !important;
    }

    /* 2 colonne su desktop wide */
    @media (min-width: 720px) {
      .rsm-compass__nav { grid-template-columns: 1fr 1fr !important; }
    }

    /* ═════════════════ RESPONSIVE ═════════════════ */
    @media (max-width: 760px) {
      body[data-page="home"] {
        --rsm-home-section-space: 22px !important;
      }
      .rsm-banner {
        min-height: max(440px, 100svh);
        padding-top: calc(var(--rsm-topbar-safe-offset) + 20px);
        padding-bottom: clamp(28px, 10vw, 56px);
        align-items: flex-end;
      }
      .rsm-banner__content {
        padding-inline: 20px;
        max-width: 100%;
      }
      .rsm-banner__scroll-hint {
        bottom: 18px;
      }
      .rsm-hero {
        padding-top: clamp(56px, 14vw, 88px);
        padding-bottom: clamp(36px, 10vw, 56px);
      }
      .rsm-hero__layout {
        gap: 22px;
      }
      .rsm-hero__main {
        gap: 16px;
      }
      .rsm-hero__media {
        min-height: 260px;
        max-height: 420px;
        border-radius: 28px;
      }
      .rsm-hero__metrics {
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px !important;
        margin-top: var(--rsm-s-8);
        padding-top: var(--rsm-s-5);
      }
      .rsm-metric {
        padding-top: 12px;
      }
      .rsm-edit-band {
        margin-top: 4px;
      }
      .rsm-festa {
        padding-top: clamp(52px, 14vw, 80px);
        padding-bottom: clamp(40px, 12vw, 64px);
      }
      .rsm-festa__head {
        margin-bottom: var(--rsm-s-8);
      }
      .rsm-festa__poster {
        width: min(100%, 300px);
      }
      .rsm-festa__seal {
        --seal-size: 92px;
        right: -10px;
        bottom: -14px;
      }
      .rsm-festa__dates {
        padding: var(--rsm-s-4);
        gap: var(--rsm-s-2);
      }
      .rsm-festa__day,
      .festa-day {
        padding: 12px 6px;
      }
      .rsm-festa__grid,
      .rsm-festa__foot {
        gap: var(--rsm-s-5);
      }
      .post-featured__footer,
      .post-card__footer {
        flex-direction: column;
        align-items: flex-start;
      }
      .rsm-gallery__marquee {
        margin-top: var(--rsm-s-5);
      }
      .rsm-gallery__marquee-track > span {
        font-size: clamp(1.1rem, 7vw, 1.6rem);
      }
      .rsm-atlas-photo {
        max-height: 360px;
      }
      .rsm-valli-frame {
        padding: 20px;
      }
      .rsm-valli__summary {
        grid-template-columns: 1fr;
      }
      .rsm-contact__card {
        padding: 22px;
      }
      .rsm-contact__line {
        gap: 8px;
      }
    }
    @media (max-width: 600px) {
      .rsm-banner__title {
        font-size: clamp(2.6rem, 14vw, 4.4rem) !important;
        max-width: 10ch;
        line-height: 1.02 !important;
      }
      .rsm-banner__sub { font-size: 0.96rem !important; }
      .rsm-banner__cta {
        width: 100%;
        justify-content: center;
      }
      .rsm-edit-band-group { gap: 20px; padding-right: 20px; }
    }

    /* ════════════════════════════════════════════════════════════
       FIX TYPOGRAPHY GLOBALE — Syne ovunque + no Times fallback
       ════════════════════════════════════════════════════════════ */
    .rsm-h1,
    .rsm-h2,
    .rsm-h3,
    .rsm-h4,
    .rsm-display-1,
    .rsm-display-2,
    .rsm-festa__title,
    .rsm-newsletter h2,
    .rsm-modal__title,
    .rsm-xp-card h3,
    .rsm-xp-body h3,
    .rsm-atlas-copy h3,
    .post-featured__title,
    .news-empty strong {
      font-family: 'Syne', 'Cabinet Grotesk', system-ui, -apple-system, sans-serif !important;
      font-weight: 700 !important;
      letter-spacing: -0.025em !important;
      line-height: 1.04 !important;
      text-wrap: balance;
      word-spacing: 0.02em;
    }

    /* Em italic accents — Fraunces con gradient, padding anti-clip */
    .rsm-h1 em,
    .rsm-h2 em,
    .rsm-h3 em,
    .rsm-display-1 em,
    .rsm-display-2 em,
    .rsm-festa__title em,
    .rsm-newsletter h2 em,
    .rsm-banner__title em,
    .rsm-hero__title em,
    .rsm-compass__copy .rsm-h1 em {
      font-family: 'Fraunces', Georgia, serif !important;
      font-style: italic !important;
      font-weight: 500 !important;
      padding: 0 0.06em !important;
      margin: 0 -0.02em !important;
      display: inline-block;
    }

    /* Titoli h1 — più aria, no taglio */
    .rsm-h1 {
      font-size: clamp(2rem, 4vw, 3.6rem) !important;
      letter-spacing: -0.02em !important;
    }
    .rsm-h2 {
      font-size: clamp(1.5rem, 2.6vw, 2.4rem) !important;
      letter-spacing: -0.015em !important;
    }
    .rsm-h3 {
      font-size: clamp(1.2rem, 1.7vw, 1.55rem) !important;
      letter-spacing: -0.01em !important;
    }
    .rsm-festa__title {
      font-size: clamp(2rem, 4.4vw, 4rem) !important;
      letter-spacing: -0.025em !important;
    }
    .rsm-banner__title {
      font-size: clamp(3rem, 9vw, 8rem) !important;
      letter-spacing: -0.04em !important;
    }
    .rsm-hero__title {
      font-size: clamp(2.2rem, 4.6vw, 4.4rem) !important;
      letter-spacing: -0.025em !important;
    }
    .rsm-compass__copy .rsm-h1 {
      font-size: clamp(1.8rem, 3.4vw, 3rem) !important;
    }

    /* Body fonts forced sans (no serif fallback ovunque) */
    .rsm-lead,
    .rsm-body,
    p:not(.rsm-kicker),
    .rsm-newsletter p,
    .rsm-newsletter label,
    .rsm-newsletter .privacy-note {
      font-family: 'Space Grotesk', 'Cabinet Grotesk', system-ui, -apple-system, sans-serif !important;
    }

    /* ════════════════════════════════════════════════════════════
       BOTTONI: zero frecce, più in rilievo
       ════════════════════════════════════════════════════════════ */
    .rsm-btn .rsm-btn-icon,
    .rsm-btn-icon {
      display: none !important;
    }
    .rsm-btn {
      min-height: 56px !important;
      padding: 0 26px !important;
      font-family: 'Syne', 'Cabinet Grotesk', system-ui, sans-serif !important;
      font-weight: 700 !important;
      letter-spacing: -0.005em !important;
      border-radius: 999px !important;
      border: 1px solid rgba(255, 255, 255, 0.22) !important;
      background: rgba(255, 255, 255, 0.12) !important;
      color: var(--rsm-text-strong) !important;
      backdrop-filter: blur(16px) saturate(135%) !important;
      -webkit-backdrop-filter: blur(16px) saturate(135%) !important;
      box-shadow:
        0 18px 38px rgba(11, 13, 20, 0.16),
        0 2px 6px rgba(11, 13, 20, 0.06),
        inset 0 1px 0 rgba(255, 255, 255, 0.26) !important;
      transition:
        transform 320ms var(--rsm-edit-ease-spring),
        box-shadow 320ms var(--rsm-edit-ease),
        background 320ms var(--rsm-edit-ease) !important;
    }
    .rsm-btn:hover {
      transform: translateY(-2px) !important;
      box-shadow:
        0 24px 54px rgba(11, 13, 20, 0.18),
        0 10px 22px rgba(74, 155, 255, 0.10),
        inset 0 1px 0 rgba(255, 255, 255, 0.32) !important;
    }
    .rsm-btn:active {
      transform: translateY(-1px) scale(0.98) !important;
    }

    .rsm-btn--brand {
      background:
        linear-gradient(180deg, rgba(255, 255, 255, 0.16), rgba(255, 255, 255, 0.06)) padding-box,
        linear-gradient(120deg, rgba(47, 224, 188, 0.95) 0%, rgba(74, 155, 255, 0.95) 52%, rgba(90, 129, 255, 0.95) 100%) border-box !important;
      color: #07111f !important;
      text-shadow: none !important;
      box-shadow:
        0 18px 42px rgba(74, 155, 255, 0.24),
        0 10px 24px rgba(31, 191, 125, 0.12),
        0 0 0 1px rgba(255, 255, 255, 0.14),
        inset 0 1px 0 rgba(255, 255, 255, 0.34) !important;
    }
    .rsm-btn--brand:hover {
      box-shadow:
        0 26px 58px rgba(74, 155, 255, 0.28),
        0 14px 30px rgba(31, 191, 125, 0.16),
