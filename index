      background: #0b0d14 !important;
      color: #fff !important;
    }
    body[data-page="home"] .tippy-box[data-theme~="rsm"] .tippy-arrow {
      color: #0b0d14 !important;
    }

    /* Kicker "em" e link colorati restano leggibili (sono già accent) */
    body[data-page="home"] .rsm-festa__menu-name em {
      color: var(--rsm-violet-2);
    }
    body[data-page="home"] .kw {
      color: var(--rsm-text-on-dark) !important;
