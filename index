  <script>
  (function () {
    'use strict';

    var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var CATEGORY_ORDER = ['Eventi', 'Territorio', 'Vita locale', 'Avvisi', 'Richieste', 'Storie'];
    var LEGACY_TO_CANONICAL = {
      'eventi': 'Eventi',
      'territorio': 'Territorio',
      'vita locale': 'Vita locale',
      'avvisi': 'Avvisi',
      'richieste': 'Richieste',
      'storie': 'Storie',
      'il luccio': 'Storie',
      'fauna': 'Territorio',
      'ambiente': 'Territorio',
      'ecoturismo': 'Territorio',
      'storia': 'Storie'
    };
    var BADGE_COLOR_BY_CATEGORY = {
      'Eventi': 'green',
      'Territorio': 'default',
      'Vita locale': 'default',
      'Avvisi': 'green',
      'Richieste': 'green',
      'Storie': 'default'
    };

    function $(selector, root) {
      return (root || document).querySelector(selector);
    }

    function $all(selector, root) {
      return Array.prototype.slice.call((root || document).querySelectorAll(selector));
    }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function canonicalCategory(input) {
      var raw = String(input || '').trim();
      if (!raw) return '';
      var normalized = raw.toLowerCase();
      if (LEGACY_TO_CANONICAL[normalized]) return LEGACY_TO_CANONICAL[normalized];
      for (var i = 0; i < CATEGORY_ORDER.length; i += 1) {
        if (CATEGORY_ORDER[i].toLowerCase() === normalized) return CATEGORY_ORDER[i];
      }
      return raw;
    }

    function badgeColor(input) {
      return BADGE_COLOR_BY_CATEGORY[canonicalCategory(input)] || 'default';
    }

    function categoryHref(input) {
      return 'category?name=' + encodeURIComponent(canonicalCategory(input) || '');
    }

    window.RSM_CATEGORIES = {
      all: function () { return CATEGORY_ORDER.slice(); },
      canonical: canonicalCategory,
      badgeColor: badgeColor,
      categoryHref: categoryHref
    };

    function initNav() {
      var toggle = $('#navToggle');
      var nav = $('#navList');
      if (!toggle || !nav) return;

      function closeMenu() {
        nav.classList.remove('open');
        toggle.classList.remove('open');
        toggle.setAttribute('aria-expanded', 'false');
        document.body.classList.remove('menu-open');
      }

      toggle.addEventListener('click', function () {
        var open = !nav.classList.contains('open');
        nav.classList.toggle('open', open);
        toggle.classList.toggle('open', open);
        toggle.setAttribute('aria-expanded', String(open));
        document.body.classList.toggle('menu-open', open);
      });

      $all('a[href^="#"]', nav).forEach(function (link) {
        link.addEventListener('click', closeMenu);
      });

      document.addEventListener('keydown', function (event) {
        if (event.key === 'Escape') closeMenu();
      });

      var sectionIds = ['home', 'esperienze', 'galleria', 'valli', 'luccio', 'news', 'chi-siamo', 'dove-siamo', 'contatti'];
      var links = $all('a[href^="#"]', nav);
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          links.forEach(function (link) {
            link.classList.toggle('active', link.getAttribute('href') === '#' + entry.target.id);
          });
        });
      }, { rootMargin: '-42% 0px -52% 0px', threshold: 0.01 });

      sectionIds.forEach(function (id) {
        var section = document.getElementById(id);
        if (section) observer.observe(section);
      });
    }

    function initReveal() {
      var items = $all('[data-reveal]');
      if (!items.length) return;
      if (reduceMotion || !('IntersectionObserver' in window)) {
        items.forEach(function (item) { item.classList.add('is-visible'); });
        return;
      }

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.14 });

      items.forEach(function (item) { observer.observe(item); });
    }

    function initCounters() {
      var counters = $all('[data-count]');
      if (!counters.length) return;
      if (reduceMotion || !('IntersectionObserver' in window)) {
        counters.forEach(function (el) { el.textContent = el.dataset.count || '0'; });
        return;
      }

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          var el = entry.target;
          var target = parseInt(el.dataset.count, 10) || 0;
          var start = performance.now();
          var duration = 1300;
          function frame(now) {
            var t = Math.min((now - start) / duration, 1);
            var eased = 1 - Math.pow(1 - t, 3);
            el.textContent = String(Math.round(target * eased));
            if (t < 1) requestAnimationFrame(frame);
          }
          requestAnimationFrame(frame);
          observer.unobserve(el);
        });
      }, { threshold: 0.45 });

      counters.forEach(function (el) { observer.observe(el); });
    }

    function initMagneticButtons() {
      $all('.magnetic').forEach(function (button) {
        button.addEventListener('pointermove', function (event) {
          var rect = button.getBoundingClientRect();
          var x = ((event.clientX - rect.left) / rect.width) * 100;
          var y = ((event.clientY - rect.top) / rect.height) * 100;
          button.style.setProperty('--mx', x + '%');
          button.style.setProperty('--my', y + '%');
        });
      });
    }

    function initNewsletter() {
      var form = $('#newsletter-form');
      var input = $('#newsletter-email');
      var status = $('#newsletter-status');
      if (!form || !input || !status) return;

      form.addEventListener('submit', function (event) {
        event.preventDefault();
        var value = input.value.trim();
        if (!value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) {
          status.textContent = 'Inserisci un indirizzo email valido.';
          input.focus();
          return;
        }
        status.textContent = 'Grazie, iscrizione registrata in questa sessione.';
        form.reset();
      });
    }

    function initCarousel() {
      if (typeof Swiper === 'undefined') return;
      document.querySelectorAll('.rsm-swiper:not(.rsm-swiper--hero)').forEach(function (el) {
        var slideCount = el.querySelectorAll('.swiper-slide').length;
        var hasMultipleSlides = slideCount > 1;
        new Swiper(el, {
          loop: hasMultipleSlides,
          grabCursor: true,
          spaceBetween: 30,
          effect: 'fade',
          fadeEffect: { crossFade: true },
          autoplay: hasMultipleSlides ? {
            delay: 4000,
            disableOnInteraction: false,
          } : false,
          pagination: {
            el: el.querySelector('.swiper-pagination'),
            clickable: true,
            dynamicBullets: true,
          },
          navigation: {
            nextEl: el.querySelector('.swiper-button-next'),
            prevEl: el.querySelector('.swiper-button-prev'),
          },
          keyboard: { enabled: true },
        });
      });
    }

    function initHeroVideoSwiper() {
      var heroEl = document.querySelector('.rsm-swiper--hero');
      if (!heroEl || typeof Swiper === 'undefined') return;

      var heroSwiper = new Swiper(heroEl, {
        loop: true,
        grabCursor: true,
        effect: 'fade',
        fadeEffect: { crossFade: true },
        autoplay: false,
        pagination: {
          el: heroEl.querySelector('.swiper-pagination'),
          clickable: true,
          dynamicBullets: true,
        },
        navigation: {
          nextEl: heroEl.querySelector('.swiper-button-next'),
          prevEl: heroEl.querySelector('.swiper-button-prev'),
        },
        keyboard: { enabled: true },
      });

      function playActiveVideo() {
        heroEl.querySelectorAll('video').forEach(function (v) {
          v.pause();
          v.currentTime = 0;
        });
        var active = heroEl.querySelector('.swiper-slide-active video');
        if (active) active.play().catch(function () {});
      }

      var fallbackTimer = null;

      // Frecce: slideChangeTransitionEnd scatta dopo il fade → slide attiva già visibile
      heroSwiper.on('slideChangeTransitionEnd', function () {
        clearTimeout(fallbackTimer);
        playActiveVideo();
      });

      // Drag: slideChangeTransitionEnd spesso non scatta → fallback a 350ms
      heroSwiper.on('slideChange', function () {
        clearTimeout(fallbackTimer);
        fallbackTimer = setTimeout(function () {
          var active = heroEl.querySelector('.swiper-slide-active video');
          if (active && active.paused) playActiveVideo();
        }, 350);
      });

      // Avanza slide solo se è il video attivo a finire (evita loop nascosti)
      heroEl.addEventListener('ended', function (e) {
        if (e.target.tagName !== 'VIDEO') return;
        var active = heroEl.querySelector('.swiper-slide-active video');
        if (e.target === active) heroSwiper.slideNext();
      }, true);

      playActiveVideo();
    }

    function initBannerVideo() {
      var vid = document.querySelector('.img-banner-video');
      if (!vid) return;
      if (vid.tagName !== 'VIDEO') return;
      var obs = new IntersectionObserver(function (entries) {
        if (entries[0].isIntersecting) {
          vid.play().catch(function () {});
          obs.disconnect();
        }
      }, { threshold: 0.1 });
      obs.observe(vid);
    }

    function initAuth() {
      var nav = $('#nav-auth');
      if (!nav) return;
      if (typeof supabase === 'undefined' || typeof SUPABASE_URL === 'undefined' || SUPABASE_URL.indexOf('your-project') >= 0) {
        nav.innerHTML = '<a href="login" class="nav-login">Accedi</a>';
        return;
      }

      var client = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
      var outsideBound = false;

      function initials(username) {
        return String(username || 'utente').trim().slice(0, 2).toUpperCase();
      }

      function closeDropdown() {
        var dropdown = $('#profileDropdown');
        var button = $('#profileBtn');
        if (dropdown) dropdown.classList.remove('open');
        if (button) button.setAttribute('aria-expanded', 'false');
      }

      function item(label, href, active, primary) {
        return '<a href="' + href + '" role="menuitem" class="' + (active ? 'active ' : '') + (primary ? 'item-primary' : '') + '"><span>' + label + '</span><span aria-hidden="true">&rarr;</span></a>';
      }

      function buildMenu(username, color, emoji) {
        emoji = emoji || '🌿';
        var safe = escapeHtml(username);
        var current = window.location.pathname;
        var profileHref = 'profile?u=' + encodeURIComponent(username);
        var isProfile = current.indexOf('profile') >= 0;
        var currentLower = current.toLowerCase();
        var isDashboard = currentLower.indexOf('/dashboard') >= 0 || currentLower.indexOf('/me') >= 0;
        var isWrite = current.indexOf('write') >= 0;
        var editItem = isProfile && new URLSearchParams(window.location.search).get('u') === username
          ? item('Modifica profilo', 'modifica-profilo', false, false)
          : '';

        return '<div class="profile-menu" id="profileMenu">' +
          '<button class="profile-btn" id="profileBtn" type="button" aria-haspopup="true" aria-expanded="false">' +
          '<span class="profile-avatar" style="background:' + escapeHtml(color || '#2f6b67') + '">' + escapeHtml(emoji) + '</span>' +
          '<span>@' + safe + '</span>' +
          '</button>' +
          '<div class="profile-dropdown" id="profileDropdown" role="menu" aria-label="Menu navigazione">' +
          '<div class="profile-dropdown__section-title">Navigazione</div>' +
          item('Profilo', profileHref, isProfile, false) +
          item('Dashboard', '/dashboard', isDashboard, false) +
          editItem +
          item('Scrivi', 'write', isWrite, true) +
          item('Categorie', '/category', current.indexOf('/category') >= 0, false) +
          item('Aspetto', 'preferenze', current.indexOf('preferenze') >= 0, false) +
          item('Reimposta Password', 'reset', current.indexOf('reset') >= 0, false) +
          '<div class="profile-dropdown__sep"></div>' +
          '<button type="button" data-action="logout" class="danger" role="menuitem"><span>Esci</span><span aria-hidden="true">&rarr;</span></button>' +
          '</div></div>';
      }

      function bindMenu() {
        var button = $('#profileBtn');
        var dropdown = $('#profileDropdown');
        if (!button || !dropdown) return;

        button.addEventListener('click', function (event) {
          event.stopPropagation();
          var open = !dropdown.classList.contains('open');
          dropdown.classList.toggle('open', open);
          button.setAttribute('aria-expanded', String(open));
        });

        $all('[data-action="logout"]', dropdown).forEach(function (logoutButton) {
          logoutButton.addEventListener('click', function () {
            client.auth.signOut().then(function () { window.location.reload(); });
          });
        });

        $all('a', dropdown).forEach(function (link) {
          link.addEventListener('click', closeDropdown);
        });

        if (!outsideBound) {
          document.addEventListener('click', function (event) {
            var menu = $('#profileMenu');
            if (menu && !menu.contains(event.target)) closeDropdown();
          }, { capture: true });
          document.addEventListener('keydown', function (event) {
            if (event.key === 'Escape') closeDropdown();
          });
          outsideBound = true;
        }
      }

      function render(session) {
        if (!session) {
          nav.innerHTML = '<a href="login" class="nav-login">Accedi</a>';
          nav.classList.add('auth-ready');
          var ml = document.querySelector('.nav-mobile-login');
          if (ml) ml.classList.add('auth-ready');
          return;
        }

        client.from('profiles')
          .select('username,avatar_emoji,avatar_color')
          .eq('id', session.user.id)
          .single()
          .then(function (result) {
            var profile = result && result.data ? result.data : {};
            var username = profile.username || (session.user.email || 'profilo').split('@')[0];
            nav.innerHTML = buildMenu(username, profile.avatar_color || '#2f6b67', profile.avatar_emoji || '🌿');
            nav.classList.add('auth-ready');
            var ml = document.querySelector('.nav-mobile-login');
            if (ml) ml.classList.add('auth-ready');
            bindMenu();
          });
      }

      client.auth.onAuthStateChange(function (_event, session) { render(session); });
      client.auth.getSession().then(function (result) {
        render(result && result.data ? result.data.session : null);
      });
    }

    function newsSeed(post) {
      var type = String(post.image_type || post.category || 'territorio').toLowerCase().replace(/[^a-z0-9]+/g, '-');
      return type || 'territorio';
    }

    function newsPhoto(slot, seed) {
      return '<div class="news-card__media photo-slot" data-photo-slot="' + escapeHtml(slot) + '" style="--photo:url(https://picsum.photos/seed/rivalta-news-' + escapeHtml(seed) + '/900/680)" aria-hidden="true"></div>';
    }

    function initPosts() {
      var status = $('#news-status');
      var filterRow = $('#news-filter-row');
      var featured = $('#post-featured');
      var grid = $('#posts-grid');
      var empty = $('#news-empty');
      if (!status || !filterRow || !featured || !grid || !empty) return;

      var categories = CATEGORY_ORDER.slice();
      var activeCategory = 'all';
      var posts = [];

      function setStatus(message) {
        status.textContent = message || '';
        status.style.display = message ? '' : 'none';
      }

      function fmt(iso) {
        if (!iso) return '';
        return new Date(iso).toLocaleDateString('it-IT', { day: 'numeric', month: 'short', year: 'numeric' });
      }

      function badgeClass(color) {
        return color === 'green' ? 'badge green' : 'badge';
      }

      function normalize(post) {
        var category = canonicalCategory(post.category) || 'Territorio';
        return Object.assign({}, post, {
          category: category,
          badge_color: post.badge_color || badgeColor(category)
        });
      }

      function filteredPosts() {
        if (activeCategory === 'all') return posts;
        return posts.filter(function (post) { return post.category === activeCategory; });
      }

      function renderFilters() {
        var chips = ['all'].concat(categories);
        filterRow.innerHTML = chips.map(function (cat) {
          var label = cat === 'all' ? 'Tutte' : cat;
          var on = activeCategory === cat ? ' on' : '';
          return '<button type="button" class="news-filter-chip' + on + '" data-cat="' + escapeHtml(cat) + '">' + escapeHtml(label) + '</button>';
        }).join('');

        $all('[data-cat]', filterRow).forEach(function (button) {
          button.addEventListener('click', function () {
            activeCategory = button.getAttribute('data-cat') || 'all';
            renderFilters();
            renderPosts();
          });
        });
      }

      function cardMarkup(post) {
        var seed = newsSeed(post);
        return '<article class="post-card">' +
          newsPhoto('news-card-' + escapeHtml(seed), seed) +
          '<div class="post-card__body">' +
          '<div class="post-meta"><time>' + escapeHtml(fmt(post.published_at)) + '</time><a href="' + categoryHref(post.category) + '">' + escapeHtml(post.category) + '</a></div>' +
          '<h3 class="post-card__title"><a href="post?id=' + encodeURIComponent(post.id) + '">' + escapeHtml(post.title || 'Articolo') + '</a></h3>' +
          '<p class="post-card__excerpt">' + escapeHtml(post.excerpt || '') + '</p>' +
          '<div class="post-card__footer"><a class="btn-read" href="post?id=' + encodeURIComponent(post.id) + '">Leggi <span aria-hidden="true">&rarr;</span></a><span class="' + badgeClass(post.badge_color) + '">' + escapeHtml(post.badge || post.category) + '</span></div>' +
          '</div></article>';
      }

      function renderPosts() {
        var list = filteredPosts();
        featured.style.display = 'none';
        grid.innerHTML = '';

        if (!list.length) {
          empty.style.display = '';
          setStatus(activeCategory === 'all' ? '' : 'Nessun articolo per la categoria selezionata.');
          return;
        }

        empty.style.display = 'none';
        setStatus('');
        var first = list[0];
        var seed = newsSeed(first);
        featured.classList.remove('skeleton');
        featured.innerHTML =
          newsPhoto('news-featured-' + escapeHtml(seed), seed) +
          '<div class="post-featured__body">' +
          '<div class="post-meta"><time>' + escapeHtml(fmt(first.published_at)) + '</time><a href="' + categoryHref(first.category) + '">' + escapeHtml(first.category) + '</a></div>' +
          '<h2 class="post-featured__title"><a href="post?id=' + encodeURIComponent(first.id) + '">' + escapeHtml(first.title || 'Articolo') + '</a></h2>' +
          '<p class="post-featured__excerpt">' + escapeHtml(first.excerpt || '') + '</p>' +
          '<div class="post-featured__footer"><a class="btn-read" href="post?id=' + encodeURIComponent(first.id) + '">Leggi <span aria-hidden="true">&rarr;</span></a><span class="' + badgeClass(first.badge_color) + '">' + escapeHtml(first.badge || first.category) + '</span></div>' +
          '</div>';
        featured.style.display = '';
        grid.innerHTML = list.slice(1, 7).map(cardMarkup).join('');
      }

      renderFilters();

      if (typeof supabase === 'undefined' || typeof SUPABASE_URL === 'undefined' || SUPABASE_URL.indexOf('your-project') >= 0) {
        posts = [];
        renderPosts();
        setStatus('Archivio non collegato. Quando Supabase risponde, le news appariranno qui.');
        return;
      }

      var client = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
      client
        .from('posts')
        .select('id, title, excerpt, category, badge, badge_color, image_type, published_at')
        .eq('published', true)
        .order('published_at', { ascending: false })
        .limit(60)
        .then(function (result) {
          if (result.error) {
            posts = [];
            renderPosts();
            setStatus('Non riesco a caricare le news in questo momento.');
            return;
          }
          posts = (result.data || []).map(normalize);
          renderPosts();
        });
    }

    function initGsap() {
      if (reduceMotion || typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
      gsap.registerPlugin(ScrollTrigger);

      gsap.utils.toArray('[data-parallax]').forEach(function (el) {
        var amount = parseFloat(el.getAttribute('data-parallax') || '0.1') * 240;
        gsap.to(el, {
          y: amount,
          ease: 'none',
          scrollTrigger: {
            trigger: el,
            start: 'top bottom',
            end: 'bottom top',
            scrub: 1.2
          }
        });
      });

      gsap.utils.toArray('.photo-slot').forEach(function (slot) {
        gsap.fromTo(slot,
          { scale: 0.94 },
          {
            scale: 1.03,
            ease: 'none',
            scrollTrigger: {
              trigger: slot,
              start: 'top bottom',
              end: 'bottom top',
              scrub: 1.4
            }
          }
        );
      });

      ScrollTrigger.refresh();
    }

    function initAnimeJs() {
      if (reduceMotion || typeof anime === 'undefined' || typeof anime.animate !== 'function') return;

      anime.animate('.nav-island', {
        translateY: [-28, 0],
        opacity: [0, 1],
        duration: 880,
        ease: 'out(4)'
      });

      anime.animate('.hero-copy-block > *', {
        translateY: [30, 0],
        opacity: [0, 1],
        delay: anime.stagger(95, { start: 140 }),
        duration: 900,
        ease: 'out(3)'
      });

      anime.animate('.hero-media', {
        translateX: [22, 0],
        scale: [0.97, 1],
        opacity: [0, 1],
        duration: 980,
        delay: 220,
        ease: 'out(4)'
      });

      anime.animate('.fact', {
        translateY: [18, 0],
        opacity: [0, 1],
        delay: anime.stagger(130, { start: 380 }),
        duration: 760,
        ease: 'out(3)'
      });

      anime.animate('.marquee-track span', {
        opacity: [0.42, 1],
        delay: anime.stagger(120),
        duration: 1700,
        direction: 'alternate',
        loop: true,
        ease: 'inOut(2)'
      });

      var interactiveCards = $all('.stack-card, .post-card, .community-item, .festa-day, .festa-poster-frame');
      interactiveCards.forEach(function (card) {
        card.addEventListener('pointerenter', function () {
          anime.animate(card, {
            scale: 1.015,
            translateY: -5,
            duration: 360,
            ease: 'out(3)'
          });
        });

        card.addEventListener('pointerleave', function () {
          anime.animate(card, {
            scale: 1,
            translateY: 0,
            duration: 420,
            ease: 'out(3)'
          });
        });
      });

      var backToTop = $('.back-to-top');
      if (backToTop && 'IntersectionObserver' in window) {
        var footer = $('.footer');
        if (footer) {
          var footerObserver = new IntersectionObserver(function (entries) {
            if (!entries[0]) return;
            if (entries[0].isIntersecting) {
              anime.animate(backToTop, {
                scale: [1, 1.09, 1],
                duration: 740,
                ease: 'inOut(3)'
              });
            }
          }, { threshold: 0.28 });
          footerObserver.observe(footer);
        }
      }
    }

    document.addEventListener('DOMContentLoaded', function () {
      var year = $('#year');
      if (year) year.textContent = String(new Date().getFullYear());
      initBannerVideo();
      initNav();
      initReveal();
      initCounters();
      initMagneticButtons();
      initNewsletter();
      initCarousel();
      initHeroVideoSwiper();
      initAuth();
      initPosts();
      initGsap();
      initAnimeJs();
    });
  })();
  </script>
</body>
</html>
