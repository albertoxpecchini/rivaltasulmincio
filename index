    /* =========================================================
       AURORA BACKGROUND — bianco pulito + 3 blob blurrati
       ========================================================= */
    .rsm-aurora {
      position: fixed;
      inset: 0;
      z-index: var(--rsm-z-aurora);
      pointer-events: none;
      overflow: hidden;
    }
    .rsm-aurora__blob {
      position: absolute;
      width: 60vmax;
      height: 60vmax;
      border-radius: 50%;
      filter: blur(120px);
      opacity: 0.55;
      will-change: transform;
      animation: rsm-aurora-float 28s ease-in-out infinite;
    }
    .rsm-aurora__blob--emerald {
      top: -22vmax;
      left: -18vmax;
      background: radial-gradient(circle, rgba(31, 191, 125, 0.55), rgba(31, 191, 125, 0) 65%);
      animation-delay: -2s;
    }
    .rsm-aurora__blob--azure {
      top: 10vmax;
