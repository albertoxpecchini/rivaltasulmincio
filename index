        height: 32px;
      }

      .photo-rail {
        grid-auto-columns: minmax(236px, 80vw);
      }

      .footer-bottom {
        display: grid;
      }

      .rsm-swiper .swiper-button-prev,
      .rsm-swiper .swiper-button-next {
        display: none;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      *,
