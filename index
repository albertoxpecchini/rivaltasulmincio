  <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2/dist/umd/popper.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/tippy.js@6/dist/tippy.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/splitting@1.0.6/dist/splitting.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  <script src="/node_modules/animejs/dist/bundles/anime.umd.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
  <script src="/supabase.config.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
  <script>
  (function () {
    'use strict';

    var reduceMotion = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var CATEGORY_ORDER = [
      'Ambiente', 'Anniversari', 'Assemblea', 'Canoa', 'Ciclismo',
      'Festa del Pesce', 'Iniziative', 'Love-luccio', 'Mincio-art',
      'Natale', 'Rassegna Stampa', 'Tesseramento', 'Video'
    ];
    var LEGACY_TO_CANONICAL = {
      'ambiente': 'Ambiente', 'anniversari': 'Anniversari', 'assemblea': 'Assemblea',
      'canoa': 'Canoa', 'ciclismo': 'Ciclismo', 'festa del pesce': 'Festa del Pesce',
      'festa-del-pesce': 'Festa del Pesce', 'iniziative': 'Iniziative',
      'love-luccio': 'Love-luccio', 'mincio-art': 'Mincio-art', 'natale': 'Natale',
      'rassegna stampa': 'Rassegna Stampa', 'rassegna-stampa': 'Rassegna Stampa',
      'tesseramento': 'Tesseramento', 'video': 'Video',
      'eventi': 'Iniziative', 'territorio': 'Ambiente', 'vita locale': 'Iniziative',
      'avvisi': 'Iniziative', 'richieste': 'Iniziative', 'storie': 'Iniziative',
      'il luccio': 'Iniziative', 'fauna': 'Ambiente', 'ecoturismo': 'Ambiente',
      'storia': 'Iniziative'
    };
    var BADGE_COLOR_BY_CATEGORY = {
      'Ambiente': 'default', 'Anniversari': 'green', 'Assemblea': 'default',
      'Canoa': 'green', 'Ciclismo': 'default', 'Festa del Pesce': 'green',
      'Iniziative': 'green', 'Love-luccio': 'green', 'Mincio-art': 'default',
      'Natale': 'green', 'Rassegna Stampa': 'default', 'Tesseramento': 'default',
      'Video': 'default'
    };

    function $(selector, root) { return (root || document).querySelector(selector); }
    function $all(selector, root) { return Array.prototype.slice.call((root || document).querySelectorAll(selector)); }

    function escapeHtml(value) {
      return String(value || '')
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');
    }

    function canonicalCategory(input) {
      var raw = String(input || '').trim();
      if (!raw) return '';
      var normalized = raw.toLowerCase();
      if (LEGACY_TO_CANONICAL[normalized]) return LEGACY_TO_CANONICAL[normalized];
      for (var i = 0; i < CATEGORY_ORDER.length; i += 1) {
        if (CATEGORY_ORDER[i].toLowerCase() === normalized) return CATEGORY_ORDER[i];
      }
      return raw;
    }

    function badgeColor(input) { return BADGE_COLOR_BY_CATEGORY[canonicalCategory(input)] || 'default'; }
    function categoryHref(input) { return 'category?name=' + encodeURIComponent(canonicalCategory(input) || ''); }

    window.RSM_CATEGORIES = {
      all: function () { return CATEGORY_ORDER.slice(); },
      canonical: canonicalCategory, badgeColor: badgeColor, categoryHref: categoryHref
    };

    /* ─── Reveal on scroll ─── */
    function initReveal() {
      var items = $all('[data-reveal]');
      if (!items.length) return;
      if (reduceMotion || !('IntersectionObserver' in window)) {
        items.forEach(function (item) { item.classList.add('is-visible'); });
        return;
      }
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, { threshold: 0.14 });
      items.forEach(function (item) { observer.observe(item); });
    }

    /* ─── Counters ─── */
    function initCounters() {
      var counters = $all('[data-count]');
      if (!counters.length) return;
      if (reduceMotion || !('IntersectionObserver' in window)) {
        counters.forEach(function (el) { el.textContent = el.dataset.count || '0'; });
        return;
      }
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          var el = entry.target;
          var target = parseInt(el.dataset.count, 10) || 0;
          var start = performance.now();
          var duration = 1300;
          function frame(now) {
            var t = Math.min((now - start) / duration, 1);
            var eased = 1 - Math.pow(1 - t, 3);
            el.textContent = String(Math.round(target * eased));
            if (t < 1) requestAnimationFrame(frame);
          }
          requestAnimationFrame(frame);
          observer.unobserve(el);
        });
      }, { threshold: 0.45 });
      counters.forEach(function (el) { observer.observe(el); });
    }

    /* ─── Magnetic buttons ─── */
    function initMagneticButtons() {
      $all('.magnetic').forEach(function (button) {
        button.addEventListener('pointermove', function (event) {
          var rect = button.getBoundingClientRect();
          var x = ((event.clientX - rect.left) / rect.width) * 100;
          var y = ((event.clientY - rect.top) / rect.height) * 100;
          button.style.setProperty('--mx', x + '%');
          button.style.setProperty('--my', y + '%');
        });
      });
    }

    /* ─── Newsletter form (inline + modal) ─── */
    function bindNewsletter(formId, inputId, statusId) {
      var form = $('#' + formId);
      var input = $('#' + inputId);
      var status = $('#' + statusId);
      if (!form || !input || !status) return;
      form.addEventListener('submit', function (event) {
        event.preventDefault();
        var value = input.value.trim();
        if (!value || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value)) {
          status.textContent = 'Inserisci un indirizzo email valido.';
          status.style.color = 'var(--rsm-danger)';
          input.focus();
          return;
        }
        status.textContent = 'Grazie, iscrizione registrata in questa sessione.';
        status.style.color = 'var(--rsm-success)';
        form.reset();
      });
    }
    function initNewsletter() {
      bindNewsletter('newsletter-form', 'newsletter-email', 'newsletter-status');
      bindNewsletter('newsletter-modal-form', 'newsletter-modal-email', 'newsletter-modal-status');
    }

    /* ─── Modal handling ─── */
    function initModals() {
      $all('[data-modal-open]').forEach(function (trigger) {
        trigger.addEventListener('click', function () {
          var id = trigger.getAttribute('data-modal-open');
          var modal = document.getElementById(id);
          if (!modal) return;
          modal.removeAttribute('hidden');
          requestAnimationFrame(function () { modal.classList.add('is-open'); });
          var firstInput = modal.querySelector('input, button:not([data-modal-close])');
          if (firstInput) setTimeout(function(){ firstInput.focus(); }, 200);
        });
      });
      function close(modal) {
        modal.classList.remove('is-open');
        setTimeout(function () { modal.setAttribute('hidden', ''); }, 360);
      }
      $all('.rsm-modal').forEach(function (modal) {
        modal.addEventListener('click', function (e) {
          if (e.target === modal || (e.target.closest && e.target.closest('[data-modal-close]'))) {
            close(modal);
          }
        });
      });
      document.addEventListener('keydown', function (e) {
        if (e.key !== 'Escape') return;
        $all('.rsm-modal.is-open').forEach(close);
      });
    }

    /* ─── Carousels (Swiper) ─── */
    function initCarousel() {
      if (typeof Swiper === 'undefined') return;
      document.querySelectorAll('.rsm-swiper:not(.rsm-swiper--hero)').forEach(function (el) {
        var slideCount = el.querySelectorAll('.swiper-slide').length;
        var hasMultipleSlides = slideCount > 1;
        new Swiper(el, {
          loop: hasMultipleSlides, grabCursor: true, spaceBetween: 20,
          effect: 'fade', fadeEffect: { crossFade: true },
          autoplay: hasMultipleSlides ? { delay: 4500, disableOnInteraction: false } : false,
          pagination: { el: el.querySelector('.swiper-pagination'), clickable: true, dynamicBullets: true },
          navigation: { nextEl: el.querySelector('.swiper-button-next'), prevEl: el.querySelector('.swiper-button-prev') },
          keyboard: { enabled: true }
        });
      });
    }

    function initHeroVideoSwiper() {
      var heroEl = document.querySelector('.rsm-swiper--hero');
      if (!heroEl || typeof Swiper === 'undefined') return;
      new Swiper(heroEl, {
        loop: true, grabCursor: true,
        effect: 'fade', fadeEffect: { crossFade: true },
        autoplay: { delay: 4200, disableOnInteraction: false },
        pagination: { el: heroEl.querySelector('.swiper-pagination'), clickable: true, dynamicBullets: true },
        navigation: { nextEl: heroEl.querySelector('.swiper-button-next'), prevEl: heroEl.querySelector('.swiper-button-prev') },
        keyboard: { enabled: true }
      });
    }

    /* ─── Helpers per news ─── */
    function isValidHttpsUrl(url) {
      if (!url || typeof url !== 'string') return false;
      try { var u = new URL(url); return u.protocol === 'https:'; } catch (_) { return false; }
    }
    function newsSeed(post) {
      var type = String(post.image_type || post.category || 'territorio').toLowerCase().replace(/[^a-z0-9]+/g, '-');
      return type || 'territorio';
    }
    function newsPhoto(mediaClass, slot, seed, imageUrl) {
      var url = (isValidHttpsUrl(imageUrl) ? imageUrl : null) ||
                ('https://picsum.photos/seed/rivalta-news-' + encodeURIComponent(seed) + '/900/680');
      return '<div class="' + escapeHtml(mediaClass) + ' news-card__media--photo photo-slot" data-photo-slot="' + escapeHtml(slot) + '" style="--photo:none" aria-hidden="true"><img class="news-card__img" src="' + escapeHtml(url) + '" alt="" loading="lazy" decoding="async" /></div>';
    }

    /* ─── Posts (Supabase) ─── */
    function initPosts() {
      var status = $('#news-status');
      var filterRow = $('#news-filter-row');
      var featured = $('#post-featured');
      var grid = $('#posts-grid');
      var empty = $('#news-empty');
      if (!status || !filterRow || !featured || !grid || !empty) return;

      var categories = CATEGORY_ORDER.slice();
      var activeCategory = 'all';
      var posts = [];

      function setStatus(message) {
        status.textContent = message || '';
        status.style.display = message ? '' : 'none';
      }
      function fmt(iso) {
        if (!iso) return '';
        return new Date(iso).toLocaleDateString('it-IT', { day: 'numeric', month: 'short', year: 'numeric' });
      }
      function badgeClass(color) { return color === 'green' ? 'badge green' : 'badge'; }
      function normalize(post) {
        var category = canonicalCategory(post.category) || 'Territorio';
        return Object.assign({}, post, { category: category, badge_color: post.badge_color || badgeColor(category) });
      }
      function filteredPosts() {
        if (activeCategory === 'all') return posts;
        return posts.filter(function (post) { return post.category === activeCategory; });
      }
      function renderFilters() {
        var chips = ['all'].concat(categories);
        filterRow.innerHTML = chips.map(function (cat) {
          var label = cat === 'all' ? 'Tutte' : cat;
          var on = activeCategory === cat ? ' on' : '';
          return '<button type="button" class="news-filter-chip' + on + '" data-cat="' + escapeHtml(cat) + '">' + escapeHtml(label) + '</button>';
        }).join('');
        $all('[data-cat]', filterRow).forEach(function (button) {
          button.addEventListener('click', function () {
            activeCategory = button.getAttribute('data-cat') || 'all';
            renderFilters(); renderPosts();
          });
        });
      }
      function cardMarkup(post) {
        var seed = newsSeed(post);
        return '<article class="post-card">' +
          newsPhoto('news-card__media', 'news-card-' + seed, seed, post.image_url) +
          '<div class="post-card__body">' +
          '<div class="post-meta"><time>' + escapeHtml(fmt(post.published_at)) + '</time><a href="' + categoryHref(post.category) + '">' + escapeHtml(post.category) + '</a></div>' +
          '<h3 class="post-card__title"><a href="post?id=' + encodeURIComponent(post.id) + '">' + escapeHtml(post.title || 'Articolo') + '</a></h3>' +
          '<p class="post-card__excerpt">' + escapeHtml(post.excerpt || '') + '</p>' +
          '<div class="post-card__footer"><a class="btn-read" href="post?id=' + encodeURIComponent(post.id) + '">Leggi <span aria-hidden="true">&rarr;</span></a><span class="' + badgeClass(post.badge_color) + '">' + escapeHtml(post.badge || post.category) + '</span></div>' +
          '</div></article>';
      }
      function renderPosts() {
        var list = filteredPosts();
        featured.style.display = 'none';
        grid.innerHTML = '';
        if (!list.length) {
          empty.style.display = '';
          setStatus(activeCategory === 'all' ? '' : 'Nessun articolo per la categoria selezionata.');
          return;
        }
        empty.style.display = 'none'; setStatus('');
        var first = list[0]; var seed = newsSeed(first);
        featured.classList.remove('skeleton');
        featured.innerHTML =
          newsPhoto('post-featured__media', 'news-featured-' + seed, seed, first.image_url) +
          '<div class="post-featured__body">' +
          '<div class="post-meta"><time>' + escapeHtml(fmt(first.published_at)) + '</time><a href="' + categoryHref(first.category) + '">' + escapeHtml(first.category) + '</a></div>' +
          '<h2 class="post-featured__title"><a href="post?id=' + encodeURIComponent(first.id) + '">' + escapeHtml(first.title || 'Articolo') + '</a></h2>' +
          '<p class="post-featured__excerpt">' + escapeHtml(first.excerpt || '') + '</p>' +
          '<div class="post-featured__footer"><a class="btn-read" href="post?id=' + encodeURIComponent(first.id) + '">Leggi <span aria-hidden="true">&rarr;</span></a><span class="' + badgeClass(first.badge_color) + '">' + escapeHtml(first.badge || first.category) + '</span></div>' +
          '</div>';
        featured.style.display = '';
        grid.innerHTML = list.slice(1, 7).map(cardMarkup).join('');
      }
      renderFilters();

      if (typeof supabase === 'undefined' || typeof SUPABASE_URL === 'undefined' || SUPABASE_URL.indexOf('your-project') >= 0) {
        posts = []; renderPosts();
        setStatus('Archivio non collegato. Quando Supabase risponde, le news appariranno qui.');
        return;
      }
      var client = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
      client.from('posts')
        .select('id, title, excerpt, category, badge, badge_color, image_type, image_url, published_at')
        .eq('published', true).order('published_at', { ascending: false }).limit(60)
        .then(function (result) {
          if (result.error) { posts = []; renderPosts(); setStatus('Non riesco a caricare le news in questo momento.'); return; }
          posts = (result.data || []).map(normalize); renderPosts();
        });
    }

    /* ─── GSAP scroll triggers ─── */
    function initGsap() {
      if (reduceMotion || typeof gsap === 'undefined' || typeof ScrollTrigger === 'undefined') return;
      gsap.registerPlugin(ScrollTrigger);

      gsap.utils.toArray('[data-parallax]').forEach(function (el) {
        var amount = parseFloat(el.getAttribute('data-parallax') || '0.1') * 240;
        gsap.to(el, { y: amount, ease: 'none',
          scrollTrigger: { trigger: el, start: 'top bottom', end: 'bottom top', scrub: 1.2 }
        });
      });

      gsap.utils.toArray('.photo-slot').forEach(function (slot) {
        gsap.fromTo(slot, { scale: 0.96 }, {
          scale: 1.04, ease: 'none',
          scrollTrigger: { trigger: slot, start: 'top bottom', end: 'bottom top', scrub: 1.4 }
        });
      });

      ScrollTrigger.refresh();
    }

    /* ─── Anime.js entrance + hover ─── */
    function initAnimeJs() {
      if (reduceMotion || typeof anime === 'undefined' || typeof anime.animate !== 'function') return;

      anime.animate('.nav-island', { translateY: [-28, 0], opacity: [0, 1], duration: 880, ease: 'out(4)' });

      anime.animate('.rsm-hero__main > *', {
        translateY: [30, 0], opacity: [0, 1],
        delay: anime.stagger(95, { start: 140 }),
        duration: 900, ease: 'out(3)'
      });

      anime.animate('.rsm-hero__media', {
        translateY: [22, 0], scale: [0.97, 1], opacity: [0, 1],
        duration: 1000, delay: 220, ease: 'out(4)'
      });

      anime.animate('.rsm-hero__metrics .rsm-metric', {
        translateY: [16, 0], opacity: [0, 1],
        delay: anime.stagger(110, { start: 480 }),
        duration: 760, ease: 'out(3)'
      });

      anime.animate('.rsm-gallery__marquee-track', {
        opacity: [0.4, 1], duration: 1700,
        direction: 'alternate', loop: true, ease: 'inOut(2)'
      });

      var interactiveCards = $all('.stack-card, .post-card, .rsm-card, .festa-day, .rsm-festa__poster');
      interactiveCards.forEach(function (card) {
        card.addEventListener('pointerenter', function () {
          anime.animate(card, { scale: 1.012, translateY: -4, duration: 360, ease: 'out(3)' });
        });
        card.addEventListener('pointerleave', function () {
          anime.animate(card, { scale: 1, translateY: 0, duration: 420, ease: 'out(3)' });
        });
      });
    }

    /* ─── Splitting.js: typewriter sui titoli ─── */
    function initSplitting() {
      if (typeof Splitting !== 'function' || !window.gsap) return;
      Splitting({ target: '.rsm-display-1', by: 'words' });
      Splitting({ target: '.rsm-festa__title', by: 'chars' });
      Splitting({ target: '.rsm-valli__drop', by: 'words' });

      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          var el = entry.target;
          var chars = el.querySelectorAll('.char');
          var words = el.querySelectorAll('.word');
          if (chars.length) {
            gsap.fromTo(chars,
              { opacity: 0, y: 14, rotateX: -40 },
              { opacity: 1, y: 0, rotateX: 0, duration: 0.45, stagger: 0.026, ease: 'power3.out', clearProps: 'transform' });
          } else if (words.length) {
            gsap.fromTo(words,
              { opacity: 0, y: 8 },
              { opacity: 1, y: 0, duration: 0.55, stagger: 0.07, ease: 'power2.out', clearProps: 'transform' });
          }
          io.unobserve(el);
        });
      }, { threshold: 0.25 });

      document.querySelectorAll('.rsm-display-1, .rsm-festa__title, .rsm-valli__drop').forEach(function (el) {
        io.observe(el);
      });
    }

    /* ─── Tippy popups (.kw) ─── */
    var KW_FALLBACK = {
      'lago-di-garda':    { title: 'Lago di Garda',                   body: 'Il Mincio nasce dal suo angolo meridionale e alimenta le Valli.' },
      'anno-1984':        { title: 'Riserva dal 1984',                body: 'Istituita con D.C.R. 1739 dell\'11 ottobre 1984, superficie 1.081 ha.' },
      'ramsar':           { title: 'Convenzione di Ramsar',           body: 'Trattato del 1971 che protegge le zone umide di importanza internazionale.' },
      'uccelli-acquatici':{ title: 'Uccelli acquatici',                body: 'Oltre 260 specie censite nelle Valli: aironi, garzette, nitticore, svassi.' },
      'pianura-padana':   { title: 'Pianura Padana',                   body: 'Le Valli del Mincio sono una delle ultime oasi umide intatte della pianura.' },
      'canneti':          { title: 'Canneto (Phragmites australis)',   body: 'Specie dominante: crea habitat per nidificazione di aironi e tarabusi.' },
      'canne-palustri':   { title: 'Raccolta delle canne',             body: 'Fino agli anni 60 le canne venivano tagliate e vendute per coperture.' },
      'arelle':           { title: 'Arelle',                            body: 'Stuoie intrecciate con giunchi, documentate al Museo Etnografico di Corte Mincio.' },
      'martin-pescatore': { title: 'Martin pescatore (Alcedo atthis)',  body: 'Specie protetta, indicatore di qualità dell\'acqua.' }
    };
    var _kwClientCache = Object.create(null);
    function buildKwPopupHtml(key, data) {
      var fb = KW_FALLBACK[key] || {};
      var title = fb.title || key;
      var html = '<strong class="kw-pop-title">' + title + '</strong>';
      if (data && data.wiki) html += '<p class="kw-pop-wiki">' + data.wiki + '</p>';
      else if (fb.body)     html += '<p class="kw-pop-wiki">' + fb.body + '</p>';
      if (data && data.claude) html += '<p class="kw-pop-claude"><span class="kw-pop-label">Sul Mincio</span>' + data.claude + '</p>';
      return html;
    }
    function initKwPopups() {
      if (typeof tippy !== 'function') return;
      document.querySelectorAll('.kw[data-kw]').forEach(function (el) {
        var key = el.dataset.kw;
        var label = el.textContent.trim();
        tippy(el, {
          content: '<span class="kw-loading">· · ·</span>',
          allowHTML: true, theme: 'rsm', placement: 'top', maxWidth: 320,
          delay: [200, 80], touch: ['hold', 500], interactive: false,
          onShow: function (i) {
            if (_kwClientCache[key]) { i.setContent(_kwClientCache[key]); return; }
            var url = '/api/kw-context?kw=' + encodeURIComponent(key) + '&title=' + encodeURIComponent(label);
            fetch(url)
              .then(function (r) { return r.ok ? r.json() : null; })
              .then(function (data) { var html = buildKwPopupHtml(key, data); _kwClientCache[key] = html; i.setContent(html); })
              .catch(function () { var html = buildKwPopupHtml(key, null); _kwClientCache[key] = html; i.setContent(html); });
          }
        });
      });
    }

    /* ─── DOMContentLoaded ─── */
    document.addEventListener('DOMContentLoaded', function () {
      var year = $('#year');
      if (year) year.textContent = String(new Date().getFullYear());
      initReveal();
      initCounters();
      initMagneticButtons();
      initNewsletter();
      initModals();
      initCarousel();
      initHeroVideoSwiper();
      initPosts();
      initGsap();
      initAnimeJs();
      initKwPopups();
      initSplitting();
    });
  })();
  </script>
