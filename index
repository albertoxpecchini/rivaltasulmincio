    }

    /* ═════════════════ REDUCED MOTION ═════════════════ */
    @media (prefers-reduced-motion: reduce) {
      .rsm-banner__blob,
      .rsm-compass__blob,
      .rsm-banner__title em,
      .rsm-hero__title em,
      .rsm-compass__copy .rsm-h1 em,
      .rsm-banner__kicker .festa-pulse,
