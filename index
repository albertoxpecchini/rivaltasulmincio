<script>
/* ── Nav auth state ───────────────────────────────────────────────── */
(function() {
  if(typeof SUPABASE_URL==='undefined'||SUPABASE_URL.includes('your-project')) return;
  const _sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  const nav = document.getElementById('nav-auth');
  if(!nav) return;

  let outsideCloseBound = false;

  function escapeHtml(value) {
    return String(value || '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
  }

  function closeDropdown() {
    document.getElementById('profileDropdown')?.classList.remove('open');
    document.getElementById('profileBtn')?.setAttribute('aria-expanded', 'false');
  }

  function buildUserMenu(username, emoji, color) {
    const safe = escapeHtml(username);
    const profileHref = 'profile?u=' + encodeURIComponent(username);
    const path = window.location.pathname;

    const isProfile   = path.includes('profile');
    const isDashboard = path.includes('me');
    const isWrite     = path.includes('write');
    const isOwnProfile = isProfile &&
      new URLSearchParams(window.location.search).get('u') === username;

    const cls = (condition, extra) =>
      condition ? ` class="active${extra ? ' ' + extra : ''}"` : (extra ? ` class="${extra}"` : '');

    const editItem = isOwnProfile
      ? `<a href="modifica-profilo?u=${encodeURIComponent(username)}" role="menuitem">✏️&nbsp; Modifica profilo</a>`
      : '';

    return `
      <div class="profile-menu" id="profileMenu">
        <button class="profile-btn" id="profileBtn" aria-haspopup="true" aria-expanded="false">
          <span class="profile-avatar" style="background:${color}">${emoji}</span>
          @${safe}
        </button>
        <div class="profile-dropdown" id="profileDropdown" role="menu" aria-label="Menu navigazione">
          <div class="profile-dropdown__section-title">Navigazione</div>
          <a href="${profileHref}" role="menuitem"${cls(isProfile)}>👤&nbsp; Profilo</a>
          <a href="me" role="menuitem"${cls(isDashboard)}>📊&nbsp; Dashboard</a>
          ${editItem}
          <a href="write" role="menuitem"${cls(isWrite, 'item-primary')}>✍&nbsp; Scrivi</a>
          <div class="profile-dropdown__sep"></div>
          <button data-action="logout" class="danger" role="menuitem">🚪&nbsp; Esci</button>
        </div>
      </div>`;
  }

  function bindMenuActions() {
    const menu = document.getElementById('profileMenu');
    const btn = document.getElementById('profileBtn');
    const dd = document.getElementById('profileDropdown');
    if(!menu || !btn || !dd) return;

    btn.addEventListener('click', (event) => {
      event.stopPropagation();
      const open = dd.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });

    dd.querySelectorAll('[data-action="logout"]').forEach((logoutBtn) => {
      logoutBtn.addEventListener('click', async () => {
        await _sb.auth.signOut();
        window.location.reload();
      });
    });

    dd.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        closeDropdown();
      });
    });

    if(!outsideCloseBound) {
      document.addEventListener('click', (event) => {
        const activeMenu = document.getElementById('profileMenu');
        if(!activeMenu) return;
        if(activeMenu.contains(event.target)) return;
        closeDropdown();
      }, { capture: true });

      document.addEventListener('keydown', (event) => {
        if(event.key === 'Escape') closeDropdown();
      });

      outsideCloseBound = true;
    }
  }

  async function renderAuth(session) {
    if(session) {
      const {data:p} = await _sb.from('profiles').select('username,avatar_emoji,avatar_color').eq('id',session.user.id).single();
      const emoji = p?.avatar_emoji || '👤';
      const color = p?.avatar_color || '#1F6F8B';
      const username = p?.username || session.user.email?.split('@')[0] || 'profilo';

      nav.innerHTML = buildUserMenu(username, emoji, color);
      bindMenuActions();

    } else {
      nav.innerHTML = `<a href="login" class="nav-accedi-btn">Accedi</a>`;
    }
  }

  _sb.auth.onAuthStateChange((_event, session) => { renderAuth(session); });
  _sb.auth.getSession().then(({data:{session}}) => renderAuth(session));
})();

/* ── Posts loader ──────────────────────────────────────────────────── */
(async function loadPosts() {
  if (typeof SUPABASE_URL === 'undefined' || SUPABASE_URL.includes('your-project')) return;

  const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  const fallbackCategories = ['Eventi', 'Territorio', 'Vita locale', 'Avvisi', 'Richieste', 'Storie'];
  const categories = window.RSM_CATEGORIES ? window.RSM_CATEGORIES.all() : fallbackCategories;
  const canonicalCategory = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.canonical(value)
    : String(value || '').trim();
  const badgeColorByCategory = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.badgeColor(value)
    : 'default';
  const categoryHref = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.categoryHref(value)
    : ('category?name=' + encodeURIComponent(canonicalCategory(value)));
  const escapeHtml = (value) => String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
  const sanitizePost = (post) => {
    const category = canonicalCategory(post.category) || 'Territorio';
    return {
      ...post,
      category,
      badge_color: post.badge_color || badgeColorByCategory(category),
    };
  };

  const { data: posts, error } = await sb
    .from('posts')
    .select('id, title, excerpt, category, badge, badge_color, image_type, published_at')
    .eq('published', true)
    .order('published_at', { ascending: false })
    .limit(60);

  if (error) { console.warn('[Posts] Supabase error:', error.message); return; }
  const normalizedPosts = (posts || []).map(sanitizePost);

  const fmt = iso => new Date(iso).toLocaleDateString('it-IT', { day: 'numeric', month: 'short', year: 'numeric' });
  const badgeCls = c => c === 'green' ? 'badge green' : 'badge';
  const emptyEl = document.getElementById('news-empty');
  const featured = document.getElementById('post-featured');
  const grid = document.getElementById('posts-grid');
  const filterRow = document.getElementById('news-filter-row');

  if (!featured || !grid) return;

  const urlState = new URL(window.location.href);
  const rawCat = canonicalCategory(urlState.searchParams.get('cat') || '');
  let activeCategory = categories.includes(rawCat) ? rawCat : 'all';

  function getFilteredPosts() {
    if (activeCategory === 'all') return normalizedPosts;
    return normalizedPosts.filter(p => p.category === activeCategory);
  }

  function syncFilterUrl() {
    const next = new URL(window.location.href);
    if (activeCategory === 'all') next.searchParams.delete('cat');
    else next.searchParams.set('cat', activeCategory);
    window.history.replaceState({}, '', next.pathname + next.search + next.hash);
  }

  function setFilter(category) {
    activeCategory = category;
    syncFilterUrl();
    renderFilters();
    renderPosts();
  }

  function renderFilters() {
    if (!filterRow) return;
    const chips = ['all'].concat(categories);
    filterRow.innerHTML = chips.map((cat) => {
      const isAll = cat === 'all';
      const label = isAll ? 'Tutte' : cat;
      const on = activeCategory === cat ? ' on' : '';
      return `<button type="button" class="news-filter-chip${on}" data-cat="${escapeHtml(cat)}">${escapeHtml(label)}</button>`;
    }).join('');

    filterRow.querySelectorAll('[data-cat]').forEach((node) => {
      node.addEventListener('click', () => {
        const cat = node.getAttribute('data-cat') || 'all';
        setFilter(cat);
      });
    });
  }

  /* illustration SVG snippets keyed by image_type */
  const ILL = {
    festival: `<svg viewBox="0 0 400 250" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice"><rect width="400" height="250" fill="url(#grad-sunset)"/><g fill="#143B43" opacity=".88"><rect x="40" y="160" width="60" height="60"/><polygon points="32,160 70,118 108,160"/><rect x="100" y="145" width="80" height="75"/><polygon points="92,145 140,98 188,145"/><rect x="240" y="140" width="70" height="80"/><polygon points="232,140 275,95 318,140"/></g><path d="M30,90 Q200,140 370,80" stroke="#fff" stroke-width="1" fill="none" opacity=".4"/><g fill="#F9A825"><circle cx="60" cy="105" r="3"/><circle cx="180" cy="138" r="3"/><circle cx="300" cy="120" r="3"/></g></svg>`,
    heron:   `<svg viewBox="0 0 400 250" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice"><rect width="400" height="250" fill="url(#grad-marsh)"/><rect x="0" y="150" width="400" height="100" fill="url(#grad-water)"/><g transform="translate(180 60)"><path d="M22 100 L20 160" stroke="#0F2A30" stroke-width="2.5" stroke-linecap="round"/><path d="M28 100 L32 160" stroke="#0F2A30" stroke-width="2.5" stroke-linecap="round"/><path d="M5 80 Q25 65 60 78 Q80 85 90 95 Q82 105 65 103 L30 105 Q10 102 5 80 Z" fill="#0F2A30"/><path d="M55 82 Q45 50 50 25" stroke="#0F2A30" stroke-width="6" stroke-linecap="round" fill="none"/><ellipse cx="52" cy="22" rx="9" ry="6" fill="#0F2A30" transform="rotate(-15 52 22)"/><path d="M58 21 L78 17" stroke="#F9A825" stroke-width="2.5" stroke-linecap="round"/></g></svg>`,
    cycling: `<svg viewBox="0 0 400 250" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice"><rect width="400" height="250" fill="url(#grad-spring)"/><path d="M0,165 Q120,140 240,155 T400,150 L400,200 L0,200 Z" fill="#1F6F8B" opacity=".4"/><path d="M0,200 Q200,210 400,200 L400,250 L0,250 Z" fill="url(#grad-water)"/><path d="M-20,210 Q120,195 280,210 T420,205" stroke="#EAF4F4" stroke-width="20" fill="none" opacity=".7"/><g transform="translate(170 168)"><circle cx="0" cy="20" r="14" fill="none" stroke="#0F2A30" stroke-width="2.5"/><circle cx="40" cy="20" r="14" fill="none" stroke="#0F2A30" stroke-width="2.5"/><path d="M0,20 L15,-2 L30,20 L40,20" stroke="#0F2A30" stroke-width="2.5" fill="none" stroke-linecap="round"/><circle cx="22" cy="-22" r="6" fill="#0F2A30"/></g></svg>`,
    village: `<svg viewBox="0 0 400 250" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice"><rect width="400" height="250" fill="url(#grad-deep)"/><circle cx="320" cy="55" r="25" fill="#EAF4F4" opacity=".85"/><circle cx="312" cy="50" r="22" fill="#0F2A30"/><g fill="#0F2A30"><rect x="30" y="150" width="50" height="50"/><polygon points="22,150 55,118 88,150"/><rect x="148" y="100" width="22" height="100"/><polygon points="142,100 159,72 176,100"/><rect x="170" y="160" width="50" height="40"/><polygon points="162,160 195,128 228,160"/></g><g fill="#F9A825" opacity=".9"><rect x="42" y="170" width="5" height="7"/><rect x="180" y="175" width="5" height="7"/></g><rect x="0" y="200" width="400" height="50" fill="url(#grad-water)"/></svg>`,
    reeds:   `<svg viewBox="0 0 400 250" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice"><rect width="400" height="250" fill="url(#grad-marsh)"/><rect x="0" y="160" width="400" height="90" fill="url(#grad-water)"/><g stroke="#143B43" stroke-width="2.5" stroke-linecap="round" fill="none"><path d="M20,250 L20,140"/><path d="M50,250 L50,135"/><path d="M80,250 L80,145"/><path d="M310,250 L310,160"/><path d="M340,250 L340,155"/><path d="M370,250 L370,138"/></g><g fill="#5b3a1f"><ellipse cx="20" cy="138" rx="3" ry="11"/><ellipse cx="50" cy="133" rx="3" ry="11"/><ellipse cx="80" cy="143" rx="3" ry="11"/><ellipse cx="340" cy="153" rx="3" ry="11"/><ellipse cx="370" cy="136" rx="3" ry="11"/></g></svg>`,
    fishing: `<svg viewBox="0 0 400 250" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice"><rect width="400" height="250" fill="url(#grad-deep)"/><g transform="translate(80 130)"><path d="M0,0 L100,0 L92,22 L8,22 Z" fill="#0F2A30"/><g transform="translate(40 -38)"><circle cx="5" cy="0" r="6" fill="#0F2A30"/><path d="M-2,5 L-5,30 L0,38 L8,38 L12,30 L8,5 Z" fill="#0F2A30"/><path d="M8,12 L40,-15" stroke="#5b3a1f" stroke-width="2" stroke-linecap="round"/></g></g><rect x="0" y="160" width="400" height="90" fill="url(#grad-water)"/></svg>`,
    nature:  `<svg viewBox="0 0 400 250" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice"><rect width="400" height="250" fill="url(#grad-water)"/><g><ellipse cx="100" cy="220" rx="40" ry="9" fill="#43A047"/><ellipse cx="220" cy="180" rx="48" ry="11" fill="#43A047"/><ellipse cx="370" cy="240" rx="44" ry="10" fill="#43A047"/></g><g transform="translate(220 175)"><circle r="9" fill="#fff"/><ellipse cx="-8" cy="-2" rx="7" ry="3.5" fill="#fff" transform="rotate(-30)"/><ellipse cx="8" cy="-2" rx="7" ry="3.5" fill="#fff" transform="rotate(30)"/><circle r="3" fill="#F9A825"/></g></svg>`,
  };

  const ill = type => ILL[type] || ILL.nature;

  const makeCard = p => `
    <article class="post-card">
      <div class="post-card__img">
        ${ill(p.image_type)}
        <div class="post-card__img-overlay"></div>
        <a class="post-card__cat" href="${categoryHref(p.category)}">${escapeHtml(p.category || '')}</a>
      </div>
      <div class="post-card__body">
        <div class="post-card__meta">
          <time>${fmt(p.published_at)}</time>
          <span>·</span>
          <a href="${categoryHref(p.category)}">${escapeHtml(p.category || '')}</a>
        </div>
        <h3 class="post-card__title"><a href="post?id=${p.id}">${escapeHtml(p.title || 'Articolo')}</a></h3>
        <p class="post-card__excerpt">${escapeHtml(p.excerpt || '')}</p>
        <div class="post-card__footer">
          <a href="post?id=${p.id}" class="btn-read">Leggi <svg><use href="#i-arrow-r"/></svg></a>
          <span class="${badgeCls(p.badge_color)}">${escapeHtml(p.badge || p.category || '')}</span>
        </div>
      </div>
    </article>`;

  function renderPosts() {
    const filtered = getFilteredPosts();
    if (!filtered.length) {
      featured.style.display = 'none';
      grid.innerHTML = '';
      if (emptyEl) {
        emptyEl.style.display = '';
        const label = activeCategory === 'all' ? 'nessuna categoria' : activeCategory;
        const lead = emptyEl.querySelector('p[style*="font-family"]');
        const text = emptyEl.querySelector('p[style*="font-size:.88rem"]');
        if (lead) lead.textContent = 'Nessun articolo disponibile';
        if (text) text.textContent = `Non ci sono contenuti pubblicati per ${label}.`;
      }
      return;
    }

    if (emptyEl) emptyEl.style.display = 'none';

    const p0 = filtered[0];
    featured.innerHTML = `
      <div class="post-featured__img">
        ${ill(p0.image_type)}
        <span class="featured-label">In evidenza</span>
      </div>
      <div class="post-featured__body">
        <div class="post-meta">
          <time>${fmt(p0.published_at)}</time>
          <span class="post-meta__dot"></span>
          <a href="${categoryHref(p0.category)}">${escapeHtml(p0.category || '')}</a>
        </div>
        <h2 class="post-featured__title"><a href="post?id=${p0.id}">${escapeHtml(p0.title || 'Articolo')}</a></h2>
        <p class="post-featured__excerpt">${escapeHtml(p0.excerpt || '')}</p>
        <div class="post-featured__footer">
          <a href="post?id=${p0.id}" class="btn-read">Leggi <svg width="14" height="14"><use href="#i-arrow-r"/></svg></a>
          <div class="post-cats"><span class="${badgeCls(p0.badge_color)}">${escapeHtml(p0.badge || p0.category || '')}</span></div>
        </div>
      </div>`;
    featured.style.display = '';

    grid.innerHTML = filtered.slice(1, 7).map(makeCard).join('');
  }

  renderFilters();
  renderPosts();
})();
</script>
<!-- GSAP + ScrollTrigger -->
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12.5/dist/ScrollTrigger.min.js"></script>
<script>
(function() {
  if (typeof gsap === 'undefined') return;
  gsap.registerPlugin(ScrollTrigger);

  /* ─── 1. Hover Physics on cards ─────────────────────────────────── */
  const hoverTargets = '.feature-card, .dato-card, .value-card, .recipe-card-v2, .post-card, .info-card';
  document.querySelectorAll(hoverTargets).forEach(card => {
    card.addEventListener('mouseenter', () => {
      gsap.to(card, { y: -7, scale: 1.025, duration: 0.45, ease: 'power2.out' });
    });
    card.addEventListener('mouseleave', () => {
      gsap.to(card, { y: 0, scale: 1, duration: 0.55, ease: 'power3.out' });
    });
  });

  /* ─── 2. Image Scale & Fade Scroll ──────────────────────────────── */
  const scaleImgs = '.intro-art, .valli-art, .luccio-art-wrap, .hero__float-card';
  document.querySelectorAll(scaleImgs).forEach(el => {
    gsap.fromTo(el,
      { scale: 0.88, opacity: 0.6 },
      {
        scale: 1, opacity: 1,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 88%',
          end: 'top 30%',
          scrub: 1.2,
        }
      }
    );
    /* Fade out as it leaves viewport */
    gsap.to(el, {
      opacity: 0.2,
      scale: 0.95,
      ease: 'power1.in',
      scrollTrigger: {
        trigger: el,
        start: 'bottom 60%',
        end: 'bottom 10%',
        scrub: 1.2,
      }
    });
  });

  /* ─── 3. Fade-up entrances for section text ──────────────────────── */
  document.querySelectorAll('.reveal').forEach((el, i) => {
    if (!el.classList.contains('in')) return; // only re-animate if already revealed
  });
  /* Use GSAP for reveal items that haven't triggered yet */
  document.querySelectorAll('.reveal:not(.in), .reveal-stagger:not(.in)').forEach(el => {
    gsap.fromTo(el,
      { y: 32, opacity: 0 },
      {
        y: 0, opacity: 1,
        duration: 0.9,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          toggleActions: 'play none none none',
        }
      }
    );
  });

  /* ─── 4. Stats counter section: pin label left, scroll right ────── */
  const datSection = document.querySelector('.dati-section');
  if (datSection) {
    const cards = datSection.querySelectorAll('.dato-card');
    cards.forEach((card, i) => {
      gsap.fromTo(card,
        { y: 50, opacity: 0 },
        {
          y: 0, opacity: 1,
          duration: 0.7,
          delay: i * 0.12,
          ease: 'power3.out',
          scrollTrigger: {
            trigger: card,
            start: 'top 82%',
            toggleActions: 'play none none none',
          }
        }
      );
    });
  }

  /* ─── 5. Hero float card subtle parallax ────────────────────────── */
  const floatCard = document.querySelector('.hero__float-card');
  if (floatCard) {
    gsap.to(floatCard, {
      y: -60,
      ease: 'none',
      scrollTrigger: {
        trigger: '.hero',
        start: 'top top',
        end: 'bottom top',
        scrub: 1.5,
      }
    });
  }

})();
</script>

