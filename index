      /* Festa poster: spin + scale entrance */
      anime.animate('.rsm-festa__poster', {
        rotate: [-8, 0], scale: [0.9, 1], opacity: [0, 1],
        duration: 1100, ease: 'out(4)'
      });

      /* Section headings: stagger words */
      var sectionHeadings = $all('.rsm-section-head h2');
      sectionHeadings.forEach(function (heading) {
        if (heading.closest('[data-reveal]')) return;
        var words = heading.querySelectorAll('.word');
        if (words.length) {
          anime.fromTo(words, { opacity: 0, translateY: 12 }, {
            opacity: 1, translateY: 0, duration: 600,
            delay: anime.stagger(40, { start: 200 }), ease: 'out(3)'
          });
        }
      });

      /* Interactive cards: rich hover effects */
      var interactiveCards = $all('.stack-card, .post-card, .rsm-card, .festa-day, .rsm-festa__poster, .rsm-valli');
      interactiveCards.forEach(function (card) {
        card.addEventListener('pointerenter', function () {
          anime.animate(card, { scale: 1.015, translateY: -6, duration: 420, ease: 'out(3)' });
        });
        card.addEventListener('pointerleave', function () {
          anime.animate(card, { scale: 1, translateY: 0, duration: 480, ease: 'out(3)' });
        });
      });

      /* Newsletter form: reveal on view */
      var newsletterForm = $('.rsm-newsletter');
      if (newsletterForm) {
        anime.animate(newsletterForm, {
          scale: [0.92, 1], opacity: [0, 1],
          duration: 900, ease: 'out(4)', delay: 200
        });
      }
    }

    /* ─── Splitting.js: typewriter sui titoli ─── */
    function initSplitting() {
      if (typeof Splitting !== 'function' || !window.gsap) return;
      Splitting({ target: '.rsm-display-1', by: 'words' });
      Splitting({ target: '.rsm-festa__title', by: 'chars' });
      Splitting({ target: '.rsm-valli__drop', by: 'words' });

      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          var el = entry.target;
          var chars = el.querySelectorAll('.char');
          var words = el.querySelectorAll('.word');
          if (chars.length) {
            gsap.fromTo(chars,
              { opacity: 0, y: 14, rotateX: -40 },
              { opacity: 1, y: 0, rotateX: 0, duration: 0.45, stagger: 0.026, ease: 'power3.out', clearProps: 'transform' });
          } else if (words.length) {
            gsap.fromTo(words,
              { opacity: 0, y: 8 },
              { opacity: 1, y: 0, duration: 0.55, stagger: 0.07, ease: 'power2.out', clearProps: 'transform' });
          }
          io.unobserve(el);
        });
      }, { threshold: 0.25 });

      document.querySelectorAll('.rsm-display-1, .rsm-festa__title, .rsm-valli__drop').forEach(function (el) {
        io.observe(el);
      });
    }

    /* ─── Tippy popups (.kw) ─── */
    var KW_FALLBACK = {
      'lago-di-garda':     { title: 'Lago di Garda',                    body: 'Il Mincio nasce dall\'uscita meridionale del Garda e alimenta il sistema delle Valli.' },
      'anno-1984':         { title: 'Riserva dal 1984',                 body: 'La Riserva Naturale Valli del Mincio viene istituita nel 1984 con tutela regionale specifica.' },
      'ramsar':            { title: 'Convenzione di Ramsar',            body: 'Trattato internazionale del 1971 per la tutela e l\'uso razionale delle zone umide.' },
      'natura-2000':       { title: 'Rete Natura 2000',                 body: 'Rete europea di siti protetti per habitat e specie, fondata sulle direttive Uccelli e Habitat.' },
      'mincio':            { title: 'Mincio',                            body: 'Fiume emissario del Garda che attraversa Mantova e crea un corridoio idraulico-ecologico unico.' },
      'zona-umida':        { title: 'Zona umida',                        body: 'Ambiente di transizione tra terra e acqua, fondamentale per biodiversita, depurazione naturale e mitigazione idraulica.' },
      'biodiversita':      { title: 'Biodiversita',                      body: 'Varieta di geni, specie ed ecosistemi: nelle Valli indica la ricchezza biologica del mosaico acquatico.' },
      'uccelli-acquatici': { title: 'Uccelli acquatici',                 body: 'Nelle Valli si osservano specie stanziali e migratrici legate a canneti, chiari e acque basse.' },
      'airone-cenerino':   { title: 'Airone cenerino',                   body: 'Ardeide comune nelle zone umide europee, predatore di pesci, anfibi e piccoli vertebrati.' },
      'garzetta':          { title: 'Garzetta',                           body: 'Piccolo airone bianco, specie tipica di acque basse e rive fangose ricche di prede.' },
      'nitticora':         { title: 'Nitticora',                          body: 'Airone crepuscolare e notturno: nelle zone umide usa canneti e alberature ripariali per riposo e nidificazione.' },
      'pianura-padana':    { title: 'Pianura Padana',                    body: 'Grande pianura alluvionale dell\'Italia settentrionale, dove le Valli sono uno dei principali sistemi umidi residui.' },
      'canneti':           { title: 'Canneto (Phragmites australis)',    body: 'Formazione vegetale dominante nei margini d\'acqua: stabilizza sponde e ospita molte specie di avifauna.' },
      'fitodepurazione':   { title: 'Fitodepurazione',                    body: 'Processo in cui piante, microrganismi e substrato contribuiscono alla riduzione degli inquinanti in acqua.' },
      'eutrofizzazione':   { title: 'Eutrofizzazione',                    body: 'Arricchimento eccessivo di nutrienti che puo alterare equilibrio ecologico e ossigenazione delle acque.' },
      'canne-palustri':    { title: 'Raccolta delle canne',              body: 'Pratica storica locale per ottenere materiale da copertura e intreccio legato all\'economia del fiume.' },
      'arelle':            { title: 'Arelle',                             body: 'Stuoie intrecciate in canna o giunco, testimonianza artigianale della cultura materiale delle Valli.' },
      'martin-pescatore':  { title: 'Martin pescatore (Alcedo atthis)',   body: 'Specie indicatrice della qualita dell\'acqua, visibile lungo rive tranquille e canali secondari.' }
    };
    var _kwClientCache = Object.create(null);
    function buildKwPopupHtml(key, data) {
      var fb = KW_FALLBACK[key] || {};
      var title = fb.title || key;
      var html = '<strong class="kw-pop-title">' + title + '</strong>';
      if (data && data.wiki) html += '<p class="kw-pop-wiki">' + data.wiki + '</p>';
      else if (fb.body)     html += '<p class="kw-pop-wiki">' + fb.body + '</p>';
      if (data && data.claude) html += '<p class="kw-pop-claude"><span class="kw-pop-label">Sul Mincio</span>' + data.claude + '</p>';
      return html;
    }
    function initKwPopups() {
      if (typeof tippy !== 'function') return;
      document.querySelectorAll('.kw[data-kw]').forEach(function (el) {
        var key = el.dataset.kw;
        var label = el.textContent.trim();
        tippy(el, {
          content: '<span class="kw-loading">· · ·</span>',
          allowHTML: true, theme: 'rsm', placement: 'top', maxWidth: 320,
          delay: [200, 80], touch: ['hold', 500], interactive: false,
          onShow: function (i) {
            if (_kwClientCache[key]) { i.setContent(_kwClientCache[key]); return; }
            var url = '/api/kw-context?kw=' + encodeURIComponent(key) + '&title=' + encodeURIComponent(label);
            fetch(url)
              .then(function (r) { return r.ok ? r.json() : null; })
              .then(function (data) { var html = buildKwPopupHtml(key, data); _kwClientCache[key] = html; i.setContent(html); })
              .catch(function () { var html = buildKwPopupHtml(key, null); _kwClientCache[key] = html; i.setContent(html); });
          }
        });
      });
    }

    /* ─── DOMContentLoaded ─── */
    document.addEventListener('DOMContentLoaded', function () {
      var year = $('#year');
      if (year) year.textContent = String(new Date().getFullYear());
      initReveal();
      initCounters();
      initMagneticButtons();
      initNewsletter();
      initModals();
      initPosts();
      initGsap();
      initAnimeJs();
      initKwPopups();
      initSplitting();
    });
  })();
  </script>
  <!-- ════════════════════════════════════════════════════════════
       PREMIUM EDITORIAL LAYER — JS (stagger + mouse-tracking)
       ════════════════════════════════════════════════════════════ -->
  <script>
  (function(){
    var reduced = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function revealStaggerBlock(node) {
      if (!node) return;
      node.classList.add('is-visible');
      node.querySelectorAll('.rsm-edit-line').forEach(function(line){ line.classList.add('is-in'); });
    }

    /* ── Stagger reveal ── */
    if ('IntersectionObserver' in window) {
      var io = new IntersectionObserver(function(entries){
        entries.forEach(function(entry){
          if (!entry.isIntersecting) return;
          revealStaggerBlock(entry.target);
          io.unobserve(entry.target);
        });
      }, { threshold: 0.18, rootMargin: '0px 0px -6% 0px' });

      document.querySelectorAll('[data-rsm-edit-stagger]').forEach(function(n){
        io.observe(n);
        var rect = n.getBoundingClientRect();
        if (rect.top < window.innerHeight * 0.9 && rect.bottom > 0) {
          revealStaggerBlock(n);
        }
      });
    } else {
      document.querySelectorAll('[data-rsm-edit-stagger]').forEach(function(n){ revealStaggerBlock(n); });
    }

    /* Banner: trigger immediato (sopra il fold) */
    var banner = document.querySelector('[data-rsm-edit-banner]');
    if (banner) {
      banner.querySelectorAll('.rsm-edit-line').forEach(function(n){ n.classList.add('is-in'); });
    }

    if (reduced) return;

    /* ── Mouse-tracking aurora (banner + compass) ── */
    function bindAurora(scope, auroraEl){
      if (!scope || !auroraEl) return;

      scope.addEventListener('pointermove', function(e){
        var rect = scope.getBoundingClientRect();
        if (!rect.width || !rect.height) return;
        var x = ((e.clientX - rect.left) / rect.width) * 100;
        var y = ((e.clientY - rect.top) / rect.height) * 100;
        auroraEl.style.setProperty('--mx', x.toFixed(2) + '%');
        auroraEl.style.setProperty('--my', y.toFixed(2) + '%');
      }, { passive: true });
    }

    var bannerScope = document.querySelector('[data-rsm-edit-banner]');
    if (bannerScope) bindAurora(bannerScope, bannerScope.querySelector('.rsm-banner__aurora'));

    var compassScope = document.querySelector('[data-rsm-edit-compass]');
    if (compassScope) bindAurora(compassScope, compassScope.querySelector('.rsm-compass__aurora'));
  })();
  </script>
