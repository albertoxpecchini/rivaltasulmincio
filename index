      --rsm-flat-panel-border: rgba(255, 255, 255, 0.12);
      --rsm-flat-panel-shadow: 0 18px 40px rgba(4, 10, 34, 0.22), inset 0 1px 0 rgba(255, 255, 255, 0.05);
