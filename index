      --line-dark: rgba(255, 250, 240, 0.16);
      --shadow: 0 26px 80px rgba(37, 63, 53, 0.16);
      --shadow-strong: 0 42px 110px rgba(23, 34, 29, 0.28);
      --ease: cubic-bezier(0.32, 0.72, 0, 1);
