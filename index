      left: 30vmax;
      background: radial-gradient(circle, rgba(139, 92, 246, 0.42), rgba(139, 92, 246, 0) 65%);
      animation-delay: -16s;
      animation-duration: 36s;
    }
    .rsm-aurora::after {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at 50% 50%, rgba(255,255,255,0) 0%, rgba(255,255,255,0.65) 90%),
        linear-gradient(180deg, rgba(255,255,255,0.30), rgba(255,255,255,0.10));
    }
    @keyframes rsm-aurora-float {
      0%, 100% { transform: translate3d(0, 0, 0) rotate(0deg) scale(1); }
      33%      { transform: translate3d(8vmax, 4vmax, 0) rotate(60deg) scale(1.08); }
      66%      { transform: translate3d(-6vmax, 8vmax, 0) rotate(-30deg) scale(0.94); }
    }

