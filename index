        <div class="recipe-card-v2__body">
          <div class="recipe-ingr">
            <div class="recipe-ingr__label">Ingredienti</div>
            <div class="recipe-ingr__list">
              <span class="recipe-ingr__pill">Luccio (500–1000 g)</span>
              <span class="recipe-ingr__pill">Limone</span>
              <span class="recipe-ingr__pill">Cedro di Gargnano del Garda</span>
              <span class="recipe-ingr__pill">Olio EVO Lago di Garda</span>
              <span class="recipe-ingr__pill">Grana Padano</span>
              <span class="recipe-ingr__pill">Noce moscata</span>
              <span class="recipe-ingr__pill">Pepe nero</span>
