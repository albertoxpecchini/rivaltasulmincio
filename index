(async function loadPosts() {
  if (typeof SUPABASE_URL === 'undefined' || SUPABASE_URL.includes('your-project')) return;

  const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  const fallbackCategories = ['Eventi', 'Territorio', 'Vita locale', 'Avvisi', 'Richieste', 'Storie'];
  const categories = window.RSM_CATEGORIES ? window.RSM_CATEGORIES.all() : fallbackCategories;
  const canonicalCategory = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.canonical(value)
    : String(value || '').trim();
  const badgeColorByCategory = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.badgeColor(value)
    : 'default';
  const categoryHref = (value) => window.RSM_CATEGORIES
    ? window.RSM_CATEGORIES.categoryHref(value)
    : ('category?name=' + encodeURIComponent(canonicalCategory(value)));
  const escapeHtml = (value) => String(value || '')
    .replace(/&/g, '&amp;')
    .replace(/</g, '&lt;')
    .replace(/>/g, '&gt;')
    .replace(/"/g, '&quot;')
    .replace(/'/g, '&#39;');
  const sanitizePost = (post) => {
    const category = canonicalCategory(post.category) || 'Territorio';
    return {
      ...post,
      category,
      badge_color: post.badge_color || badgeColorByCategory(category),
    };
  };

  const { data: posts, error } = await sb
    .from('posts')
    .select('id, title, excerpt, category, badge, badge_color, image_type, published_at')
    .eq('published', true)
    .order('published_at', { ascending: false })
    .limit(60);

