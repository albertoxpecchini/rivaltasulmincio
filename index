       diamo un riquadro glass-dark per riportare contrasto ai testi bianchi. */
    .rsm-hero,
    .rsm-compass,
    .rsm-festa,
    .rsm-events,
    .rsm-gallery,
    .rsm-territory,
    .rsm-contact,
    .rsm-newsletter,
