      .hero-title {
        max-width: 100%;
        white-space: normal;
        overflow-wrap: break-word;
        word-break: break-word;
      }

      .hero-media {
        order: 0;
        aspect-ratio: auto;
        min-height: auto;
        overflow: hidden;
        border-radius: 16px;
      }

      .hero-photo-main {
        inset: 22px 0 118px 18px;
      }

      .hero-photo-side {
        width: 54%;
        bottom: 58px;
      }

      .hero-photo-tiny {
        width: 50%;
        right: 0;
      }

      .hero-note {
        left: 18px;
        top: 0;
        width: 150px;
      }

      .section-head,
      .stack-card-inner,
      .post-featured {
        grid-template-columns: 1fr;
      }

      .section {
        padding: 78px 0;
      }

      .fact-grid,
      .post-card-grid {
        grid-template-columns: 1fr;
      }

      .atlas-photo .photo-slot,
      .map-plate,
      .map-plate .photo-slot {
        min-height: 460px;
      }

      .map-plate .rsm-swiper--map {
        min-height: 460px;
      }

      .stack-card,
      .stack-card-inner,
      .stack-card .photo-slot {
        min-height: auto;
      }

      .stack-card .photo-slot {
        min-height: 320px;
      }

      .rsm-swiper {
        height: 260px;
      }

      .rsm-swiper--hero {
        aspect-ratio: auto;
        height: 280px;
        border-radius: 16px;
      }

      .rsm-slide {
        width: 100%;
        height: 100%;
      }

      .button-row {
        flex-direction: column;
        align-items: flex-start;
      }

      .button {
        min-height: 44px;
        padding: 6px 8px 6px 16px;
        font-size: 0.9rem;
