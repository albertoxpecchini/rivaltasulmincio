<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard - Rivalta sul Mincio</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Sora:wght@400;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      color-scheme: light;
      --bg: #f5f5f7;
      --sb: rgba(255,255,255,.86);
      --surface: #ffffff;
      --surface-2: rgba(245,245,247,.94);
      --border: #d2d2d7;
      --text: #1d1d1f;
      --muted: #86868b;
      --p: #2253df;
      --a: #0da9d6;
      --g: #0a996a;
      --warn: #da8c23;
      --err: #b94747;
      --ok: #1b8d61;
      --accent: #1F6F8B;
      --accent-2: #3a8c8a;
      --radius: 22px;
    }

    body {
      min-height: 100vh;
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Sans', 'Segoe UI', sans-serif;
      line-height: 1.5;
      overflow-x: hidden;
    }

    .layout {
      position: relative;
      z-index: 1;
      display: grid;
      grid-template-columns: 1fr;
      min-height: 100vh;
    }

    .sidebar { display: none; }

    .sb-brand {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 8px;
      border-radius: 12px;
      border: 1px solid var(--border);
      background: var(--surface-2);
    }

    .sb-logo {
      width: 34px;
      height: 34px;
      border-radius: 10px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg,#1F6F8B,#3a8c8a);
      font-size: 1rem;
      color: #fff;
    }

    .sb-name {
      font-family: 'Sora', sans-serif;
      background: linear-gradient(135deg,#163748,#3a8c8a);
      background-clip: text;
      -webkit-background-clip: text;
      color: transparent;
      -webkit-text-fill-color: transparent;
    }

    .sb-menu {
      display: grid;
      gap: 6px;
      margin-top: 4px;
    }

    .sb-item {
      width: 100%;
      text-align: left;
      display: inline-flex;
      align-items: center;
      gap: 10px;
      padding: 10px 11px;
      border-radius: 10px;
      border: 1px solid transparent;
      background: transparent;
      color: var(--muted);
      font-size: .87rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      transition: all .2s;
    }

    .sb-item:hover {
      color: var(--text);
      border-color: #bfd0da;
      background: #eef5f9;
    }

    .sb-item.on {
      color: var(--text);
      border-color: rgba(58,140,138,.33);
      background: rgba(58,140,138,.12);
    }

    .sidebar-foot {
      margin-top: auto;
      display: grid;
      gap: 6px;
    }

    .main {
      padding: 20px;
      width: min(1360px, 100%);
      margin: 0 auto;
      display: grid;
      gap: 16px;
    }

    .topbar {
      position: sticky; top: 0; z-index: 100;
      height: 52px;
      background: rgba(255,255,255,.94); backdrop-filter: blur(14px);
      border-bottom: 1px solid rgba(0,0,0,.06);
      display: flex; align-items: center; justify-content: space-between;
      padding: 0 20px;
    }

    .top-brand {
      display: inline-flex; align-items: center; gap: 8px;
      font-family: 'Sora', sans-serif; font-size: .88rem; font-weight: 700;
      color: var(--text); text-decoration: none; letter-spacing: -.01em;
    }

    .top-logo {
      width: 28px; height: 28px; border-radius: 8px; flex-shrink: 0;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      display: inline-flex; align-items: center; justify-content: center;
      font-size: .78rem; color: #fff; font-weight: 700;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      border-radius: 9px;
      border: 1px solid var(--border);
      background: var(--surface);
      color: var(--text);
      font-family: 'DM Sans', sans-serif;
      font-size: .82rem;
      font-weight: 600;
      padding: 8px 14px;
      cursor: pointer;
      text-decoration: none;
      transition: all .15s;
    }

    .btn:hover {
      border-color: #aaa;
    }
    .btn:disabled { opacity: .55; cursor: not-allowed; }

    .btn-primary {
      border-color: transparent;
      background: linear-gradient(135deg, #1F6F8B, #3a8c8a);
      color: #fff;
      box-shadow: 0 4px 16px rgba(31,111,139,.28);
    }
    .btn-primary:hover { box-shadow: 0 6px 22px rgba(31,111,139,.4); border-color: transparent; }

    .btn-ghost {
      color: var(--muted);
    }

    .card {
      border: 1px solid var(--border);
      border-radius: var(--radius);
      background: var(--surface);
      padding: 16px;
    }

    .dash-head {
      display: grid;
      gap: 12px;
    }

    .dash-head-top {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 14px;
      flex-wrap: wrap;
    }

    .dash-head h1 {
      font-family: 'Sora', sans-serif;
      font-size: clamp(1.45rem, 2.7vw, 2rem);
      line-height: 1.1;
      margin-bottom: 6px;
    }

    .dash-head p {
      color: var(--muted);
      font-size: .86rem;
      max-width: 720px;
    }

    .head-meta {
      display: flex;
      gap: 10px;
      flex-wrap: wrap;
      align-items: center;
    }

    .chip {
      border: 1px solid var(--border);
      border-radius: 999px;
      background: linear-gradient(180deg, rgba(255,255,255,.9), rgba(245,249,255,.84));
      color: var(--muted);
      padding: 6px 10px;
      font-size: .75rem;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      gap: 7px;
    }

    .select {
      border: 1px solid var(--border);
      border-radius: 999px;
      appearance: none;
      background: rgba(244,248,255,.95);
      background-image:
        linear-gradient(45deg, transparent 50%, #5f6c8f 50%),
        linear-gradient(135deg, #5f6c8f 50%, transparent 50%);
      background-position:
        calc(100% - 16px) calc(50% - 2px),
        calc(100% - 11px) calc(50% - 2px);
      background-size: 5px 5px, 5px 5px;
      background-repeat: no-repeat;
      color: var(--text);
      padding: 7px 32px 7px 12px;
      font-family: inherit;
      font-size: .8rem;
      font-weight: 700;
    }

    .select:focus,
    .field select:focus {
      outline: none;
      border-color: rgba(34,83,223,.52);
      box-shadow: 0 0 0 3px rgba(34,83,223,.15);
    }

    .select option,
    .field select option {
      background: #ffffff;
      color: var(--text);
    }

    .kpi-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 10px;
    }

    .kpi {
      border: 1px solid var(--border);
      border-radius: 13px;
      background: var(--surface-2);
      padding: 12px;
      display: grid;
      gap: 7px;
    }

    .kpi-label {
      color: var(--muted);
      font-size: .74rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      font-weight: 700;
    }

    .kpi-value {
      font-family: 'Sora', sans-serif;
      font-size: 1.8rem;
      line-height: 1;
      color: var(--text);
    }

    .kpi-meta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap;
      font-size: .75rem;
      color: var(--muted);
    }

    .delta {
      font-weight: 700;
      letter-spacing: .02em;
    }

    .delta.up { color: #9be3a0; }
    .delta.down { color: #ef9a9a; }
    .delta.same { color: #b0bec5; }

    .section-title {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
      margin-bottom: 10px;
    }

    .section-title h2 {
      font-family: 'Sora', sans-serif;
      font-size: 1.2rem;
    }

    .section-title p {
      color: var(--muted);
      font-size: .8rem;
    }

    .group-switch {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
    }

    .switch-btn {
      border: 1px solid var(--border);
      border-radius: 999px;
      background: rgba(245,249,255,.9);
      color: var(--muted);
      font-size: .75rem;
      font-weight: 700;
      padding: 6px 11px;
      cursor: pointer;
      transition: transform .2s ease, box-shadow .2s ease, background .2s ease;
    }

    .switch-btn.on {
      color: #fff;
      border-color: transparent;
      background: linear-gradient(135deg, #1e3fd4 0%, #2253df 47%, #0da9d6 100%);
      box-shadow: 0 10px 24px rgba(34,83,223,.28);
    }

    .chart-wrap {
      border: 1px solid var(--border);
      border-radius: 18px;
      background: linear-gradient(180deg, rgba(255,255,255,.82) 0%, rgba(246,250,255,.76) 100%);
      padding: 14px;
    }

    .chart-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 8px;
      flex-wrap: wrap;
      margin-bottom: 10px;
      font-size: .78rem;
      color: var(--muted);
    }

    .chart-bars {
      height: 210px;
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(10px, 1fr);
      align-items: end;
      gap: 4px;
      border-bottom: 1px solid rgba(105,124,168,.22);
      padding: 12px 2px 10px;
    }

    .bar {
      border-radius: 6px 6px 3px 3px;
      background: linear-gradient(180deg, rgba(13,169,214,.95), rgba(34,83,223,.64));
      min-height: 3px;
      position: relative;
      box-shadow: 0 8px 16px rgba(34,83,223,.18);
    }

    .bar::after {
      content: attr(data-v);
      position: absolute;
      top: -20px;
      left: 50%;
      transform: translateX(-50%);
      font-size: .66rem;
      color: var(--muted);
      opacity: 0;
      transition: opacity .2s;
      pointer-events: none;
    }

    .bar:hover::after { opacity: 1; }

    .chart-labels {
      margin-top: 6px;
      display: grid;
      grid-auto-flow: column;
      grid-auto-columns: minmax(10px, 1fr);
      gap: 4px;
    }

    .chart-label {
      text-align: center;
      font-size: .65rem;
      color: var(--muted);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .ops-grid {
      display: grid;
      grid-template-columns: 1.1fr 1fr 1fr;
      gap: 10px;
    }

    .ops-card {
      border: 1px solid var(--border);
      border-radius: 13px;
      background: var(--surface-2);
      padding: 12px;
      display: grid;
      gap: 10px;
      min-height: 240px;
      align-content: start;
    }

    .ops-card h3 {
      font-family: 'Sora', sans-serif;
      font-size: .98rem;
      margin-bottom: 2px;
    }

    .ops-card p {
      color: var(--muted);
      font-size: .76rem;
      line-height: 1.45;
    }

    .list {
      display: grid;
      gap: 8px;
    }

    .list-item {
      border: 1px solid rgba(105,124,168,.24);
      border-radius: 14px;
      background: linear-gradient(180deg, rgba(255,255,255,.94), rgba(246,250,255,.86));
      padding: 9px;
      display: grid;
      gap: 4px;
    }

    .list-item strong {
      font-size: .84rem;
      line-height: 1.35;
      color: var(--text);
      font-weight: 600;
    }

    .mini-meta {
      font-size: .72rem;
      color: var(--muted);
      display: inline-flex;
      align-items: center;
      gap: 7px;
      flex-wrap: wrap;
    }

    .pill {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      border-radius: 999px;
      font-size: .68rem;
      font-weight: 700;
      letter-spacing: .03em;
      padding: 3px 8px;
      border: 1px solid rgba(105,124,168,.24);
      color: var(--muted);
      background: rgba(255,255,255,.66);
    }

    .pill.draft {
      color: #b16b12;
      border-color: rgba(218,140,35,.28);
      background: rgba(218,140,35,.14);
    }

    .pill.pub {
      color: #136f4f;
      border-color: rgba(10,153,106,.3);
      background: rgba(10,153,106,.14);
    }

    .note-line {
      font-size: .73rem;
      color: var(--muted);
      line-height: 1.45;
      border-top: 1px solid var(--border);
      padding-top: 8px;
    }

    .empty-state {
      border: 1px dashed rgba(105,124,168,.34);
      border-radius: 16px;
      background: rgba(251,253,255,.82);
      padding: 14px;
      text-align: center;
      display: grid;
      gap: 7px;
    }

    .empty-state p {
      color: var(--muted);
      font-size: .83rem;
      line-height: 1.45;
    }

    .tiny {
      font-size: .7rem;
      color: var(--muted);
    }

    .toast {
      position: fixed;
      bottom: 22px;
      right: 22px;
      z-index: 70;
      border: 1px solid var(--border);
      border-radius: 11px;
      background: rgba(255,255,255,.98);
      color: var(--text);
      padding: 10px 14px;
      font-size: .82rem;
      transform: translateY(12px);
      opacity: 0;
      transition: all .22s;
      pointer-events: none;
      box-shadow: 0 10px 25px rgba(15,45,62,.18);
    }

    .toast.show {
      opacity: 1;
      transform: none;
    }

    .toast.err { color: var(--err); }
    .toast.ok { color: var(--ok); }

    .modal-backdrop {
      position: fixed;
      inset: 0;
      z-index: 60;
      background: rgba(14,42,56,.24);
      backdrop-filter: blur(4px);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 16px;
    }

    .modal-backdrop.open { display: flex; }

    .modal {
      width: min(760px, 100%);
      border: 1px solid var(--border);
      border-radius: 16px;
      background: #ffffff;
      box-shadow: 0 20px 60px rgba(15,45,62,.20);
      overflow: hidden;
    }

    .modal-head {
      padding: 13px 14px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      flex-wrap: wrap;
    }

    .modal-head h3 {
      font-family: 'Sora', sans-serif;
      font-size: 1rem;
    }

    .modal-body {
      padding: 14px;
      display: grid;
      gap: 10px;
    }

    .field {
      display: grid;
      gap: 5px;
    }

    .field label {
      font-size: .74rem;
      text-transform: uppercase;
      letter-spacing: .05em;
      color: var(--muted);
      font-weight: 700;
    }

    .field input,
    .field textarea,
    .field select {
      width: 100%;
      border-radius: 10px;
      border: 1px solid var(--border);
      background: #ffffff;
      color: var(--text);
      font-family: inherit;
      font-size: .88rem;
      padding: 9px 11px;
    }

    .field textarea {
      min-height: 120px;
      resize: vertical;
      line-height: 1.55;
    }

    .field select {
      appearance: none;
      background-image:
        linear-gradient(45deg, transparent 50%, #587282 50%),
        linear-gradient(135deg, #587282 50%, transparent 50%);
      background-position:
        calc(100% - 16px) calc(50% - 2px),
        calc(100% - 11px) calc(50% - 2px);
      background-size: 5px 5px, 5px 5px;
      background-repeat: no-repeat;
      padding-right: 30px;
    }

    .modal-actions {
      padding: 0 14px 14px;
      display: flex;
      gap: 9px;
      flex-wrap: wrap;
      justify-content: flex-end;
    }

    .modal-msg {
      min-height: 18px;
      color: var(--err);
      font-size: .8rem;
      padding: 0 14px 4px;
    }

    .mobile-nav {
      display: none;
      position: sticky;
      top: 8px;
      z-index: 21;
      border: 1px solid var(--border);
      border-radius: 16px;
      background: rgba(255,255,255,.8);
      backdrop-filter: blur(14px);
      padding: 8px;
      gap: 6px;
      grid-template-columns: repeat(5, minmax(0, 1fr));
      box-shadow: 0 12px 28px rgba(17,33,76,.12);
    }

    .mobile-nav button,
    .mobile-nav a {
      border: 1px solid rgba(105,124,168,.24);
      background: linear-gradient(180deg, rgba(255,255,255,.9), rgba(244,248,255,.84));
      color: var(--muted);
      border-radius: 11px;
      padding: 8px 6px;
      text-align: center;
      font-size: .7rem;
      font-weight: 700;
      text-decoration: none;
      font-family: inherit;
      cursor: pointer;
    }

    .mobile-nav button.on {
      color: #fff;
      border-color: rgba(34,83,223,.4);
      background: linear-gradient(135deg, #1e3fd4 0%, #2253df 47%, #0da9d6 100%);
      box-shadow: 0 10px 20px rgba(34,83,223,.25);
    }

    /* ====== BENTO GRID ====== */
    .bento {
      display: grid;
      gap: 12px;
      grid-template-columns: 1fr 1fr 1fr;
      grid-template-areas:
        "hero  posts  stat"
        "hero  views  stat"
        "chart chart  draft"
        "recent notif motto";
    }

    .bc {
      background: linear-gradient(165deg, rgba(255,255,255,.78) 0%, rgba(243,247,255,.72) 100%);
      backdrop-filter: blur(18px);
      border: 1px solid var(--border);
      border-radius: 26px;
      padding: 22px 24px;
      display: flex;
      flex-direction: column;
      position: relative;
      overflow: hidden;
      box-shadow: 0 14px 34px rgba(17,33,76,.11);
      transition: transform .3s ease, box-shadow .3s ease;
      opacity: 0;
      animation: cardIn .58s cubic-bezier(.2,.7,.2,1) forwards;
    }

    .bc:hover {
      transform: translateY(-3px);
      box-shadow: 0 18px 36px rgba(17,33,76,.16);
    }

    .bc:nth-of-type(1) { animation-delay: .03s; }
    .bc:nth-of-type(2) { animation-delay: .08s; }
    .bc:nth-of-type(3) { animation-delay: .12s; }
    .bc:nth-of-type(4) { animation-delay: .16s; }
    .bc:nth-of-type(5) { animation-delay: .2s; }
    .bc:nth-of-type(6) { animation-delay: .24s; }
    .bc:nth-of-type(7) { animation-delay: .28s; }
    .bc:nth-of-type(8) { animation-delay: .32s; }

    @keyframes cardIn {
      from { opacity: 0; transform: translateY(16px) scale(.99); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .bc-hero {
      grid-area: hero;
      justify-content: flex-start;
      padding: 30px;
      background:
        radial-gradient(circle at 86% 14%, rgba(34,83,223,.22), transparent 34%),
        linear-gradient(160deg, rgba(255,255,255,.82) 0%, rgba(244,249,255,.76) 100%);
    }
    .bc-hero::before {
      content: '';
      position: absolute;
      top: 0; left: 0; right: 0;
      height: 5px;
      background: linear-gradient(90deg, #1e3fd4, #2253df, #0da9d6, #0a996a);
      border-radius: 26px 26px 0 0;
    }

    .bc-eyebrow {
      font-size: .71rem;
      font-weight: 700;
      color: #2253df;
      text-transform: uppercase;
      letter-spacing: .09em;
      margin-bottom: 10px;
    }

    .bc-title {
      font-family: 'Sora', sans-serif;
      font-size: clamp(2.2rem, 4vw, 2.8rem);
      font-weight: 700;
      color: var(--text);
      letter-spacing: -.03em;
      line-height: 1.1;
      margin-bottom: 8px;
    }

    .bc-sub {
      font-size: .88rem;
      color: var(--muted);
      line-height: 1.56;
      flex: 1;
      max-width: 46ch;
    }

    .bc-hero-foot {
      margin-top: 20px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .bc-hero-foot .period-row {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .hero-stats {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
    }

    .hero-stat {
      border: 1px solid rgba(105,124,168,.24);
      border-radius: 16px;
      padding: 10px 12px;
      background: linear-gradient(180deg, rgba(255,255,255,.86), rgba(244,248,255,.72));
      display: grid;
      gap: 2px;
    }

    .hero-stat-label {
      font-size: .67rem;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .06em;
    }

    .hero-stat-value {
      font-size: 1.18rem;
      font-weight: 800;
      letter-spacing: -.02em;
      color: #163db8;
      line-height: 1.15;
    }

    .bc-kpi {
      background: linear-gradient(180deg, rgba(255,255,255,.84), rgba(243,248,255,.7));
      justify-content: center;
    }

    .bc-kpi-lbl {
      font-size: .7rem;
      font-weight: 700;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: .07em;
      margin-bottom: 8px;
    }

    .bc-kpi-val {
      font-family: 'Sora', sans-serif;
      font-size: 2.6rem;
      font-weight: 700;
      letter-spacing: -.03em;
      line-height: 1;
      color: #1238b0;
      margin-bottom: 6px;
    }

    .bc-kpi-meta { font-size: .74rem; color: var(--muted); display: flex; align-items: center; gap: 7px; flex-wrap: wrap; }

    .bc-stat {
