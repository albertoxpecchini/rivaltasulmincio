  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink: #10192b;
      --ink-soft: #5a6882;
      --cream: #f4f7ff;
      --paper: #fbfdff;
      --marsh: #12203a;
      --water: #4a9bff;
      --reed: #1fbf7d;
      --line: rgba(18,32,58,0.14);
      --sans: "Cabinet Grotesk", system-ui, sans-serif;
      --serif: "Fraunces", Georgia, serif;
    }

    body {
      min-height: 100vh;
      background:
        radial-gradient(ellipse 80% 52% at 18% 8%, rgba(31,191,125,.16) 0%, transparent 60%),
        radial-gradient(ellipse 60% 44% at 82% 10%, rgba(74,155,255,.18) 0%, transparent 58%),
        radial-gradient(ellipse 56% 42% at 84% 84%, rgba(139,92,246,.12) 0%, transparent 60%),
        linear-gradient(160deg, #f8fbff 0%, #eef4ff 46%, #e8eefb 100%);
      color: var(--ink);
      font-family: var(--sans);
      line-height: 1.55;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      background-image: radial-gradient(circle, rgba(18,32,58,.08) 1px, transparent 1px);
      background-size: 18px 18px;
      mix-blend-mode: multiply;
      opacity: 0.16;
    }

    

    /* ── Page ── */
    .page {
      position: relative;
      z-index: 1;
      max-width: 980px;
      margin: 0 auto;
      padding: 100px 20px 60px;
    }

    .page-head { margin-bottom: 20px; }
    .page-head h1 {
      font-family: var(--serif);
      font-size: 1.6rem;
      font-weight: 650;
      margin-bottom: 4px;
    }
    .page-head p { font-size: .88rem; color: var(--ink-soft); }

    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 12px;
    }

    .card {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 16px;
      box-shadow: 0 1px 6px rgba(37,63,53,.05);
    }
    .card h2 {
      font-size: .85rem;
      text-transform: uppercase;
      letter-spacing: .06em;
      color: var(--ink-soft);
      margin-bottom: 10px;
      font-weight: 700;
    }
    .result { font-size: .82rem; font-family: 'Courier New', monospace; line-height: 1.6; word-break: break-all; }
    .ok      { color: #2E7D32; }
    .err     { color: #b94747; }
    .pending { color: var(--ink-soft); }

    .badge { display: inline-block; padding: 2px 8px; border-radius: 999px; font-size: .72rem; font-weight: 700; margin-right: 4px; }
    .badge-ok   { background: rgba(46,125,50,.12); color: #2E7D32; }
    .badge-err  { background: rgba(185,71,71,.10); color: #b94747; }
    .badge-skip { background: rgba(37,63,53,.07); color: var(--ink-soft); }

    pre { white-space: pre-wrap; margin-top: 6px; font-size: .78rem; color: var(--ink-soft); }

    .summary {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 14px;
      padding: 16px;
      margin-bottom: 16px;
      display: flex;
      gap: 16px;
      align-items: center;
      flex-wrap: wrap;
      box-shadow: 0 1px 6px rgba(37,63,53,.05);
    }
    .summary strong { font-size: 1.1rem; }

    .run-btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 18px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: var(--marsh);
      color: var(--cream);
      font-family: var(--sans);
      font-size: .84rem;
      font-weight: 700;
      cursor: pointer;
      margin-bottom: 16px;
      transition: opacity .2s;
    }
    .run-btn:hover { opacity: .82; }

    .config-card {
      margin-bottom: 16px;
      display: grid;
      gap: 12px;
    }

    .config-copy {
      font-size: .84rem;
      color: var(--ink-soft);
    }

    .config-grid {
      display: grid;
      gap: 12px;
    }

    .field {
      display: grid;
      gap: 6px;
    }

    .field span {
      font-size: .76rem;
      font-weight: 700;
      color: var(--ink-soft);
      letter-spacing: .04em;
      text-transform: uppercase;
    }

    .field input,
    .field textarea {
      width: 100%;
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fffdf8;
      color: var(--ink);
      font-family: var(--sans);
      font-size: .86rem;
      padding: 11px 12px;
    }

    .field textarea {
      min-height: 120px;
      resize: vertical;
      font-family: 'Courier New', monospace;
      font-size: .78rem;
      line-height: 1.45;
    }

    .field input:focus,
    .field textarea:focus {
      outline: none;
      border-color: var(--water);
      box-shadow: 0 0 0 3px rgba(47,107,103,.12);
    }

    .config-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: center;
    }

    .btn-inline {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 9px 14px;
      border-radius: 999px;
      border: 1px solid var(--line);
      background: rgba(255,250,240,.88);
      color: var(--ink);
      font-family: var(--sans);
      font-size: .8rem;
      font-weight: 700;
      cursor: pointer;
    }

    .btn-inline:hover { background: rgba(37,63,53,.06); }

    .config-note {
      font-size: .8rem;
      color: var(--ink-soft);
      line-height: 1.5;
    }

    .config-note.ok { color: #2E7D32; }
    .config-note.err { color: #b94747; }
  </style>
  <link rel="stylesheet" href="/theme.css" />
</head>
<body>

