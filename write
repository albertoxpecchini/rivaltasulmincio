  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,500;0,9..144,650;1,9..144,550&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --ink:        #17221d;
      --ink-soft:   #31453b;
      --cream:      #f7f0e4;
      --paper:      #fffaf0;
      --mist:       #e4ddcf;
      --marsh:      #253f35;
      --marsh-2:    #3d6353;
      --water:      #2f6b67;
      --clay:       #b8663f;
      --reed:       #c6a462;
      --white:      #fffdf8;
      --line:       rgba(37, 63, 53, 0.15);
      --ok:         #2f6b67;
      --err:        #b83232;
      --warn:       #b16b12;
      --radius:     14px;
      --shadow-card: 0 2px 24px rgba(37, 63, 53, 0.09), 0 0 0 1px rgba(37, 63, 53, 0.07);
      --sans:       "Cabinet Grotesk", system-ui, sans-serif;
      --serif:      "Fraunces", Georgia, serif;
      --ease:       cubic-bezier(0.32, 0.72, 0, 1);
    }

    body {
      font-family: var(--sans);
      background:
        radial-gradient(circle at 14% 8%, rgba(198, 164, 98, 0.28), transparent 28rem),
        radial-gradient(circle at 88% 2%, rgba(47, 107, 103, 0.16), transparent 34rem),
        linear-gradient(135deg, var(--cream), #efe5d2 54%, #f8f2e8);
      color: var(--ink);
      min-height: 100vh;
      position: relative;
      -webkit-font-smoothing: antialiased;
    }

    body::before {
      content: '';
      position: fixed; inset: 0;
      z-index: 0; pointer-events: none;
      opacity: 0.16;
      background-image:
        radial-gradient(circle at 12% 18%, rgba(23, 34, 29, 0.11) 0 1px, transparent 1px),
        radial-gradient(circle at 77% 54%, rgba(23, 34, 29, 0.08) 0 1px, transparent 1px);
      background-size: 23px 23px, 31px 31px;
      mix-blend-mode: multiply;
    }

    a { color: var(--marsh); text-decoration: none; }
    a:hover { color: var(--water); }

    /* ── Nav Island ── */
    .site-header {
      position: fixed;
      top: 20px; left: 0; right: 0;
      z-index: 70;
      pointer-events: none;
    }
    .nav-island {
      position: relative;
      width: min(100% - 28px, 1240px);
      margin: 0 auto;
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: 18px;
      padding: 8px 10px 8px 12px;
      border: 1px solid rgba(255, 250, 240, 0.68);
      border-radius: 999px;
      background: rgba(247, 240, 228, 0.82);
      box-shadow: 0 18px 48px rgba(23, 34, 29, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.7);
      backdrop-filter: blur(24px);
      -webkit-backdrop-filter: blur(24px);
      pointer-events: auto;
    }
    .brand {
      display: inline-flex; align-items: center; gap: 11px;
      min-width: 0; color: var(--ink); text-decoration: none;
    }
    .logo-mark {
      width: 42px; height: 42px; flex: 0 0 42px;
      border-radius: 14px; overflow: hidden;
      display: flex; align-items: center; justify-content: center;
    }
    .logo-mark img { width: 42px; height: 42px; object-fit: cover; display: block; }
    .brand-name { display: grid; line-height: 1.02; letter-spacing: -0.02em; }
    .brand-name strong { font-size: 0.98rem; font-weight: 800; }
    .brand-name span { font-size: 0.72rem; color: rgba(23, 34, 29, 0.55); font-weight: 600; }
    #nav-auth { display: flex; align-items: center; }

    .profile-btn {
      border: 0;
      border-radius: 999px;
      background: #253f35;
      color: #fffaf0;
      min-height: 42px;
      padding: 0 16px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      font-weight: 500;
      box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.16);
      transition: transform 420ms cubic-bezier(0.32, 0.72, 0, 1), background 420ms cubic-bezier(0.32, 0.72, 0, 1), box-shadow 420ms cubic-bezier(0.32, 0.72, 0, 1);
      cursor: pointer;
      font-family: var(--sans);
    }

    .profile-btn:hover {
      transform: translateY(-1px);
      background: #1f362e;
      box-shadow: 0 14px 30px rgba(23, 34, 29, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.20);
    }

    .profile-btn:active {
      transform: scale(0.98);
    }

    .profile-menu { position: relative; }

    .profile-avatar {
      width: 26px;
      height: 26px;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 8px;
      background: #2f6b67;
      color: #fffaf0;
      font-size: 1rem;
      line-height: 1;
    }

    .profile-dropdown {
      position: absolute;
      right: 0;
      top: calc(100% + 12px);
      width: 230px;
      padding: 10px;
      border: 1px solid rgba(255, 250, 240, 0.58);
      border-radius: 24px;
      background: rgba(255, 250, 240, 0.94);
      box-shadow: 0 26px 80px rgba(37, 63, 53, 0.16);
      backdrop-filter: blur(20px);
      opacity: 0;
      visibility: hidden;
      transform: translateY(10px) scale(0.98);
      transition: opacity 360ms cubic-bezier(0.32, 0.72, 0, 1), transform 360ms cubic-bezier(0.32, 0.72, 0, 1), visibility 360ms cubic-bezier(0.32, 0.72, 0, 1);
    }

    .profile-dropdown.open {
      opacity: 1;
      visibility: visible;
      transform: translateY(0) scale(1);
    }

    .profile-dropdown__section-title {
      padding: 8px 10px;
      font-size: 0.66rem;
      letter-spacing: 0.16em;
      text-transform: uppercase;
      color: rgba(23, 34, 29, 0.5);
      font-weight: 900;
    }

    .profile-dropdown a,
    .profile-dropdown button {
      width: 100%;
      border: 0;
      background: transparent;
      color: #17221d;
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 38px;
      padding: 0 10px;
      border-radius: 14px;
      font-weight: 750;
      text-align: left;
      transition: background 300ms cubic-bezier(0.32, 0.72, 0, 1), transform 300ms cubic-bezier(0.32, 0.72, 0, 1);
      text-decoration: none;
      cursor: pointer;
    }

    .profile-dropdown a:hover,
    .profile-dropdown button:hover,
    .profile-dropdown .active {
      background: rgba(37, 63, 53, 0.08);
      transform: translateX(2px);
    }

    .profile-dropdown .danger { color: #8f3b28; }
    .profile-dropdown__sep { height: 1px; background: rgba(37, 63, 53, 0.15); margin: 8px 4px; }

    /* ── Buttons ── */
    .btn {
      display: inline-flex; align-items: center; gap: 6px;
      border-radius: 999px; border: 1px solid var(--line);
      background: var(--paper); color: var(--ink);
      font-family: var(--sans); font-size: .82rem; font-weight: 700;
      padding: 8px 18px; cursor: pointer; text-decoration: none; transition: all .15s;
    }
    .btn:hover { background: var(--mist); }
    .btn:disabled { opacity: .45; cursor: not-allowed; }
    .btn-primary {
      border-color: transparent;
      background: var(--marsh);
      color: var(--paper); box-shadow: 0 4px 16px rgba(37,63,53,.28);
    }
    .btn-primary:hover { background: #1f362e; box-shadow: 0 6px 22px rgba(37,63,53,.4); border-color: transparent; }
    .btn-ghost { color: var(--ink-soft); }
    .btn-danger { color: var(--err); border-color: rgba(184,50,50,.22); }
    .btn-danger:hover { background: rgba(184,50,50,.05); }

    /* ── Page ── */
    .page {
      position: relative; z-index: 1;
      max-width: 920px; margin: 0 auto;
      padding: 108px 16px 80px;
      display: grid; gap: 14px;
    }

    .page-eyebrow {
      font-size: 10px; font-weight: 800; color: var(--water);
      text-transform: uppercase; letter-spacing: .12em; margin-bottom: 5px;
    }

    .page-title {
      font-family: var(--serif);
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 650; letter-spacing: -.03em; line-height: 1.1;
      color: var(--ink);
    }

    .page-sub { font-size: .84rem; color: var(--ink-soft); margin-top: 4px; }

    /* ── Compose Card ── */
    .compose-card {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 20px;
      box-shadow: var(--shadow-card);
      overflow: visible;
      display: flex;
      flex-direction: column;
    }

    .compose-card::before {
      content: '';
      display: block;
      height: 3px;
      background: linear-gradient(90deg, var(--marsh), var(--water), var(--reed));
      border-radius: 20px 20px 0 0;
      flex-shrink: 0;
    }

    .compose-inputs {
      padding: 22px 26px 0;
      display: flex;
      flex-direction: column;
    }

    .compose-title {
      font-family: var(--serif);
      font-size: clamp(1.4rem, 3vw, 1.9rem);
      font-weight: 650;
      color: var(--ink);
      letter-spacing: -.03em;
      border: none;
      outline: none;
      background: transparent;
      width: 100%;
      padding: 0 0 10px;
      border-bottom: 1px solid var(--line);
      margin-bottom: 4px;
    }
    .compose-title::placeholder { color: rgba(23,34,29,.22); }

    .compose-hint {
      font-size: .66rem;
      color: rgba(23,34,29,.28);
      text-align: right;
      margin-bottom: 10px;
    }

    .compose-excerpt {
      font-family: var(--sans);
      font-size: .88rem;
      color: var(--ink);
      border: none;
      outline: none;
      background: transparent;
      width: 100%;
      padding: 0 0 10px;
      border-bottom: 1px solid var(--line);
      margin-bottom: 4px;
    }
    .compose-excerpt::placeholder { color: rgba(23,34,29,.3); }

    .compose-body {
      font-family: var(--sans);
      font-size: .94rem;
      line-height: 1.75;
      color: var(--ink);
      border: none;
      outline: none;
      background: transparent;
      width: 100%;
      min-height: 260px;
      resize: vertical;
      padding: 18px 26px;
    }
    .compose-body::placeholder { color: rgba(23,34,29,.28); }

    .compose-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
      padding: 12px 18px;
      background: linear-gradient(148deg, #0e1f19, #1a3328, #253f35);
      flex-wrap: wrap;
      flex-shrink: 0;
    }

    .compose-bar-left {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .compose-bar-right {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    /* ── Custom dropdowns in compose bar ── */
    .compose-dropdown { position: relative; }

    .compose-dropdown-btn {
      border: 1px solid rgba(255,255,255,.18);
      background: rgba(255,255,255,.08);
      color: rgba(255,255,255,.75);
      border-radius: 999px;
      padding: 6px 14px;
      font-family: var(--sans);
      font-size: .78rem;
      font-weight: 600;
      cursor: pointer;
      outline: none;
      display: inline-flex;
      align-items: center;
      gap: 6px;
      transition: background .15s, color .15s;
      white-space: nowrap;
    }
    .compose-dropdown-btn:hover,
    .compose-dropdown-btn.open { background: rgba(255,255,255,.16); color: #fff; }

    .compose-dropdown-btn .caret {
      opacity: .55;
      font-size: .65rem;
      transition: transform .2s;
    }
    .compose-dropdown-btn.open .caret { transform: rotate(180deg); }

    .compose-dropdown-menu {
      position: absolute;
      top: calc(100% + 10px);
      left: 0;
      min-width: 196px;
      padding: 8px;
      border: 1px solid rgba(37,63,53,.12);
      border-radius: 22px;
      background: rgba(255,250,240,.97);
      box-shadow: 0 24px 60px rgba(37,63,53,.18), 0 2px 8px rgba(37,63,53,.08);
      backdrop-filter: blur(20px);
      z-index: 80;
      visibility: hidden;
      opacity: 0;
      transform: translateY(8px) scale(.98);
      transition: opacity .22s var(--ease), transform .22s var(--ease), visibility .22s var(--ease);
    }
    .compose-dropdown-menu.open {
      visibility: visible;
      opacity: 1;
      transform: none;
    }

    .compose-dropdown-menu--img {
      min-width: 310px;
      max-width: 340px;
    }

    .compose-dropdown-section {
      font-size: .62rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .14em;
      color: rgba(23,34,29,.38);
      padding: 6px 10px 4px;
    }

    .compose-dropdown-item {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      padding: 9px 10px;
      border-radius: 14px;
      font-size: .84rem;
      font-weight: 600;
      color: var(--ink);
      cursor: pointer;
      transition: background .15s, transform .12s;
      border: 0;
      background: transparent;
      text-align: left;
      font-family: var(--sans);
    }
    .compose-dropdown-item:hover { background: rgba(37,63,53,.07); transform: translateX(2px); }
    .compose-dropdown-item.selected { color: var(--marsh); font-weight: 750; background: rgba(37,63,53,.05); }
    .compose-dropdown-item.selected::after { content: '✓'; font-size: .8rem; color: var(--marsh); }

    .compose-img-label {
      font-size: .62rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: .12em;
      color: rgba(23,34,29,.38);
      padding: 4px 4px 10px;
    }

    .compose-char {
      font-size: .72rem;
      color: rgba(255,255,255,.38);
      font-weight: 600;
    }

    /* ── Stats strip ── */
    .stats-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
    }

    .stat-tile {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 16px;
      box-shadow: var(--shadow-card);
      padding: 16px 18px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .stat-tile-num {
      font-family: var(--serif);
      font-size: 1.8rem;
      font-weight: 650;
      letter-spacing: -.03em;
      line-height: 1;
    }
    .stat-tile-num.pub   { color: var(--marsh); }
    .stat-tile-num.draft { color: var(--err); }
    .stat-tile-num.total { color: var(--water); }
    .stat-tile-num.top   { font-size: .94rem; color: var(--ok); min-height: 1.8rem; display: flex; align-items: center; }

    .stat-tile-label {
      font-size: .72rem;
      color: var(--ink-soft);
      font-weight: 600;
    }

    /* ── Compose status (edit mode) ── */
    .compose-status {
      display: none;
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: 16px;
      box-shadow: var(--shadow-card);
      padding: 14px 20px;
      flex-direction: row;
      align-items: center;
      gap: 20px;
      flex-wrap: wrap;
    }
    .compose-status.visible { display: flex; }

    .status-pill {
      display: inline-flex; align-items: center; gap: 5px;
      border-radius: 999px; font-size: .72rem; font-weight: 700;
      padding: 4px 10px; border: 1px solid var(--line);
    }
    .status-pill.draft { color: var(--warn); border-color: rgba(177,107,18,.3); background: rgba(177,107,18,.1); }
    .status-pill.pub   { color: var(--ok);  border-color: rgba(47,107,103,.3);  background: rgba(47,107,103,.1); }
    .status-date { font-size: .76rem; color: var(--ink-soft); }
    .status-num {
      font-family: var(--serif); font-size: 1.6rem; font-weight: 650;
      letter-spacing: -.03em; line-height: 1; color: var(--marsh);
    }
    .status-num-label { font-size: .72rem; color: var(--ink-soft); font-weight: 500; }

    /* ── Image picker ── */
    .img-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(72px, 1fr)); gap: 6px; }
    .img-opt {
      border: 2px solid var(--line); border-radius: 12px;
      cursor: pointer; overflow: hidden; transition: border-color .15s, transform .15s;
    }
    .img-opt:hover { transform: translateY(-2px); border-color: var(--marsh); }
    .img-opt.selected { border-color: var(--marsh); box-shadow: 0 0 0 3px rgba(37,63,53,.18); }
    .img-opt input { display: none; }
    .img-thumb { height: 44px; overflow: hidden; }
    .img-thumb svg { width: 100%; height: 100%; display: block; }
    .img-label { font-size: .6rem; font-weight: 700; color: var(--ink-soft); text-align: center; padding: 3px 2px 5px; }

    /* ── Misc ── */
    .err-msg { color: var(--err); font-size: .8rem; min-height: 16px; padding: 0 2px; }
    .toast {
      position: fixed; bottom: 22px; right: 22px; z-index: 200;
      border: 1px solid var(--line); border-radius: 14px;
      background: var(--paper); color: var(--ink);
      padding: 10px 16px; font-family: var(--sans); font-size: .82rem; font-weight: 700;
      transform: translateY(12px); opacity: 0; transition: all .22s;
      pointer-events: none; box-shadow: 0 8px 24px rgba(37,63,53,.18);
    }
    .toast.show { opacity: 1; transform: none; }
    .toast.err { color: var(--err); }
    .toast.ok  { color: var(--ok); }

    @media (max-width: 700px) {
      .stats-strip {
        grid-template-columns: repeat(2, 1fr);
      }
      .compose-bar {
        flex-direction: column;
        align-items: stretch;
      }
      .compose-bar-left, .compose-bar-right {
        justify-content: space-between;
      }
      .page { padding: 88px 12px 60px; }
      .brand-name { display: none; }
    }

    @media (prefers-reduced-motion: reduce) {
      .ps-card, .ps-bar { animation: none; transition: none; }
    }

    /* ── Footer ── */
    .footer { color:rgba(255,250,240,.72); background:#101c18; padding:72px 0 34px; font-family:var(--sans); }
    .footer-container { width:min(100% - 44px, 1400px); margin:0 auto; }
    .footer-grid { display:grid; grid-template-columns:minmax(0,0.72fr) repeat(3,minmax(140px,0.22fr)); gap:clamp(24px,5vw,76px); align-items:start; }
    .footer h3,.footer h4 { margin:0 0 16px; color:var(--paper); letter-spacing:-0.02em; }
    .footer h3 { font-family:var(--serif); font-size:clamp(2rem,4vw,4.8rem); line-height:0.96; letter-spacing:-0.055em; }
    .footer p { max-width:540px; line-height:1.66; }
    .footer-links { list-style:none; padding:0; margin:0; display:grid; gap:10px; }
    .footer-links a { color:rgba(255,250,240,.68); font-weight:750; text-decoration:none; }
    .footer-links a:hover { color:var(--paper); }
    .footer-bottom { display:flex; justify-content:space-between; flex-wrap:wrap; gap:14px; margin-top:64px; padding-top:24px; border-top:1px solid rgba(255,250,240,.12); font-size:0.86rem; }
    @media(max-width:760px){ .footer-grid { grid-template-columns:1fr; } }
  </style>
  <link rel="stylesheet" href="/theme.css" />
</head>
<body>

<!-- SVG gradient defs for illustration thumbnails -->
<svg width="0" height="0" style="position:absolute" aria-hidden="true"><defs>
  <linearGradient id="g-water"  x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#2d8b89"/><stop offset="100%" stop-color="#0F2A30"/></linearGradient>
  <linearGradient id="g-marsh"  x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#5fb085"/><stop offset="100%" stop-color="#15433a"/></linearGradient>
  <linearGradient id="g-sunset" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#f0c084"/><stop offset="100%" stop-color="#c0392b"/></linearGradient>
  <linearGradient id="g-spring" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#a8d8a8"/><stop offset="100%" stop-color="#2d8b60"/></linearGradient>
  <linearGradient id="g-deep"   x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#1a2f3a"/><stop offset="100%" stop-color="#030d12"/></linearGradient>
</defs></svg>

