  <style>
    body[data-page="write"] {
      position: relative;
      font-family: 'Syne', var(--rsm-font-sans, "Cabinet Grotesk", system-ui, sans-serif);
      color: var(--rsm-text, #10192b);
      overflow-x: hidden;
      background:
        radial-gradient(circle at 14% 18%, rgba(31, 191, 125, 0.16), transparent 30%),
        radial-gradient(circle at 86% 16%, rgba(74, 155, 255, 0.16), transparent 34%),
        radial-gradient(circle at 78% 76%, rgba(139, 92, 246, 0.14), transparent 36%),
        linear-gradient(180deg, var(--rsm-bg, #f8fbff) 0%, var(--rsm-paper, #eef4ff) 48%, var(--rsm-bg, #f8fbff) 100%);
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    .rsm-write-page,
    .rsm-write-page *,
    .rsm-write-page *::before,
    .rsm-write-page *::after,
    .toast,
    .toast::before,
    .toast::after {
      box-sizing: border-box;
    }

    body[data-page="write"] button,
    body[data-page="write"] input,
    body[data-page="write"] select,
    body[data-page="write"] textarea {
      font: inherit;
    }

    body[data-page="write"]::before,
    body[data-page="write"]::after {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      z-index: 0;
    }

    body[data-page="write"]::before {
      opacity: 0.18;
      background-image:
        radial-gradient(circle at 1px 1px, rgba(11, 13, 20, 0.14) 0.6px, transparent 1.2px),
        radial-gradient(circle at 1px 1px, rgba(11, 13, 20, 0.08) 0.6px, transparent 1.2px);
      background-size: 24px 24px, 36px 36px;
      background-position: 0 0, 12px 14px;
      mix-blend-mode: multiply;
    }

    body[data-page="write"]::after {
      opacity: 0.9;
      background:
        radial-gradient(ellipse at 22% 24%, rgba(31, 191, 125, 0.14), transparent 42%),
        radial-gradient(ellipse at 74% 20%, rgba(74, 155, 255, 0.14), transparent 44%),
        radial-gradient(ellipse at 66% 78%, rgba(139, 92, 246, 0.10), transparent 46%);
      animation: rsm-write-aurora 26s ease-in-out infinite;
    }

    .rsm-write-page {
      --write-ink: var(--rsm-text, #10192b);
      --write-muted: var(--rsm-muted, #5a6882);
      --write-line: rgba(18, 32, 58, 0.14);
      --write-paper: rgba(255,255,255,0.72);
      --write-paper-strong: rgba(255,255,255,0.9);
      --write-brand: #1fbf7d;
      --write-water: #4a9bff;
      --write-violet: #8b5cf6;
      --write-shadow: 0 24px 70px rgba(18, 32, 58, 0.16), 0 0 0 1px rgba(255,255,255,0.72) inset;
      position: relative;
      z-index: 1;
      min-height: 100dvh;
      padding: clamp(76px, 7vw, 108px) 0 clamp(30px, 5vw, 76px);
      overflow: hidden;
      isolation: isolate;
    }

    .rsm-write-page a { color: inherit; text-decoration: none; }

    .rsm-write__accent {
      position: absolute;
      width: 132%;
      height: 132%;
      top: -16%;
      left: -16%;
      z-index: -1;
      pointer-events: none;
      background:
        radial-gradient(ellipse at 18% 22%, rgba(46, 224, 170, 0.18), transparent 48%),
        radial-gradient(ellipse at 82% 78%, rgba(167, 119, 255, 0.18), transparent 48%),
        radial-gradient(ellipse at 50% 50%, rgba(86, 156, 255, 0.10), transparent 60%);
      animation: rsm-write-float 30s ease-in-out infinite;
    }

    .rsm-write__container {
      width: min(100% - 40px, 1460px);
      margin: 0 auto;
    }

    .rsm-write__layout {
      display: grid;
      grid-template-columns: minmax(260px, 0.58fr) minmax(420px, 1fr) minmax(260px, 0.54fr);
      gap: clamp(14px, 2vw, 22px);
      align-items: stretch;
    }

    .rsm-write__intro,
    .compose-card,
    .rsm-write__side-card,
    .compose-status,
    .stat-tile {
      position: relative;
      overflow: hidden;
      isolation: isolate;
      border: 1px solid rgba(255,255,255,0.62);
      background:
        linear-gradient(145deg, rgba(255,255,255,0.86), rgba(255,255,255,0.56)),
        radial-gradient(ellipse at 0% 0%, rgba(31, 191, 125, 0.10), transparent 52%);
      box-shadow: var(--write-shadow);
      backdrop-filter: blur(22px) saturate(1.15);
      -webkit-backdrop-filter: blur(22px) saturate(1.15);
    }

    .rsm-write__intro::before,
    .compose-card::before,
    .rsm-write__side-card::before,
    .compose-status::before {
      content: "";
      position: absolute;
      inset: 0 0 auto 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, rgba(255,255,255,0.85), transparent);
      opacity: 0.9;
    }

    .rsm-write__intro {
      min-height: 100%;
      border-radius: 34px;
      padding: clamp(24px, 3.4vw, 42px);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 28px;
    }

    .page-eyebrow,
    .rsm-write__kicker,
    .compose-img-label,
    .compose-dropdown-section,
    .stat-tile-label,
    .status-num-label {
      font-size: 0.72rem;
      font-weight: 900;
      letter-spacing: 0.13em;
      text-transform: uppercase;
    }

    .page-eyebrow,
    .rsm-write__kicker {
      display: inline-flex;
      width: max-content;
      align-items: center;
      gap: 9px;
      color: rgba(16, 25, 43, 0.66);
    }

    .page-eyebrow::before,
    .rsm-write__kicker::before {
      content: "";
      width: 9px;
      height: 9px;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--write-brand), var(--write-water));
      box-shadow: 0 0 0 7px rgba(31, 191, 125, 0.12);
    }

    .page-title {
      max-width: 9ch;
      margin-top: 16px;
      font-family: 'Fraunces', Georgia, serif;
      font-size: clamp(3rem, 7vw, 6.7rem);
      font-weight: 850;
      line-height: 0.86;
      letter-spacing: -0.08em;
      color: var(--write-ink);
    }

    .page-title::after {
      content: "";
      display: block;
      width: min(180px, 55%);
      height: 10px;
      margin-top: 22px;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--write-brand), var(--write-water), var(--write-violet));
    }

    .page-sub {
      max-width: 31rem;
      margin-top: 20px;
      font-size: clamp(1rem, 1.3vw, 1.18rem);
      line-height: 1.55;
      color: var(--write-muted);
    }

    .page-summary {
      display: grid;
      gap: 10px;
      margin-top: 8px;
    }

    .page-chip {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 48px;
      padding: 0 16px;
      border: 1px solid rgba(18, 32, 58, 0.10);
      border-radius: 18px;
      background: rgba(255,255,255,0.50);
      color: rgba(16, 25, 43, 0.74);
      font-weight: 850;
      letter-spacing: -0.01em;
    }

    .page-chip::after {
      content: "↗";
      color: var(--write-water);
      font-weight: 900;
    }

    .rsm-write__note {
      display: grid;
      gap: 10px;
      padding: 18px;
      border-radius: 24px;
      background: linear-gradient(135deg, rgba(5, 28, 44, 0.92), rgba(42, 17, 71, 0.88));
      color: rgba(255,255,255,0.78);
      box-shadow: 0 18px 44px rgba(5, 28, 44, 0.22);
    }

    .rsm-write__note strong {
      color: #fff;
      font-size: 1.04rem;
      letter-spacing: -0.03em;
    }

    .rsm-write__note span {
      line-height: 1.5;
    }

    .rsm-write__editor {
      min-width: 0;
      display: grid;
      gap: 14px;
    }

    .compose-card {
      min-height: clamp(620px, 74vh, 840px);
      border-radius: 34px;
      display: flex;
      flex-direction: column;
    }

    .compose-inputs {
      padding: clamp(22px, 3vw, 34px) clamp(20px, 3vw, 34px) 0;
      display: flex;
      flex-direction: column;
    }

    .compose-title,
    .compose-excerpt,
    .compose-body {
      width: 100%;
      border: 0;
      outline: 0;
      background: transparent;
      color: var(--write-ink);
    }

    .compose-title {
      min-height: 108px;
      padding: 0 0 16px;
      border-bottom: 1px solid rgba(18, 32, 58, 0.11);
      font-family: 'Fraunces', Georgia, serif;
      font-size: clamp(2.1rem, 4.7vw, 4.9rem);
      font-weight: 800;
      line-height: 0.95;
      letter-spacing: -0.075em;
    }

    .compose-excerpt {
      padding: 13px 0 15px;
      border-bottom: 1px solid rgba(18, 32, 58, 0.10);
      font-size: clamp(1rem, 1.2vw, 1.12rem);
      font-weight: 650;
      color: rgba(16, 25, 43, 0.74);
    }

    .compose-body {
      flex: 1;
      min-height: 320px;
      resize: vertical;
      padding: 24px clamp(20px, 3vw, 34px);
      font-family: var(--rsm-font-sans, "Cabinet Grotesk", system-ui, sans-serif);
      font-size: 1.08rem;
      line-height: 1.78;
    }

    .compose-title::placeholder,
    .compose-excerpt::placeholder,
    .compose-body::placeholder { color: rgba(16, 25, 43, 0.28); }

    .compose-hint {
      min-height: 22px;
      margin-top: -12px;
      margin-bottom: 4px;
      text-align: right;
      color: rgba(16, 25, 43, 0.36);
      font-size: 0.74rem;
      font-weight: 800;
    }

    .compose-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 14px;
      margin: 0 14px 14px;
      border: 1px solid rgba(255,255,255,0.16);
      border-radius: 24px;
      background:
        radial-gradient(ellipse at 12% 0%, rgba(102, 255, 214, 0.18), transparent 40%),
        radial-gradient(ellipse at 86% 100%, rgba(196, 122, 255, 0.18), transparent 42%),
        linear-gradient(135deg, rgba(5, 28, 44, 0.96), rgba(8, 38, 73, 0.94) 52%, rgba(42, 17, 71, 0.94));
      box-shadow: 0 20px 54px rgba(5, 28, 44, 0.24);
      flex-wrap: wrap;
    }

    .compose-bar-left,
    .compose-bar-right {
      display: flex;
      align-items: center;
      gap: 8px;
      flex-wrap: wrap;
    }

    .btn,
    .compose-dropdown-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      min-height: 40px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.18);
      background: rgba(255,255,255,0.10);
      color: rgba(255,255,255,0.82);
      padding: 8px 16px;
      font-size: 0.84rem;
      font-weight: 850;
      cursor: pointer;
      transition: transform 180ms ease, background 180ms ease, color 180ms ease, box-shadow 180ms ease;
      white-space: nowrap;
    }

    .btn:hover,
    .compose-dropdown-btn:hover,
    .compose-dropdown-btn.open {
      transform: translateY(-1px);
      background: rgba(255,255,255,0.17);
      color: #fff;
    }

    .btn:disabled { opacity: 0.48; cursor: not-allowed; transform: none; }

    .btn-primary {
      border-color: transparent;
      background: linear-gradient(135deg, #2ee0aa, #4a9bff 54%, #a777ff);
      color: #07111f;
      box-shadow: 0 12px 34px rgba(74, 155, 255, 0.32);
    }

    .btn-primary:hover { color: #07111f; box-shadow: 0 16px 42px rgba(74, 155, 255, 0.42); }
    .btn-danger { color: #ffd7d7; border-color: rgba(255, 168, 168, 0.30); }
    .btn-ghost { color: rgba(255,255,255,0.64); }

    .compose-char {
      display: inline-flex;
      align-items: center;
      min-height: 40px;
      padding: 0 12px;
      border-radius: 999px;
      background: rgba(255,255,255,0.08);
      color: rgba(255,255,255,0.58);
      font-size: 0.78rem;
      font-weight: 850;
    }

    .compose-dropdown { position: relative; }
    .compose-dropdown-btn .caret { opacity: 0.65; font-size: 0.72rem; }

    .compose-dropdown-menu {
      position: absolute;
      left: 0;
      bottom: calc(100% + 10px);
      z-index: 20;
      min-width: 230px;
      max-height: 310px;
      overflow: auto;
      padding: 10px;
      border-radius: 22px;
      border: 1px solid rgba(255,255,255,0.66);
      background: rgba(255,255,255,0.92);
      box-shadow: 0 24px 58px rgba(18, 32, 58, 0.22);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      opacity: 0;
      visibility: hidden;
      transform: translateY(8px) scale(0.98);
      transform-origin: bottom left;
      transition: opacity 160ms ease, visibility 160ms ease, transform 160ms ease;
    }

    .compose-dropdown-menu.open { opacity: 1; visibility: visible; transform: translateY(0) scale(1); }
    .compose-dropdown-menu--img { width: min(380px, calc(100vw - 40px)); }

    .compose-dropdown-section,
    .compose-img-label {
      margin: 4px 6px 9px;
      color: rgba(16,25,43,0.46);
    }

    .compose-dropdown-item {
      width: 100%;
      border: 0;
      border-radius: 14px;
      background: transparent;
      color: rgba(16,25,43,0.76);
      padding: 11px 12px;
      text-align: left;
      font-weight: 850;
      cursor: pointer;
    }

    .compose-dropdown-item:hover,
    .compose-dropdown-item.selected { background: rgba(74,155,255,0.12); color: #10192b; }

    .img-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 10px;
    }

    .img-opt {
      display: grid;
      gap: 7px;
      padding: 8px;
      border: 1px solid rgba(18,32,58,0.10);
      border-radius: 18px;
      background: rgba(255,255,255,0.62);
      cursor: pointer;
      transition: transform 160ms ease, border-color 160ms ease, box-shadow 160ms ease;
    }

    .img-opt input { position: absolute; opacity: 0; pointer-events: none; }
    .img-opt:hover,
    .img-opt.selected { transform: translateY(-1px); border-color: rgba(74,155,255,0.42); box-shadow: 0 14px 28px rgba(18,32,58,0.12); }
    .img-thumb { overflow: hidden; border-radius: 13px; line-height: 0; }
    .img-thumb svg { width: 100%; height: auto; display: block; }
    .img-label { color: rgba(16,25,43,0.74); font-size: 0.82rem; font-weight: 850; }

    .err-msg {
      display: none;
      padding: 14px 16px;
      border-radius: 18px;
      border: 1px solid rgba(184,50,50,0.20);
      background: rgba(184,50,50,0.08);
      color: #8f2020;
      font-weight: 850;
    }

    .err-msg:not(:empty) { display: block; }

    .rsm-write__side {
      display: grid;
      gap: 14px;
      align-content: start;
    }

    .rsm-write__side-card,
    .compose-status {
      border-radius: 30px;
      padding: 22px;
    }

    .rsm-write__side-title {
      margin: 10px 0 6px;
      color: var(--write-ink);
      font-size: clamp(1.5rem, 2vw, 2.2rem);
      line-height: 1;
      letter-spacing: -0.06em;
      font-weight: 900;
    }

    .rsm-write__side-text {
      color: var(--write-muted);
      line-height: 1.55;
      font-weight: 650;
    }

    .compose-status {
      display: none;
      gap: 16px;
      flex-direction: column;
    }

    .compose-status.visible { display: flex; }
    .status-pill {
      display: inline-flex;
      align-items: center;
      min-height: 32px;
      padding: 0 12px;
      border-radius: 999px;
      border: 1px solid rgba(18,32,58,0.12);
      background: rgba(255,255,255,0.54);
      color: var(--write-muted);
      font-size: 0.78rem;
      font-weight: 900;
    }
    .status-pill.draft { color: #9a5a0c; border-color: rgba(177,107,18,.25); background: rgba(177,107,18,.10); }
    .status-pill.pub { color: #08764d; border-color: rgba(31,191,125,.28); background: rgba(31,191,125,.10); }
    .status-date { color: var(--write-muted); font-size: 0.84rem; font-weight: 700; }
    .status-num { color: var(--write-ink); font-size: 2.35rem; line-height: 1; font-weight: 950; letter-spacing: -0.07em; }
    .status-num-label { color: var(--write-muted); }

    .stats-strip {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .stat-tile {
      min-height: 138px;
      border-radius: 26px;
      padding: 18px;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      gap: 12px;
    }

    .stat-tile::after {
      content: "";
      position: absolute;
      width: 94px;
      height: 94px;
      top: -42px;
      right: -34px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(74,155,255,0.22), transparent 66%);
      z-index: -1;
    }

    .stat-tile-num {
      color: var(--write-ink);
      font-size: clamp(1.55rem, 3vw, 2.5rem);
      font-weight: 950;
      line-height: 0.92;
      letter-spacing: -0.07em;
      overflow-wrap: anywhere;
    }

    .stat-tile-num.pub { color: #0f9f6e; }
    .stat-tile-num.draft { color: #9a5a0c; }
    .stat-tile-num.total { color: #2476d4; }
    .stat-tile-num.top { color: #6840d7; font-size: clamp(1.15rem, 2.1vw, 1.7rem); }
    .stat-tile-label { color: rgba(16,25,43,0.48); }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 26px;
      z-index: 1000;
      max-width: min(520px, calc(100vw - 32px));
      padding: 14px 18px;
      border-radius: 999px;
      border: 1px solid rgba(255,255,255,0.62);
      background: rgba(16,25,43,0.88);
      color: #fff;
      box-shadow: 0 20px 46px rgba(16,25,43,0.28);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      font-weight: 850;
      opacity: 0;
      visibility: hidden;
      transform: translate(-50%, 14px);
      transition: opacity 180ms ease, transform 180ms ease, visibility 180ms ease;
    }

    .toast.show { opacity: 1; visibility: visible; transform: translate(-50%, 0); }
    .toast.err { background: rgba(127,29,29,0.92); }
    .toast.ok { background: rgba(6,95,70,0.92); }

    @keyframes rsm-write-aurora {
      0%, 100% { transform: translate3d(0,0,0) scale(1); }
      45% { transform: translate3d(-1.6%, 1%, 0) scale(1.03); }
      72% { transform: translate3d(1.4%, -1.2%, 0) scale(1.02); }
    }

    @keyframes rsm-write-float {
      0%, 100% { transform: rotate(0deg) scale(1); }
      50% { transform: rotate(5deg) scale(1.04); }
    }

    @media (max-width: 1180px) {
      .rsm-write__layout { grid-template-columns: minmax(0, 1fr) minmax(340px, 0.86fr); }
      .rsm-write__intro { grid-column: 1 / -1; min-height: auto; }
      .page-title { max-width: 12ch; }
      .page-summary { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    }

    @media (max-width: 860px) {
      .rsm-write-page { padding-top: 86px; }
      .rsm-write__container { width: min(100% - 28px, 1460px); }
      .rsm-write__layout { grid-template-columns: 1fr; }
      .page-summary,
      .stats-strip { grid-template-columns: 1fr; }
      .compose-card { min-height: 620px; }
      .compose-title { min-height: 84px; }
      .compose-bar { align-items: stretch; }
      .compose-bar-left,
      .compose-bar-right { width: 100%; justify-content: space-between; }
      .compose-dropdown-menu { bottom: auto; top: calc(100% + 10px); transform-origin: top left; }
    }

    @media (max-width: 560px) {
      .rsm-write__intro,
      .compose-card,
      .rsm-write__side-card,
      .compose-status { border-radius: 24px; }
