<!DOCTYPE html>
<html lang="it">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" href="/img/favicon.png" type="image/png" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Laboratorio di scrittura – Rivalta sul Mincio</title>
  <meta name="robots" content="noindex" />
</head>
<body>
<!--PARTIAL:nav-->

<main class="container rsm-page py-4">
  <p class="text-primary fw-semibold text-uppercase small mb-1">Rivalta sul Mincio</p>
  <h1 class="page-title" id="page-title">Laboratorio di scrittura</h1>
  <p class="text-muted" id="page-sub">Nuovo editor completo: campi narrativi, SEO, metadati evento e controllo qualità del testo.</p>

  <div class="row g-4 mt-1">
    <section class="col-12 col-xl-8">
      <div class="alert alert-danger" id="err-msg" style="display:none"></div>

      <div class="card-wrapper mb-3"><div class="card card-bg"><div class="card-body">
        <h2 class="h5 mb-3">Identità del contenuto</h2>
        <div class="row g-3">
          <div class="col-12">
            <label for="f-title" class="form-label">Titolo principale</label>
            <input id="f-title" class="form-control" maxlength="120" placeholder="Titolo del post" />
            <small class="form-text"><span id="title-count">0 / 120</span></small>
          </div>
          <div class="col-12 col-md-6">
            <label for="f-subtitle" class="form-label">Sottotitolo</label>
            <input id="f-subtitle" class="form-control" maxlength="160" placeholder="Taglio giornalistico o poetico" />
            <small class="form-text"><span id="subtitle-count">0 / 160</span></small>
          </div>
          <div class="col-12 col-md-6">
            <label for="f-category" class="form-label">Categoria editoriale</label>
            <select id="f-category" class="form-select"></select>
          </div>
          <div class="col-12">
            <label for="f-excerpt" class="form-label">Estratto</label>
            <textarea id="f-excerpt" class="form-control" rows="2" maxlength="240" placeholder="Riassunto breve per anteprime"></textarea>
            <small class="form-text"><span id="excerpt-count">0 / 240</span></small>
          </div>
          <div class="col-12 col-md-6">
            <label for="f-tone" class="form-label">Tono editoriale</label>
            <select id="f-tone" class="form-select">
              <option value="istituzionale">Istituzionale</option>
              <option value="narrativo">Narrativo</option>
              <option value="giornalistico">Giornalistico</option>
              <option value="conviviale">Conviviale</option>
            </select>
          </div>
          <div class="col-12 col-md-6">
            <label for="f-reading-level" class="form-label">Livello di lettura</label>
            <select id="f-reading-level" class="form-select">
              <option value="semplice">Semplice</option>
              <option value="medio">Medio</option>
              <option value="approfondito">Approfondito</option>
            </select>
          </div>
        </div>
      </div></div></div>

      <div class="card-wrapper mb-3"><div class="card card-bg"><div class="card-body">
        <h2 class="h5 mb-3">Corpo del post</h2>
        <label for="f-content" class="form-label">Testo completo</label>
        <textarea id="f-content" class="form-control font-monospace" rows="14" placeholder="Scrivi il testo completo..."></textarea>
        <small class="form-text"><span id="content-count">0 caratteri</span> · <span id="content-words">0 parole</span></small>

        <div class="row g-3 mt-1">
          <div class="col-12 col-md-6">
            <label for="f-keywords" class="form-label">Parole chiave (virgola separate)</label>
            <input id="f-keywords" class="form-control" placeholder="mincio, evento, comunità" />
          </div>
          <div class="col-12 col-md-6">
            <label for="f-tags" class="form-label">Tag pubblici</label>
            <input id="f-tags" class="form-control" placeholder="festival, natura" />
          </div>
          <div class="col-12">
            <label for="f-cta" class="form-label">Call to action</label>
            <input id="f-cta" class="form-control" maxlength="180" placeholder="Partecipa, condividi, prenota..." />
          </div>
        </div>
      </div></div></div>

      <div class="card-wrapper mb-3"><div class="card card-bg"><div class="card-body">
        <h2 class="h5 mb-3">Campi evento e sorgenti</h2>
        <div class="row g-3">
          <div class="col-12 col-md-4">
            <label for="f-event-start" class="form-label">Inizio evento</label>
            <input id="f-event-start" class="form-control" type="datetime-local" />
          </div>
          <div class="col-12 col-md-4">
            <label for="f-event-end" class="form-label">Fine evento</label>
            <input id="f-event-end" class="form-control" type="datetime-local" />
          </div>
          <div class="col-12 col-md-4">
            <label for="f-location" class="form-label">Luogo</label>
            <input id="f-location" class="form-control" maxlength="180" placeholder="Piazza / sede / indirizzo" />
          </div>
          <div class="col-12 col-md-6">
            <label for="f-source-url" class="form-label">URL sorgente primaria</label>
            <input id="f-source-url" class="form-control" type="url" maxlength="500" placeholder="https://..." />
          </div>
          <div class="col-12 col-md-6">
            <label for="f-image-url" class="form-label">URL immagine cover</label>
            <input id="f-image-url" class="form-control" type="url" maxlength="500" placeholder="https://..." />
          </div>
        </div>
      </div></div></div>

      <div class="d-flex flex-wrap gap-2 justify-content-end">
        <a class="btn btn-outline-secondary" href="/dashboard">Annulla</a>
        <button class="btn btn-outline-primary" id="btn-draft" type="button">Salva bozza evoluta</button>
        <button class="btn btn-primary" id="btn-publish" type="button">Pubblica versione finale</button>
      </div>
    </section>

    <aside class="col-12 col-xl-4">
      <div class="card-wrapper mb-3"><div class="card card-bg"><div class="card-body">
        <h2 class="h5">Diagnostica scrittura</h2>
        <ul class="list-unstyled small mb-0" id="diagnostics"></ul>
      </div></div></div>

      <div class="card-wrapper mb-3"><div class="card card-bg"><div class="card-body">
        <h2 class="h5">Schema payload inventato</h2>
        <pre id="payload-preview" class="small mb-0" style="white-space:pre-wrap"></pre>
      </div></div></div>
    </aside>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js"></script>
<script src="/supabase.config.js"></script>
<script>
(() => {
  const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
  const $ = (id) => document.getElementById(id);
  const categories = window.RSM_CATEGORIES ? window.RSM_CATEGORIES.all() : [
    'Ambiente','Assemblea','Ciclismo','Eventi','Iniziative','Video'
  ];

  const state = { session: null, profile: null };

  const fields = [
    'f-title','f-subtitle','f-excerpt','f-content','f-keywords','f-tags','f-cta','f-location','f-source-url','f-image-url'
  ];

  function setErr(msg) {
    const el = $('err-msg');
    el.textContent = msg || '';
    el.style.display = msg ? 'block' : 'none';
  }

  function listFromCsv(value) {
    return String(value || '').split(',').map(s => s.trim()).filter(Boolean);
  }

  function readabilityScore(text) {
    const clean = String(text || '').trim();
    const words = clean ? clean.split(/\s+/).length : 0;
    const sentences = Math.max(1, (clean.match(/[.!?]+/g) || []).length);
    const avg = words / sentences;
    if (avg < 12) return 'scorrevole';
    if (avg < 22) return 'equilibrato';
    return 'denso';
  }

  function buildPayload(published) {
    const content = $('f-content').value;
    const nowIso = new Date().toISOString();
    const words = content.trim() ? content.trim().split(/\s+/).length : 0;

    return {
      title: $('f-title').value.trim(),
      subtitle: $('f-subtitle').value.trim(),
      excerpt: $('f-excerpt').value.trim(),
      content,
      category: $('f-category').value,
      tone: $('f-tone').value,
      reading_level: $('f-reading-level').value,
      cta_text: $('f-cta').value.trim(),
      keywords: listFromCsv($('f-keywords').value),
      tags: listFromCsv($('f-tags').value),
      source_url: $('f-source-url').value.trim() || null,
      image_url: $('f-image-url').value.trim() || null,
      location_text: $('f-location').value.trim() || null,
      event_start_at: $('f-event-start').value || null,
      event_end_at: $('f-event-end').value || null,
      quality: {
        chars: content.length,
        words,
        readability: readabilityScore(content),
        generated_at: nowIso
      },
      meta: {
        editor_version: 'write-lab-v2',
        created_in_ui: 'laboratorio_scrittura',
        locale: 'it-IT'
      },
      published,
      published_at: published ? nowIso : null,
      author_id: state.session?.user?.id || null
    };
  }

  async function save(published) {
    setErr('');
    const payload = buildPayload(published);
    if (!payload.title || payload.title.length < 6) {
      setErr('Titolo troppo corto (minimo 6 caratteri).');
      return;
    }
    if (!payload.content || payload.content.length < 80) {
      setErr('Testo troppo corto (minimo 80 caratteri).');
      return;
    }

    const { error } = await sb.from('posts').insert(payload);
    if (error) {
      setErr(`Salvataggio fallito: ${error.message}`);
      return;
    }
    location.href = '/dashboard';
  }

  function renderDiagnostics() {
    const content = $('f-content').value;
    const words = content.trim() ? content.trim().split(/\s+/).length : 0;
    $('content-count').textContent = `${content.length} caratteri`;
    $('content-words').textContent = `${words} parole`;
    $('title-count').textContent = `${$('f-title').value.length} / 120`;
    $('subtitle-count').textContent = `${$('f-subtitle').value.length} / 160`;
    $('excerpt-count').textContent = `${$('f-excerpt').value.length} / 240`;

    const points = [
      ['Leggibilità', readabilityScore(content)],
      ['Paragrafi', (content.split(/\n{2,}/).filter(Boolean).length || 0)],
      ['Keyword', listFromCsv($('f-keywords').value).length],
      ['Tag', listFromCsv($('f-tags').value).length]
    ];

    $('diagnostics').innerHTML = points.map(([k,v]) => `<li><strong>${k}:</strong> ${v}</li>`).join('');
    $('payload-preview').textContent = JSON.stringify(buildPayload(false), null, 2);
  }

  async function bootstrap() {
    const [{ data: auth }, { data: profileData }] = await Promise.all([
      sb.auth.getSession(),
      sb.from('profiles').select('id, username, display_name').limit(1)
    ]);

    state.session = auth?.session || null;
    state.profile = (profileData && profileData[0]) || null;

    if (!state.session) {
      location.href = '/login';
      return;
    }

    $('f-category').innerHTML = categories.map(c => `<option value="${c}">${c}</option>`).join('');
    fields.forEach((id) => $(id).addEventListener('input', renderDiagnostics));
    ['f-event-start','f-event-end','f-tone','f-reading-level','f-category'].forEach((id) => $(id).addEventListener('change', renderDiagnostics));

    $('btn-draft').addEventListener('click', () => save(false));
    $('btn-publish').addEventListener('click', () => save(true));

    renderDiagnostics();
  }

  bootstrap().catch((e) => setErr(`Errore inizializzazione: ${e.message}`));
})();
</script>
</body>
</html>
